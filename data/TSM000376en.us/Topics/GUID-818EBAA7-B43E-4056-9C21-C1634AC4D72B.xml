<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-818EBAA7-B43E-4056-9C21-C1634AC4D72B" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-818EBAA7-B43E-4056-9C21-C1634AC4D72B" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Log files and Colorado system</title><abstract class="- topic/abstract " id="GUID-9C631935-A322-4774-A553-6D0B52308454"><p class="- topic/p "> The system logs several different types of events in log files. The log files do serve different purposes and are created in different ways. 
</p><p class="- topic/p "> Most of the engine related logging can be retrieved by means of On Remote Service (ORS). This is the highly preferred way, since it is easy and fast to use. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Diagnostics</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-CC2486E9-E593-4DE9-907E-7BF8FE167E9F" class="- topic/section "><title class="- topic/title ">Overview of the most important log files</title><table pgwide="1" id="GUID-E8683A97-CFAA-42AC-B15B-8375DE8C5137" class="- topic/table "><tgroup cols="4" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="25*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="25*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="25*" class="- topic/colspec "/><colspec colname="col4" colnum="4" colwidth="25*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Name 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Description 
</p></entry><entry colname="col3" namest="col3" nameend="col4" valign="top" class="- topic/entry "><p class="- topic/p ">Retrieval 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "/><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">ORS</b> 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">On-site 
</b> 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Datalog.xml 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> The main log file containing high level system information, like counters, parameters, settings and events occurred. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Yes 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">See 
<xref keyref="GetDatalog" class="- topic/xref " href="GUID-070DCC02-4548-4B55-8741-14B970925BC5.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text How to get the datalog file?>How to get the datalog file</xref> 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> ProductSpecificData.zip 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Detailed logging about the engine and printheads. Also referred to as functional logging. 
</p><p class="- topic/p "> This file is encrypted. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Yes 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> TraceData.zip 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Detailed logging about system software. 
</p><p class="- topic/p "> The TraceData is automatically created when an MRE error occurs. This file is stored in the log store of the controller and can be collected later on. 
</p><p class="- topic/p "> This file is encrypted. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Yes 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">See<xref keyref="GetTraceFiles2" class="- topic/xref " href="GUID-E5B8292A-7DC5-434F-A78B-2C9D13902D1E.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text How to get the trace files?>How to get the trace files</xref> 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> ProductLogbook.xml 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Contains the logbook information entered in ADAM. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "/><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> Account logs 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Contains print job information for the customer like ink usage. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Yes, customer sensitive data is removed 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">See 
<xref keyref="Saveaccountlogs" class="- topic/xref " href="GUID-2EAA15CE-037A-47FF-A061-59BFFB1B1749.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text How to save the account logs?>How to save the account logs</xref> 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Job data 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Contains the last received job sent to the printer. This feature is disabled by default. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">No 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">See 
<xref keyref="GetJobData" class="- topic/xref " href="GUID-279766E4-2950-4DFB-8398-989A2744FA99.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text How to save received job data?>How to save received job data</xref> 
</p></entry></row></tbody></tgroup></table></section><section id="GUID-53EB6263-AAA9-465D-BCB2-647DFAC17B6C" class="- topic/section "><title class="- topic/title ">What if the system starts with an error ?</title><p class="- topic/p ">If this happens you can start the system in zero SDS. In Zero SDS logging retrieval is always possible. 
</p><p class="- topic/p ">See<xref keyref="ZeroSDS" class="- topic/xref " href="GUID-7B8634B6-A3A4-4DAA-BF9D-10586F2D4E53.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text How to enter Zero SDS?>How to enter Zero SDS</xref> 
</p></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5C937DF0-2BDD-497B-B1AC-3013A8804D24.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Diagnostics</linktext></link></linkpool></related-links>
