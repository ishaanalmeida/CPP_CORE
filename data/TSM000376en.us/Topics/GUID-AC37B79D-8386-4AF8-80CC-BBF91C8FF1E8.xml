<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-AC37B79D-8386-4AF8-80CC-BBF91C8FF1E8" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-AC37B79D-8386-4AF8-80CC-BBF91C8FF1E8" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">19 How to adapt the winder for reverse (inside) winding</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to adapt/modify the winder for reverse (inside) winding. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the take-up media shaft. 
</p><p class="- topic/p ">See : 
<xref keyref="19DISA015" class="- topic/xref " href="GUID-2885BF56-7B36-423E-B567-AB29516FD4CC.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 19 How to remove the take-up media shaft?>19 How to remove the take-up media shaft</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the Tension bar. 
</p></li><li id="LI_21C8B271522344C0958B457D5D3BA087" class="- topic/li "><p class="- topic/p ">Remove the left and right hand side cover of the winder. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA058" class="- topic/xref " href="GUID-018F073E-4ED3-414A-8FEC-3740B53F5DBE.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the left (or right) hand side cover of the winder?>24 How to remove the left (or right) hand side cover of the winder</xref> 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A32A562039FB485780CA65B069EE577C" class="- topic/ul "><li id="LI_55373F9DAE644089ABBC568E03CDE4FC" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Open ended spanner or socket wrench 7 mm 
</p></li><li class="- topic/li "><p class="- topic/p ">Small screwdriver 
</p></li><li class="- topic/li "><p class="- topic/p ">Tape 
</p></li><li class="- topic/li "><p class="- topic/p ">a few sheets of paper (A4/B size) 
</p></li><li class="- topic/li "><p class="- topic/p ">Modification kit for reverse winding 
</p><fig id="GUID-73CFFDE2-CD96-4DCD-90ED-96440FD97DC3" class="- topic/fig "><image href="GUID-1B3D4157-AD27-445E-A618-9D470E436802-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1B3D4157-AD27-445E-A618-9D470E436802-low.png"/></fig></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-7E1944FF-F024-450B-A2BA-0A9FD2B494C3" class="- topic/fig "><image href="GUID-A4EB1AE1-9F21-4366-A8E6-BAFF0D9B021A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A4EB1AE1-9F21-4366-A8E6-BAFF0D9B021A-low.png"/></fig></section><section id="SECTION_521D99F65A144454BCCB5E25B2366263" class="- topic/section "><title class="- topic/title ">How to remove the old unit</title><table pgwide="1" id="TABLE_F0323E51D9184ACDAA5DAB8F03D11BA5" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Move the screen of the printer in a horizontal position. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-12102EEE-9945-445F-B794-D8F645BBEA11" class="- topic/fig "><image href="GUID-6747AD4B-5184-4E6D-A442-5D8A0B77216E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6747AD4B-5184-4E6D-A442-5D8A0B77216E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place the guide strip assembly in the upper position and tape it to the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FE3EC762-4539-4AF9-87A9-67624F950B86" class="- topic/fig "><image href="GUID-B35D9843-0CC6-4203-8E03-6CFC8157011D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B35D9843-0CC6-4203-8E03-6CFC8157011D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">At the right hand side (near printer screen): 
</p><p class="- topic/p ">Remove the 2 screws. 
</p><note id="GUID-78FD26F8-4F95-4938-B884-BE0A918E6A1F" class="- topic/note "><p class="- topic/p ">Place the removed parts on a sheet of paper. You need them during install again. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EF689620-85AF-44D1-9D5F-90BCC9051112" class="- topic/fig "><image href="GUID-48537CF9-3C00-454F-A04C-99E9C8D8B177-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-48537CF9-3C00-454F-A04C-99E9C8D8B177-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6755558C-6E6E-46E9-BCDF-C4FD04FFFE0C" class="- topic/fig "><image href="GUID-570AD9D3-5584-4B81-B15F-886FBC529795-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-570AD9D3-5584-4B81-B15F-886FBC529795-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the circlip (E-ring). 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the lever from the pin. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-AB60F176-E510-454F-AFA4-9FA71F4EF778" class="- topic/fig "><image href="GUID-3D05F7D0-BF54-49B3-85DB-8F43A16860E1-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3D05F7D0-BF54-49B3-85DB-8F43A16860E1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the circlip (E-ring) 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A31906B5-70F3-41C9-AA4D-871EF233878F" class="- topic/fig "><image href="GUID-CED2DF96-2FFB-4D8F-B933-96BE107D9F30-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CED2DF96-2FFB-4D8F-B933-96BE107D9F30-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the block. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the pin. 
</p><note id="GUID-E888FD7C-9962-4B29-8CA3-012783064EEB" class="- topic/note "><p class="- topic/p ">Do not loose it. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4D250147-1806-49B0-9E48-AE30B09C42D9" class="- topic/fig "><image href="GUID-92EA8176-998D-4EEB-814B-88FBC510F989-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-92EA8176-998D-4EEB-814B-88FBC510F989-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the circlip (E-ring). 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the bearing from the axis. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A1EA1AF1-3FDC-4582-9D7F-6ACEC05491E0" class="- topic/fig "><image href="GUID-F0501459-E9C2-4421-9217-B43A7AED5865-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F0501459-E9C2-4421-9217-B43A7AED5865-low.png"/></fig><fig id="GUID-112F5ABE-C5FF-45D1-BF39-1473761AD804" class="- topic/fig "><image href="GUID-B03BA02B-D951-4AB8-93B8-BD9DFAED0BF4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B03BA02B-D951-4AB8-93B8-BD9DFAED0BF4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Overview of the removed parts. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-567308C9-BAF1-4373-915E-BB382ABEDB9A" class="- topic/fig "><image href="GUID-74DCFA2C-C3FA-4AF3-96D8-062A67C71B16-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-74DCFA2C-C3FA-4AF3-96D8-062A67C71B16-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> At the left hand side (ink handling): 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the circlip (E-ring). 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the lever from the pin: turn the pulley if needed. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-DCDCF00F-861D-4345-BBE9-AB35ECDF48F2" class="- topic/fig "><image href="GUID-4B8572DA-6752-440B-BCDF-5B61FD3D804C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4B8572DA-6752-440B-BCDF-5B61FD3D804C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the drive belt from the gear. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E9D0443F-B67E-46E4-A5A3-517F76C2C976" class="- topic/fig "><image href="GUID-46FCC305-0F24-4818-9BE2-E94E1A620B03-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-46FCC305-0F24-4818-9BE2-E94E1A620B03-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the circlip (E-ring). 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the gear. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EFCA25F9-B2D1-41FD-8E03-E4D821A8CDB2" class="- topic/fig "><image href="GUID-C4E2B7E2-8242-41B4-A2C1-6C23D644824A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C4E2B7E2-8242-41B4-A2C1-6C23D644824A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the pin. 
</p><note id="GUID-4A1B23B0-C040-4266-95B8-FDC33FABDF96" class="- topic/note "><p class="- topic/p ">Do not loose it. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D62B2209-0A16-460B-8BC1-B17FF6E99FB3" class="- topic/fig "><image href="GUID-ED674F56-9A9C-4A12-815A-3CCA80821918-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-ED674F56-9A9C-4A12-815A-3CCA80821918-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the locking plate (2 nuts). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-561371A0-CF0D-49A4-9993-7A42BA0F5B8E" class="- topic/fig "><image href="GUID-F711CF21-806D-428A-930E-29433E2CD24D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F711CF21-806D-428A-930E-29433E2CD24D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7F1B7AF6-B0E0-4FB5-94EB-83F36137FC2D" class="- topic/fig "><image href="GUID-EDF6B7EC-30F4-44FF-8D68-414664401E1C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EDF6B7EC-30F4-44FF-8D68-414664401E1C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5DC1F835-26E7-4BB2-9A24-5B5ACDE06B87" class="- topic/fig "><image href="GUID-5ACEEBC4-B37D-49B3-8C58-EBC49E1C7819-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5ACEEBC4-B37D-49B3-8C58-EBC49E1C7819-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the circlip (E-ring). 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the bearing from the axis. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-36E0A781-7E2A-4522-A51C-4922E3C1F1C5" class="- topic/fig "><image href="GUID-FBD0A66E-4483-467C-A451-CF53D510767E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FBD0A66E-4483-467C-A451-CF53D510767E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Overview of the removed components at the left hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-83C87049-66CD-4ABF-B493-11FFA6AF2FAB" class="- topic/fig "><image href="GUID-659BD6B9-7F6D-4B51-9C8B-F757E5560DCE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-659BD6B9-7F6D-4B51-9C8B-F757E5560DCE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide the axis 3 cm (1.2") to the drive side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F39B3132-20E7-4EC9-AA72-48BF82C6591D" class="- topic/fig "><image href="GUID-6380EF8C-9934-423F-A73C-7D52962A10D6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6380EF8C-9934-423F-A73C-7D52962A10D6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">21 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">At the left/middle/right hand side of the winder: 
</p><p class="- topic/p ">Remove the 8 screws and remove the bracket. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E9C338BA-A6E9-4B39-9199-F0FD5C1F8F47" class="- topic/fig "><image href="GUID-2F10F610-CBD4-41B7-8642-9CE1CECFFE65-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2F10F610-CBD4-41B7-8642-9CE1CECFFE65-low.png"/></fig><fig id="GUID-6E2B3C8A-8DA0-42FC-9EA7-A5E76BA7CCA3" class="- topic/fig "><image href="GUID-E9A08098-F283-4D76-924C-DE172C080B0A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E9A08098-F283-4D76-924C-DE172C080B0A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">22 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the cable ties of the cable bundle. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5D67F4F2-6FB2-4CA2-B16F-88AF87FEFC20" class="- topic/fig "><image href="GUID-56A2955D-AFA2-4C19-9770-4BE1412C8961-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-56A2955D-AFA2-4C19-9770-4BE1412C8961-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">23 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connector from sensor 19B5. 
</p><p class="- topic/p ">The bundle is now free. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-859BFA75-E9C4-4C7F-9E02-7D92509B7419" class="- topic/fig "><image href="GUID-0C884698-753E-4923-AD83-568447906E76-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0C884698-753E-4923-AD83-568447906E76-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">24 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the sensor from the bracket (1 screw). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-10F9E11F-7DBE-4C5F-BB86-15E6F6C15537" class="- topic/fig "><image href="GUID-BA16CBC2-1AAD-44FC-870C-E3BA381B117D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BA16CBC2-1AAD-44FC-870C-E3BA381B117D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">25 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 3 screws at the left, middle and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D5665A2B-9540-4165-B404-8393B628672A" class="- topic/fig "><image href="GUID-42015FF0-C4AD-43B4-AA21-1A2593ACF2D8-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-42015FF0-C4AD-43B4-AA21-1A2593ACF2D8-low.png"/></fig><fig id="GUID-70EC3603-13C3-4DE8-A5DB-A26A18159C83" class="- topic/fig "><image href="GUID-DE4B657A-2D2C-4395-A1CA-C0BBBDE733D3-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-DE4B657A-2D2C-4395-A1CA-C0BBBDE733D3-low.png"/></fig><fig id="GUID-2C0686B7-C4EB-4F5C-B944-83B7675432E7" class="- topic/fig "><image href="GUID-1D16C5A6-7174-4742-B30A-D7A1FDDF887A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1D16C5A6-7174-4742-B30A-D7A1FDDF887A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">26 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the clamp. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">27 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the old unit with the axis from the winder. 
</p><note id="GUID-F6683B15-70CC-4E16-B41B-95F6F0165150" class="- topic/note "><p class="- topic/p ">Keep the 2 paper guides in position. 
</p></note><p class="- topic/p "> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-276CF357-7709-4991-9AAD-2854BAA6B7DB" class="- topic/fig "><image href="GUID-B04BBF3C-3E7B-46AA-BE04-2D31D6969577-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B04BBF3C-3E7B-46AA-BE04-2D31D6969577-low.png"/></fig><fig id="GUID-26F896FD-666B-4043-9829-C73A5B622473" class="- topic/fig "><image href="GUID-EF373877-549B-4332-947A-8744324A4155-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EF373877-549B-4332-947A-8744324A4155-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install the new </title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the new (with the rollers) and old unit on a table: 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the axis of the 
<b class="+ topic/ph hi-d/b ">old</b> unit. 
</p></li><li class="- topic/li "><p class="- topic/p ">Slide the axis in the 
<b class="+ topic/ph hi-d/b ">new</b> unit. Push out the axis of the unit. 
</p><note id="GUID-1D99AA54-08CA-4737-AFDC-5CE72D88E1FD" class="- topic/note "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">3 
</b>grooves in the axis must be at the left hand side of the unit. 
</p></note></li><li class="- topic/li "><p class="- topic/p ">Move the axis 3 cm (1.2") out of the frame at the left hand (drive side). 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7FBAF5A6-7161-438D-8A44-BD427F8D4CF0" class="- topic/fig "><title class="- topic/title ">New unit</title><image href="GUID-1B3D4157-AD27-445E-A618-9D470E436802-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1B3D4157-AD27-445E-A618-9D470E436802-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check the paper guide at the left and right hand side 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A6600F45-A56A-4A86-8FE2-128A2C45ECFC" class="- topic/fig "><image href="GUID-32FD9928-6F95-44C0-B7AB-5F8CAB2D7BD8-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-32FD9928-6F95-44C0-B7AB-5F8CAB2D7BD8-low.png"/></fig><fig id="GUID-8C6BF032-A95E-4DD3-87AE-1133167FF3E4" class="- topic/fig "><image href="GUID-68430DAC-4A0A-4EBC-8EAF-CDA9B487F3BC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-68430DAC-4A0A-4EBC-8EAF-CDA9B487F3BC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Place the 
<b class="+ topic/ph hi-d/b ">new</b> unit in the winder: left hand side first and than the right hand side. 
</p></li><li class="- topic/li "><p class="- topic/p ">Slide the axis inside the unit (left and right hand side are equal). 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2798E177-4074-44BA-B53C-C6CD7EACD93A" class="- topic/fig "><image href="GUID-1131AA07-FEB5-4658-8355-E993DE8534D3-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1131AA07-FEB5-4658-8355-E993DE8534D3-low.png"/></fig><fig id="GUID-FBDDE972-7D73-4B89-AD83-250077924BA6" class="- topic/fig "><image href="GUID-53CF5F16-8059-40AA-859F-2C582E0F6CFA-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-53CF5F16-8059-40AA-859F-2C582E0F6CFA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Hold the unit and check the sliding movement of the paper guide plates. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-168656B3-9EDE-4F1A-85F5-593778E08316" class="- topic/fig "><image href="GUID-F762EBA5-6930-412B-A735-7EA5D30650F9-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F762EBA5-6930-412B-A735-7EA5D30650F9-low.png"/></fig><fig id="GUID-50794790-2EF7-4872-9903-DDB872C30AB5" class="- topic/fig "><image href="GUID-636601A7-AFA7-47B0-BFFF-733C1BF74147-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-636601A7-AFA7-47B0-BFFF-733C1BF74147-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lock the unit with the 4 screws at the right hand side. 
</p><note id="GUID-479019BC-E977-4781-BC01-3B88A3B30267" class="- topic/note "><p class="- topic/p ">Do not tighten the 4 screws. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EE6E184C-3AEC-4049-95C3-F0CBB7A93726" class="- topic/fig "><image href="GUID-1CEF3C88-118D-422E-9977-5510290E08DC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1CEF3C88-118D-422E-9977-5510290E08DC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lock the unit with the 4 screws at the right hand side. 
</p><note id="GUID-46E21307-AC23-49DF-98D4-B2603C4DE2A4" class="- topic/note "><p class="- topic/p ">Do not tighten the 4 screws. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-378A1474-6389-41CB-8869-B9E6AAE0B0E5" class="- topic/fig "><image href="GUID-5589AC49-70DC-43D1-8679-574ACE59A031-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5589AC49-70DC-43D1-8679-574ACE59A031-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the 3 screws (left, middle and right hand side) to lock the unit 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B670825E-D4D4-4A8C-9C49-A90E68438A20" class="- topic/fig "><image href="GUID-BE16E539-CC11-4A83-A4E4-75A7A8B9AD8B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BE16E539-CC11-4A83-A4E4-75A7A8B9AD8B-low.png"/></fig><fig id="GUID-FC9B69A9-FC04-41C5-84F8-4D39BD95652D" class="- topic/fig "><image href="GUID-40C8A601-7E5F-4582-A4D4-92AC28EBC5DF-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-40C8A601-7E5F-4582-A4D4-92AC28EBC5DF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the sensor in the middle of the unit (1screw). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C9E5D5F1-8866-4EB3-BAC7-A24BCC823B21" class="- topic/fig "><image href="GUID-7CD54CE6-9499-48C0-A4A0-4F6E5D12977D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7CD54CE6-9499-48C0-A4A0-4F6E5D12977D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect the connector to the sensor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-54D9610F-07A3-42D4-A403-F80A3E6296B5" class="- topic/fig "><image href="GUID-CE2B5E83-4649-4294-B638-BE8E2A4B17E9-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CE2B5E83-4649-4294-B638-BE8E2A4B17E9-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Hook the cable bundle in the cable guides. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CC10AF9E-8231-4AF4-8C5F-464CAADCF33B" class="- topic/fig "><image href="GUID-86DEAE46-A7BD-44EE-81EE-5D056E072C44-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-86DEAE46-A7BD-44EE-81EE-5D056E072C44-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the guide plate (8 screws). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0D671074-0A3B-4EF2-A5D6-2C62E85BC354" class="- topic/fig "><image href="GUID-29E2A2D9-99BA-4567-B085-14FFE176B0E2-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-29E2A2D9-99BA-4567-B085-14FFE176B0E2-low.png"/></fig><fig id="GUID-80804F28-62AE-4971-8050-EA08D2444ED9" class="- topic/fig "><image href="GUID-8FBF402D-BFBE-4CB9-935D-8EA6C27310C1-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8FBF402D-BFBE-4CB9-935D-8EA6C27310C1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the bearing and the circlip (E-ring). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-58C3FF9B-E3FD-4B51-9096-71E9C05CCBD8" class="- topic/fig "><image href="GUID-CFF4D5A6-A775-4D9D-A618-E0185E0A804C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CFF4D5A6-A775-4D9D-A618-E0185E0A804C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Install the locking plate (2 nuts) 
</p></li><li class="- topic/li "><p class="- topic/p ">Install the pin in the axis. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C89CB9AD-E11B-4EF0-9F88-EEB490D9B514" class="- topic/fig "><image href="GUID-B650A5D4-8C85-4F4E-AF8D-7524F25F80FE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B650A5D4-8C85-4F4E-AF8D-7524F25F80FE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the gear. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B78FDCF5-AC50-40DB-B4C4-F0E4B104EDE9" class="- topic/fig "><image href="GUID-1606B20E-8328-4FE3-856C-36AB252DF48F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1606B20E-8328-4FE3-856C-36AB252DF48F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the drive belt over the gear. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-263A3C9E-894A-4F2E-95F4-E23E58C2D350" class="- topic/fig "><image href="GUID-F865C4BC-4961-49A1-8535-9C7C8519EA9C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F865C4BC-4961-49A1-8535-9C7C8519EA9C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the bracket and the circlip (E-ring). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A61BE129-07CC-465B-86C8-24BA40D70A9C" class="- topic/fig "><image href="GUID-8003AB29-7A49-48F3-8B71-5BF9CE6E43F2-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8003AB29-7A49-48F3-8B71-5BF9CE6E43F2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the bearing and the circlip (E-ring). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-739D66E4-F4A3-4BAE-8D48-41D5BD4FFB0F" class="- topic/fig "><image href="GUID-950B89E0-56C6-43D1-8537-14C4985928A4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-950B89E0-56C6-43D1-8537-14C4985928A4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the block and circlip (E-ring). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CCAF67C7-3117-4EE4-8791-C323CA969CD3" class="- topic/fig "><image href="GUID-13AA58B7-6D51-44F3-84AB-07E798716981-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-13AA58B7-6D51-44F3-84AB-07E798716981-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the bracket and circlip (E-ring). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2D0DBF82-E2D4-4B0A-836A-92A030D13BDA" class="- topic/fig "><image href="GUID-EE723C45-3169-4516-B05F-D4F9213E7ED2-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EE723C45-3169-4516-B05F-D4F9213E7ED2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Tighten the 4 screws at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">21 
