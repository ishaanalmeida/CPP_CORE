<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-A55435A4-F1B1-490B-ADB7-C7D7F8AB19A7" version="4" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-A55435A4-F1B1-490B-ADB7-C7D7F8AB19A7" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to remove the runner block of the curing carriage</title><abstract class="- topic/abstract " id="GUID-CAB2B4FF-9E7B-42F0-823B-9E5AFCC91FBE"><p class="- topic/p "> This document describes how to remove the runner block of the curing carriage. 
</p><p class="- topic/p ">The runner block enables the movement of the curing carriage in y-direction. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_CA72A11EC2AC4C48863612B5463B3EEE" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-5336C61E-428B-4155-A159-4E02791CDD76" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li><li class="- topic/li "><p class="- topic/p ">Put a sheet of paper on the platen to prevent screws falling into the printer. 
</p></li></ol></prereq><section id="GUID-781D87E3-B53B-45A0-AA30-BA562FA762E3" class="- topic/section "><title class="- topic/title "/></section><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_840C79ECCB334F8AA1075BBA0086BC39" class="- topic/ul "><li id="LI_0B417F2969424F2E8B3BB07815511E4C" class="- topic/li "><p class="- topic/p ">Philips screwdriver (for lubricators) 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10, T20, 1/4 rachet set 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-3B517AA2-20E4-44D1-8F2B-A548FCBAACE3" class="- topic/section "><title class="- topic/title "/></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-F46A53A9-669C-46CE-94D2-C1DD775E077B" class="- topic/fig "><image href="GUID-B92F97E4-556A-4658-8D9D-1ECD815BAA85-low.png" placement="inline" class="- topic/image " otherprops="GUID-B92F97E4-556A-4658-8D9D-1ECD815BAA85-low.png"/></fig><fig id="GUID-80AAFA02-ABD5-4FD5-881B-85C9D5CEBF60" class="- topic/fig "><title class="- topic/title ">Fig.1</title><image href="GUID-25DCE0B0-57D7-4ECF-91B4-A83F072C4097-low.png" placement="inline" class="- topic/image " otherprops="GUID-25DCE0B0-57D7-4ECF-91B4-A83F072C4097-low.png"/></fig></section><section id="SECTION_2ED55A2BDE0B4458AC37B33FC1C7B7AA" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_B5424687F5CB4E4CADC5ABF3E101FBF3" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the emission filters if equipped.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-32061534-3FC3-4B49-8C56-C07DA08FACE0" class="- topic/fig "><title class="- topic/title ">Fig.2</title><image href="GUID-C7B694D7-9556-4A00-A69C-F517C6C0A8C0-low.png" placement="inline" class="- topic/image " otherprops="GUID-C7B694D7-9556-4A00-A69C-F517C6C0A8C0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Detach the Curing carriage ruler sensor and place it temporary on top.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FE0F0CDF-A8A2-4618-BF7F-4E1550FB4C04" class="- topic/fig "><title class="- topic/title ">Fig.3</title><image href="GUID-B1D1C20C-CA0E-4D98-AC1D-B3F64C06F90D-low.png" placement="inline" class="- topic/image " otherprops="GUID-B1D1C20C-CA0E-4D98-AC1D-B3F64C06F90D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the curing carriage drive belt.
</p><p class="- topic/p ">See:<xref href="GUID-8FB9F0EF-C8CA-4F08-9A24-F52C1F32E158.xml" class="- topic/xref " type="task"><?ditaot gentext?>01 How to remove the curing carriage drive belt</xref>
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-32D42F5F-0C2D-4C7B-9A9E-87B19E4CE8EB" class="- topic/fig "><title class="- topic/title ">Fig.4</title><image href="GUID-B072EFE0-CCED-457D-8DCB-1D6E90F31652-low.png" placement="inline" class="- topic/image " otherprops="GUID-B072EFE0-CCED-457D-8DCB-1D6E90F31652-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 3 screws at the bottom via the space where the filters seat. Use a ¼ mini ratchet and T20 bit. 
</p><fig id="GUID-EC9F743F-0022-4C4F-A42B-3347FB7851EE" class="- topic/fig "><title class="- topic/title ">Fig.5</title><image href="GUID-91019577-61E8-4F4B-92BB-836907FEAF69-low.png" placement="inline" class="- topic/image " otherprops="GUID-91019577-61E8-4F4B-92BB-836907FEAF69-low.png"/></fig></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4FBFAD31-3BBC-4EF5-9AB1-4F69098C4349" class="- topic/fig "><title class="- topic/title ">Fig.6</title><image href="GUID-BB771273-319F-4F41-A827-9FC726B193AF-low.png" placement="inline" class="- topic/image " otherprops="GUID-BB771273-319F-4F41-A827-9FC726B193AF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place a piece of cardboard between the print surface and curing carriage. Remove the 3 top screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1EA19437-F658-4C01-8CB0-E7C6800B09E8" class="- topic/fig "><title class="- topic/title ">Fig.7</title><image href="GUID-65A37860-62C1-4426-B47F-FA6087A200BF-low.png" placement="inline" class="- topic/image " otherprops="GUID-65A37860-62C1-4426-B47F-FA6087A200BF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> While holding the curing carriage, slide out the runner block. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6F16A8FC-4D4B-43F2-8611-129BC475FA3D" class="- topic/fig "><title class="- topic/title ">Fig.8</title><image href="GUID-CBA34DB1-7C4C-462B-932A-141614C34190-low.png" placement="inline" class="- topic/image " otherprops="GUID-CBA34DB1-7C4C-462B-932A-141614C34190-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove lubricators. Remember the needles. 
</p><p class="- topic/p ">
</p><p class="- topic/p ">Remove the 2 shafts marked with red arrows. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-BEBDC69D-D995-499B-A18F-36364F74BAF2" class="- topic/fig "><title class="- topic/title ">Fig.9</title><image href="GUID-D02198C5-792D-4F64-AE61-8A93CDE09E84-low.png" placement="inline" class="- topic/image " otherprops="GUID-D02198C5-792D-4F64-AE61-8A93CDE09E84-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 3 screws and detach the tensioner assy.
</p><p class="- topic/p ">
</p><p class="- topic/p "> Note: be aware of the harness to the sensor.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0845AE52-CC0E-40A9-8261-786240ABA8E8" class="- topic/fig "><title class="- topic/title ">Fig.10</title><image href="GUID-730C2D40-6B4A-4ACD-B80D-12D094509B14-low.png" placement="inline" class="- topic/image " otherprops="GUID-730C2D40-6B4A-4ACD-B80D-12D094509B14-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Slide out the runner block
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FD9B7351-5CE0-4C7F-AE13-CCD329998E41" class="- topic/fig "><title class="- topic/title ">Fig.11</title><image href="GUID-E4955FB8-381B-4831-95FD-99D1FB88D7F9-low.png" placement="inline" class="- topic/image " otherprops="GUID-E4955FB8-381B-4831-95FD-99D1FB88D7F9-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_E3FC7EE10DDC46BA880F87671551C890" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Adjust the Curing carriage ruler sensor ( 01B5 ;CUR_CAR_RUL_SE).
</p><p class="- topic/p ">See: 
<xref href="GUID-8F959988-F852-45E0-9091-A6B6EA4310B4.xml" class="- topic/xref " type="task"><?ditaot gentext?>01 How to adjust the Curing carriage ruler sensor 01B5 CUR_CAR_RUL_SE</xref>
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-22D79A6A-2191-46FA-BE14-24F47FE4288E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>