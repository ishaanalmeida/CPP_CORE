<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-2FB6105E-9D58-4917-9A1A-C36A83AE8A79" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-2FB6105E-9D58-4917-9A1A-C36A83AE8A79" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title "> Print the ONYX test print </title><abstract class="- topic/abstract " id="M028334-B18"><p class="- topic/p ">Print the ONYX test print. 
</p><p class="- topic/p ">This help make sure that printing from ONYX is working as expected. 
</p><note class="- topic/note " id="GUID-D25A9F6D-6789-4D94-85D1-4F91CD5ACDFE"><p class="- topic/p ">The screen dumps in this document are used from the Colorado 1640. 
</p></note></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-94C20406-75A1-4BD0-A7DB-8CD9777F04B0" class="- topic/section "><title class="- topic/title ">Procedure</title><table id="NEW" class="- topic/table "><tgroup align="left" outputclass="step" cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="90*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Load the standard media. 
</p><fig id="FIG_5B8646F3842F490D8F20764433AE65B4" class="- topic/fig "><image href="GUID-18970E71-8F4D-4702-950C-67CCCA46A29B-low.png" id="IMAGE_8F1403FC911C4141AB9B38C49267768D" keyref="" placement="inline" class="- topic/image " otherprops="GUID-18970E71-8F4D-4702-950C-67CCCA46A29B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Apply the correct media settings on the printer operator panel and calibrate the media. 
</p><fig id="FIG_6572DE420D6847A8B56CCB00B5CA32E7" class="- topic/fig "><image href="GUID-9438C479-7160-4093-B15E-7FC8C46E579C-low.png" id="IMAGE_A841FEE6A0504BC9851B1822EEF90537" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9438C479-7160-4093-B15E-7FC8C46E579C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Select in Thrive RIP-Queue, Open. 
</p><fig id="FIG_2831829294E2427E806FC1ADAE27C48D" class="- topic/fig "><image href="GUID-0577428B-5D0E-484A-B8E3-4AA133591663-low.png" id="IMAGE_F29350059CC7499891F357A17E81497B" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0577428B-5D0E-484A-B8E3-4AA133591663-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Select the ONYX Quality Test.pdf file. 
</p><fig id="FIG_A8E418AD79374A9F953FC13F3B30537D" class="- topic/fig "><image href="GUID-A9CD680B-90F7-4B9D-8EE7-2FA258EA7F28-low.png" id="IMAGE_F1063148C3AE4D89A173C0613FF261B0" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A9CD680B-90F7-4B9D-8EE7-2FA258EA7F28-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Select "Open in Job Editor" 
</p><fig id="FIG_2A123148C37947F784E1B49DC14A1D8A" class="- topic/fig "><image href="GUID-841E7AD6-0A6F-4A48-A035-6097DBED3C7C-low.png" id="IMAGE_41FE4DB3B0E0479384CEA980C41C5939" keyref="" placement="inline" class="- topic/image " otherprops="GUID-841E7AD6-0A6F-4A48-A035-6097DBED3C7C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Apply the settings as shown in the Printer and Media tab. 
</p><fig id="FIG_E9E77059B0AB41B18FF383B18CC918D8" class="- topic/fig "><image href="GUID-3E569837-DBF7-45C0-BDF9-F4B744B88922-low.png" id="IMAGE_72067E0AC44F4A03AD3897A4167E1576" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3E569837-DBF7-45C0-BDF9-F4B744B88922-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Select Apply. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Open the Print tab. 
</p><fig id="FIG_2DD8739470DF4E87A4DE51809D8406CC" class="- topic/fig "><image href="GUID-B60759AC-D958-4A8D-9AAA-BEFB4F387BCD-low.png" id="IMAGE_F48EC1DD20CA43DBAE403A727B064936" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B60759AC-D958-4A8D-9AAA-BEFB4F387BCD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Select Submit. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The job is ripped in the Thrive RIP queue. You must wait till "Waiting to Print" is displayed. 
</p><fig id="FIG_6F7ECDD242DD4289A882006CF3E8789D" class="- topic/fig "><image href="GUID-08742821-13FD-4494-9959-A122FE4885C0-low.png" id="IMAGE_894C959C4FC9405C91E85612FAFD8773" keyref="" placement="inline" class="- topic/image " otherprops="GUID-08742821-13FD-4494-9959-A122FE4885C0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Select Print Now. 
</p><fig id="FIG_A12F3DA1CF054D62A66DC4584506595A" class="- topic/fig "><image href="GUID-74F13950-4967-4AFA-9EA0-E94992C6EBAF-low.png" id="IMAGE_433AC50127C541CDBA5D63A168B255D2" keyref="" placement="inline" class="- topic/image " otherprops="GUID-74F13950-4967-4AFA-9EA0-E94992C6EBAF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Apply the correct width (use "Edit button) if necessary. 
</p><fig id="FIG_523F48165C374D9A83062CB2A9C0214F" class="- topic/fig "><image href="GUID-C457E269-AB6F-405C-A1CC-A1ACD8402C58-low.png" id="IMAGE_A233C2645BF846578B0E56A5282E90D5" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C457E269-AB6F-405C-A1CC-A1ACD8402C58-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Select Print Panel. 
</p><fig id="FIG_249BC722EBCB4CB9B887684CC8763079" class="- topic/fig "><image href="GUID-7353C86B-0356-4654-9FDA-A0F8B4EEF0D8-low.png" id="IMAGE_1AEA252FC78441B09566C91842E4992B" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7353C86B-0356-4654-9FDA-A0F8B4EEF0D8-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The Job is printed. 
</p><fig id="FIG_4A2C5F74D8A845499A65524345743337" class="- topic/fig "><image href="GUID-BD927A81-AEE5-4D2D-86C6-C979F5C3EE3F-low.png" id="IMAGE_598DDFDA2A2841CCA3689A0843F4CEC6" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BD927A81-AEE5-4D2D-86C6-C979F5C3EE3F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Do not judge the print quality. 
</p><p class="- topic/p ">You just made sure that printing with ONYX is working. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Dispose the print. 
</p></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-3140D264-493B-4163-8934-73ACCD3B6AA1.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
