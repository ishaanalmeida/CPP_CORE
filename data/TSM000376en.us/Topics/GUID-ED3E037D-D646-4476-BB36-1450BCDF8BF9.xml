<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-ED3E037D-D646-4476-BB36-1450BCDF8BF9" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-ED3E037D-D646-4476-BB36-1450BCDF8BF9" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title translate="no" class="- topic/title ">04-6-036 Jet stability setting</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">SDS</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-2BD8C3DB-27B0-44E5-B999-CF486EF1CE0D" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">SDS</ph></title><p class="- topic/p "> 
<object id="GUID-A56B801F-B15A-4D37-92E2-41383C2F0616" class="- topic/object "><desc class="- topic/desc "><p class="- topic/p ">Jet stability setting</p></desc><param name="testid" value="046036" class="- topic/param "/><param name="target" value="NIL" class="- topic/param "/><param name="axmodule" value="None" class="- topic/param "/></object> 
</p></section><section id="GUID-033BF38E-3397-4AA5-848A-23A944B68B1B" class="- topic/section "><title class="- topic/title ">Introduction</title><note type="important" id="GUID-51040A35-9E95-46D0-A526-9152AB42A08E" class="- topic/note "><p class="- topic/p ">This SDS test is visible in the user interface; please refrain from using it, as it is intended solely for R&amp;D purposes 
</p></note><p class="- topic/p "><draft-comment translate="no" class="- topic/draft-comment "> This test is to change the jet stability setting of the print heads. 
</draft-comment> 
</p><p class="- topic/p "><draft-comment translate="no" class="- topic/draft-comment ">When a print head is running with -Adapted- jet stability its temperature is elevated by a few degrees. 
</draft-comment> 
</p><p class="- topic/p "> 
<draft-comment translate="no" class="- topic/draft-comment ">At -Automatic- the jet stability setting for a print head is based on the warm time of the print head. 
</draft-comment> 
</p><p class="- topic/p "><draft-comment translate="no" class="- topic/draft-comment "> When changing this setting a print head calibration may be required to actually change the temperature. 
</draft-comment> 
</p><note id="GUID-508F63E3-35F5-49ED-A728-06DC56870A50" class="- topic/note "><p class="- topic/p "><draft-comment translate="no" class="- topic/draft-comment ">Some configurations or inks do not need -Adapted- jet stability.</draft-comment> 
</p></note><p class="- topic/p "> 
<draft-comment translate="no" class="- topic/draft-comment ">Then this setting has no effect and always -Nominal- is shown.</draft-comment> 
</p></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-686678F1-A321-4B08-84D3-63C9CD28C7FA.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>SDS</linktext></link></linkpool></related-links>
