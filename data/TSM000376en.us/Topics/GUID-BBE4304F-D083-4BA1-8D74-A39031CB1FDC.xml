<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-BBE4304F-D083-4BA1-8D74-A39031CB1FDC" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-BBE4304F-D083-4BA1-8D74-A39031CB1FDC" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">06 How to disconnect the tubes of the Chiller (V2)</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><context id="GUID-B732961D-902F-4C5B-8070-15B3B3285C87" class="- topic/section task/context "><p class="- topic/p ">The tubes have to be disconnected when you remove the Chiller. 
</p></context><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_4C94C73DC4F44D89B7FB313D2EFA662A" class="- topic/li "><p class="- topic/p ">Unplug the mains cables. 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the chiller. 
</p><p class="- topic/p ">See : 
<xref keyref="06DISA003V2" class="- topic/xref " href="GUID-BF384AC4-FF34-48F3-9D8C-4DB12B517E06.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06 How to open the Chiller (V2)?>06 How to open the Chiller (V2)</xref> 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A4E6F006ECAE4473A0F5CE15E4454364" class="- topic/ul "><li id="LI_C6D2D88D00D346F99E8A00DE1E85C8BC" class="- topic/li "><p class="- topic/p ">Pliers 
</p></li><li id="LI_D25FDAE9F4C54062BB4F70936D0F92DE" class="- topic/li "><p class="- topic/p ">2 Cable ties 
</p></li><li id="LI_89BB898704EC4BEFA2AB51E24B6C2F5F" class="- topic/li "><p class="- topic/p ">A bucket. 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title></section><section id="SECTION_412D814C231741FE8DB700FAAC99CF48" class="- topic/section "><title class="- topic/title ">How to disconnect</title><table pgwide="1" id="TABLE_25A15BBCA4F94DCF9706305F356CE9E8" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place paper tissues and a bucket below the connection point of the tube. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Before removing the tubes 
<b class="+ topic/ph hi-d/b ">drain</b> the coolant system 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-054AE071-3FD2-4F62-B7FB-F440291C072E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-8082EF8C-6872-4535-A91F-B6AC29724457-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8082EF8C-6872-4535-A91F-B6AC29724457-low.png"/></fig><fig id="GUID-2B93D5F9-F1B0-490F-9C3F-0C10A6F0B31E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-A4B42787-3F82-46D9-82A4-52A06B9C2444-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A4B42787-3F82-46D9-82A4-52A06B9C2444-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Squeeze and unlock the tube clamp. 
</p><p class="- topic/p ">The tube with red indicator does not have a clamp.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-44A4DF03-3A59-4250-887E-8F0BFDD74E9C" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B0D2ECD0-FEFC-4EFC-B103-23A712EFD424-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B0D2ECD0-FEFC-4EFC-B103-23A712EFD424-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the 2 tubes from the chiller. 
</p><p class="- topic/p ">Fold the tubes and use the table ties to avoid leakage. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EE0C1C9B-3253-4BA3-B6FD-7C8A4601F443" class="- topic/fig "><title class="- topic/title "/><image href="GUID-E52C8794-4674-44A1-ABE6-F656A4DE36DE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E52C8794-4674-44A1-ABE6-F656A4DE36DE-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to connect</title><table pgwide="1" id="TABLE_E3FC7EE10DDC46BA880F87671551C890" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> connect in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-935FFAA3-C046-4B95-B22E-A4AC33BEEF53.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
