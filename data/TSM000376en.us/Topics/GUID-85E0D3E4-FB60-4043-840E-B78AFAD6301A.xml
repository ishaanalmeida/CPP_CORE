" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="3.08*" align="left" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="1.00*" class="- topic/colspec "/><colspec colname="col4" colnum="4" colwidth="3.08*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Technology</p></entry><entry colname="col2" namest="col2" nameend="col4" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Specification</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Printing</b></p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Printing method</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">UVgel piezoelectric inkjet</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Print modes</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">See 
<xref keyref="Overview-printmodes-and-use" class="- topic/xref " href="GUID-0083A3EF-C118-4859-8E05-DAAD00010D3D.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text Overview of the printmodes and use?>Overview of the printmodes and use</xref></p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Print resolution</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Up to 1800 dpi</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Ink type</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">UVgel 460 ink</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Ink color</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">CMYK, optionally white.</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Ink packaging</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> 0.7 liter bottle or 1 liter bottle.</p><p class="- topic/p ">Ink reservoir can accommodate up to 1.8 liter per ink color.</p><p class="- topic/p ">Refill while printing.</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Printheads</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> UVgel M10 PrintHead</p><p class="- topic/p ">High frequency drop-on-demand piezoelectric printhead (1/color)</p><p class="- topic/p ">PAINT (Piezo Acoustic Integrated Nozzle Technology) constantly monitors and compensates for nozzle failures that can occur during printing.</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Automatic Maintenance</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Automatic Maintenance performed daily in seconds.</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Curing </p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">UV LED (Optional license: PinCure enabled). </p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Additional licenses</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Second roll in the drawer license </p></li><li class="- topic/li "><p class="- topic/p ">Matte print modes license </p></li><li class="- topic/li "><p class="- topic/p ">Print inside and double sided license </p></li><li class="- topic/li "><p class="- topic/p ">White</p></li></ul></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Media</b></p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Roll width</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">279 mm (11") to 1625 mm (64")</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Print margin</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">5.3, 9 or 17.5 mm depending on the Automatic Advance Correction in the RIP </p><p class="- topic/p "> (None: 5.3 mm; Normal: 9.0 mm; Enhanced 17.5 mm)</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Roll weight</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Up to 50 kg (110 lbs)</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Roll diameter</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Up to 220 mm (8.7")</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Media thickness</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Up to 0.8 mm (0.03") (31.5 mils). Note that the system will automatically adjust printhead height once the thickness has been added to the media profile.</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Media length</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Whole roll, excluding the last 54 cm (22"). </p><p class="- topic/p ">In case of tight winding and manual loading also first 75 cm (30") cannot be printed (calibration; new media type or on customer decision) or first 225 cm (89"), (only for weak media). Tight winding is needed for weak media that needs to be pulled from the other side, and therefore has to be rolled on the take up unit before starting to print.</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Number of input rolls</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">1 (optional license: 2<sup class="+ topic/ph hi-d/sup ">nd</sup> roll enabled).</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Media take-up system </p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Output: no winding, loose winding (no tension bar), tight winding (with tension bar), stiff winding (locked tension bar); depending on the media.</p><p class="- topic/p ">The winding quality (telescoping) is within 5mm (in Y). </p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Double sided, inside-out printing enabled</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Optional license.</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Positioning accuracy</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Deviation for measured length of the same image on different positions of the roll in the transport direction: &lt; or equal 0.35 mm/m</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Double sided accuracy</p><p class="- topic/p "> (front-to-back registration error)</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Transport direction: &lt; 3 mm + &lt; 5 mm / 10 m media length</p><p class="- topic/p "> Cross-direction: &lt; 3 mm</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">UVgel technology</b></p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">UVgel technology - instant pinning and dot gain control</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Low temperature curing - suitable for thin and heat-sensitive media</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Outstanding scratch resistance</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Easy lamination, smooth ink film</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">High precision color-matching and consistency</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Odorless and instant dry printout</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Environmental and Safe Use Certifications</b></p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Indoor AgBB (general)</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Greenguard Gold (wallpaper general)</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">EN15102 (decorative wall coverings)</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">M1 Finish indoor wallpaper</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">A+ French indoor wallpaper</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Odor Smell</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Avery Denisson ICS waranty SA vinyl</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">3M warranty SA vinyl</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Interface</b></p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Ethernet (100/1000 Mbits/s)</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b "> Dimensions</b></p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Printer W x D X H</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">3022 x 1093 x 1310 mm (119 x 43 x 52")</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Weight</b></p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Printer</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">740 kg (1631 lbs)</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b ">Working Environment</b></p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Operation printer</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><ul id="UL_82F154A76CFC46EC91DB4B4CA74172FC" class="- topic/ul "><li id="LI_EF4B9DC459F140B4BC46C78B38FF19D6" class="- topic/li "><p class="- topic/p ">Temperature: 18 ... 30 
<sup class="+ topic/ph hi-d/sup ">0</sup>C (64 ... 86 
<sup class="+ topic/ph hi-d/sup ">0</sup>F </p><p class="- topic/p ">Recommended: 20 ... 27 
<sup class="+ topic/ph hi-d/sup ">0</sup>C (68 ... 81 
<sup class="+ topic/ph hi-d/sup ">0</sup>F </p></li><li id="LI_345E662C5A2B4281BCDF7FC49E305A75" class="- topic/li "><p class="- topic/p ">Humidity: 20 - 80% (no condensation)</p><p class="- topic/p ">Recommended: 30 - 60% </p></li><li class="- topic/li "><p class="- topic/p ">Air pressure: Between 850 mbar and 1050 mbar</p></li><li class="- topic/li "><p class="- topic/p ">Ventilation</p><p class="- topic/p ">Regular room ventilation: &gt;420 m<sup class="+ topic/ph hi-d/sup ">3</sup> / hour (&gt;14832 ft<sup class="+ topic/ph hi-d/sup ">3 
</sup>/ hour).</p></li><li class="- topic/li "><p class="- topic/p ">The printer can be equipped with filters or connected to external ventilation.</p><p class="- topic/p "> The printer may not be operated without proper ventilation.</p><p class="- topic/p "> If the printer is equipped with the optional filter, the air in the room needs to be refreshed with a minimum of 420 m<sup class="+ topic/ph hi-d/sup ">3</sup>/hour.</p><p class="- topic/p "> If the machine is connected to an external air exhaust, the air flow through the exhaust should be at least 120 m<sup class="+ topic/ph hi-d/sup ">3</sup>/hour.</p><p class="- topic/p ">In this case, the minimum room ventilation can be reduced with the volume that is extracted by the external air exhaust.</p><p class="- topic/p "> (Example: If a room has 1 machine installed that is connected to an external exhaust with an airflow of 150m<sup class="+ topic/ph hi-d/sup ">3</sup>/hour, then the minimum room ventilation is reduced to 420-150= 270 m<sup class="+ topic/ph hi-d/sup ">3</sup>/hour).</p></li></ul></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Regulatory Certifications</b></p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Overview</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">TUV-GS, c-UL, CETECOM, FCC, VCCI, RCM, CB and CE</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Software</b></p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Supported RIPs</p></entry><entry colname="col2" namest="col2" nameend="col4" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">ONYX Graphics, Caldera and other registered RIP Vendors</p></entry></row></tbody></tgroup></table></section><section id="GUID-9E9FF962-AC61-4E68-9295-C526F668B645" class="- topic/section "><title class="- topic/title "/></section></refbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-033BA4C4-476D-4C92-BA63-BAE09A5D9EB3.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Specifications</linktext></link></linkpool></related-links>
