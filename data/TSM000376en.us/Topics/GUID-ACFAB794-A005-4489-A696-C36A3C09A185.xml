<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-ACFAB794-A005-4489-A696-C36A3C09A185" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-ACFAB794-A005-4489-A696-C36A3C09A185" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title "> 05 How to replace the Aerosol Ink filter fan</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes the replacement of the Aerosol Ink filter fan. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_CEA4CD427612471CA3540AD5430B21C2" class="- topic/ul "><li id="LI_B007BBFF5E5743C89A24651737F64808" class="- topic/li "><p class="- topic/p ">Small screwdriver. 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Cutter 
</p></li><li class="- topic/li "><p class="- topic/p "> Magnetizer tool 
</p></li><li class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-98726AAF-BB3F-4F58-8400-2939AAB281D0" class="- topic/section "><title class="- topic/title "/></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-2D7D94A0-B26C-4C0B-B6A3-20C8621663A2" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-BCF9CC76-F25B-4AF8-B39D-9707EF8C6035" class="- topic/section "><title class="- topic/title ">Before you begin</title><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Position manually the Carriage to the left side (chiller side) of the printer. 
</p></li><li class="- topic/li "><p class="- topic/p ">Place a sheet to protect the platen. 
</p><fig id="GUID-A6A10599-4B7F-41B2-BC6C-B0CA70F23903" class="- topic/fig "><image href="GUID-484B1913-E78A-4ED9-B9B1-C3821013F1E7-low.png" placement="inline" class="- topic/image " otherprops="GUID-484B1913-E78A-4ED9-B9B1-C3821013F1E7-low.png"/></fig></li></ol><note id="GUID-09896636-68E1-4A32-A0AD-FD2DC898F45B" class="- topic/note "><p class="- topic/p "> Use a magnetizer tool to prevent screws from falling down, during the next actions. 
</p></note></section><section id="GUID-C9A93D68-64A4-4E21-878E-9A0BD1F5DB34" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-084740A5-EC5B-4001-B705-667D2F45CAAA" class="- topic/fig "><image href="GUID-760693B5-F5FE-42DF-8605-20443201918C-low.png" placement="inline" class="- topic/image " otherprops="GUID-760693B5-F5FE-42DF-8605-20443201918C-low.png"/></fig></section><section id="SECTION_83EFA574E57B4B64A0DD595529E957E2" class="- topic/section "><title class="- topic/title ">Replace the Aerosol Ink filter fan</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove Ink filter fan 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Disconnect fan connector. 
</p></li><li class="- topic/li "><p class="- topic/p "> Loosen the 2 screws and remove the Aerosol ink filter fan. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-676D73BB-0969-495E-9B3C-69E00DD56848" class="- topic/fig "><title class="- topic/title ">Right-hand side</title><image href="GUID-741AFC30-A6C2-41AD-9F44-A811E8D0F7FA-low.png" placement="inline" class="- topic/image " otherprops="GUID-741AFC30-A6C2-41AD-9F44-A811E8D0F7FA-low.png"/></fig><fig id="GUID-F63D72EE-23A9-417F-A629-E3C580FCAB56" class="- topic/fig "><title class="- topic/title "> Left-hand side</title><image href="GUID-3DE5ECD2-0FCC-4C8C-95EC-D0C740F3F666-low.png" placement="inline" class="- topic/image " otherprops="GUID-3DE5ECD2-0FCC-4C8C-95EC-D0C740F3F666-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Position the new Fan against the assy and hold the Nut plate from the inside of the Fan-assy and fasten both screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect Fan connector. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Reconnect the service jumper and exit SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Press 
<b class="+ topic/ph hi-d/b ">Restart</b> on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-413D000D-1733-4578-95D7-CBC36AC62908.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
