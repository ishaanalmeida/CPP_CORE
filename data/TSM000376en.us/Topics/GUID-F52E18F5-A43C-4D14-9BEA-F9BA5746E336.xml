<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-F52E18F5-A43C-4D14-9BEA-F9BA5746E336" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-F52E18F5-A43C-4D14-9BEA-F9BA5746E336" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Printed image is too short / long</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Diagnostics</category><category class="- topic/category ">Diagnostics</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-50B00AD6-0A38-41AB-B3CF-DCE2951AFA8A" class="- topic/section "><title class="- topic/title "/><table id="GUID-53E5F599-B620-44AD-919D-C7253ABD770C" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="50*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Schematic overview 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Real example 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><fig id="GUID-0AAB06AB-EF04-408E-B9C2-401C073FDD82" class="- topic/fig "><image href="GUID-A935DCB1-3643-4DAD-840E-3EDA20D33E0E-low.png" placement="inline" class="- topic/image " otherprops="GUID-A935DCB1-3643-4DAD-840E-3EDA20D33E0E-low.png"/></fig></entry><entry colname="col2" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-EC1EAE23-40EC-4B10-A2C9-83873F76DC70" class="- topic/section "><title class="- topic/title ">Collect</title><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Symptoms</b> 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> The length of the print is different than expected. 
</p></li><li class="- topic/li "><p class="- topic/p "> The length between the same images is different than expected. 
</p></li><li class="- topic/li "><p class="- topic/p "> In extreme cases white/dark lines are visible in the carriage direction. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> (See PQ_23 White dark lines 1 m leading edge.docx). 
</p></li></ul></li></ul></section><section id="GUID-53170989-CB3E-4660-862F-7345ADC62739" class="- topic/section "><title class="- topic/title ">Functional logging (if available)</title><p class="- topic/p ">No logging available which can pinpoint to this case 
</p></section><section id="GUID-91624F39-82E7-4C15-AA0D-4DEF939F8F67" class="- topic/section "><title class="- topic/title ">ADAM-triggers</title><p class="- topic/p ">No available ADAM-triggers 
</p></section><section id="GUID-DDCC1BB0-B402-4010-9156-67DB737F3DE5" class="- topic/section "><title class="- topic/title ">Analyze/Repair</title><fig id="GUID-5B0573B1-81F3-4681-A53E-F563ABB265B0" class="- topic/fig "><title class="- topic/title "/><image href="GUID-0711BD95-3292-4486-AA50-86ED8E55C110-low.png" placement="inline" class="- topic/image " otherprops="GUID-0711BD95-3292-4486-AA50-86ED8E55C110-svg.svg"/></fig></section><section id="GUID-BB9BDDD1-E29C-42C5-BF10-2854E3AE4223" class="- topic/section "><title class="- topic/title ">Steps explanation</title><table pgwide="1" id="GUID-D963269B-E108-446A-A212-4581FEAA8740" class="- topic/table "><tgroup cols="4" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="20*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><colspec colname="col4" colnum="4" colwidth="30*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Type 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">To do 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Decision 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Check whether AAC markers are used selected in the profile 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Enable AAC-markers (Normal or Enhanced) 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Decision 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Is a media-step correction factor set in the profile ? 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><fig id="GUID-09F95E69-5A09-45C6-B670-7897413F4D05" class="- topic/fig "><image href="GUID-9180A4B8-A657-4EDE-B085-7EF228422FF7-low.png" placement="inline" class="- topic/image " otherprops="GUID-9180A4B8-A657-4EDE-B085-7EF228422FF7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Set correction factor to 0. 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Decision 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Is the first print printed from the leading edge ? 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Print 1 meter using a random image and cut the media. Reprint the needed image 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Lower vacuum-settings 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><note id="GUID-3B4AA448-1E66-4160-B5B5-33E656423486" class="- topic/note "><p class="- topic/p "> Low vacuum-settings increase the change of media touches/crashes.
</p></note></entry></row></tbody></tgroup></table></section><section id="GUID-2513E5DF-C282-453D-9841-6E539DB0EB51" class="- topic/section "><title class="- topic/title ">Evaluate/Prevention</title><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> Keep the buffer and platen clean. 
</p></li><li class="- topic/li "><p class="- topic/p "> Use calibrated media 
</p></li><li class="- topic/li "><p class="- topic/p ">Use AAC-markers 
</p></li><li class="- topic/li "><p class="- topic/p "> Use the correct profile for the used media. 
</p></li><li class="- topic/li "><p class="- topic/p "> Don’t use the media step correction factor. 
</p></li></ul></section><section id="GUID-987F83F9-80F0-41BC-B82B-BB16DA268203" class="- topic/section "><title class="- topic/title ">Background info</title><p class="- topic/p ">The printed image should be equal to the length given in the controller. 
</p><p class="- topic/p ">The length of the print is managed by the yellow or black markers at the side of the image. 
</p><p class="- topic/p "> In case the media-step is not stable the length of the printed image can be different than expected. 
</p><p class="- topic/p ">In most cases this effect can be seen at images which are printed from the leading edge and the media is not calibrated well. In those cases white and/or darker lines are visible. 
</p><p class="- topic/p "> 
</p><p class="- topic/p ">The vacuum settings in the profile can also influence the performance of the media-step controller. 
</p></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-00803BE3-C849-4315-B1B2-2BBE04B8DBA4.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Solutions</linktext></link></linkpool></related-links>
