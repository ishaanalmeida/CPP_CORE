<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-87A6D33A-0528-4BED-911F-CAE7B1FCAFEC" version="3" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-87A6D33A-0528-4BED-911F-CAE7B1FCAFEC" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">05 How to adjust the strip support</title><abstract class="- topic/abstract " id="GUID-173AF84C-D126-4DD5-8ABA-ADD08113B9D4"><p class="- topic/p ">This document describes the adjustment of the strip support. 
</p><p class="- topic/p ">The strip support is mounted between the guidance and the printhead carriage. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Adjustment</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><context id="GUID-A02F419C-DBA9-48C5-9566-05B40F550DFD" class="- topic/section task/context "><p class="- topic/p ">Do this adjustment after you replace an ink tube, air tube, fiber cable, flex cable or the metal strip. 
</p></context><prereq id="GUID-982BAB96-F1AC-436A-A6A8-B6CC211033FE" class="- topic/section task/prereq "><p class="- topic/p "> A training video is available in the training video section: See 
<xref href="http://localhost:20346/VIDEO00394EN.US/video11/index.html" format="html" scope="external" class="- topic/xref "><?ditaot usertext?>How to adjust the strip support to avoid bouncing</xref> 
</p><ul id="UL_FC1647DBE66F40EAAF0086BB3E0A9CE1" class="- topic/ul "><li id="LI_E562AA275D63474CB2E1FE6DD165A477" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p></li></ul></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A392D23B9FA5434A8095E72A33F001E1" class="- topic/ul "><li id="LI_BFC835835B5440A98A2DF72417BDB02D" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_50BCE33E1BE540B7B863D5726E371F62" class="- topic/li "><p class="- topic/p ">Caliper. 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-EE39E312-2D63-4375-AE38-835657667E0A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-42B5B806-DFA9-447E-AAA5-D44B9B19BEB9-low.png" placement="inline" class="- topic/image " otherprops="GUID-42B5B806-DFA9-447E-AAA5-D44B9B19BEB9-low.png"/></fig></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to adjust the metal strip</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the printhead carriage on 750 +/- 20 mm from the belt tensioner. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_23A8B6639FCC4D04BC66BA201BE33309" class="- topic/fig "><image href="GUID-0151D962-0816-481D-A109-6571E108EA2F-low.png" id="IMAGE_D39418347F7F49C19D04121B26D00170" placement="inline" class="- topic/image " otherprops="GUID-0151D962-0816-481D-A109-6571E108EA2F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">1st</b> measuring point: 
</p><p class="- topic/p ">Measure the distance between the metal strip and the guidance. 
</p><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Specification</b>: 16.6 +/- 1 mm. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><image href="GUID-564A602F-2272-482B-9A9E-BBE8417D9FFC-low.png" placement="inline" class="- topic/image " otherprops="GUID-564A602F-2272-482B-9A9E-BBE8417D9FFC-low.png"/>
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">2nd</b> measuring point at 20 +/- 10 mm. 
</p><p class="- topic/p ">Measure the distance between the metal strip and the guidance. 
</p><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Specification</b>: 16.6 +/- 1 mm. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-02039F03-DAC8-430D-90B1-72D9BA576547" class="- topic/fig "><image href="GUID-92D578F0-10C8-48BD-A03C-60A5B0B31AB5-low.png" placement="inline" class="- topic/image " otherprops="GUID-92D578F0-10C8-48BD-A03C-60A5B0B31AB5-low.png"/></fig><fig id="FIG_4EA8B6EC46F7493193839F166D995BCA" class="- topic/fig "><image href="GUID-564A602F-2272-482B-9A9E-BBE8417D9FFC-low.png" id="IMAGE_3E10F8DFB63C45E1BE19F3A6260E121B" placement="inline" class="- topic/image " otherprops="GUID-564A602F-2272-482B-9A9E-BBE8417D9FFC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Make sure all 6 screws are tightened. 
</p><p class="- topic/p ">Loosen the 2 screws [A]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_C7FB5A4E39424B6E9F3CF51C9A231C57" class="- topic/fig "><image href="GUID-164536AF-84D1-432A-A23B-FA48A132F13C-low.png" id="IMAGE_2DF0877140AC4C2D91C9EB44DB53591A" placement="inline" class="- topic/image " otherprops="GUID-164536AF-84D1-432A-A23B-FA48A132F13C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Adjust the metal strip to the specification on the 2 measuring points. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Fasten the 2 screws [A]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EEAD65FB-C5EB-488A-B263-5CD377FB8D66" class="- topic/fig "><image href="GUID-164536AF-84D1-432A-A23B-FA48A132F13C-low.png" placement="inline" class="- topic/image " otherprops="GUID-164536AF-84D1-432A-A23B-FA48A132F13C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Keep the printhead carriage in the same position. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_460BFD955AC44392A113FDA5CAB61113" class="- topic/fig "><image href="GUID-0151D962-0816-481D-A109-6571E108EA2F-low.png" id="IMAGE_25280D6DC15E47D8B34EABC331FE7206" placement="inline" class="- topic/image " otherprops="GUID-0151D962-0816-481D-A109-6571E108EA2F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws [A] at the printhead carriage. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_EF9150CC34FC4BADAA811B894897AF53" class="- topic/fig "><image href="GUID-7BD8CBFD-C708-4544-ABBB-099CB4800213-low.png" id="IMAGE_6BC5DC15403D4E17B5B2ED06D44A9ECA" placement="inline" class="- topic/image " otherprops="GUID-7BD8CBFD-C708-4544-ABBB-099CB4800213-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check if the angle between the metal strip and guide frame is 90 +/ - 2 degrees. 
</p><p class="- topic/p ">Adjust the metal strip if needed. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0C9E0556-46E9-4950-8592-4528F14EF232" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B50A93B0-A0E3-4D72-960A-99D2B9AB7C7F-low.png" placement="inline" class="- topic/image " otherprops="GUID-B50A93B0-A0E3-4D72-960A-99D2B9AB7C7F-low.png"/></fig><fig id="GUID-78A6845E-1716-4422-811B-42ABD88EC24E" class="- topic/fig "><image href="GUID-3A7DEAA9-3E3C-4427-8B0E-1B5D27710DEC-low.png" placement="inline" class="- topic/image " otherprops="GUID-3A7DEAA9-3E3C-4427-8B0E-1B5D27710DEC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Fasten the 2 screws [A]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1E569C90-AF5F-4676-9C5F-DF8A5565117E" class="- topic/fig "><image href="GUID-7BD8CBFD-C708-4544-ABBB-099CB4800213-low.png" placement="inline" class="- topic/image " otherprops="GUID-7BD8CBFD-C708-4544-ABBB-099CB4800213-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="SECTION_8AFA3172A3EA47AFAF79FDC79779D4B4" class="- topic/section "><title class="- topic/title ">How to adjust the flex cable assembly and foil</title><table pgwide="1" id="TABLE_9E7E2C8963F547B481F03355D9A68C89" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place the carriage at the belt tensioner. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_6F23C35618EF4E078E4B22836CC14E40" class="- topic/fig "><image href="GUID-B69EE0BD-ED8C-4971-8631-76712D852142-low.png" id="IMAGE_393127BDA02F4D328E705851194955A0" placement="inline" class="- topic/image " otherprops="GUID-B69EE0BD-ED8C-4971-8631-76712D852142-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the printhead carriage to the right hand side till the 
<b class="+ topic/ph hi-d/b ">1st</b> guide strip of the flex cable is in the middle of the bended metal strip. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_0B36F2641C814876BCFD17743280FF90" class="- topic/fig "><image href="GUID-45EE5C8A-B649-4D5D-9384-03F98D166A3F-low.png" id="IMAGE_08D5D365FF2A423EA8F04A97609C9235" placement="inline" class="- topic/image " otherprops="GUID-45EE5C8A-B649-4D5D-9384-03F98D166A3F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Specification</b>: guide strip is 
<b class="+ topic/ph hi-d/b ">maximum 5 mm free</b> of the metal strip. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws [B]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-80296883-F4D5-4F28-B3E3-B170E1287D36" class="- topic/fig "><image href="GUID-31D4FD38-E4A4-4A6A-B01D-583BFE8BF8F7-low.png" placement="inline" class="- topic/image " otherprops="GUID-31D4FD38-E4A4-4A6A-B01D-583BFE8BF8F7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Push or pull at the flex cable assembly and foil to get to specification. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the printhead carriage to the right hand side and check that also the next 3 guide strips of the flex cables are within specification. 
</p><p class="- topic/p ">If needed: Push or pull at the flex cable assembly and foil to get to specification. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E512BB46-C846-45F2-905A-30EB0C436266" class="- topic/fig "><image href="GUID-81EC03A7-06BD-492D-AD26-359D4633881A-low.png" placement="inline" class="- topic/image " otherprops="GUID-81EC03A7-06BD-492D-AD26-359D4633881A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Fasten the 2 screws [B]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-48C73DB1-A27C-4261-9377-7089442794CD" class="- topic/fig "><image href="GUID-31D4FD38-E4A4-4A6A-B01D-583BFE8BF8F7-low.png" placement="inline" class="- topic/image " otherprops="GUID-31D4FD38-E4A4-4A6A-B01D-583BFE8BF8F7-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="SECTION_ACEA660190D741D58A7932FCF53691B9" class="- topic/section "><title class="- topic/title ">How to adjust the ink and air tubes and fiber optical cable</title><table pgwide="1" id="TABLE_DF26363F528D4E1F82A0F1722D8B56F4" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place the carriage at the belt tensioner. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_6B2D457D2FCC4118B43AFAE375041332" class="- topic/fig "><image href="GUID-B69EE0BD-ED8C-4971-8631-76712D852142-low.png" id="IMAGE_91F9D1C87C544B2EBDCD65BA270EB03E" placement="inline" class="- topic/image " otherprops="GUID-B69EE0BD-ED8C-4971-8631-76712D852142-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the carriage till the 2 guide strips are positioned above each other. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_C6193EDF1A754D0CA5D205D810D5A59F" class="- topic/fig "><image href="GUID-F2135768-B144-428B-8338-436DED87CC7A-low.png" id="IMAGE_0B03B82F85784ADA9412D408864E5C5B" placement="inline" class="- topic/image " otherprops="GUID-F2135768-B144-428B-8338-436DED87CC7A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Specification</b>: ink tubes and fiber cable is 
<b class="+ topic/ph hi-d/b ">maximum 5 mm free</b> of the flex cable assembly. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws [C]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_63DC587C0D9E42BD8256817C93E45CE3" class="- topic/fig "><image href="GUID-DF58E62D-9A6D-484A-BADC-E74EBA16F04A-low.png" id="IMAGE_138D4B5B2FE149EDAAA8920E039A00E1" placement="inline" class="- topic/image " otherprops="GUID-DF58E62D-9A6D-484A-BADC-E74EBA16F04A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Push or pull at the ink tubes and cable to get to specification. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
