<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-685E6504-D43E-4063-96D4-B0A4F752A1F6" version="6" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-685E6504-D43E-4063-96D4-B0A4F752A1F6" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">How to start <ph varid="Adam" translate="no" class="- topic/ph ">ADAM</ph></title><abstract class="- topic/abstract " id="GUID-E7A31B8A-01EF-4341-871A-08EF409DC7ED"><p class="- topic/p ">To start <ph class="- topic/ph " translate="no" varid="Adam">ADAM</ph> on the <ph class="- topic/ph " varid="productname">Colorado M-Series</ph> follow the procedure below. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Tools</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-3D42A283-1207-4478-A6F3-AD93DEDA4700" class="- topic/section task/prereq "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">You need a SAM key with valid licenses for this print system. 
</p><p class="- topic/p ">Licenses should include SDS and TSM. 
</p></li></ul></prereq><steps id="GUID-A658A112-D7C8-4E1B-9920-99DFF69E2CD1" class="- topic/ol task/steps "><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Insert the SAM Key with the licenses in the USB connection below the operator panel. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap the service button on the operator panel. 
</cmd><info class="- topic/itemgroup task/info "><fig id="GUID-CE5790D1-39D0-44D9-BA1A-DEC3994C0BC9" class="- topic/fig "><image href="GUID-B92780D2-4430-4C4B-8F32-B5B59E3B1FBA-low.png" placement="inline" class="- topic/image " otherprops="GUID-B92780D2-4430-4C4B-8F32-B5B59E3B1FBA-low.png"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd "><ph varid="Adam" translate="no" class="- topic/ph ">ADAM</ph> will start. 
</cmd><info class="- topic/itemgroup task/info "><fig id="GUID-3E014A7D-5A56-4FF3-918A-40CC87A50990" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AB99BCA3-437E-4E94-91A6-D68D29625E0F-low.png" placement="inline" class="- topic/image " otherprops="GUID-AB99BCA3-437E-4E94-91A6-D68D29625E0F-low.png"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd "> Per product an option “Installation feedback” can be enabled. When this option is enabled then the first service visit being logged in the product logbook, using ADAM will be considered as an installation visit. The question: “Are you currently installing this printer?” will be asked. Select “Yes” when the visit is an installation visit and Select No in case ADAM is being used for the first time on an already earlier installed product. When the option “installation feedback is disabled” ADAM will provide normal collect opening screen.
</cmd><info class="- topic/itemgroup task/info "><fig id="GUID-9C371085-7099-48C5-AEF2-4C7CCF2BD5B4" class="- topic/fig "><title class="- topic/title "/><image href="GUID-8947ACC8-6A0A-49A6-B808-9104DC8C3812-low.png" placement="inline" class="- topic/image " otherprops="GUID-8947ACC8-6A0A-49A6-B808-9104DC8C3812-low.png"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd "> When <ph varid="Adam" translate="no" class="- topic/ph ">ADAM</ph> shows the collect screen the application has finished analyzing and processing data and is ready for use.
</cmd><info class="- topic/itemgroup task/info "><fig id="GUID-066E516E-D05F-4116-BC4C-50E3A4ADD231" class="- topic/fig "><image href="GUID-1041FF5B-1DD9-4B38-A8A3-158D774DC94D-low.png" placement="inline" class="- topic/image " otherprops="GUID-1041FF5B-1DD9-4B38-A8A3-158D774DC94D-low.png"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">ADAM Collect opening screen when 
<b class="+ topic/ph hi-d/b ">installation feedback</b> for the product is enabled and when the question “Are you currently installing the printer?” is answered with “Yes”.
</cmd><info class="- topic/itemgroup task/info "><fig id="GUID-3BD8B02B-41E9-4843-AF6D-997B0F5CD84A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-168BBBD3-0209-443F-9D9E-DD4B7FE900E4-low.png" placement="inline" class="- topic/image " otherprops="GUID-168BBBD3-0209-443F-9D9E-DD4B7FE900E4-low.png"/></fig></info></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-3823F84D-ACBC-47D2-BC36-31C46B5849A8.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>ADAM</linktext></link></linkpool></related-links>
