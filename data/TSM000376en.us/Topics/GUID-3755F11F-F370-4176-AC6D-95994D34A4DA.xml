<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-3755F11F-F370-4176-AC6D-95994D34A4DA" version="3" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-3755F11F-F370-4176-AC6D-95994D34A4DA" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to replace the E-Chain IGUS</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-4A711738-96E0-45A9-B83B-6D90217E1943" class="- topic/section "><title class="- topic/title ">Introduction</title><p class="- topic/p ">This document describes how to replace the E-Chain IGUS of the Colorado M-series. 
</p></section><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "/><section id="GUID-1AA11A91-9FB0-47E1-A3A0-BE13FB150C40" class="- topic/section "><title class="- topic/title ">Before you begin</title><p class="- topic/p ">Carefully check the position of the cooling hoses and cables on top of the carriage to return them to their original position. 
</p><p class="- topic/p ">After draining the cooling system clamp the cooling hoses to avoid spillage or leaking of coolant. 
</p></section><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_0492307DCD35442EAC71B8DA95C8A8E5" class="- topic/ul "><li id="LI_421ADE177A4748CB8EAE9311930065D8" class="- topic/li "><p class="- topic/p ">screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">flathead screwdriver 4 
</p></li><li class="- topic/li "><p class="- topic/p ">caliper / feeler gauges for alignment of the e-chain 
</p></li><li class="- topic/li "><p class="- topic/p ">a sheet of paper 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">How to replace</title><fig id="GUID-E2FF997A-3D69-440D-8537-DC74947917A9" class="- topic/fig "/></section><section id="GUID-1E55A782-2771-49C6-9B05-C95668ECAC16" class="- topic/section "><title class="- topic/title ">Disconnect the electrical connecters and coolant tubes from the curing carriage</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="5" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="1.47*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="7.41*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="1.00*" class="- topic/colspec "/><colspec colname="col4" colnum="4" colwidth="5.77*" class="- topic/colspec "/><colspec colname="col5" colnum="5" colwidth="9.17*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/><entry colname="col4" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry><entry colname="col5" align="left" valign="top" class="- topic/entry "/></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" namest="col2" nameend="col4" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the top cover:<xref href="GUID-5CE51160-E27D-4814-BCC5-CA5F098D6CE7.xml" scope="local" format="dita" class="- topic/xref " type="task"><?ditaot gentext?>24 How to remove the top cover</xref> 
</p></entry><entry colname="col5" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" namest="col2" nameend="col4" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the sheet of paper underneath the curing carriage. 
</p><p class="- topic/p ">Drain the cooling liquid of the chiller unit. 
</p><p class="- topic/p ">Use cleaning cloths to absorb leaking coolant. 
</p><p class="- topic/p "><xref keyref="06DISA004V2" class="- topic/xref " href="GUID-FFE707FB-03C0-490F-8FEF-97228036917B.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06 How to drain the cooling liquid of the chiller unit (V2)?>06 How to drain the cooling liquid of the chiller unit (V2)</xref> 
</p></entry><entry colname="col5" align="left" valign="top" class="- topic/entry "><fig id="GUID-2F5CF009-A545-456D-87BB-AFFCA16CC7E6" class="- topic/fig "><image href="GUID-6F5469AC-2256-41D6-854D-B2825411FFC4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6F5469AC-2256-41D6-854D-B2825411FFC4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" namest="col2" nameend="col4" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the crash sensor connectors on the left and right side of the carriage. 
</p></entry><entry colname="col5" align="left" valign="top" class="- topic/entry "><fig id="GUID-14FE5392-8856-4006-878D-892043CB2765" class="- topic/fig "><image href="GUID-4335A001-57ED-4571-8414-6C6753B0C335-low.png" placement="inline" class="- topic/image " otherprops="GUID-4335A001-57ED-4571-8414-6C6753B0C335-low.png"/></fig><fig id="GUID-3BF5DD76-49DD-4BC9-9F5E-FD8E9036FC87" class="- topic/fig "><image href="GUID-DB22B8FB-BFB0-4E0C-AA70-42DBFF48C3C6-low.png" placement="inline" class="- topic/image " otherprops="GUID-DB22B8FB-BFB0-4E0C-AA70-42DBFF48C3C6-low.png"/></fig><fig id="GUID-8E6012A5-941B-41A2-9E0A-1DCDB811804C" class="- topic/fig "><image href="GUID-956B43B4-6D3A-4772-879A-B8B9F73B76F0-low.png" placement="inline" class="- topic/image " otherprops="GUID-956B43B4-6D3A-4772-879A-B8B9F73B76F0-low.png"/></fig><fig id="GUID-6A148464-3804-43F2-9205-11A2851BF146" class="- topic/fig "><image href="GUID-4540EE9D-1DB5-4E01-BDEA-155D500511C0-low.png" placement="inline" class="- topic/image " otherprops="GUID-4540EE9D-1DB5-4E01-BDEA-155D500511C0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" namest="col2" nameend="col4" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the clamps. 
</p><p class="- topic/p ">Disconnect the coolant tubes. 
</p><p class="- topic/p ">Use towels to collect coolant drips leaking from the tubes. 
</p></entry><entry colname="col5" align="left" valign="top" class="- topic/entry "><fig id="GUID-DEEF34D2-471B-4D25-BC10-C8BE609EEB07" class="- topic/fig "><image href="GUID-347B62CE-4A46-48C1-B439-77349D222394-low.png" placement="inline" class="- topic/image " otherprops="GUID-347B62CE-4A46-48C1-B439-77349D222394-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" namest="col2" nameend="col4" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the two power connectors on top of the carriage. 
</p></entry><entry colname="col5" align="left" valign="top" class="- topic/entry "><fig id="GUID-631BECAA-DB50-49CC-A712-051349143B61" class="- topic/fig "><title class="- topic/title "/><image href="GUID-96A5F5CC-2890-49EC-938E-3BAFE3B5CB2E-low.png" placement="inline" class="- topic/image " otherprops="GUID-96A5F5CC-2890-49EC-938E-3BAFE3B5CB2E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" namest="col2" nameend="col4" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the upper and lower connecter of the controller. 
</p></entry><entry colname="col5" align="left" valign="top" class="- topic/entry "><fig id="GUID-9A6139B3-D5D9-4A7A-AA77-44D3E343B7E6" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B078661F-CFF1-41BA-AE3F-EB97854284E9-low.png" placement="inline" class="- topic/image " otherprops="GUID-B078661F-CFF1-41BA-AE3F-EB97854284E9-low.png"/></fig><fig id="GUID-41FC4914-7DC7-4897-817C-3B99E5DEDFB8" class="- topic/fig "><title class="- topic/title "/><image href="GUID-18C4C5C8-8B30-4E2D-8C5F-77120B3849C6-low.png" placement="inline" class="- topic/image " otherprops="GUID-18C4C5C8-8B30-4E2D-8C5F-77120B3849C6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" namest="col2" nameend="col4" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the connector of the crash sensors. 
</p><p class="- topic/p ">After the coolant is drained, tubes and connectors disconnected and loosened, remove the IGUS chain by removing the 2x 4 screws at the lower and upper part of the e-chain as indicated. 
</p></entry><entry colname="col5" align="left" valign="top" class="- topic/entry "><fig id="GUID-B4CFAED7-5820-4CD0-9E97-54D2A00EA849" class="- topic/fig "><image href="GUID-D37EC76C-448C-48FA-A6A1-F32793323323-low.png" placement="inline" class="- topic/image " otherprops="GUID-D37EC76C-448C-48FA-A6A1-F32793323323-low.png"/></fig><fig id="GUID-63AE6E48-41A0-4C6D-AE60-9DB29C67D088" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3236358B-2399-431D-8773-736100C7ECB6-low.png" placement="inline" class="- topic/image " otherprops="GUID-3236358B-2399-431D-8773-736100C7ECB6-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-6CF3CC84-4D55-409E-98B3-D11458B1EAA2" class="- topic/section "><title class="- topic/title ">Installation </title><table id="GUID-A0621DEF-506C-424B-B50B-A885983DAAA5" class="- topic/table "><tgroup cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="1.00*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="9.31*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="5.93*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Remark 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Installation must be done in reversed order. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Adjustment of the e-chain see: 
<xref href="GUID-2ECE36D3-F461-4772-BF21-F76F47C1DCFF.xml" scope="local" format="dita" class="- topic/xref " type="task"><?ditaot gentext?>01 How to adjust the e-chain IGUS</xref> 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-22D79A6A-2191-46FA-BE14-24F47FE4288E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
