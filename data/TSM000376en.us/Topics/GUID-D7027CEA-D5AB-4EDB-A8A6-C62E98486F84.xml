<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-D7027CEA-D5AB-4EDB-A8A6-C62E98486F84" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-D7027CEA-D5AB-4EDB-A8A6-C62E98486F84" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">19 How to adjust the winder with respect to the printer </title><abstract class="- topic/abstract " id="GUID-173AF84C-D126-4DD5-8ABA-ADD08113B9D4"><p class="- topic/p ">This document describes the adjustment of winder with respect to the printer. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Adjustment</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><context id="GUID-A02F419C-DBA9-48C5-9566-05B40F550DFD" class="- topic/section task/context "><p class="- topic/p ">Do this adjustment after you install the printer or you moved the printer to another location. 
</p></context><prereq id="GUID-982BAB96-F1AC-436A-A6A8-B6CC211033FE" class="- topic/section task/prereq "><ul id="UL_B83391B74DF44613866BCD1E7A96268F" class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">3 Feet of the printer are positioned already correctly. 
</p><p class="- topic/p ">See 
<xref keyref="ENGADJU01" class="- topic/xref " href="GUID-2BFE3033-C726-47A1-9A09-044CAA7F04FE.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 00 How to level the printer?>00 How to level the printer</xref> 
</p></li></ul></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_BFA685CC9BB948B1A9E612E35307E84B" class="- topic/ul "><li id="LI_2387A051BFC44D048CFB262399A5FBBA" class="- topic/li "><p class="- topic/p ">Adjustment tool winder 
</p><note type="important" id="GUID-50C51413-F776-4C1A-961A-57ABC3547BCE" class="- topic/note "><p class="- topic/p ">The adjustment tool is 
<b class="+ topic/ph hi-d/b ">only</b> usable for this printer !! 
</p></note></li><li id="LI_25A6D068D150444999722C3ABE713E89" class="- topic/li "><p class="- topic/p ">Open ended spanner 19 or allen key wrench 
</p></li><li id="LI_4C372961ECA348D9BE731C14D6225582" class="- topic/li "><p class="- topic/p ">Small screwdriver 
</p></li><li id="LI_EDC8AA76441747AFA7CA51A5F9C74D07" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-E0744C42-ABAC-49E6-AC01-06127BEDE6A3" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note><note type="important" id="GUID-637764DC-FE0E-48E7-9F28-A42561682338" class="- topic/note "><p class="- topic/p ">Do 
<b class="+ topic/ph hi-d/b ">not</b> put the top cover in the service position. It can damage the adjustment tool. If the tool is damaged you need to order a new system !!! 
</p><fig id="GUID-98CACAC8-B95E-4EE9-9A65-CBF35348A0FA" class="- topic/fig "><image href="GUID-A25D5FD1-AE2D-4974-A9B8-720294FF0121-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A25D5FD1-AE2D-4974-A9B8-720294FF0121-low.png"/></fig></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-F53FB23F-B1FF-41E9-B13E-BC3B00ABD796" class="- topic/fig "><image href="GUID-C034FB29-CCA6-443D-9442-9FB5C85FE83D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C034FB29-CCA6-443D-9442-9FB5C85FE83D-low.png"/></fig><fig id="GUID-EC85E3AE-1F55-4480-8280-11C22C5F4279" class="- topic/fig "><title class="- topic/title ">Detail at top of adjustment tool</title><image href="GUID-3D00A39F-3947-46CC-B4E4-D26199CE2B82-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3D00A39F-3947-46CC-B4E4-D26199CE2B82-low.png"/></fig></section><section id="GUID-AC297FE3-DC38-4D58-AEEA-293B2E609B8A" class="- topic/section "><title class="- topic/title ">Video</title><p class="- topic/p ">There is a video describing the use of the winder adjustment tool.
</p><p class="- topic/p "><xref href="http://localhost:20346/VIDEO00394EN.US/video14/index.html" format="html" scope="external" class="- topic/xref "><?ditaot usertext?>The use of the winder adjustment tool</xref>
</p></section><section id="GUID-572456BF-28FE-4706-9116-4D5E91E310E3" class="- topic/section "><title class="- topic/title ">How to check</title><table id="NEW" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Open the right hand side cover of the roll winder. 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the 2 screws (T20) to unlock the cover. 
</p></li><li class="- topic/li "><p class="- topic/p ">Move the cover to the right side. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><draft-comment translate="no" class="- topic/draft-comment ">foto's updaten</draft-comment> 
</p><fig id="GUID-FB7D0E24-A81C-4A98-8A04-3DB7BB57DCED" class="- topic/fig "><image href="GUID-E67E936A-73F9-4A2F-8590-85D09FB3A879-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E67E936A-73F9-4A2F-8590-85D09FB3A879-low.png"/></fig><fig id="GUID-A7782E61-9F1B-4B89-80BD-9D5878127FDA" class="- topic/fig "><image href="GUID-296763B8-A53E-4E2C-9922-4A36CB66D816-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-296763B8-A53E-4E2C-9922-4A36CB66D816-low.png"/></fig><fig id="FIG_57584C582D9E43B0960309A8E3414CE3" class="- topic/fig "><image href="GUID-CD4264D5-023F-42DD-A0BA-5E2860C43935-low.png" id="IMAGE_6E316D20D02A4987AE4ED49FDC86AB9C" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CD4264D5-023F-42DD-A0BA-5E2860C43935-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cover. 
</p><ul id="UL_E4401F28A0CF4D6FBA4D21CAE1FFB544" class="- topic/ul "><li id="LI_3E0DD562512543A7A0041FE8C91777F7" class="- topic/li "><p class="- topic/p ">Pull the locking pin down in the top corner of the cover. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-AEDD7275-4D6D-49ED-A373-7BC33749B3E3" class="- topic/fig "><image href="GUID-4F6619AD-5CFE-477A-AA57-1D1D4316186E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4F6619AD-5CFE-477A-AA57-1D1D4316186E-low.png"/></fig><fig id="FIG_5BFDB3432D0C4D6A91F5D158B9AE2735" class="- topic/fig "><image href="GUID-D0FB7768-E7C0-4A3D-B36F-6312BC05BF94-low.png" id="IMAGE_057A7A5BE4924346B9868572E93FDB97" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D0FB7768-E7C0-4A3D-B36F-6312BC05BF94-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws and remove the adjustment tool. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-63E21915-8BAE-4BA7-A354-0A09D0C70F43" class="- topic/fig "><image href="GUID-911D3F5C-3FB5-43FF-A9C1-600AABD91C34-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-911D3F5C-3FB5-43FF-A9C1-600AABD91C34-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-EFFBC390-9BB3-41C9-90C8-43004D8B1A2D" class="- topic/note "><p class="- topic/p ">Do 
<b class="+ topic/ph hi-d/b ">not</b> put the top cover in the service position. It can damage the adjustment tool. If the tool is damaged you need to order a new system !!! 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Slide the knife (green) to the right hand side. 
</p></li><li class="- topic/li "><p class="- topic/p ">Move the tube and cables upwards. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E7B3BB53-7EEE-4B65-B5A0-AEFB19DA0633" class="- topic/fig "><image href="GUID-D1CAF233-0CB8-438C-A1AC-2C1ED6DD4A1A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D1CAF233-0CB8-438C-A1AC-2C1ED6DD4A1A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2AA142F8-73E1-4687-A035-7636816E7A13" class="- topic/fig "><image href="GUID-D5ABD008-DA03-4A28-9D30-5E5B80A05D26-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D5ABD008-DA03-4A28-9D30-5E5B80A05D26-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" align="left" valign="top" class="- topic/entry "><ul id="UL_98262B341A5E49CBA0B5583289E956A8" class="- topic/ul "><li id="LI_3E853F354A9D4DF08A5DCEAE3CCFCE44" class="- topic/li "/><li id="LI_24C2E65F3B94449DBD38883EF9F6BE8E" class="- topic/li "><p class="- topic/p ">Mount the adjustment tool beside the print surface. 
</p><note id="GUID-98DF9629-6117-4FF2-937A-1907D685A2E7" class="- topic/note "><p class="- topic/p ">The position of the adjustment tool must be in the 
<b class="+ topic/ph hi-d/b ">middle</b> (minimum 1 mm at each side)<b class="+ topic/ph hi-d/b ">above</b> the fixed pin on the winder. 
</p></note></li><li id="LI_8EFFAD0990AF497F912DDD83BE3D253D" class="- topic/li "><p class="- topic/p ">Lock the 2 screws. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A12187E4-567E-43C5-A75C-122F8CC32FA0" class="- topic/fig "><image href="GUID-A0A10014-81B6-473B-B75B-BC6770155E13-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A0A10014-81B6-473B-B75B-BC6770155E13-low.png"/></fig><fig id="GUID-9F852478-E379-4D40-BE3B-CB72B3E99386" class="- topic/fig "><image href="GUID-C034FB29-CCA6-443D-9442-9FB5C85FE83D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C034FB29-CCA6-443D-9442-9FB5C85FE83D-low.png"/></fig><fig id="GUID-6B236F92-6992-4EE7-952E-1F2CBC532F92" class="- topic/fig "><image href="GUID-E7455475-45F5-47E7-A50D-C7578C1FDC58-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E7455475-45F5-47E7-A50D-C7578C1FDC58-low.png"/></fig><fig id="GUID-3A8B86F4-55A6-4A70-A8AD-4C068E524AFF" class="- topic/fig "><image href="GUID-48C75546-82C0-4961-9DA6-A5A00E0250E8-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-48C75546-82C0-4961-9DA6-A5A00E0250E8-low.png"/></fig><fig id="GUID-5574A8D3-3C15-4FA4-ACDE-C43F3B604646" class="- topic/fig "><image href="GUID-7D1A893C-D67E-4887-BF65-3C24EC5E1B8F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7D1A893C-D67E-4887-BF65-3C24EC5E1B8F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Specification</b>: 
</p><p class="- topic/p ">The vertical pin must be visible as indicated. 
</p><p class="- topic/p ">If partly visible: the adjustment is not correct. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A82CC9C5-BEAA-4214-BB03-A3E979A5DC09" class="- topic/fig "><image href="GUID-3D00A39F-3947-46CC-B4E4-D26199CE2B82-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3D00A39F-3947-46CC-B4E4-D26199CE2B82-low.png"/></fig><fig id="GUID-E8B907C7-C0FE-4715-8EE2-AE3ABE93BBEB" class="- topic/fig "><image href="GUID-32227C6A-2B78-492C-AFCB-422CD60060DB-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-32227C6A-2B78-492C-AFCB-422CD60060DB-low.png"/></fig><fig id="GUID-4C0CDDFC-CC05-4DDE-8769-D03659027521" class="- topic/fig "><image href="GUID-3DA298D9-1F8F-424D-879E-3561082F4FED-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3DA298D9-1F8F-424D-879E-3561082F4FED-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to adjust</title><table pgwide="1" id="TABLE_47FA782163A340509F8AB035B39CDD58" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Lift</b> or 
<b class="+ topic/ph hi-d/b ">lower</b> the printer: use the 
<b class="+ topic/ph hi-d/b ">height adjustment bolt below the user panel</b> to adjust. 
</p><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Specification</b>: 
</p><p class="- topic/p ">The tip of the arrow must be visible in the slit as indicated. 
</p><p class="- topic/p ">If the tip of the arrow is partly visible in the slit: the adjustment is not correct. 
</p><note id="GUID-6CD0BEEC-5B93-46A2-A415-63D03B3FB808" class="- topic/note "><p class="- topic/p ">The wheel should not touch the floor. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_E9241B7F4E644468A48B06A554070133" class="- topic/fig "><image href="GUID-D88F3ED2-7604-42F2-9455-26F5ED81D135-low.png" id="IMAGE_DAB00E8F8D124E09B365E41FCEA5DA05" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D88F3ED2-7604-42F2-9455-26F5ED81D135-low.png"/></fig><fig id="GUID-1426419A-D445-49D4-BBEE-ED3A4B433C00" class="- topic/fig "><image href="GUID-3D00A39F-3947-46CC-B4E4-D26199CE2B82-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3D00A39F-3947-46CC-B4E4-D26199CE2B82-low.png"/></fig><fig id="GUID-62242DB0-8CA5-4BD1-845D-B0C848321DDE" class="- topic/fig "><image href="GUID-32227C6A-2B78-492C-AFCB-422CD60060DB-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-32227C6A-2B78-492C-AFCB-422CD60060DB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><note type="important" id="GUID-89358012-C45F-49C1-A5F3-14E05C367C10" class="- topic/note "><p class="- topic/p ">Remove the adjustment tool after the adjustment. This to prevent collision with the curing carriage. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Result: 
</b>The winder works correct. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0E2468F5-4849-4A9F-9C3E-C7973F23BBF9" class="- topic/fig "><image href="GUID-D9844FF7-94C3-47AB-B581-0E929A273022-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D9844FF7-94C3-47AB-B581-0E929A273022-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
