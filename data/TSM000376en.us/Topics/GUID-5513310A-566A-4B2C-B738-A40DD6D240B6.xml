<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-5513310A-566A-4B2C-B738-A40DD6D240B6" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-5513310A-566A-4B2C-B738-A40DD6D240B6" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to adjust the new Roll clamp mechanism</title><abstract class="- topic/abstract " id="GUID-173AF84C-D126-4DD5-8ABA-ADD08113B9D4"><p class="- topic/p ">This document describes the adjustment of the new Roll clamp mechanism. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Adjustment</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><context id="GUID-A02F419C-DBA9-48C5-9566-05B40F550DFD" class="- topic/section task/context "><p class="- topic/p ">During the system installation and when there are media roll skip issues. 
</p></context><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_0662F977771246BE9B95F622DEB4DF02" class="- topic/ul "><li id="LI_B34A5CCD38BF4E28B8A0721C3B67CCA2" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li class="- topic/li "><p class="- topic/p ">Media roll core for testing 
</p></li></ul></section><section id="GUID-572456BF-28FE-4706-9116-4D5E91E310E3" class="- topic/section "><title class="- topic/title ">How to adjust</title><table id="NEW" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen 2 screws so that the Plate-assy can move freely up and down. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CB71B789-3E27-4F17-8CB1-684EB1443D1D" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B2EA9BA6-DC05-40F8-BB36-55ADC67EA3B5-low.png" placement="inline" class="- topic/image " otherprops="GUID-B2EA9BA6-DC05-40F8-BB36-55ADC67EA3B5-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check that the roll clamp is properly closed and in the latched (locked) position. 
</p><p class="- topic/p ">The front of the roll clamp should be touching the frame assy. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D039BE83-4128-4E4F-B24C-76023953F4B5" class="- topic/fig "><title class="- topic/title "/><image href="GUID-F3635559-E3AB-4503-83BB-104571381EF5-low.png" placement="inline" class="- topic/image " otherprops="GUID-F3635559-E3AB-4503-83BB-104571381EF5-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the roll clamp and insert a media roll core in the Drawer. Now close the roll clamp. 
</p><p class="- topic/p ">Press the plate assy down until the white roll bearing touches the media roll core. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3E2768C8-FA28-42DA-B07C-76A806135CC3" class="- topic/fig "><title class="- topic/title "/><image href="GUID-4E1C91A2-CF96-4172-B64B-5D6ED8C074CA-low.png" placement="inline" class="- topic/image " otherprops="GUID-4E1C91A2-CF96-4172-B64B-5D6ED8C074CA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Adjust and position the Plate-assy so it is roughly parallel to the top surface of the Roll clamp. 
</p><p class="- topic/p ">Fasten both screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5C80211E-D35F-4EF9-A837-9C73AF9ABA55" class="- topic/fig "><title class="- topic/title "/><image href="GUID-DAFFB2C8-68E9-4A04-A2E7-0607CD1FA39A-low.png" placement="inline" class="- topic/image " otherprops="GUID-DAFFB2C8-68E9-4A04-A2E7-0607CD1FA39A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Unlock the green handle and open the Roll clamp to about a 45<sup class="+ topic/ph hi-d/sup ">0</sup> angle. 
</p><p class="- topic/p ">Now drop the roll clamp. 
</p><p class="- topic/p ">Check if the green handle is in the latched (locked) position. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6E9A5AE7-12FD-412B-8719-F32D8A392247" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B3C310A5-5E31-4981-8D8B-34EB141AF1A3-low.png" placement="inline" class="- topic/image " otherprops="GUID-B3C310A5-5E31-4981-8D8B-34EB141AF1A3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check if there is no gap between the Bearing and the Media roll core. 
</p><p class="- topic/p ">Rotate the media roll core a few times to check if there are vibrations or roll skip issues. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A8CC77BC-3CD5-4538-AE34-CFF8152890D0" class="- topic/fig "><title class="- topic/title "/><image href="GUID-09DF1147-DA1C-4799-9615-945E59B0DBE3-low.png" placement="inline" class="- topic/image " otherprops="GUID-09DF1147-DA1C-4799-9615-945E59B0DBE3-low.png"/></fig></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-4A4AA0B2-27C7-4473-A368-B61BD4835D5E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Adjustment</linktext></link></linkpool></related-links>
