<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-071B0226-AACC-46CD-A87D-278A3C181B00" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-071B0226-AACC-46CD-A87D-278A3C181B00" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Replace the maintenance tray </title><abstract class="- topic/abstract " id="GUID-4A003431-ACAE-4FCB-883F-E1A9B9B472A0"><p class="- topic/p ">Replace the maintenance tray when the system gives a warning. 
</p><ul class="- topic/ul " id="UL_E0AEC5F207E7414FBFC48396EC447A3C"><li class="- topic/li " id="LI_0032DAF49D774C3789F68A1B568999FC"><p class="- topic/p ">The operator panel gives an orange warning when you can replace the maintenance tray. 
</p></li><li class="- topic/li " id="LI_49819EE430F741B5B7C2E0E77C584F35"><p class="- topic/p ">The operator panel gives a red warning when you must replace the maintenance tray. The printing process is stopped until you have replaced the maintenance tray. 
</p></li></ul><p class="- topic/p ">Video: <ph class="- topic/ph " varref="Video: Replace the maintenance tray"><xref class="- topic/xref " format="html" href="https://sus.cpp.canon/9VQKQ15E" scope="external"><?ditaot usertext?> 
<image class="- topic/image " href="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png" keyref="" placement="inline" otherprops="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png"/> Replace the maintenance tray</xref></ph> 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-30FE504F-E811-4526-91E6-FE6386C3C614" class="- topic/section task/prereq "><p class="- topic/p ">Use <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> prescribed: 
</p><ul id="UL_88FE82F1C6B343028F9B61DB8C430ED7" class="- topic/ul "><li id="LI_F4B9AC154F1445FBAA8F889824E6FD43" class="- topic/li "><p class="- topic/p "><ph translate="no" class="- topic/ph ">Microflex</ph> gloves for handling ink 
</p></li><li id="LI_6FA5A3A7E0FE4587B6D4539C231C8B45" class="- topic/li "><p class="- topic/p ">Lint free cloths 
</p></li><li id="LI_CB737E3FC4D04C7AA5607B614DF66F03" class="- topic/li "><p class="- topic/p ">Maintenance tray 
</p></li></ul></prereq><section id="SECTION_92CB3EB1972544B5B40D2A0DF574B6BB" class="- topic/section "><title class="- topic/title "/><note id="GUID-63777676-A525-4D82-A52A-21187CD6321C" class="- topic/note " type="caution"><p class="- topic/p "> Wear gloves when contact with ink or maintenance materials is possible. Gloves should always overlap sleeves. Wear safety glasses with side shields when handling ink or maintenance materials. Follow the ink related Safety Data Sheets (SDS) guidelines carefully in order to ensure maximum safety. 
</p></note><note id="GUID-53C225D4-14F2-4FCC-84E8-18C91E512091" type="important" class="- topic/note "><p class="- topic/p ">Only open the maintenance drawer when the operator panel displays a message allowing you to open it. 
</p></note></section><steps id="GUID-F269E114-B085-4B2F-97AC-2E43F14B98C2" class="- topic/ol task/steps "><step id="d2653e79" class="- topic/li task/step "><cmd class="- topic/ph task/cmd "> On the operator panel tap on the <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Tools</text></uicontrol></ph> icon on the right. 
</cmd></step><step id="d2653e86" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Go to <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol ">Maintenance tray</uicontrol></ph>. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d2653e94" class="- topic/fig "><image href="GUID-AFB10B73-BD94-485D-AB65-D9C908948451-low.png" id="d2653e95" placement="inline" class="- topic/image " otherprops="GUID-AFB10B73-BD94-485D-AB65-D9C908948451-low.png"/></fig></info></step><step id="d2653e96" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Replace</text></uicontrol></ph> and read the instructions. 
</cmd></step><step id="d2653e103" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Put on the <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> approved gloves. 
</cmd></step><step id="d2653e109" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Go to the media input side and locate the maintenance drawer on the right. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d2653e113" class="- topic/fig "><image href="GUID-D8B4CC27-8821-4E26-BC99-46A9437421B2-low.png" id="d2653e114" placement="inline" class="- topic/image " otherprops="GUID-D8B4CC27-8821-4E26-BC99-46A9437421B2-low.png"/></fig></info></step><step id="d2653e115" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Open the media cover (1) and lift the lever of the maintenance drawer on the right (2). 
</cmd><info class="- topic/itemgroup task/info "><fig id="d2653e119" class="- topic/fig "><image href="GUID-6735690F-9394-424A-A997-E6E9DE7AA015-low.png" placement="inline" class="- topic/image " otherprops="GUID-6735690F-9394-424A-A997-E6E9DE7AA015-low.png"/></fig></info></step><step id="d2653e121" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Pull carefully to slide the maintenance drawer to the front (3). Make sure to extend the drawer completely. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-FF2CA648-0B15-48D0-B46F-B65AA94514DA" class="- topic/note " type="caution"><p class="- topic/p ">Open the maintenance drawer very carefully to not let the ink splash and spill. 
</p></note></info></step><step id="d2653e127" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Lift the metal holder up. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d2653e131" class="- topic/fig "><image href="GUID-85BA58D4-2FE0-4E60-8E4E-BB4FBD5D4460-low.png" placement="inline" class="- topic/image " otherprops="GUID-85BA58D4-2FE0-4E60-8E4E-BB4FBD5D4460-low.png"/></fig></info></step><step id="d2653e133" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Put the lid on the tray. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d2653e137" class="- topic/fig "><image href="GUID-788E7A18-B110-42A9-B03E-FE7BBA259859-low.png" placement="inline" class="- topic/image " otherprops="GUID-788E7A18-B110-42A9-B03E-FE7BBA259859-low.png"/></fig></info></step><step id="d2653e139" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">For both hands, put your thumb on the lid and your other fingers under the side reel. Squeeze to click and seal the lid completely. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d2653e143" class="- topic/fig "><image href="GUID-BDED1A14-29ED-4F21-AB07-62678481B16F-low.png" placement="inline" class="- topic/image " otherprops="GUID-BDED1A14-29ED-4F21-AB07-62678481B16F-low.png"/></fig></info></step><step id="d2653e145" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Lift the maintenance tray out with both hands on the sides of the tray. Dispose the sealed maintenance tray as chemical waste according to local regulations. 
</cmd></step><step id="d2653e149" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Take a lint free cloth and clean the drawer and holder on the inside and outside until all residue ink is gone. 
</cmd></step><step id="d2653e152" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Take a new and empty maintenance tray and place it in the maintenance drawer. 
</cmd><info class="- topic/itemgroup task/info "><note id="d2653e156" type="important" class="- topic/note "><p class="- topic/p ">Do not place the lid on the new maintenance tray, as ink can spill that will damage the machine. 
</p></note></info><info class="- topic/itemgroup task/info "><fig id="d2653e160" class="- topic/fig "><image href="GUID-7238E110-95F3-4E28-946D-D35816FA662E-low.png" placement="inline" class="- topic/image " otherprops="GUID-7238E110-95F3-4E28-946D-D35816FA662E-low.png"/></fig></info></step><step id="d2653e162" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Close the metal holder. 
</cmd></step><step id="d2653e165" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dispose the gloves as chemical waste according to local regulations. 
</cmd></step><step id="d2653e168" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Push and close the maintenance drawer. 
</cmd></step><step id="d2653e171" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">On the operator panel tap <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Replaced</text></uicontrol></ph> to confirm you replaced a full maintenance tray with an empty maintenance tray and end the action. 
</cmd></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-EAB54A10-F7C3-4675-BFDD-94735EBEE8B0.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
</task>