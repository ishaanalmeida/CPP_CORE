<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-260E8B4D-A641-48EF-84A7-7344BE9CE5EC" version="4" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-260E8B4D-A641-48EF-84A7-7344BE9CE5EC" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">06 How to install the chiller (V2)</title><abstract class="- topic/abstract " id="GUID-82506349-79D3-42D0-A6D7-EA7FE0A0F240"><p class="- topic/p ">This document describes the installation of the Chiller V2. 
</p><p class="- topic/p ">Video: 
<xref class="- topic/xref " format="html" href="http://localhost:20346/VIDEO00394EN.US/video06/index.html" scope="external"><?ditaot usertext?>How to install the chiller V2</xref> 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A4E6F006ECAE4473A0F5CE15E4454364" class="- topic/ul "><li id="LI_6B0B1FB771FA4536B7D8FEF12F5AE0F0" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_C6D2D88D00D346F99E8A00DE1E85C8BC" class="- topic/li "><p class="- topic/p ">Pliers 
</p></li><li id="LI_D25FDAE9F4C54062BB4F70936D0F92DE" class="- topic/li "><p class="- topic/p ">2 Cable ties 
</p></li><li class="- topic/li "><p class="- topic/p ">Minimum Firmware level: 
</p><p class="- topic/p ">* C1640 - r1.4.5.0 
</p><p class="- topic/p "> * C1650 - r2.5.1.0 
</p><p class="- topic/p "> * C1630 - r3.1.1.0 
</p></li></ul></section><section id="SECTION_699E47B73D514CC4845BD3EBF5E71F83" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_6CF86CFFEB384A0A827D6CD72CB05366" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Set the correct mains voltage of the trafo box. 
</p><p class="- topic/p "> See: 
<xref keyref="06ADJU001" class="- topic/xref " href="GUID-89EA44C7-2322-4626-BAAF-FC7D434979B6.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06 How to adjust the voltage of the trafo box (V2)?>06 How to adjust the voltage of the trafo box (V2)</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0D4D2E92-FCE7-4A1A-8149-5359C4C17911" class="- topic/fig "><title class="- topic/title "/><image href="GUID-48CCD02D-7861-4B16-B1C0-0127046C2531-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-48CCD02D-7861-4B16-B1C0-0127046C2531-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Lower the feet to just above the floor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C2B7FDC9-A1C7-4343-8AC4-127F4ED01FC9" class="- topic/fig "><image href="GUID-3EDC4F5C-23CE-487A-B78F-345338D96A79-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3EDC4F5C-23CE-487A-B78F-345338D96A79-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the bracket cover out assy with the supplied blank screws. 
</p><p class="- topic/p ">The screws are (3x) Screw Torx TPG ST 4.2 / 9.5mm. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E5CDFA69-14C9-498C-9B23-8F0A6CA6558C" class="- topic/fig "><image href="GUID-834A6FB3-271B-4FD5-90DA-542E12074EBA-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-834A6FB3-271B-4FD5-90DA-542E12074EBA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Cut the two straps holding the chiller onto the roller cart assy. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9F24C23D-0225-4880-ACFF-5DDCC4476EE7" class="- topic/fig "><image href="GUID-D9F8DEB4-A4C3-4DD3-B911-0D9966376232-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D9F8DEB4-A4C3-4DD3-B911-0D9966376232-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the Cover under the User Interface. 
</p><p class="- topic/p ">See: 
<xref keyref="24DISA030" class="- topic/xref " href="GUID-EC9A0E63-A0B8-48DB-B875-363CAF6EBE73.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the cover below the operator panel?>24 How to remove the cover below the operator panel</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F44C0117-B75B-4D3E-BF65-A3EDF4492D68" class="- topic/fig "><image href="GUID-12843F2A-24E5-45EC-B76B-D02C2887C4FD-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-12843F2A-24E5-45EC-B76B-D02C2887C4FD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Fill the chiller with an initial 6 liter of cooling liquid up to the yellow ‘Full’ 
</p><p class="- topic/p ">See: 
<xref keyref="fillchillercooling" class="- topic/xref " href="GUID-D3650796-0743-4A38-A09E-D30FA69E8314.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06 how to fill the V2 chiller with cooling liquid?>06 how to fill the V2 chiller with cooling liquid</xref> 
</p><note id="GUID-A9CAA871-FBDB-4F3A-8F21-A5B968946AE3" class="- topic/note "><p class="- topic/p ">Add the additional 2-3 liters of cooling liquid (8-9L in total) only after the system has been turned on for the first time. (initial filling of the system) 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-43BCA4EE-2101-4D3B-BDF7-7AB2EA06C61F" class="- topic/fig "><image href="GUID-F1B65323-ABC5-4A69-BB03-AB8B5242D4D2-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F1B65323-ABC5-4A69-BB03-AB8B5242D4D2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Disconnect the bridging tube from the chiller. 
</p><note id="GUID-9F2BC725-8044-43F4-B3F3-5AAC21E79CEC" class="- topic/note "><p class="- topic/p ">Keep some kitchen towels at hand for possible residual liquid in the system. 
</p></note></li><li class="- topic/li "><p class="- topic/p ">Store the removed bridging tube and plug in the open space of the chiller for possible future service events. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B8D7E5B5-B578-4AB3-8219-46732F982E36" class="- topic/fig "><image href="GUID-9A3E3EBD-33F6-4F63-8671-7F1A6CC3F789-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9A3E3EBD-33F6-4F63-8671-7F1A6CC3F789-low.png"/></fig><fig id="GUID-BABF234B-F336-4493-BE40-B5F33A836F6E" class="- topic/fig "><image href="GUID-20B77A1A-0D44-4902-86E5-E96EFA4BAD1F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-20B77A1A-0D44-4902-86E5-E96EFA4BAD1F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Disconnect the tubes from the printer. 
</p></li><li class="- topic/li "><p class="- topic/p ">Store the plastic hose connector with the bridging tube. 
</p></li></ol><note id="GUID-5D7C62EE-D63A-47FA-8145-A8C19986383B" class="- topic/note "><p class="- topic/p ">Be aware that while disconnecting the coolant hoses, residual coolant may come out of the hoses. Use a cleaning cloth in advance to collect this coolant. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6D13AFB4-30F0-4F9C-B516-C97810F69BD3" class="- topic/fig "><image href="GUID-234D27EB-5355-476A-ACE0-6B42F24BFF70-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-234D27EB-5355-476A-ACE0-6B42F24BFF70-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect the two cooling liquid tubes from the printer to the chiller. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Connect the tube without color marker to the metal tube connector. 
</p></li><li class="- topic/li "><p class="- topic/p "> secured with the spring clip 
</p><p class="- topic/p ">This is the supply line. 
</p></li></ul><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> Connect the tube with the red indicator to the plastic tube connector. 
</p><note id="GUID-D248751B-FF18-42DE-9CF6-1C04206D6396" class="- topic/note "><p class="- topic/p "> Securing with a spring clip is not necessary, because this is the return line 
</p></note></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-051A3277-7322-40B1-B9A3-F2E51BAE696D" class="- topic/fig "><image href="GUID-1CB28BC8-757A-4A44-A2E0-61A0A9516001-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1CB28BC8-757A-4A44-A2E0-61A0A9516001-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect the 4 connectors and earth wire at top of the chiller 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3B3FEE1F-BE1A-4FD8-AE97-0F699E6BECDD" class="- topic/fig "><image href="GUID-DB3B5493-B125-4CAF-B8D9-7DEAB28746D2-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-DB3B5493-B125-4CAF-B8D9-7DEAB28746D2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect the 3 power connectors on the trafo box 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-BEA754D2-EEBF-4303-9C1A-BDDEDC3563C5" class="- topic/fig "><title class="- topic/title "/><image href="GUID-4EDFC715-F883-46DA-8C83-8E0D7A1C81CF-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4EDFC715-F883-46DA-8C83-8E0D7A1C81CF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">After the rest of the installation is done and the system is turned on for the first time, the Chiller will power up and fill the system with cooling liquid. 
</p><p class="- topic/p ">At this moment you can add the additional 3 liter of cooling liquid to the chiller. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B9BEC8C6-E44D-40DC-BCE2-3585D4B2A4CD" class="- topic/fig "><image href="GUID-11AC0124-8412-454E-8CF2-D3A6AAE7BCE2-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-11AC0124-8412-454E-8CF2-D3A6AAE7BCE2-low.png"/></fig><fig id="GUID-01E01A00-00FD-42F9-A3C2-706089F9F02F" class="- topic/fig "><image href="GUID-D8945207-B14B-41D5-A3AB-ADA00AD2CC25-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8945207-B14B-41D5-A3AB-ADA00AD2CC25-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install the cover input left. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Roll the chiller in position. 
</p></li><li class="- topic/li "><p class="- topic/p ">Be sure that coolant tubes and cables are positioned properly 
</p></li><li class="- topic/li "><p class="- topic/p ">Adjust the position. 
</p><p class="- topic/p ">See : 
<xref keyref="06ADJU002" class="- topic/xref " href="GUID-4D0D68A4-09BC-4ECD-A279-89F6E59CE58E.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06 How to adjust the position of the chiller (V2)?>06 How to adjust the position of the chiller (V2)</xref> 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-293B3F32-36DE-4E61-B29A-78D8BAE13DAF" class="- topic/fig "><image href="GUID-DC89BBAD-599B-4C29-8BC2-822D02064505-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-DC89BBAD-599B-4C29-8BC2-822D02064505-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount cover left and right. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">IMPORTANT!!! 
</p><p class="- topic/p ">Fill-in the serial number of the new chiller. This is required for warranty. 
</p><p class="- topic/p ">Do 
<xref keyref="SDS06-1-003V2" class="- topic/xref " href="GUID-05E9A25F-810A-4DEB-8BDC-CB4807838E61.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06-1-003 The serial number of the chiller [Parameters] (V2)?>06-1-003 The serial number of the chiller [Parameters] (V2)</xref> and fill-in the serial number of the new chiller. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to remove</title><p class="- topic/p ">See: 
<xref keyref="06DISA001V2" class="- topic/xref " href="GUID-FC1A6DFD-807D-4052-ACED-FC6F6C31BFB5.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06 How to remove the Chiller (V2)?>06 How to remove the Chiller (V2)</xref> 
</p></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-0CF1F378-65AF-4B46-B46E-82F7EE70A33A.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
</task>