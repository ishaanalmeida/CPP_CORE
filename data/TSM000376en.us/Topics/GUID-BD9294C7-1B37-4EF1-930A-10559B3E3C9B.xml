<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-BD9294C7-1B37-4EF1-930A-10559B3E3C9B" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-BD9294C7-1B37-4EF1-930A-10559B3E3C9B" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title translate="no" class="- topic/title ">04-6-035 Measure differential X disturbances [Special Tests]</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">SDS</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-2BD8C3DB-27B0-44E5-B999-CF486EF1CE0D" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">SDS</ph></title><p class="- topic/p "> 
<object id="GUID-D44DE1C4-8F20-4C1E-B49A-96C1F57AE27B" class="- topic/object "><desc class="- topic/desc "><p class="- topic/p "> Measure differential X disturbances </p></desc><param name="testid" value="046035" class="- topic/param "/><param name="target" value="NIL" class="- topic/param "/><param name="axmodule" value="None" class="- topic/param "/></object> 
</p></section><section id="GUID-1156E15C-FA11-42F7-80CE-F9823F371FA9" class="- topic/section "><title class="- topic/title ">Function</title><p class="- topic/p "> This test measures disturbances in X direction. 
</p><p class="- topic/p ">To be robust for nozzle failure, 16 bars are printed with different nozzle groups. 
</p><p class="- topic/p ">If 12 out of the 16 bars are measured correctly, the test ends successful. 
</p><p class="- topic/p ">The test "Results" tab values need to be interpreted. 
</p></section><section id="GUID-419CA7A1-97B8-4F3A-B3DC-B3F675659A66" class="- topic/section "><title class="- topic/title ">Pre-condition</title><p class="- topic/p "> Media width must be 50 inch or wider. 
</p></section><section id="GUID-8B850BDF-E4F3-4353-8EA8-26E9EC89A7EC" class="- topic/section "><title class="- topic/title ">Description</title><p class="- topic/p "> This test shows the measured frequencies that have an X amplitude of more than 0.5 um. 
</p><p class="- topic/p "> Each frequency must be verified within or without specification. If a frequency has an amplitude out of specification, a corrective action can be done. 
</p><p class="- topic/p ">The table below shows the known frequencies with the corrective actions. 
</p><table id="GUID-63490866-094C-4E9C-BE52-BB0E4333783E" class="- topic/table "><tgroup cols="4" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="*" class="- topic/colspec "/><colspec colname="col4" colnum="4" colwidth="*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> Frequency [Hz] 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Amplitude Specification [0.1um] * 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Copmponent 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">Corrective action 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">8 Hz 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Magnet holder of the printhead carriage 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">Verify if the magnet holder is loose or broken. Tighten screws or replace. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> 20 Hz 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Curing beam guidance 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p "> Lubricators 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> 23 Hz 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Drive belt of the printhead carriage belt 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">Adjust the tension of the drive belt 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">28 Hz 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Bearing of the printhead carriage 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">Clean the rail 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">35 Hz 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> The 1e natural frequency of the print carriage beam in z/x-direction!! 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p "> Can be caused by polluted carriage bearing. 
</p><p class="- topic/p ">Clean the surface and the outer circumference of the bearing. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">50 Hz 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Chiller 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p "> Re-adjust the stand of the chiller. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">51 Hz 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Pulley of the printhead carriage motor. 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">55 Hz 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> The 2e natural frequency of the print carriage beam. Introduced by the printhead carriage motor pulley. 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">125 Hz 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "/><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Inner bearing of the printhead carriage bearing 
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row></tbody></tgroup></table><p class="- topic/p ">* = Specification will be added later-on when enough statistical data is available. Expected Q1-2022 
</p></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-686678F1-A321-4B08-84D3-63C9CD28C7FA.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>SDS</linktext></link></linkpool></related-links>
