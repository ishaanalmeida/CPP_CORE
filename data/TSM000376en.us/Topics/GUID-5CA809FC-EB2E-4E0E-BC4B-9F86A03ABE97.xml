<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-5CA809FC-EB2E-4E0E-BC4B-9F86A03ABE97" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-5CA809FC-EB2E-4E0E-BC4B-9F86A03ABE97" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to remove the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Media loading drawer 1 pinch 1 motor encoder</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 12B4 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">MLO_DRA1_PINCH1_MO_ENC</compsignal></comp></title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_34F2C03C97F249649B92631C09DBB41B" class="- topic/li "><p class="- topic/p ">Open the media loading drawer. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_69BB0AEB395F4E8AB96FD94A4C0C8696" class="- topic/ul "><li id="LI_06B1AE50C8584502AA32D102711C1229" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li id="LI_561D1BF957EA49F8BB49139266A92893" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li id="LI_B784B59E966743309622F0F98A079F05" class="- topic/li "><p class="- topic/p ">Open ended spanner 13. 
</p></li></ul></section><section id="GUID-F56DEEE4-F746-4C5E-B808-E951147DF22A" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Caution:</ph></title><p class="- topic/p ">When you remove this encoder it is broken. Make sure you have a replacement. 
</p><p class="- topic/p "> Do not remove the base plate of the encoder. The base plate is positioned during production and must not be loosened. 
</p></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-1C6A5506-8461-4BFD-8B7C-FB47C7EF289A" class="- topic/fig "><desc class="- topic/desc "><p class="- topic/p ">The encoder 12B4 is mounted on the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Media loading drawer 1 pinch 1 motor</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 12M2 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">MLO_DRA1_PINCH1_MO</compsignal></comp>. 
</p></desc><image href="GUID-2A0311F4-E0C1-4260-AB46-E8608380F3D9-low.png" id="IMAGE_4DC6EE8C1B14407E8C7C4A980645B932" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2A0311F4-E0C1-4260-AB46-E8608380F3D9-low.png"/></fig></section><section id="SECTION_9A4E31FC8A1D474082EB98039B353FF0" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_BC6D1128E6D045B0884B679CB3343E94" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the indicated screw and nut of the mounting of the cover over the first pinch. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-20C1DA02-3D9B-4E86-9336-DD581A0ED8BC" class="- topic/fig "><image href="GUID-7EAB127A-FF8B-4B42-917A-7DFC9F185DD7-low.png" placement="inline" class="- topic/image " otherprops="GUID-7EAB127A-FF8B-4B42-917A-7DFC9F185DD7-low.png"/></fig><fig id="GUID-B9CB9BA4-A114-472B-A903-B7769A8B19F5" class="- topic/fig "><image href="GUID-70BBB8B3-F504-4DA9-B07C-B8056ADB0F05-low.png" placement="inline" class="- topic/image " otherprops="GUID-70BBB8B3-F504-4DA9-B07C-B8056ADB0F05-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Release the green lever. 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the pinch. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D743890E-C4A7-4728-965E-1A090CB6FC6E" class="- topic/fig "><image href="GUID-BAE24F9B-847D-428E-8423-494E288B003D-low.png" placement="inline" class="- topic/image " otherprops="GUID-BAE24F9B-847D-428E-8423-494E288B003D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws of the cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A457A127-8EB0-480C-B03E-9297B46D6DE0" class="- topic/fig "><image href="GUID-8FF1ACE1-14CA-41A6-9C9C-302663E59707-low.png" placement="inline" class="- topic/image " otherprops="GUID-8FF1ACE1-14CA-41A6-9C9C-302663E59707-low.png"/></fig><fig id="GUID-9671626E-9BB9-4CF1-B17D-8A1160463F1F" class="- topic/fig "><image href="GUID-9971575B-3401-4F89-9C23-0FEF897EBE06-low.png" placement="inline" class="- topic/image " otherprops="GUID-9971575B-3401-4F89-9C23-0FEF897EBE06-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cover to the top. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-13594457-E3D3-4177-8B77-980964925A12" class="- topic/fig "><image href="GUID-AC7D8BB0-183D-4375-97FA-A9D83F19333D-low.png" placement="inline" class="- topic/image " otherprops="GUID-AC7D8BB0-183D-4375-97FA-A9D83F19333D-low.png"/></fig><fig id="FIG_2D3AE3328DC84F9AA9845504C09080F1" class="- topic/fig "><image href="GUID-9DA12108-7938-4AE9-A280-9BB7255AD922-low.png" id="IMAGE_F41942FC40674CDA88BFF1EB368BD80B" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9DA12108-7938-4AE9-A280-9BB7255AD922-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the encoder. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_FE5916467AE746A985823662A1866FED" class="- topic/fig "><image href="GUID-5E65C4D6-842F-4F71-AADB-032A0B643240-low.png" id="IMAGE_031CF33715EB434E840050802DFB94B6" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5E65C4D6-842F-4F71-AADB-032A0B643240-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Rotate the encoder to unlock the bayonet lock, and remove the encoder housing. 
</p><note id="GUID-51C0E261-E7B0-47E9-AAF9-32798189A2E1" type="important" class="- topic/note "><p class="- topic/p ">The base plate of the encoder must remain on the motor. The base plate is positioned during production and must not be loosened. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_13570A842ADE47409ABDDFFB9CBC88DE" class="- topic/fig "><image href="GUID-39260836-E408-4375-8F5C-302683F32351-low.png" id="IMAGE_79D9208B0D3D42709A36377DF1690EB9" keyref="" placement="inline" class="- topic/image " otherprops="GUID-39260836-E408-4375-8F5C-302683F32351-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p><note id="GUID-B352DC5D-EF95-4679-B7E0-4F75756CEAC6" class="- topic/note "><p class="- topic/p ">Always install a new encoder. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B96AB9C-8847-4643-A8CB-09918FE19AAB.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>