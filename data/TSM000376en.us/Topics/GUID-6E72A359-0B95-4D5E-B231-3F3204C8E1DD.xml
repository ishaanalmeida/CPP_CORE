<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-6E72A359-0B95-4D5E-B231-3F3204C8E1DD" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-6E72A359-0B95-4D5E-B231-3F3204C8E1DD" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">How to downgrade CMYK-W to CMYK (mod 11)</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p "> When the customer no longer wants white in the system, this procedure must be executed to remove the white functionality from the system. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><p class="- topic/p ">Inform the customer that this action is not reversible. 
</p></section><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_CEA4CD427612471CA3540AD5430B21C2" class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Screwdriver small 
</p></li><li class="- topic/li "><p class="- topic/p ">Antistatic wrist strap 
</p></li><li class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex 
</b>93-260 gloves 
</p></li></ul></section><section id="GUID-8C399BF3-32D5-406D-8695-761028378845" class="- topic/section "><title class="- topic/title ">Requirements</title><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">License: 
</p><p class="- topic/p "> Disable White License 
</p><p class="- topic/p ">This is a commercial item that the customer needs to order. When ordered, the license will be available on ILMS and can be downloaded (optional). 
</p></li><li class="- topic/li "><p class="- topic/p ">Parts: 
</p><p class="- topic/p "> Kit 1070131787, white downgrade kit 
</p></li></ul><p class="- topic/p ">The white downgrade kit contains of the following parts: 
</p><table id="GUID-8DBB7BE8-73C2-46B9-B6AE-66AAD6299F84" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Description 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Part 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1x DUMMY-PRINTHEAD-ASSY 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><fig id="GUID-1058E018-8791-4F71-81F9-DFEAE36B403A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3747AA39-363C-4F77-BAA5-F4D4795FEAA6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3747AA39-363C-4F77-BAA5-F4D4795FEAA6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> 1x PLUG-AIRDUCT 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><fig id="GUID-423113F5-BEA6-4F39-9C3A-2A2A043D7ED2" class="- topic/fig "><title class="- topic/title "/><image href="GUID-BE43B44A-314F-4D57-AE75-5C5FC12AE808-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BE43B44A-314F-4D57-AE75-5C5FC12AE808-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> 1x MALE-LUER-LOCK-RING-PLUG-RED -LP4-3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><fig id="GUID-151E9732-96E0-4009-BB16-8BE883CBCFC5" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B17EC59D-11CE-4E19-B30F-3A4DFC6656E8-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B17EC59D-11CE-4E19-B30F-3A4DFC6656E8-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> 1x SYRINGE 50-60ML LUER LOK 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><fig id="GUID-853B8708-5BA7-4B35-9CB0-DF54EEF39F43" class="- topic/fig "><title class="- topic/title "/><image href="GUID-E4094EB0-C40D-4D59-9ABC-EB246E43E43F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E4094EB0-C40D-4D59-9ABC-EB246E43E43F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> 2x FEMALE COUPLER FTLLO25 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><fig id="GUID-4FA65550-BB8A-45A1-9180-E44CE406AEF4" class="- topic/fig "><title class="- topic/title "/><image href="GUID-EE8B60B9-9FCC-450E-B6C4-273ED9B2E726-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EE8B60B9-9FCC-450E-B6C4-273ED9B2E726-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> 50 mm TUBE-6X4-LLDPE 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><fig id="GUID-9D07FFB1-6CC7-45AB-9442-1E0522C03042" class="- topic/fig "><title class="- topic/title "/><image href="GUID-0A2C39B3-CD7D-4260-B312-9EF81AEFF9FF-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0A2C39B3-CD7D-4260-B312-9EF81AEFF9FF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> 1x FEMALE-LUER-THREAD-STYLE-CAP-RED-FTLLP-3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><fig id="GUID-94151E1D-B152-4AEF-8708-5BC705B97D82" class="- topic/fig "><title class="- topic/title "/><image href="GUID-BACDC3C7-2BB5-4B11-92D3-CF1FE3D2F2B3-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BACDC3C7-2BB5-4B11-92D3-CF1FE3D2F2B3-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">Procedure</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Preparation:
</p><p class="- topic/p "> Upgrade the software to at least R4.4 if not done already. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Check that the engine information is displayed in PRISMAservice. 
</p><p class="- topic/p ">For the upgrade procedure, see 
<xref keyref="00_GEN_ORS_UPGRADE" class="- topic/xref " href="GUID-7D9DDF42-47A6-492C-97AF-14DDEE7A03E4.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 11 Remote software upgrade via On Remote Service (ORS)?>11 Remote software upgrade via On Remote Service (ORS)</xref> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Preparation:
</p><p class="- topic/p ">Assemble the hose and 2 Luer FEMALE COUPLER FTLLO25 couplings and mount these on the syringe. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-63613980-7432-4C7A-AFA2-C809E485A221" class="- topic/fig "><title class="- topic/title "/><image href="GUID-1488B9A8-8253-4307-B5F4-8A4F3EE13D7D-low.png" placement="inline" class="- topic/image " otherprops="GUID-1488B9A8-8253-4307-B5F4-8A4F3EE13D7D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Preparation:
</p><p class="- topic/p "> Preconditions: Empty print queue. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Execute SDS test 
<b class="+ topic/ph hi-d/b ">02-1-007 WhiteInkHardwareInstalled</b> and set the value to 0 (not-installed). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">If the SDS test is not executed, then the error “450001 PHD communication error” will be reported on initialization. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">In SDS, goto the Modification menu and check the box for number 11. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The modification 11 marks the disabling of white functionality. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Execute SDS test 
<b class="+ topic/ph hi-d/b ">04-6-015 Cool down printheads</b> [Special Tests]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Cool down the Printheads. The printheads can be hot due to previous prints. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Go to the settings editor and update the “Permanent White Ink Downgrade” license. 
</p><note id="GUID-9AE6EBF2-70C6-40AE-AD79-1FDEAC438CCF" class="- topic/note "><p class="- topic/p ">When the machine is connected to ORS and the license is already updated in the back office, it is sufficient to use the button “Install license from remote server”. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">See 
<xref href="GUID-1F6EC30D-1C65-4922-A272-F5FEE55E2ABF.xml" class="- topic/xref " type="task"><?ditaot gentext?>Heavy transport of the printer</xref>TSM XXX for a detailed description on updating of licenses. 
</p><note id="GUID-61F4CAAE-2E53-4ACA-AA4B-7E69F64C89CA" class="- topic/note "><p class="- topic/p ">After a license is selected in the settings editor, to install the license, press OK (the license is not installed if Cancel is pressed). 
</p></note><fig id="GUID-23280BC1-E047-46DF-8A1B-BE4D390AE39A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-F2D657F9-662F-4F7C-B54C-BD9610F9008B-low.png" placement="inline" class="- topic/image " otherprops="GUID-F2D657F9-662F-4F7C-B54C-BD9610F9008B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">From the “system” menu, select “Power Management” and then select "Power Off". 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The system shutdown. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Black power switch: Switch Off 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">AC power is off, creates a safe work environment. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the covers from the ink side and open the Ink-cabinet. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The rear cover of the ink system must be open to be able to clean the tubes. 
</p><p class="- topic/p ">For all separate covers, see TSM: 
</p><p class="- topic/p "> 
<xref keyref="24DISA034" class="- topic/xref " href="GUID-1D8187CA-1F3B-4EBF-9E0A-F130AF910D4A.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?>24 How to remove the knife compartment cover</xref>. 
</p><p class="- topic/p "><xref keyref="24DISA032" class="- topic/xref " href="GUID-704C0C6B-5CA9-4D4D-B8A9-6C1132D65581.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?>24 How to remove the cover below the cover of the knife compartment</xref> . 
</p><p class="- topic/p "> 
<xref keyref="24DISA022" class="- topic/xref " href="GUID-A1586343-23C1-47B2-BE4B-BB8972057671.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?>24 How to remove the media input right cover</xref>. 
</p><p class="- topic/p "> 
<xref keyref="02DISA014" class="- topic/xref " href="GUID-44A21941-A21F-4C37-A066-3CEA7BE54DAA.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?>02 How to remove the rear top cover of the ink system</xref> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the white printhead. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">See TSM: 
</p><p class="- topic/p "><xref keyref="ReplaceRemovePHD" class="- topic/xref " href="GUID-ACAD0B0F-C121-43F8-87A4-AEFB386E249B.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?>04 How to replace a (failing) printhead: How to remove (Example printhead 3)</xref> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Close the vacuum tube of the white printhead. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">With a MALE-LUER-LOCK-RING-PLUG-RED -LP4-3 1070074024 .
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the dummy printhead at the white position. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Position 1 is the white position. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the airduct. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the PLUG-AIRDUCT 1070113779 after placing the Dummy printhead. 
</p></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Flush the white ink-tubes</b> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Preparation for flushing the ink. 
</p><p class="- topic/p ">Remove the transparent cap from the pump so that the tube is not blocked. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2480BEED-CCCC-4ACE-BC66-23BC751081AC" class="- topic/fig "><title class="- topic/title "/><image href="GUID-0098F7B1-0352-44A0-92BB-6E41EF9E88BD-low.png" placement="inline" class="- topic/image " otherprops="GUID-0098F7B1-0352-44A0-92BB-6E41EF9E88BD-low.png"/></fig><note id="GUID-FD39AFB0-B6A4-4719-84D2-9B4199C24564" class="- topic/note "><p class="- topic/p ">If this step is forgotten, it is possible that the ink is flushed back through the overpressure valve. 
</p></note></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Connect the Syringe assembly to the valve where the white Printhead was connected. 
</p></li><li class="- topic/li "><p class="- topic/p "> Open the valve and press the syringe. 
</p></li><li class="- topic/li "><p class="- topic/p "> Disconnect the Syringe from the black valve. 
</p></li><li class="- topic/li "><p class="- topic/p "> Retract the syringe. 
</p></li><li class="- topic/li "><p class="- topic/p "> Repeat these steps three times. 
</p></li></ol><p class="- topic/p ">(In the tube, +-35ml Ink is present. By blowing the syringe (60ml) three times, the tubes should be empty). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6A2E5FB5-BC84-4959-A06A-7BA68EF34DC0" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AD959B21-ECFE-4916-AD10-38743C83914C-low.png" placement="inline" class="- topic/image " otherprops="GUID-AD959B21-ECFE-4916-AD10-38743C83914C-low.png"/></fig><p class="- topic/p ">Some bubbling in the Ink jar can be heard. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Close the valve and seal the pipe towards the printhead with a FEMALE-LUER. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9ED5A342-68FD-402F-8CD6-F975BC90805A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-7CD0E745-3293-447E-9EA9-9CD6F94D2830-low.png" placement="inline" class="- topic/image " otherprops="GUID-7CD0E745-3293-447E-9EA9-9CD6F94D2830-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Flush the white recirculation</b> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">At the 3 way-valve: 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Connect the Syringe assembly to the tube with the green cable tie. 
</p></li><li class="- topic/li "><p class="- topic/p ">Press the syringe. 
</p></li><li class="- topic/li "><p class="- topic/p ">Disconnect the Syringe from the tube. 
</p></li><li class="- topic/li "><p class="- topic/p ">Retract the syringe. 
</p></li><li class="- topic/li "><p class="- topic/p ">Repeat these steps 3 times. 
</p></li><li class="- topic/li "><p class="- topic/p ">Place back the tube onto the 3 way-valve. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6108C259-CEC0-432D-B8C5-5E7052F48F6E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-F42FF224-0D40-4240-9DBD-5B890A376544-low.png" placement="inline" class="- topic/image " otherprops="GUID-F42FF224-0D40-4240-9DBD-5B890A376544-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the tube back in the pump and put the transparent cap onto the pump. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C65DD9EB-A5B9-4AA0-8914-EC32F397C6F1" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AC213E52-CA16-4273-B9EA-6381F7A90482-low.png" placement="inline" class="- topic/image " otherprops="GUID-AC213E52-CA16-4273-B9EA-6381F7A90482-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Switch the engine on. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">This also activates the disable white license, because everything is restarted here. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">21 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Load and select “Service media” in roll position 1. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The installation wizard needs service media on roll position 1 to execute the engine calibrations. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">22 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Execute the engine calibrations. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The engine is not accepting any prints at this time. 
</p><p class="- topic/p ">From the tools menu, go to the Resume installation wizard and press the Resume button. 
</p><note id="GUID-83DC9181-C0B6-45D5-874A-9E645D18D2A0" class="- topic/note "><p class="- topic/p ">A SAMkey must be inserted into the engine to execute the calibrations. 
</p></note></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">23 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disable the white ink option in RIP. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Update the settings related to the configuration of white in the RIP to prevent jobs being created that have white. Incorrect jobs will be rejected at reception. 
</p></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-7D3F358C-1AB9-4A5D-9B0E-C75D689F152E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
