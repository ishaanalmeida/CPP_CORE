<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-5C85D6FC-5E14-4490-AB29-1EEC54BC3FB5" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-5C85D6FC-5E14-4490-AB29-1EEC54BC3FB5" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">03 How to adjust the print height (calibration)</title><abstract class="- topic/abstract " id="GUID-173AF84C-D126-4DD5-8ABA-ADD08113B9D4"><p class="- topic/p ">This document describes the adjustment of the height between the guidance and carriage assembly and the print surface (platen). 
</p><fig class="- topic/fig " id="GUID-EFB24067-1EE2-4D81-A8EE-02A1044DD11F"><image class="- topic/image " href="GUID-5A0EA3B2-288B-4CC9-AE5C-04ED3D94A801-low.png" keyref="" placement="inline" otherprops="GUID-5A0EA3B2-288B-4CC9-AE5C-04ED3D94A801-low.png"/></fig><fig class="- topic/fig " id="GUID-DE882059-FB7C-458B-B533-EDB1AADF1AF2"><image class="- topic/image " href="GUID-A10B8800-529E-4EC1-89F0-21481C595ACA-low.png" keyref="" placement="inline" otherprops="GUID-A10B8800-529E-4EC1-89F0-21481C595ACA-low.png"/></fig></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Adjustment</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><context id="GUID-A02F419C-DBA9-48C5-9566-05B40F550DFD" class="- topic/section task/context "><p class="- topic/p ">Do this adjustment after replacement of parts or frequent media touches or print quality defects. 
</p></context><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Set of feeler gauges with the least resolution of 50 µm (0.05 mm). 
</p></li><li class="- topic/li "><p class="- topic/p ">Measuring tape. 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-2D7D94A0-B26C-4C0B-B6A3-20C8621663A2" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-572456BF-28FE-4706-9116-4D5E91E310E3" class="- topic/section "><title class="- topic/title ">Preparations / Check</title><table id="NEW" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Check if the print surface (platen) is clean. 
</p><p class="- topic/p ">If dirty clean the print surface. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Check if the matrix plate is clean. 
</p><p class="- topic/p ">If dirty clean the matrix plate. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check if the feeler gauges are straight. 
</p><note id="GUID-9F837927-EE7C-4ECD-9A0F-4BAF95996939" class="- topic/note "><p class="- topic/p ">If the tools are bent, they can give different results depending on orientation. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The printheads must be installed in the printhead carriage. The weight of the printheads is required. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use of feeler gauges 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place a maximum of 2 feeler gauges on top of one another and flat on the print surface. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Using 2 gauges provides better accuracy than 3 or more. 
</p></li><li class="- topic/li "><p class="- topic/p ">Example: 1000µm + 500µm (1 mm and 0.5 mm) is better than 600 µm + 500 µm + 400 µm (0.6 mm + 0.5 mm + 0.4 mm). 
</p></li><li class="- topic/li "><p class="- topic/p ">When using two feeler gauges, ensure they are lying on top of one another, not crossed over or misaligned as shown in the pictures. They should act as a single unit. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p><fig id="GUID-D25D2813-6F34-499A-A3B9-9D0537F236A6" class="- topic/fig "><image href="GUID-1BE4C676-1CC7-4ADE-855A-22FAE8ECA0F2-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1BE4C676-1CC7-4ADE-855A-22FAE8ECA0F2-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to adjust</title><note id="GUID-F4D97F73-27E2-4FEE-8282-4A22866F77B0" class="- topic/note "><p class="- topic/p ">The measurements and inputs of the SDS tests 03-6-102 must be done within the 
<b class="+ topic/ph hi-d/b ">time limit of 30 minutes</b>! 
</p><p class="- topic/p ">If exceeded the pinch will open and the test will end: 
<b class="+ topic/ph hi-d/b ">no values</b> are stored and the test must be restarted. 
</p></note><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Start SDS test 
<xref keyref="SDS03-6-102" class="- topic/xref " href="GUID-D12B8AD3-F839-4E39-AA78-F581E880E91D.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 03-6-102 Set Z motion system height offsets [Special Tests]?>03-6-102 Set Z motion system height offsets [Special Tests]</xref>. 
</p><p class="- topic/p ">The test in short will carry out the following steps: 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">The engine state is changed into cold SDS 
</p></li><li class="- topic/li "><p class="- topic/p "> The pinch is closed. 
</p></li><li class="- topic/li "><p class="- topic/p ">Initialize the height adjustment units to their respective home sensors and then move to print height level 1. 
</p></li><li class="- topic/li "><p class="- topic/p ">Display screen will ask for left (chiller) and then right (maintenance) print height inputs in µm. 
</p></li><li class="- topic/li "><p class="- topic/p ">After manual input by the technician, it will calculate and adjust the print height. 
</p></li><li class="- topic/li "><p class="- topic/p ">Only when continue is pressed and the test has ended successfully the new values are stored. 
</p></li></ol><p class="- topic/p ">The detailed description is in the next steps. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">When display screen requests values: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p></li><li class="- topic/li "><p class="- topic/p ">Measure and mark the distances of the 1<sup class="+ topic/ph hi-d/sup ">st</sup> and 2<sup class="+ topic/ph hi-d/sup ">nd</sup> measurement position: 92 +/- 2 cm and 172 +/- 2 cm from the left hand side edge of the guidance. 
</p></li><li class="- topic/li "><p class="- topic/p ">Move the printhead carriage to the first measurement position : 92 +/- 2 cm from the left hand side edge of the guidance. 
</p><p class="- topic/p ">Move the printhead carriage carefully by pushing along the frame. There will be resistance due to the connection of the drive system. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p><fig id="GUID-805D2328-F750-40E4-95A2-3B0A8C5C3EDF" class="- topic/fig "><image href="GUID-A10B8800-529E-4EC1-89F0-21481C595ACA-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A10B8800-529E-4EC1-89F0-21481C595ACA-low.png"/></fig><fig id="GUID-1CACDAF9-3FAF-4DE8-A03D-1C4A009340DF" class="- topic/fig "><image href="GUID-528CEE4B-0DB8-4360-AD08-209E9A474424-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-528CEE4B-0DB8-4360-AD08-209E9A474424-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place the feeler gauge set completely flat onto the print surface and in front of printhead (PHD) 4. 
</p><p class="- topic/p ">The nominal expected value is 1530 µm. For a calibrated machine, it is expected to slide under at 1500 µm and first feel the matrix plate at 1550 µm. It may be best to start here with 1000 µm + 500 µm. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">PHD4 is the center of the carriage just slightly, 1 cm, to the right (maintenance) side. 
</p></li><li class="- topic/li "><note type="important" id="GUID-823F527D-3A30-4A5C-9BD7-1C91E790638A" class="- topic/note "><p class="- topic/p ">Do not place any additional force on the guidance, printhead carriage, or print surface. i.e. there are no other tools on and do not lean on these parts. 
</p></note></li></ul><p class="- topic/p "> Measure underneath the carriage at the printhead 4 position by moving the feeler gauges in the paper step-direction, underneath the carriage matrix plate with minimal force. 
</p><ul class="- topic/ul "><li class="- topic/li "><note id="GUID-29432BC9-B3DE-4A06-8678-449DCE248CAA" class="- topic/note "><p class="- topic/p ">Do NOT use excessive force! 
</p><p class="- topic/p ">This can result in 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> elastic bending of the print surface during the measurement 
</p></li><li class="- topic/li "><p class="- topic/p ">lifting the carriage 
</p></li><li class="- topic/li "><p class="- topic/p ">and results will be wrong 
</p></li><li class="- topic/li "><p class="- topic/p ">or potential damage of the nozzle plates 
</p></li></ol></note></li><li class="- topic/li "><p class="- topic/p ">The feeler gauges must go deeper than the black plastic insulation box around the carriage, shown grey in illustration. To touch the matrix plate (MP) will be approximately 2 cm. Do not go more than 3 cm to avoid risk of nozzle plate (NP) touch. 
</p></li><li class="- topic/li "><p class="- topic/p "> If unsure how far, use a set of feeler gauges that exceeds the PS-MP (Print Surface - Matrix Plate) gap to feel where they hit the matrix plate. Then decrease the thickness of the set of gauges until measured properly. 
</p></li></ul><p class="- topic/p ">Use combinations of two feeler gauges until the matrix plate is just barely felt when moved under the carriage. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> If the feeler gauges hit or touch the matrix plate, use thinner gauges. 
</p></li><li class="- topic/li "><p class="- topic/p ">If the feeler gauges do not hit or touch the matrix plate, use thicker gauges. 
</p></li></ul><p class="- topic/p ">The difference between feeling and not feeling the matrix plate should be 50µm (limit of feeler gauges) 
</p><p class="- topic/p ">The feeler gauges can be verified by flipping them and repeating the last measurements when feeling and not feeling the matrix plate. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B224D042-759D-4224-BE2C-5F7684463B23" class="- topic/fig "><image href="GUID-F8844F6D-E05B-4A4A-A605-04452C02548E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F8844F6D-E05B-4A4A-A605-04452C02548E-low.png"/></fig><fig id="GUID-9BEC52BD-DDC5-44A8-9F6F-4BA38CBDF137" class="- topic/fig "><image href="GUID-DC31ADBA-D814-4C06-BCF3-40EDE971726C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-DC31ADBA-D814-4C06-BCF3-40EDE971726C-low.png"/></fig><fig id="GUID-6ADF0BFD-B99C-4D1B-BD9D-882351EE9A53" class="- topic/fig "><image href="GUID-FDF3FF9E-7588-4BEE-97B6-ACDDBD70C3F6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FDF3FF9E-7588-4BEE-97B6-ACDDBD70C3F6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Sum the two feeler gauges and enter the value in µm into the SDS test for the left hand side (chiller side). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Follow the instructions on the screen. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the printhead carriage so the left edge is aligned with adjustment position 2: 172 +/-2 cm from the left hand side edge of the guidance and repeat the measurement at the right hand side (maintenance side). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p><fig id="GUID-6F85CBEB-1BB1-4142-8080-70471BF25906" class="- topic/fig "><image href="GUID-A10B8800-529E-4EC1-89F0-21481C595ACA-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A10B8800-529E-4EC1-89F0-21481C595ACA-low.png"/></fig><fig id="GUID-1960BAAE-8C63-41C5-A301-7C00202C57B4" class="- topic/fig "><image href="GUID-2A9D8E43-014A-42C9-B8E7-90A19E120B97-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2A9D8E43-014A-42C9-B8E7-90A19E120B97-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Sum the feeler gauges and enter the value in µm into the SDS test for the right hand side (maintenance side). 
</p><p class="- topic/p ">Press continue. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The system now calculates and applies the new offsets. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Press continue so that the SDS test is completed and the new, calculated values are stored. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">When calibration has ended successfully, clean feeler gauges and print surface of any ink contamination. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Do SDS task: 
<xref keyref="SDStaskPrintheadcariagePart2" class="- topic/xref " href="GUID-1DA812E9-D4A2-4B1D-A409-6BEFAC5FE105.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text Calibrate the printhead carriage after replacement (Part 2) [Tasks]?>Calibrate the printhead carriage after replacement (Part 2) [Tasks]</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-60D7E25B-44DC-4B60-83F8-4A86C0AEA1A8.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Adjustment</linktext></link></linkpool></related-links>
</task>