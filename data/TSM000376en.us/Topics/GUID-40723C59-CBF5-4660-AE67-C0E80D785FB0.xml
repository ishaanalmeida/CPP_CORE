<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-40723C59-CBF5-4660-AE67-C0E80D785FB0" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-40723C59-CBF5-4660-AE67-C0E80D785FB0" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">SAM : The 'Create License Request' procedure</title><abstract class="- topic/abstract " id="M153740-B53"><p class="- topic/p ">If the local ILMS administrator asks you to create a license request file, execute the steps below. 
</p><p class="- topic/p ">A license request file contains a list of all installed licenses and certain data belonging to your SAM key. It has a unique serial number for instance.
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Tools</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><steps id="M153740-B54" class="- topic/ol task/steps "><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Click on the “License Update” button in the main screen of CodeMeter Control Center: 
</cmd><info class="- topic/itemgroup task/info "><fig outputclass="figure" id="M153740-F55" class="- topic/fig "><image href="IL059293-low.jpg" id="M153740-SH56" placement="inline" class="- topic/image " otherprops="IL059293-low.jpg"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">You get: 
</cmd><info class="- topic/itemgroup task/info "><fig outputclass="figure" id="M153740-F57" class="- topic/fig "><image href="IL059294-low.jpg" id="M153740-SH58" placement="inline" class="- topic/image " otherprops="IL059294-low.jpg"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Click Next: 
</cmd><info class="- topic/itemgroup task/info "><fig outputclass="figure" id="M153740-F59" class="- topic/fig "><image href="IL059288-low.jpg" id="M153740-SH60" placement="inline" class="- topic/image " otherprops="IL059288-low.jpg"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Select “Create license request” and click on Next: 
</cmd><info class="- topic/itemgroup task/info "><fig outputclass="figure" id="M153740-F61" class="- topic/fig "><image href="IL059289-low.jpg" id="M153740-SH62" placement="inline" class="- topic/image " otherprops="IL059289-low.jpg"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Select “Extend existing license”. 
</cmd><info class="- topic/itemgroup task/info "><fig outputclass="figure" id="M153740-F63" class="- topic/fig "><image href="IL059290-low.jpg" id="M153740-SH64" placement="inline" class="- topic/image " otherprops="IL059290-low.jpg"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Make sure that “Oce” is selected and click next: 
</cmd><info class="- topic/itemgroup task/info "><fig outputclass="figure" id="M153740-F65" class="- topic/fig "><image href="IL059291-low.jpg" id="M153740-SH66" placement="inline" class="- topic/image " otherprops="IL059291-low.jpg"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Select the directory to store the file and select Commit. 
</cmd><info class="- topic/itemgroup task/info "><fig outputclass="figure" id="M153740-F67" class="- topic/fig "><image href="IL059292-low.jpg" id="M153740-SH68" placement="inline" class="- topic/image " otherprops="IL059292-low.jpg"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">You can now mail this file to your Local ILMS administrator. 
</cmd></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-B8949918-A598-4816-BDAF-C06A30443D3A.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>SAM: Service Access Management</linktext></link></linkpool></related-links>
