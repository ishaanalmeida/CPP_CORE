<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-7CAD249F-BEF4-44B8-AF9A-1A9DEDC552D8" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-7CAD249F-BEF4-44B8-AF9A-1A9DEDC552D8" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to remove the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Pre curing lamp PBA</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 01PBA01 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">PRE_CURE_LAMP</compsignal></comp></title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-A6C4027D-0CB3-434B-9E25-1A0585D6B91C" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_38354AE763584586B66140798746F88A" class="- topic/ul "><li id="LI_DF7D2C907B2D42D290CB248965A47651" class="- topic/li "><p class="- topic/p ">Small screwdriver 
</p></li><li id="LI_5DF90D34870842BCB45AA985A971EFE4" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_96043D3239B548E7A98C800A8C8CC643" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Towel 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-260E20F2-CF3F-454B-8670-3153DAC71EFF" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p><p class="- topic/p ">Never operate the UV lamp when you can see the light. The UV light will damage your eyes. Always close the top cover first. 
</p><p class="- topic/p ">Beware the UV lamp can be very hot. 
</p></note><note type="important" id="GUID-23BD9E81-470A-411D-865B-B43797B2921E" class="- topic/note "><p class="- topic/p ">Do NOT remove the hose connectors from the lamp. This is fixed in factory with a certain torque. You can damage the UV lamp. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-C0BB8A45-4E7E-4931-B0AD-8B18FC7579A1" class="- topic/fig "><image href="GUID-6F26B2BC-E63F-4F15-BB07-EADB4E40ADF0-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6F26B2BC-E63F-4F15-BB07-EADB4E40ADF0-low.png"/></fig><fig id="GUID-7CAFC682-678C-41F2-956D-7C58655C79C2" class="- topic/fig "><image href="GUID-AF090938-530C-4104-9504-B9865CA467A0-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-AF090938-530C-4104-9504-B9865CA467A0-low.png"/></fig></section><section id="SECTION_B3F476EA69AF481E914FB3D5DC54BE8E" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_83682D28FC8D406BB28779A9E3A6368F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">To prevent overflowing of the chiller, remove 2 liter of cooling liquid from the chiller before disconnecting the hoses from the UV lamp
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F46FA36E-569B-4A1B-A64A-79C2A128E5C3" class="- topic/fig "><image href="GUID-A4B42787-3F82-46D9-82A4-52A06B9C2444-low.png" placement="inline" class="- topic/image " otherprops="GUID-A4B42787-3F82-46D9-82A4-52A06B9C2444-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place a towel under the UV lamp. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Disconnect the 2 hoses of the cooling system. 
</p></li><li class="- topic/li "><p class="- topic/p ">Unlock and disconnect the connector. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E145EC15-9D71-4B1F-B4AF-1A9C47D86223" class="- topic/fig "><image href="GUID-8EF3E640-3DBE-490B-8EBA-55028CB405DC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8EF3E640-3DBE-490B-8EBA-55028CB405DC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Loosen the 2 lower screws of the UV lamp. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the 2 upper screws. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8A82B578-734A-4677-9969-21392D1B1977" class="- topic/fig "><image href="GUID-0C44A3B7-BBDF-43DD-8A34-8A16E51CC306-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0C44A3B7-BBDF-43DD-8A34-8A16E51CC306-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the metal plate (2 screws) from the UV lamp. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-199E50DE-E3FB-49A8-A58F-3D3E60B5E275" class="- topic/fig "><image href="GUID-73AEF686-E116-4042-87A3-EA5B4C47623E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-73AEF686-E116-4042-87A3-EA5B4C47623E-low.png"/></fig><fig id="FIG_7944D011DF3C40E7B723F431A89364E5" class="- topic/fig "><image href="GUID-FEF32C18-2D97-4479-918A-F7465DA02096-low.png" id="IMAGE_70C6C096B4F3460C8EC46842DB654B23" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FEF32C18-2D97-4479-918A-F7465DA02096-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the UV lamp. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9469E390-A828-47EC-9425-C64F28ACAD7C" class="- topic/fig "><image href="GUID-AF090938-530C-4104-9504-B9865CA467A0-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-AF090938-530C-4104-9504-B9865CA467A0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">After the printer is started, wait for the beep (ca 2min) of the chiller starting up.
</p></li><li class="- topic/li "><p class="- topic/p ">You can now add the cooling liquid to the chiller again which you removed in step 1.
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1CC446CF-715F-4D24-96B4-DBBCD32DBF24" class="- topic/fig "><image href="GUID-11AC0124-8412-454E-8CF2-D3A6AAE7BCE2-low.png" placement="inline" class="- topic/image " otherprops="GUID-11AC0124-8412-454E-8CF2-D3A6AAE7BCE2-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-22D79A6A-2191-46FA-BE14-24F47FE4288E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
