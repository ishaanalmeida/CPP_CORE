<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-ACAD0B0F-C121-43F8-87A4-AEFB386E249B" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-ACAD0B0F-C121-43F8-87A4-AEFB386E249B" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">04 How to replace a (failing) printhead: How to remove (Example printhead 3)</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="SECTION_47BB0210B74F41A79960030F686F53F9" class="- topic/section "><title class="- topic/title ">How to remove (Example printhead 3)</title><table pgwide="1" id="TABLE_A60640ED6B7548638B70C78754A7290D" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the clamp bracket (loosen 4 screws). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-23B47517-3AB9-48C0-B5ED-73DACEEE8C37" class="- topic/fig "><image href="GUID-845D2E8F-E4AA-41A7-8556-20E37877F5B4-low.png" placement="inline" class="- topic/image " otherprops="GUID-845D2E8F-E4AA-41A7-8556-20E37877F5B4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close all all air tubes of the printheads with the white clamp. 
</p><note id="GUID-40F1212F-CB30-4B11-9BB5-39BB3ABD1B6B" class="- topic/note "><p class="- topic/p ">The printheads will leak ink if the air tubes of the prinheads are not closed. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FC28095E-8F21-4E57-8B95-275D00BB8D8F" class="- topic/fig "><image href="GUID-0C275F10-BBE0-4385-BA7F-0E4353A07045-low.png" placement="inline" class="- topic/image " otherprops="GUID-0C275F10-BBE0-4385-BA7F-0E4353A07045-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the 2 ink valves of the to be removed printhead. (Example: printhead 
<b class="+ topic/ph hi-d/b ">3</b>). 
</p><note id="GUID-F5663B59-E317-4961-87A5-97AEF57410F9" class="- topic/note "><p class="- topic/p ">The valves of the neighboring printheads should stay open (vertical position). 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F36E2BE5-FC78-4E3F-B993-7EAEFCE65EA5" class="- topic/fig "><image href="GUID-AA1E09B7-E616-4268-ADB3-FF6F69EC461F-low.png" placement="inline" class="- topic/image " otherprops="GUID-AA1E09B7-E616-4268-ADB3-FF6F69EC461F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the screw and the bracket. 
</p></li><li class="- topic/li "><p class="- topic/p ">Loosen the 2 screws of the air duct. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CA28E213-8DC6-41CF-801A-262CD0E0EFBE" class="- topic/fig "><image href="GUID-93E0944A-2C39-428C-858E-D30F099B495F-low.png" placement="inline" class="- topic/image " otherprops="GUID-93E0944A-2C39-428C-858E-D30F099B495F-low.png"/></fig><fig id="GUID-993AC72B-308D-410D-9408-B47DAA64517A" class="- topic/fig "><image href="GUID-66E715B8-6855-41CD-8C52-CFF0187AA92F-low.png" placement="inline" class="- topic/image " otherprops="GUID-66E715B8-6855-41CD-8C52-CFF0187AA92F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Pull away the air duct from the printheads. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-DCBD91D7-FFBF-40D0-9F47-B7FBAFA97DE1" class="- topic/fig "><image href="GUID-BE305F2B-9989-4434-B7FF-2A666656B1D8-low.png" placement="inline" class="- topic/image " otherprops="GUID-BE305F2B-9989-4434-B7FF-2A666656B1D8-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open (squeeze together and rotate the handle ) of the printhead position mechanism. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6135EC91-5264-4456-A3AD-EE504F8FCC2D" class="- topic/fig "><title class="- topic/title "/><image href="GUID-CAD877E0-9D39-45DD-9988-C61DF60B45C6-low.png" placement="inline" class="- topic/image " otherprops="GUID-CAD877E0-9D39-45DD-9988-C61DF60B45C6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Disconnect the flex cable connector at the Printhead Carriage PBA. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F48E897B-33E2-4CB9-88F4-5E83E1CDC8FC" class="- topic/fig "><image href="GUID-19B11A63-EBA8-4CDB-A68E-AC33278E700F-low.png" placement="inline" class="- topic/image " otherprops="GUID-19B11A63-EBA8-4CDB-A68E-AC33278E700F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Disconnect the air tube of the printhead (to be removed). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CF54126B-B258-4348-9774-6D022630B952" class="- topic/fig "><image href="GUID-BEE7ECAF-79F9-4168-B8E8-F89F53808C52-low.png" placement="inline" class="- topic/image " otherprops="GUID-BEE7ECAF-79F9-4168-B8E8-F89F53808C52-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Close the open end of the air tube of the printhead with red air tube cap. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EEBA3C8E-251D-4462-9038-25BA04837DF8" class="- topic/fig "><image href="GUID-6B5122AB-C2C3-4D9E-9888-9C82C0FD044E-low.png" placement="inline" class="- topic/image " otherprops="GUID-6B5122AB-C2C3-4D9E-9888-9C82C0FD044E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the ink input tube of the printhead to be removed. 
</p><p class="- topic/p ">To disconnect the ink tube: 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Take out the black tube from the fixed carriage frame 
</p></li><li class="- topic/li "><p class="- topic/p ">Loosen the central/intermediate cap 
</p></li><li class="- topic/li "><p class="- topic/p ">Take a tissue (lint free cloth) and clean the open end of ink tube (printhead side) 
</p></li><li class="- topic/li "><p class="- topic/p "> Close the open end of ink tube from printhead side with a red cap. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3F1E5C4D-1B69-4B06-99CA-1D583F421292" class="- topic/fig "><image href="GUID-5D778CD7-49BB-440A-9FFC-4B0F2FAF64AA-low.png" placement="inline" class="- topic/image " otherprops="GUID-5D778CD7-49BB-440A-9FFC-4B0F2FAF64AA-low.png"/></fig><fig id="GUID-9FED3620-D76D-44CA-8809-9F3699080545" class="- topic/fig "><image href="GUID-F9583A4F-1773-45CF-B082-8A453538829D-low.png" placement="inline" class="- topic/image " otherprops="GUID-F9583A4F-1773-45CF-B082-8A453538829D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift the printhead out of the printhead carriage. 
</p><note type="important" id="GUID-F40A93E4-0283-4DB7-9509-25FB34050EF5" class="- topic/note "><p class="- topic/p "> Keep printhead vertical. 
</p><p class="- topic/p ">Do not touch nozzle plate with neighbor printheads, tubes to avoid damage of nozzle plate (= print side of the printhead). 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6277024E-9F97-46B6-A730-B84B794B435C" class="- topic/fig "><image href="GUID-32106F86-5B38-4A46-85FC-37E13FE94863-low.png" placement="inline" class="- topic/image " otherprops="GUID-32106F86-5B38-4A46-85FC-37E13FE94863-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the green protective cap over the nozzle plate of the printhead. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-45252E20-D3CC-4E13-AD83-5296EB1A8659" class="- topic/fig "><image href="GUID-9497F89A-465D-47C3-8B52-77E6FC1EE2A7-low.png" placement="inline" class="- topic/image " otherprops="GUID-9497F89A-465D-47C3-8B52-77E6FC1EE2A7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect and remove the flex cable from the printhead. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-95FDD5BC-BA22-4E61-9FF8-A096D4DE2678" class="- topic/fig "><image href="GUID-970D962B-7D77-4F43-88D4-C9A401FEA91B-low.png" placement="inline" class="- topic/image " otherprops="GUID-970D962B-7D77-4F43-88D4-C9A401FEA91B-low.png"/></fig></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-ECEDEBD8-6D40-49D8-874E-708F1E8B0062.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
