<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-CA044853-D7B5-442F-9553-01C6A354E232" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-CA044853-D7B5-442F-9553-01C6A354E232" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">05 How to remove the printhead carriage unit</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_64BB077525D643BAA0D00A934918884D" class="- topic/ul "><li id="LI_10CD291CBF76488DBB558C50CFF62976" class="- topic/li "><p class="- topic/p ">Small screwdriver. 
</p></li><li id="LI_FEBB1892C37D4D6DA26AFAA9949BAE22" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li class="- topic/li "><p class="- topic/p "> Screwdriver Torx T25
</p></li><li class="- topic/li "><p class="- topic/p ">3 needles. 
</p></li><li class="- topic/li "><p class="- topic/p ">5 cable ties. 
</p></li><li class="- topic/li "><p class="- topic/p ">Y -coarse adjustment tool for adjusting Tissue Wipe cassette maintenance unit.
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-18A58829-3358-4BCF-BE91-E55E92C23071" class="- topic/section "><title class="- topic/title "/></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-F2BD1CD8-D885-4A5A-B5AE-580392833C42" class="- topic/fig "><image href="GUID-CE352008-6065-43E2-A983-38B892D6D0D6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CE352008-6065-43E2-A983-38B892D6D0D6-low.png"/></fig></section><section id="SECTION_AF4E08E2A3394F2DA33D1C1CE67074E1" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="GUID-3456E3A6-7C40-409B-A2A0-83B9889E7AFE" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Preparation
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">See: 
<xref keyref="ReplacePreparation" class="- topic/xref " href="GUID-F3514800-A710-4D6F-931B-1B0C130A809E.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>04 How to replace a (failing) printhead: Preparation</xref> (Step 1 -4)
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cover of the knife compartment. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">See : 
<xref keyref="24DISA034" class="- topic/xref " href="GUID-1D8187CA-1F3B-4EBF-9E0A-F130AF910D4A.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>24 How to remove the knife compartment cover</xref>. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the right side top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">See : 
<xref keyref="24DISA042" class="- topic/xref " href="GUID-F53C0184-B1EA-4AA3-A93E-FA5DB552BE10.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>24 How to remove the right side top cover</xref>. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove ALL printheads.
</p><note id="GUID-96C56B74-628C-4D7E-86DC-3439CCB49DF1" class="- topic/note "><p class="- topic/p ">Store the printheads in a blister. 
</p><p class="- topic/p ">Mark their locations and store the blisters upright.
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><xref keyref="ReplaceRemovePHD" class="- topic/xref " href="GUID-ACAD0B0F-C121-43F8-87A4-AEFB386E249B.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>04 How to replace a (failing) printhead: How to remove (Example printhead 3)</xref>
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the shielding plate.
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Loosen the 4 screws.
</p></li><li class="- topic/li "><p class="- topic/p "> Remove shielding plate.
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-62DBE108-9AFD-4A6C-92AB-1ABE0D44CB82" class="- topic/fig "><image href="GUID-FC7A44DA-CB3F-4D74-B865-A9AB904CAD9F-low.png" placement="inline" class="- topic/image " otherprops="GUID-FC7A44DA-CB3F-4D74-B865-A9AB904CAD9F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the complete mirror box at the right side.
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Remove clip.
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the 4 screws that are accessible through the 4 holes.
</p><note id="GUID-BDA4186B-7D8C-4386-8FAC-AC4EB5B2D80A" class="- topic/note "><p class="- topic/p ">Use the magnetizer tool to prevent screws from falling down.
</p></note><note id="GUID-DEB1B67E-0C87-4005-A569-8922EFECD906" class="- topic/note "><p class="- topic/p ">Do not loosen or remove the red painted screws.
</p></note></li><li class="- topic/li "><p class="- topic/p "> Remove the mirror box.
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8E3DF711-58FB-4F1A-AE7C-6AB5C3A76A40" class="- topic/fig "><image href="GUID-82EB126A-F154-4B18-A856-E98D67EC0E95-low.png" placement="inline" class="- topic/image " otherprops="GUID-82EB126A-F154-4B18-A856-E98D67EC0E95-low.png"/></fig><fig id="GUID-B94F7A7D-CB2F-4CA0-8694-C2A6DBFBD8A0" class="- topic/fig "><image href="GUID-3D463647-FCEC-4E65-AA4B-EF9B906B8AE3-low.png" placement="inline" class="- topic/image " otherprops="GUID-3D463647-FCEC-4E65-AA4B-EF9B906B8AE3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the complete mirror box at the left side.
</p><p class="- topic/p "> Remove the 4 screws that are accessible through the 4 holes and remove the mirror box.
</p><p class="- topic/p "> Cut the cable ties that connects the hoses to the frame.
</p><note type="important" id="GUID-FADF61DF-D5AE-4E94-AFC1-90410B88CD34" class="- topic/note "><p class="- topic/p ">Remove mirror box carefully.
</p></note><note id="GUID-319164ED-5D9F-4791-88C7-25CD9619FBB0" class="- topic/note "><p class="- topic/p "> Use the magnetizer tool to prevent screws from falling down.
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FDC78215-17AD-4E0E-B7A3-1AED1B903962" class="- topic/fig "><image href="GUID-5797F59C-C5D4-4A14-8829-393D9FE43A56-low.png" placement="inline" class="- topic/image " otherprops="GUID-5797F59C-C5D4-4A14-8829-393D9FE43A56-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the cover of the carriage unit
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9EC4DFFF-FB79-47E6-8DA2-5E0C3CD1F538" class="- topic/fig "><image href="GUID-7B709076-C288-45AF-8F9E-5CA401688621-low.png" placement="inline" class="- topic/image " otherprops="GUID-7B709076-C288-45AF-8F9E-5CA401688621-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Squeeze the connector of the optical fiber cable and disconnect the connector.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-91C9A514-F32B-4B5F-B0D4-B40430A2A518" class="- topic/fig "><image href="GUID-BB849409-E480-42E7-8751-52452BA614D9-low.png" placement="inline" class="- topic/image " otherprops="GUID-BB849409-E480-42E7-8751-52452BA614D9-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><note id="GUID-F40A5E98-5168-431E-818A-CBAA3103B73C" class="- topic/note "><p class="- topic/p ">Place 2 end caps on the connector to prevent pollution of the 2 glass fibers.
</p><p class="- topic/p ">Tape the optical cable to the carriage so is does not get stuck or damaged anywhere.
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-41F7D8F0-9E52-44B8-AEFB-801759125889" class="- topic/fig "><image href="GUID-F096C38C-F72A-4A31-A499-9DA9B383967E-low.png" placement="inline" class="- topic/image " otherprops="GUID-F096C38C-F72A-4A31-A499-9DA9B383967E-low.png"/></fig><fig id="GUID-440EE21C-D86B-4D87-BC97-74C2CB3DB910" class="- topic/fig "><image href="GUID-9E10CA98-E2B6-471E-8A37-C8A449307708-low.png" placement="inline" class="- topic/image " otherprops="GUID-9E10CA98-E2B6-471E-8A37-C8A449307708-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Loosen 1 screw.
</p></li><li class="- topic/li "><p class="- topic/p "> Remove the other 3 screws of the cover .
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0652AB48-9FBA-48B7-B47F-F33D4621716A" class="- topic/fig "><image href="GUID-3E8902BD-6E47-41B9-98EF-28FDD0C64004-low.png" placement="inline" class="- topic/image " otherprops="GUID-3E8902BD-6E47-41B9-98EF-28FDD0C64004-low.png"/></fig><fig id="GUID-3D4A6793-FBEF-4AA7-A43E-F5ABE3B82478" class="- topic/fig "><image href="GUID-B5F85918-8A1C-4895-9598-9D3830372D9F-low.png" placement="inline" class="- topic/image " otherprops="GUID-B5F85918-8A1C-4895-9598-9D3830372D9F-low.png"/></fig><fig id="GUID-021AA665-3DB8-49BA-95DB-62D462B6917C" class="- topic/fig "><image href="GUID-2633146E-9FA7-4032-8287-AC46C787E060-low.png" placement="inline" class="- topic/image " otherprops="GUID-2633146E-9FA7-4032-8287-AC46C787E060-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Disconnect all hoses except the connectors of the Manifolds. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9BFAD17A-84ED-4F29-A087-EDFA24EB245E" class="- topic/fig "><image href="GUID-D0B7EA6B-9C66-4AF0-B362-0855387B56D1-low.png" placement="inline" class="- topic/image " otherprops="GUID-D0B7EA6B-9C66-4AF0-B362-0855387B56D1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Lift the cover and remove the cable harness.
</p></li><li class="- topic/li "><p class="- topic/p ">Remove cover
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C56039A9-58A2-459F-A9F1-3000178077F3" class="- topic/fig "><image href="GUID-4BA02C36-3184-4D79-BBF6-06FBD358E597-low.png" placement="inline" class="- topic/image " otherprops="GUID-4BA02C36-3184-4D79-BBF6-06FBD358E597-low.png"/></fig><fig id="GUID-43A52CDB-AC4C-40E0-B4CC-07C1A20AFB71" class="- topic/fig "><image href="GUID-4AF32246-3160-4F19-839E-528F0471E9EF-low.png" placement="inline" class="- topic/image " otherprops="GUID-4AF32246-3160-4F19-839E-528F0471E9EF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove Carriage PBA assembly.
</p><p class="- topic/p ">Disconnect Flat cables Strip Support, (Printhead flat cables are already removed during printhead removal).
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7C7BEE7E-6A2C-4659-B741-EBFBB0B5AB58" class="- topic/fig "><image href="GUID-1A596D33-D2FF-41B8-97FA-91D1807C8782-low.png" placement="inline" class="- topic/image " otherprops="GUID-1A596D33-D2FF-41B8-97FA-91D1807C8782-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 3 screws (T10).
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-367AA1C9-23F1-4206-AEA0-5BBF4CB01ABC" class="- topic/fig "><image href="GUID-FEA0ECB6-98DF-410D-8329-17F0C3E6EA34-low.png" placement="inline" class="- topic/image " otherprops="GUID-FEA0ECB6-98DF-410D-8329-17F0C3E6EA34-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the PBA assembly.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D9A4E563-D0AA-44FA-95F6-6F300E02105C" class="- topic/fig "><image href="GUID-6B78AD16-2175-47AC-BFF4-A7C101EC820D-low.png" placement="inline" class="- topic/image " otherprops="GUID-6B78AD16-2175-47AC-BFF4-A7C101EC820D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the flat cable connection (2 screws) and lift out the flat cables, ink and air tube assembly of the Strip Support. and place it carefully on the print surface. 
</p><note id="GUID-6521E468-E278-498D-B180-0C15044BFFA0" class="- topic/note "><p class="- topic/p "> Do 
<b class="+ topic/ph hi-d/b ">not</b> loosen the 2 upper ones from the clamp. 
</p><p class="- topic/p ">If you do this an adjustment is required.
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CCD3DE41-4A1C-49FC-B1C9-E695884CFBDD" class="- topic/fig "><image href="GUID-BF2E5014-ED0A-433E-BEE6-875F5A6D1097-low.png" placement="inline" class="- topic/image " otherprops="GUID-BF2E5014-ED0A-433E-BEE6-875F5A6D1097-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the M&amp;C unit : 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Disconnect the connector of the M&amp;C unit. 
</p></li><li class="- topic/li "><p class="- topic/p "> Remove the M&amp;C unit (3 screws). 
</p></li></ul><p class="- topic/p "><xref keyref="05DISA004" class="- topic/xref " href="GUID-563F9EBE-CC03-4CAA-93C8-8AA3AB9B162B.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>05 How to remove the Measurement &amp; Control (M&amp;C) unit</xref>
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-27DA20CC-C5A8-4CA5-BE13-DC2F7FA14999" class="- topic/fig "><image href="GUID-E2B8ADFE-FFAC-4ACE-AF24-43A97013D6C5-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E2B8ADFE-FFAC-4ACE-AF24-43A97013D6C5-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the optical fiber cable and air tube from the cable guides and guide both to the left hand side of the unit.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-492D022C-0433-4CE5-B353-A6FC946579BB" class="- topic/fig "><image href="GUID-3E39B6A4-C00A-458B-8145-BA70055B87AB-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3E39B6A4-C00A-458B-8145-BA70055B87AB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Cut the 2 cable ties.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F3DBDEB8-8A51-42DB-8CE8-1B242D19CF53" class="- topic/fig "><image href="GUID-E361653F-3CE9-41D6-BEC3-A5E9A41633CA-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E361653F-3CE9-41D6-BEC3-A5E9A41633CA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">21
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove all ink tubes of the tube connection at the rear side of the printhead carriage.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-78B70FBD-B89E-4303-BF1B-3D1132ED86F2" class="- topic/fig "><image href="GUID-4A85D3EF-A3D0-491A-AC5A-D29B88089441-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4A85D3EF-A3D0-491A-AC5A-D29B88089441-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">22
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place a needle in the holes of the 3 guidance cleaners (felt with oil) assemblies on the printhead carriage unit.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6D5AE66D-01EE-43CD-B165-4BB263AC7CBF" class="- topic/fig "><image href="GUID-14498502-B801-4180-A436-3B5E5C324688-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-14498502-B801-4180-A436-3B5E5C324688-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">23
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 black brackets, at the left and right hand side, of the printhead carriage.
</p><p class="- topic/p ">On each side there is 1 silver and 1 black screw.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-115F2327-2A8E-4871-8CF0-26BD36E33B46" class="- topic/fig "><image href="GUID-66624A7C-4C6D-4FA3-BBA8-FECEB565707E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-66624A7C-4C6D-4FA3-BBA8-FECEB565707E-low.png"/></fig><fig id="GUID-450F6EC2-D198-48F6-81C0-0C9EC0486FFA" class="- topic/fig "><image href="GUID-2035C413-B8BA-49F5-95E6-E19D8BC7AC3B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2035C413-B8BA-49F5-95E6-E19D8BC7AC3B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">24
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 strong magnets with a small screw driver of the printhead carriage.
</p><note id="GUID-7C94F45C-208A-451B-8CC5-7E5081264421" class="- topic/note "><p class="- topic/p "> 2 Red lines are on top. Mark the position!
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0F3733C6-B74C-48DE-871C-625AD51C0D18" class="- topic/fig "><image href="GUID-3052A4CE-DB7D-400D-B5E0-0E92BE46EFA6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3052A4CE-DB7D-400D-B5E0-0E92BE46EFA6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">25
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the Drive belt. Execute the ‘How to Remove’ part of the instruction.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> See: 
</p><p class="- topic/p "><xref keyref="05DISA009" class="- topic/xref " href="GUID-897E944B-74E6-4F78-82E2-F9C042C1C99C.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>05 How to remove the printhead carriage drive belt</xref>
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">26
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide the printhead carriage above the cut-away locations in the guide rail.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B4125F70-B86B-4890-90A5-6C0D9498383F" class="- topic/fig "><image href="GUID-F0E27C9F-5BC3-4C97-AF62-8443683DBE5E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F0E27C9F-5BC3-4C97-AF62-8443683DBE5E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">27
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Tilt and take out the printhead carriage unit.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-30311B37-36E9-4CA4-8D6D-582B4B70A909" class="- topic/fig "><image href="GUID-CE352008-6065-43E2-A983-38B892D6D0D6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CE352008-6065-43E2-A983-38B892D6D0D6-low.png"/></fig></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-413D000D-1733-4578-95D7-CBC36AC62908.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
