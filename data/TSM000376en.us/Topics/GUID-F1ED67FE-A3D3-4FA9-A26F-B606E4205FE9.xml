<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-F1ED67FE-A3D3-4FA9-A26F-B606E4205FE9" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-F1ED67FE-A3D3-4FA9-A26F-B606E4205FE9" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to remove the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Pin Post Cure lamp PBA (UV LED lamp 75/50)</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 01PBA02 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">POST_PIN_CURE_LAMP</compsignal></comp></title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-9F4E0FA2-566B-45E2-8168-8D2A06749ADB" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_38354AE763584586B66140798746F88A" class="- topic/ul "><li id="LI_D3B9C458DE334F6BACB25F1F384C9FC2" class="- topic/li "><p class="- topic/p ">Small screwdriver 
</p></li><li id="LI_5DF90D34870842BCB45AA985A971EFE4" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_96043D3239B548E7A98C800A8C8CC643" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Pliers 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-E232FC98-0D63-4AB3-B7FE-29534A391F85" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p><p class="- topic/p ">Never operate the UV lamp when you can see the light. The UV light will damage your eyes. Always close the top cover first. 
</p><p class="- topic/p ">Beware the UV lamps can be very hot. 
</p></note><note type="important" id="GUID-605A48F2-2C5C-46C6-BF5E-543FEF77B021" class="- topic/note "><p class="- topic/p ">Do NOT remove the hose connectors from the lamp. This is fixed in factory with a certain torque. You can damage the UV lamp. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-830ACC47-6FD2-45FE-824C-685E040AA94C" class="- topic/fig "><image href="GUID-82C93014-AC2F-4AA5-A19D-CBBFFCB0317E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-82C93014-AC2F-4AA5-A19D-CBBFFCB0317E-low.png"/></fig><fig id="GUID-31201C46-A616-4FD3-B0EA-217F70E29FB6" class="- topic/fig "><image href="GUID-8BC0D262-71FD-4C0C-AD22-E376DE135265-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8BC0D262-71FD-4C0C-AD22-E376DE135265-low.png"/></fig></section><section id="SECTION_427616E2BC854A41A6E33F1B8684D8A6" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_0BF2156EA25344A5ABD0556D855F2FC9" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Disconnect the connector of the sensor. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the cables from the cable guides. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-122876B5-21CB-4E1D-A65B-7B802A329E5C" class="- topic/fig "><image href="GUID-A2B0A70D-3739-4FD4-B72D-DC906C7B2C9F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A2B0A70D-3739-4FD4-B72D-DC906C7B2C9F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Disconnect the 2 hoses. 
</p></li><li class="- topic/li "><p class="- topic/p ">Disconnect the connector. 
</p></li></ol><note type="important" id="GUID-8C85E686-F0E4-4411-8593-BBDFE96A96CB" class="- topic/note "><p class="- topic/p ">Do NOT remove the hose connectors from the lamp. This is fixed in factory with a certain torque. You can damage the UV lamp. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8CC529C1-E595-494F-A714-F117DC7CE7A6" class="- topic/fig "><title class="- topic/title "/><image href="GUID-6758708A-1AA8-4841-B83F-FA2C22204EC5-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6758708A-1AA8-4841-B83F-FA2C22204EC5-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 4 screws (1 screw is in the hole below the connector). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CF755D81-420C-4302-9F3A-3D3D3C0B6246" class="- topic/fig "><title class="- topic/title "/><image href="GUID-15F128E9-3B43-4D5F-8956-510049864997-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-15F128E9-3B43-4D5F-8956-510049864997-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 2 screws of the Post and Pin curing lamp. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5206D9A1-B5CB-4484-A11F-27C037941874" class="- topic/fig "><image href="GUID-5B9A175D-67E4-4620-B5AC-DEAD90601C06-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5B9A175D-67E4-4620-B5AC-DEAD90601C06-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the Post and Pin curing lamp. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-BCECC41B-0746-4AA4-B207-D401BE25099E" class="- topic/fig "><image href="GUID-8BC0D262-71FD-4C0C-AD22-E376DE135265-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8BC0D262-71FD-4C0C-AD22-E376DE135265-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
