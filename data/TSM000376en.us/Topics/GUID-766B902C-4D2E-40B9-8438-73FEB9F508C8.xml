<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-766B902C-4D2E-40B9-8438-73FEB9F508C8" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-766B902C-4D2E-40B9-8438-73FEB9F508C8" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">470024 Too many failing nozzles during PAINt calibration</title><abstract class="- topic/abstract " id="GUID-06578CB7-F8B3-4407-B080-3ABA155A3DFB"><p class="- topic/p ">Too many nozzles failed on the mentioned printhead to be able to calculate the correct paint characteristics. 
</p><p class="- topic/p "><b class="+ topic/ph hi-d/b ">No actions are required unless the print quality is out of specification</b>.
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Diagnostics</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-DD4EEA7E-146D-47A9-BCED-E21AE30CC21C" class="- topic/section "><title class="- topic/title ">Collect</title><p class="- topic/p "> 
<u class="+ topic/ph hi-d/u ">Calibration step</u> 
</p><p class="- topic/p ">This error is generated during the calibration step: "PrintheadPAINtReference" which is part of the printhead calibration sequence.
</p><p class="- topic/p "> 
<u class="+ topic/ph hi-d/u ">Patterns in calibration print</u> 
</p><fig id="GUID-AFBEF28A-9152-475B-9386-75A54B1E6316" class="- topic/fig "><title class="- topic/title "/><image href="GUID-F9BD824E-AFBE-40F6-ADC8-0274F6072463-low.png" placement="inline" class="- topic/image " otherprops="GUID-F9BD824E-AFBE-40F6-ADC8-0274F6072463-low.png"/></fig></section><section id="GUID-8C43260B-3F77-4581-9B48-DADF2185433B" class="- topic/section "><title class="- topic/title ">Analyse/Repair</title><fig id="GUID-1F29E5D1-F100-4791-87C7-0624AABB5A95" class="- topic/fig "><image href="GUID-20659F87-5423-4F4A-B7EA-74DC37618212-low.png" placement="inline" class="- topic/image " otherprops="GUID-20659F87-5423-4F4A-B7EA-74DC37618212-svg.svg"/></fig><table id="GUID-C70352B6-28FA-42C8-8B7D-D0AC59F75022" class="- topic/table "><tgroup cols="4" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="1.00*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="1.36*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="5.24*" class="- topic/colspec "/><colspec colname="col4" colnum="4" colwidth="6.29*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Type
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">ToDo
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Repeat the calibration procedure
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Perform an automatic maintenance
</p></entry><entry colname="col4" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Purse printhead
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p "> Execute SDS 07-6-002 using "Filling pulse" 3 times
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">4
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Check air hoses and manifolds for possible blockades which causes failing PH-vacuum
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p "> Presence of 250012 "Unexpected ink drop" might indicate on blockade.
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">5
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Replace printhead
</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p "><xref href="GUID-915F84BE-7881-400A-A351-FF4DB79FE9B0" class="- topic/xref "/>
</p></entry></row></tbody></tgroup></table></section><section id="GUID-4F8EE279-7E7E-4BBF-8D2A-19250471F03A" class="- topic/section "><title class="- topic/title "> 
<b class="+ topic/ph hi-d/b "> 
<b class="+ topic/ph hi-d/b "> Background info</b> 
</b> </title><p class="- topic/p ">.
</p><p class="- topic/p ">To be able to determine the correct PAINT reference values a minimum number of nozzles needs to be operational. 
</p><p class="- topic/p ">In case this calibration fails the data from a previous successful calibration is used or even the production data from this printhead.
</p><p class="- topic/p ">
</p><p class="- topic/p ">In most cases this calibration is executed when a new printhead is placed into the printer. 
</p><p class="- topic/p ">In case the filling of this new printhead was unsuccessful air might still be present in the printhead. 
</p><p class="- topic/p ">The main goal of the mentioned procedure is to get possible air out of the printhead.
</p></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-F2864082-F34C-4657-B37E-EA7C5343FE90.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Diagnostics</linktext></link></linkpool></related-links>
