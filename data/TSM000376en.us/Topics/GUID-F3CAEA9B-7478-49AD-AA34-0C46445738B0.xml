<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-F3CAEA9B-7478-49AD-AA34-0C46445738B0" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-F3CAEA9B-7478-49AD-AA34-0C46445738B0" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to remove the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Media loading drawer 1 pinch 1 encoder</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 12B5 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">MLO_DRA1_PINCH1_ENC</compsignal></comp></title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_34F2C03C97F249649B92631C09DBB41B" class="- topic/li "><p class="- topic/p ">Open the media loading drawer. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_69BB0AEB395F4E8AB96FD94A4C0C8696" class="- topic/ul "><li id="LI_06B1AE50C8584502AA32D102711C1229" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li id="LI_561D1BF957EA49F8BB49139266A92893" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li id="LI_B784B59E966743309622F0F98A079F05" class="- topic/li "><p class="- topic/p ">Open ended spanner 13. 
</p></li></ul></section><section id="GUID-F56DEEE4-F746-4C5E-B808-E951147DF22A" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Caution:</ph></title><p class="- topic/p ">After removal the old encoder is broken. A new encoder must be installed. 
</p></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-1C6A5506-8461-4BFD-8B7C-FB47C7EF289A" class="- topic/fig "><desc class="- topic/desc "><p class="- topic/p ">12B5 is the encoder connected to the wheel. 
</p><p class="- topic/p "> 12B5 is part of wheel encoder-cpl, z-1206-0220 
</p></desc><image href="GUID-5321A730-C647-4E8A-8A40-F6064573C6FD-low.png" id="IMAGE_4DC6EE8C1B14407E8C7C4A980645B932" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5321A730-C647-4E8A-8A40-F6064573C6FD-low.png"/></fig><fig id="FIG_6BEA0AA2C5344ADC8CBE547203C5ED23" class="- topic/fig "><desc class="- topic/desc "><p class="- topic/p ">The two parts of the encoder 
</p></desc><image href="GUID-B54E876D-E8F2-4C4D-9042-4B65BAAAA4F2-low.png" id="IMAGE_30E05D8D04554CDDAFFF24513DF04220" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B54E876D-E8F2-4C4D-9042-4B65BAAAA4F2-low.png"/></fig></section><section id="SECTION_9A4E31FC8A1D474082EB98039B353FF0" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_BC6D1128E6D045B0884B679CB3343E94" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the indicated screw and nut of the mounting of the cover over the first pinch. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-20C1DA02-3D9B-4E86-9336-DD581A0ED8BC" class="- topic/fig "><image href="GUID-7EAB127A-FF8B-4B42-917A-7DFC9F185DD7-low.png" placement="inline" class="- topic/image " otherprops="GUID-7EAB127A-FF8B-4B42-917A-7DFC9F185DD7-low.png"/></fig><fig id="GUID-B9CB9BA4-A114-472B-A903-B7769A8B19F5" class="- topic/fig "><image href="GUID-70BBB8B3-F504-4DA9-B07C-B8056ADB0F05-low.png" placement="inline" class="- topic/image " otherprops="GUID-70BBB8B3-F504-4DA9-B07C-B8056ADB0F05-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Release the green lever. 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the pinch. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D743890E-C4A7-4728-965E-1A090CB6FC6E" class="- topic/fig "><image href="GUID-BAE24F9B-847D-428E-8423-494E288B003D-low.png" placement="inline" class="- topic/image " otherprops="GUID-BAE24F9B-847D-428E-8423-494E288B003D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws of the cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A457A127-8EB0-480C-B03E-9297B46D6DE0" class="- topic/fig "><image href="GUID-8FF1ACE1-14CA-41A6-9C9C-302663E59707-low.png" placement="inline" class="- topic/image " otherprops="GUID-8FF1ACE1-14CA-41A6-9C9C-302663E59707-low.png"/></fig><fig id="GUID-9671626E-9BB9-4CF1-B17D-8A1160463F1F" class="- topic/fig "><image href="GUID-9971575B-3401-4F89-9C23-0FEF897EBE06-low.png" placement="inline" class="- topic/image " otherprops="GUID-9971575B-3401-4F89-9C23-0FEF897EBE06-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cover to the top. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-13594457-E3D3-4177-8B77-980964925A12" class="- topic/fig "><image href="GUID-AC7D8BB0-183D-4375-97FA-A9D83F19333D-low.png" placement="inline" class="- topic/image " otherprops="GUID-AC7D8BB0-183D-4375-97FA-A9D83F19333D-low.png"/></fig><fig id="FIG_2D3AE3328DC84F9AA9845504C09080F1" class="- topic/fig "><image href="GUID-9DA12108-7938-4AE9-A280-9BB7255AD922-low.png" id="IMAGE_F41942FC40674CDA88BFF1EB368BD80B" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9DA12108-7938-4AE9-A280-9BB7255AD922-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connector of the encoder. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4684B6D7-2635-496F-802E-73AD810C2EA6" class="- topic/fig "><image href="GUID-31BF1559-D18E-4614-928F-88E6B8091476-low.png" placement="inline" class="- topic/image " otherprops="GUID-31BF1559-D18E-4614-928F-88E6B8091476-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws from the bracket of the encoder. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-52726F98-4154-418F-B6DD-425946B62765" class="- topic/fig "><image href="GUID-198A9D64-B676-429E-81E9-B3708A7DB6A0-low.png" placement="inline" class="- topic/image " otherprops="GUID-198A9D64-B676-429E-81E9-B3708A7DB6A0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the encoder assembly. 
</p><note id="GUID-69EF1040-74A6-4B9E-B767-B39C1CF95B8B" class="- topic/note "><p class="- topic/p ">Make sure that the mounted spring does not fall. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_8F0CF7EA3BA3435D85F06EF239F49220" class="- topic/fig "><image href="GUID-23D399B5-1B00-45A1-9218-4FD3EF70D32D-low.png" id="IMAGE_7A65E7BF88194AA58CAC1ED71CDD7351" keyref="" placement="inline" class="- topic/image " otherprops="GUID-23D399B5-1B00-45A1-9218-4FD3EF70D32D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">If you want to remove the encoder : 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> The encoder is mounted using a bayonet locking mechanism. 
</p></li><li class="- topic/li "><p class="- topic/p ">Rotate the top part of the encoder counter clock wise. 
</p><p class="- topic/p ">Approximately 3 mm. 
</p></li><li class="- topic/li "><p class="- topic/p ">Now the encoder is loose. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Dispose of the encoder it is broken now 
</p></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">If removed install the top part of the encoder since the bottom part stays on the axis. 
</p><p class="- topic/p ">Make sure you keep the sensor straight when installing. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">This must be a NEW encoder. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Further install in reverse order. 
</p><note id="GUID-8CF08383-BB92-4D27-A442-477766393F3A" class="- topic/note "><p class="- topic/p ">Make sure that the cable from 12B11 is not caught between the wheel and the frame. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B96AB9C-8847-4643-A8CB-09918FE19AAB.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>