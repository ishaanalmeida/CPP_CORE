<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-7470CF2E-4C0C-4F59-881E-C83B034005E7" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-7470CF2E-4C0C-4F59-881E-C83B034005E7" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">07 How to remove the swivel assy.</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="SECTION_B3CC895230E4473B9737BE7426C6F5A1" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_E753369EFDC5426BBE20201BB8995B3D" class="- topic/ul "><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><prereq id="GUID-0033BF2B-331F-4174-A99A-44B7B932EB52" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the top cover 
</p><note type="important" id="GUID-7215619B-4D8E-42B1-B219-10C1EF6B5FB5" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-0A275662-3FC1-4E96-AED1-AD9A648FAB5A" class="- topic/section "><title class="- topic/title "/></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-C6DA5DD2-ED64-412D-8C52-D47B13DBA831" class="- topic/fig "><title class="- topic/title "/><image href="GUID-13726379-95CC-40F9-AC15-00D22CEE5704-low.png" placement="inline" class="- topic/image " otherprops="GUID-13726379-95CC-40F9-AC15-00D22CEE5704-low.png"/></fig></section><section id="SECTION_10706F4338B7408BABADE578D99770E9" class="- topic/section "><title class="- topic/title ">How to remove the swivel assy.</title><table pgwide="1" id="TABLE_6937E5A1DB7E4095B28EBF6850698301" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the main cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A874BE10-ACB6-4F8F-832B-CDEF5F44B64A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-E6CEE49C-91CB-401F-BA1B-37C9759210C4-low.png" placement="inline" class="- topic/image " otherprops="GUID-E6CEE49C-91CB-401F-BA1B-37C9759210C4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Go to Cold SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-588B0959-7751-4A5E-AF68-34333A6775DD" class="- topic/fig "><title class="- topic/title "/><image href="GUID-703DD996-720E-4F91-8355-91E449BA7EE8-low.png" placement="inline" class="- topic/image " otherprops="GUID-703DD996-720E-4F91-8355-91E449BA7EE8-low.png"/></fig><p class="- topic/p ">Move the carriage by hand to the middle above the platen. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws as mentioned in the picture and remove the black cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-AA5E5A61-EDD2-416E-A9FD-DC65C5246519" class="- topic/fig "><title class="- topic/title "/><image href="GUID-0FF4CDC1-4C7C-4D9C-A656-5350E6E62AF8-low.png" placement="inline" class="- topic/image " otherprops="GUID-0FF4CDC1-4C7C-4D9C-A656-5350E6E62AF8-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Go to the media loading side of the engine and open the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2D13FCA4-E893-44BB-865C-7B2279B6D502" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3B92B619-BFB9-4F90-8E1F-1B2CA110646C-low.png" placement="inline" class="- topic/image " otherprops="GUID-3B92B619-BFB9-4F90-8E1F-1B2CA110646C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Release the locking of the maintenance cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B3E2133E-252E-4B7D-85C0-22BDACAFF4A5" class="- topic/fig "><title class="- topic/title "/><image href="GUID-67B2EA49-834C-453D-ACB5-6E583D5DE517-low.png" placement="inline" class="- topic/image " otherprops="GUID-67B2EA49-834C-453D-ACB5-6E583D5DE517-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide out the maintenance drawer to get access to the cover screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2474F639-C78E-4917-B437-D498E7232518" class="- topic/fig "><title class="- topic/title "/><image href="GUID-93D0C179-CB01-4925-9282-8B1B095853DB-low.png" placement="inline" class="- topic/image " otherprops="GUID-93D0C179-CB01-4925-9282-8B1B095853DB-low.png"/></fig><fig id="GUID-F12314EC-F877-4488-80B1-A7439AF4EA40" class="- topic/fig "><title class="- topic/title "/><image href="GUID-E3FB9E03-9EE4-4D61-BC40-66B4B57B5134-low.png" placement="inline" class="- topic/image " otherprops="GUID-E3FB9E03-9EE4-4D61-BC40-66B4B57B5134-low.png"/></fig><fig id="GUID-257FE69D-BC58-4D6C-AF46-CAEFC77DF6E4" class="- topic/fig "><title class="- topic/title "/><image href="GUID-93981284-672E-48B1-83DF-DBC9EAAC8190-low.png" placement="inline" class="- topic/image " otherprops="GUID-93981284-672E-48B1-83DF-DBC9EAAC8190-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-63F9A82E-54B6-4EB1-B6DD-BABC46F74779" class="- topic/fig "><title class="- topic/title "/><image href="GUID-76B2252C-E785-4523-BAF9-906F34263C26-low.png" placement="inline" class="- topic/image " otherprops="GUID-76B2252C-E785-4523-BAF9-906F34263C26-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6B03BB18-D551-431E-AD71-EB8954BE5278" class="- topic/fig "><title class="- topic/title "/><image href="GUID-9966AFF0-3B8E-422A-A087-ADF7AC9BE6A8-low.png" placement="inline" class="- topic/image " otherprops="GUID-9966AFF0-3B8E-422A-A087-ADF7AC9BE6A8-low.png"/></fig><fig id="GUID-F80F060D-25C0-4B32-9C37-64E790968EA1" class="- topic/fig "><title class="- topic/title "/><image href="GUID-032ECA63-6257-4F8A-8C5C-96DD71644174-low.png" placement="inline" class="- topic/image " otherprops="GUID-032ECA63-6257-4F8A-8C5C-96DD71644174-low.png"/></fig><fig id="GUID-0C52F988-C82C-424E-BE62-984F0D14BF89" class="- topic/fig "><title class="- topic/title "/><image href="GUID-91A931D1-F125-4FEB-AC40-8385403142D9-low.png" placement="inline" class="- topic/image " otherprops="GUID-91A931D1-F125-4FEB-AC40-8385403142D9-low.png"/></fig><fig id="GUID-02B6192B-15A3-4993-9451-4F15BFC45C7E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-321E2889-F9F0-423F-9919-580464841D61-low.png" placement="inline" class="- topic/image " otherprops="GUID-321E2889-F9F0-423F-9919-580464841D61-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the cover besides the engine. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the maintenance tray and clean the waste bin. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F7D95FF6-E8A7-48F7-B0C2-98470CDEB3CD" class="- topic/fig "><title class="- topic/title "/><image href="GUID-25FC9E2F-FAED-4230-9A91-3126C4953329-low.png" placement="inline" class="- topic/image " otherprops="GUID-25FC9E2F-FAED-4230-9A91-3126C4953329-low.png"/></fig><fig id="GUID-B95ED6F3-8169-4A50-8E33-FF989959D3F1" class="- topic/fig "><title class="- topic/title "/><image href="GUID-1E243E8F-8391-4E13-9B15-C970872F86A0-low.png" placement="inline" class="- topic/image " otherprops="GUID-1E243E8F-8391-4E13-9B15-C970872F86A0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cassette wipe. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-604D66B7-A17F-4E70-93E0-9CDFC37A114D" class="- topic/fig "><title class="- topic/title "/><image href="GUID-34AC50DD-8480-4C84-A5FF-0C68CBD52DBD-low.png" placement="inline" class="- topic/image " otherprops="GUID-34AC50DD-8480-4C84-A5FF-0C68CBD52DBD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Before re-moving the tissue wipe unit from the engine the funnel needs to be removed. 
</p><p class="- topic/p ">Remove the screw of the purge tray. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1C8AFA43-5BF3-42E4-91CA-36CC156657A2" class="- topic/fig "><title class="- topic/title "/><image href="GUID-DDAAA582-F6B5-4C16-89A5-205B0CCF1CB4-low.png" placement="inline" class="- topic/image " otherprops="GUID-DDAAA582-F6B5-4C16-89A5-205B0CCF1CB4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift the funnel carefully at the same time disconnecting the connector of the purge tray. 
</p><p class="- topic/p ">Remove the purge tray gently without spoiling waste ink. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-301C9934-CC44-4112-8317-9CB848D2AFFE" class="- topic/fig "><title class="- topic/title "/><image href="GUID-6A691C74-3365-4608-93F9-7FE884AE11A6-low.png" placement="inline" class="- topic/image " otherprops="GUID-6A691C74-3365-4608-93F9-7FE884AE11A6-low.png"/></fig><fig id="GUID-94CD9A2D-5EBA-4266-9955-3279AA946322" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3AC52B85-BDD1-43B4-845F-AB11FF12E36B-low.png" placement="inline" class="- topic/image " otherprops="GUID-3AC52B85-BDD1-43B4-845F-AB11FF12E36B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the 3 connectors at the back end of the tissue wipe unit 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4BF1CB40-A5CD-4542-A91C-ECA071DFC0CA" class="- topic/fig "><title class="- topic/title "/><image href="GUID-5CA2E0EE-10D0-48F6-BD76-7D7193CB3900-low.png" placement="inline" class="- topic/image " otherprops="GUID-5CA2E0EE-10D0-48F6-BD76-7D7193CB3900-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen and remove the 2 screws at the front of the tissue wipe unit 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-80606117-E6CA-4CF1-9BAD-A6B105A513FB" class="- topic/fig "><title class="- topic/title "/><image href="GUID-C405C549-2AAC-4C20-B6AF-E8774506A929-low.png" placement="inline" class="- topic/image " otherprops="GUID-C405C549-2AAC-4C20-B6AF-E8774506A929-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Gently slide out the tissue wipe unit 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">pic 5042 &amp; 5048 
</p><fig id="GUID-A65EF197-4C5B-4030-B44F-7B0906C4CF85" class="- topic/fig "><title class="- topic/title "/><image href="GUID-55ACFCFB-3E16-4187-9133-2A789030DAF8-low.png" placement="inline" class="- topic/image " otherprops="GUID-55ACFCFB-3E16-4187-9133-2A789030DAF8-low.png"/></fig><fig id="GUID-08B6C367-A51E-49C8-96A7-CE4D9E65AF20" class="- topic/fig "><title class="- topic/title "/><image href="GUID-8BFF92B5-3B06-4936-A914-659D1484351B-low.png" placement="inline" class="- topic/image " otherprops="GUID-8BFF92B5-3B06-4936-A914-659D1484351B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the tissue wipe upside down on a table. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4214773E-F787-49F3-94E4-E28AB756F984" class="- topic/fig "><title class="- topic/title "/><image href="GUID-99AF8EA4-753D-45F7-9C0B-C94A3EEAB1FF-low.png" placement="inline" class="- topic/image " otherprops="GUID-99AF8EA4-753D-45F7-9C0B-C94A3EEAB1FF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 4 clamps and disconnect the 2 connectors. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E1E352D3-A622-48B1-A81F-23C6290559D4" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3C90804C-1ED6-44A8-BC3A-0A3769A0E28F-low.png" placement="inline" class="- topic/image " otherprops="GUID-3C90804C-1ED6-44A8-BC3A-0A3769A0E28F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 4 screws of the tissue wipe unit sub frame assy. 
</p><p class="- topic/p ">(2 Screws at the front as shown and 2 screws at te back.) 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">pic 5103 
</p><fig id="GUID-970CC53D-D415-4086-83B2-B92E6F36E672" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AF00A5AA-47CE-46B6-870C-42C788C76C9E-low.png" placement="inline" class="- topic/image " otherprops="GUID-AF00A5AA-47CE-46B6-870C-42C788C76C9E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">21 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">When all connectors and cables have loosened remove the sub frame form the tissue wipe assy. 
