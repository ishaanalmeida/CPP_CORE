<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-6D15B772-91DC-411F-95E8-9CB75187818F" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-6D15B772-91DC-411F-95E8-9CB75187818F" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">How to install TeamViewer 12 and Activate the License</title><abstract class="- topic/abstract " id="GUID-3971E95F-7900-4495-B02B-0182D686A815"><p class="- topic/p ">This document describes how to install and activate TeamViewer 12. 
</p><note class="- topic/note " id="GUID-06095CB1-591A-4C56-B0AC-9CF49F8FB5BC"><p class="- topic/p ">Do not use VPN 
</p></note></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-10479CF3-8B8C-46D4-8704-CA4342C0AAA3" class="- topic/section "><title class="- topic/title ">Download procedure</title><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Click the link below to go to the download site of TeamViewer. 
</p><p class="- topic/p "><xref href="https://www.teamviewer.com/en/download/windows/" format="html" scope="external" class="- topic/xref "><?ditaot gentext?>https://www.teamviewer.com/en/download/windows/</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Scroll down to “<b class="+ topic/ph hi-d/b ">See previous versions</b>”. 
</p><fig id="GUID-3407CB02-A2CC-4D29-8D65-93BBFFFF75CE" class="- topic/fig "><title class="- topic/title "/><image href="GUID-17590FAE-4504-43B2-8B47-98DE12BAAD8B-low.png" placement="inline" class="- topic/image " otherprops="GUID-17590FAE-4504-43B2-8B47-98DE12BAAD8B-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on “<b class="+ topic/ph hi-d/b ">See previous versions</b>” 
</p><fig id="GUID-8548261A-7E07-402E-B06F-9F697EC8B21A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-CF45BCCE-F1F7-4332-9195-C12FBEE332EA-low.png" placement="inline" class="- topic/image " otherprops="GUID-CF45BCCE-F1F7-4332-9195-C12FBEE332EA-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Scroll down to “<b class="+ topic/ph hi-d/b ">TeamViewer 12 Version</b>” 
</p><fig id="GUID-3547FEA2-30D1-4FAC-A489-DC2EC6359A26" class="- topic/fig "><title class="- topic/title "/><image href="GUID-EA194EA2-4207-4E6C-B4FF-C220DADDD2CC-low.png" placement="inline" class="- topic/image " otherprops="GUID-EA194EA2-4207-4E6C-B4FF-C220DADDD2CC-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on “<b class="+ topic/ph hi-d/b ">TeamViewer 12 Version</b>” 
</p><fig id="GUID-FDCBD7AE-A69A-4266-BD05-A358A85A3F1F" class="- topic/fig "><title class="- topic/title "/><image href="GUID-575BE283-119D-4A74-B186-CF8BADBE85E1-low.png" placement="inline" class="- topic/image " otherprops="GUID-575BE283-119D-4A74-B186-CF8BADBE85E1-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on “<b class="+ topic/ph hi-d/b ">TeamViewer</b>” for “<b class="+ topic/ph hi-d/b ">Windows (v12.0.259024)</b>” 
</p><fig id="GUID-2F6C6D58-6024-41B0-94F4-A00396540895" class="- topic/fig "><title class="- topic/title "/><image href="GUID-8EB601A6-841A-4D67-8259-BF5595BC38CA-low.png" placement="inline" class="- topic/image " otherprops="GUID-8EB601A6-841A-4D67-8259-BF5595BC38CA-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">TeamViewer will download to your laptop. 
</p><fig id="GUID-FA989CE1-0498-4B37-B0CD-09CD433973EC" class="- topic/fig "><title class="- topic/title "/><image href="GUID-9B94C85F-3AFD-441E-926E-64230D7F8AA7-low.png" placement="inline" class="- topic/image " otherprops="GUID-9B94C85F-3AFD-441E-926E-64230D7F8AA7-low.png"/></fig></li></ol></section><section id="GUID-C6F5D82A-F632-438B-8744-791BB674167A" class="- topic/section "><title class="- topic/title ">installation procedure</title><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Go to your “<b class="+ topic/ph hi-d/b ">Windows File Explorer</b>” and click to open 
</p><fig id="GUID-F3DD521E-B129-42C1-A7C1-E34432931BE2" class="- topic/fig "><title class="- topic/title "/><image href="GUID-422F781B-1082-4B70-8000-2BAC138C9E01-low.png" placement="inline" class="- topic/image " otherprops="GUID-422F781B-1082-4B70-8000-2BAC138C9E01-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on your “<b class="+ topic/ph hi-d/b ">Downloads</b>” folder and double click on “<b class="+ topic/ph hi-d/b ">TeamViewer Setup</b>” 
</p><fig id="GUID-EACB061A-1964-4E57-90E6-CCADF8DF2D79" class="- topic/fig "><title class="- topic/title "/><image href="GUID-E9FB913E-9031-4A4C-B67B-3CCAFDA041CE-low.png" placement="inline" class="- topic/image " otherprops="GUID-E9FB913E-9031-4A4C-B67B-3CCAFDA041CE-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on “<b class="+ topic/ph hi-d/b ">Run</b>” 
</p><fig id="GUID-E5BC5E38-FF19-4E54-9F86-B1FA66CEE33B" class="- topic/fig "><title class="- topic/title "/><image href="GUID-6E4FC959-EC9D-44F4-BAB4-5E97E51F6D17-low.png" placement="inline" class="- topic/image " otherprops="GUID-6E4FC959-EC9D-44F4-BAB4-5E97E51F6D17-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Select “<b class="+ topic/ph hi-d/b ">Basic Installation</b>” is chosen and click “<b class="+ topic/ph hi-d/b ">Company / Commercial use</b>”. 
</p><p class="- topic/p ">Then click on “<b class="+ topic/ph hi-d/b ">Accept – finish</b>” 
</p><fig id="GUID-C089DEA2-2A5A-4F70-AFD3-0FCD9583F34B" class="- topic/fig "><title class="- topic/title "/><image href="GUID-6A88383C-2954-4E4F-86A6-6E6D09CE4F7B-low.png" placement="inline" class="- topic/image " otherprops="GUID-6A88383C-2954-4E4F-86A6-6E6D09CE4F7B-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">If you receive a message asking you to “<b class="+ topic/ph hi-d/b ">Allow this App to make changes to your device</b>”…….. 
</p><p class="- topic/p ">Click “<b class="+ topic/ph hi-d/b ">Yes</b>”. 
</p><fig id="GUID-93F5D05B-AE65-4448-A6F6-6046697FDC6C" class="- topic/fig "><title class="- topic/title "/><image href="GUID-C1D08887-4CDC-49AF-9E84-4765986B0C8B-low.png" placement="inline" class="- topic/image " otherprops="GUID-C1D08887-4CDC-49AF-9E84-4765986B0C8B-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">TeamViewer will now begin installing…. 
</p><fig id="GUID-0E84189B-A269-4B29-B2E4-879FB9E06E3D" class="- topic/fig "><title class="- topic/title "/><image href="GUID-BB3E335F-5FA8-416F-80C7-D9330FFD17E3-low.png" placement="inline" class="- topic/image " otherprops="GUID-BB3E335F-5FA8-416F-80C7-D9330FFD17E3-low.png"/></fig></li></ol></section><section id="GUID-A98361FA-8F44-4089-B67B-577D70A302A2" class="- topic/section "><title class="- topic/title ">Install the license</title><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">To install the “<b class="+ topic/ph hi-d/b ">TeamViewer</b>” license in TeamViewer: 
</p><p class="- topic/p ">Click on “<b class="+ topic/ph hi-d/b ">Extras</b>”. 
</p><fig id="GUID-6CFF5A49-F9F8-4335-9D5D-9344E414169B" class="- topic/fig "><title class="- topic/title "/><image href="GUID-D7AA0376-140A-4BBD-8301-2D47FCEEBE1A-low.png" placement="inline" class="- topic/image " otherprops="GUID-D7AA0376-140A-4BBD-8301-2D47FCEEBE1A-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">click on “<b class="+ topic/ph hi-d/b ">Activate License</b>” 
</p><fig id="GUID-08BD291A-32D9-44F6-90F8-BAB4C81120CA" class="- topic/fig "><title class="- topic/title "/><image href="GUID-580024FC-E612-4BD4-904B-A5848050276E-low.png" placement="inline" class="- topic/image " otherprops="GUID-580024FC-E612-4BD4-904B-A5848050276E-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Type your local license number for your service organization into the License code 
</p><p class="- topic/p ">Click on the “<b class="+ topic/ph hi-d/b ">Activate license</b>” button. 
</p><fig id="GUID-CAA51D56-CB6B-46F2-9E2C-B66A9B7CBB64" class="- topic/fig "><title class="- topic/title "/><image href="GUID-F320DA04-8C52-4ADF-87B5-278BC0DA0777-low.png" placement="inline" class="- topic/image " otherprops="GUID-F320DA04-8C52-4ADF-87B5-278BC0DA0777-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">TeamViewer may ask you to create an account. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">If you already have an account enter your Email address and password. 
</p><fig id="GUID-64EAEB57-B895-44CA-8D10-BCF4770EE68A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-4B455F0B-0C27-4B32-BD08-4672B10548F3-low.png" placement="inline" class="- topic/image " otherprops="GUID-4B455F0B-0C27-4B32-BD08-4672B10548F3-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">If not create an account in the dialog window. 
</p><fig id="GUID-ADD324B6-63EE-4583-A036-8F582FF215C8" class="- topic/fig "><title class="- topic/title "/><image href="GUID-11E23FF1-D388-4650-B640-F92C3B9559CB-low.png" placement="inline" class="- topic/image " otherprops="GUID-11E23FF1-D388-4650-B640-F92C3B9559CB-low.png"/></fig></li></ul></li><li class="- topic/li "><p class="- topic/p ">The completed installation screen shows. 
</p><fig id="GUID-FD782C51-7646-4E68-B3FD-6C28C9451094" class="- topic/fig "><title class="- topic/title "/><image href="GUID-04276B27-2DBF-4D48-A76E-26B0DADB271F-low.png" placement="inline" class="- topic/image " otherprops="GUID-04276B27-2DBF-4D48-A76E-26B0DADB271F-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">If you created a new account you will receive an activation Email with an activation link. 
</p></li></ol></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-DFD95E44-6FE2-4690-855D-446A64ABF90C.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>ORS: On Remote Service</linktext></link></linkpool></related-links>
</task>