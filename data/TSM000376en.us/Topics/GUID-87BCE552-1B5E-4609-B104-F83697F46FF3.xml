<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-87BCE552-1B5E-4609-B104-F83697F46FF3" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-87BCE552-1B5E-4609-B104-F83697F46FF3" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">02 How to install and grease the pump tubes</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes the installation of pump tubes. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_CEA4CD427612471CA3540AD5430B21C2" class="- topic/ul "><li id="LI_B007BBFF5E5743C89A24651737F64808" class="- topic/li "><p class="- topic/p ">Cloth 
</p></li><li class="- topic/li "><p class="- topic/p ">A pair of scissors 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex 
</b> 93-260 gloves 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-2D7D94A0-B26C-4C0B-B6A3-20C8621663A2" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-E2420A42-20F8-4F39-8664-5B87A4EE53FD" class="- topic/fig "><title class="- topic/title "/><image href="GUID-8B5412AD-6BAD-4380-8F12-3A0A767F3DA2-low.png" placement="inline" class="- topic/image " otherprops="GUID-8B5412AD-6BAD-4380-8F12-3A0A767F3DA2-low.png"/></fig></section><section id="SECTION_83EFA574E57B4B64A0DD595529E957E2" class="- topic/section "><title class="- topic/title ">Grease and install the pump tubes</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the plastic cap of the ink pump: 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Pull, with some pressure, at the bottom of the cap. 
</p><p class="- topic/p ">The cap can be removed. 
</p><note id="GUID-194E98E5-6E02-4371-9D3A-48EA7E069DF5" class="- topic/note "><p class="- topic/p ">Keep the rollers and rotor assembly in place. 
</p></note></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A4CEDBA0-579D-4C2D-9159-65C3C35F5FEB" class="- topic/fig "><image href="GUID-BF35C432-EEBB-45ED-ABBB-E31F30382483-low.jpg" placement="inline" class="- topic/image " otherprops="GUID-BF35C432-EEBB-45ED-ABBB-E31F30382483-low.jpg"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Take the package with the small plastic bags of grease (in the box with the covers). 
</p><p class="- topic/p ">Cut off the tip of the small plastic bag with grease. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B8FD40A0-9BBC-4086-892C-D13146222E78" class="- topic/fig "><image href="GUID-CA1DEEF0-D1DE-49D3-9395-F97DD25D5A3B-low.png" placement="inline" class="- topic/image " otherprops="GUID-CA1DEEF0-D1DE-49D3-9395-F97DD25D5A3B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Apply grease in the marked area [B] of the pump tube [A]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E0F03605-41EF-435B-BAD9-98A9C099690F" class="- topic/fig "><image href="GUID-7E5DE175-1F71-448A-8397-D91E2B5EC0B5-low.jpg" placement="inline" class="- topic/image " otherprops="GUID-7E5DE175-1F71-448A-8397-D91E2B5EC0B5-low.jpg"/></fig><fig id="GUID-5EAE9D9E-CC38-48D3-BAA4-6E7D79AA9C0A" class="- topic/fig "><image href="GUID-1924A898-F3E7-4C2B-B932-3B173F206931-low.png" placement="inline" class="- topic/image " otherprops="GUID-1924A898-F3E7-4C2B-B932-3B173F206931-low.png"/></fig><fig id="GUID-BB2C1452-8BDF-409B-905E-731118AD06B2" class="- topic/fig "><image href="GUID-F6037FD4-8428-4DB5-BE31-7B3BA0950C58-low.png" placement="inline" class="- topic/image " otherprops="GUID-F6037FD4-8428-4DB5-BE31-7B3BA0950C58-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Grease also the axis [C] of the pump. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0075BCE9-042A-44C0-BAD8-340CE60444AD" class="- topic/fig "><image href="GUID-57376A45-2A46-42D4-912D-11DE309991F2-low.jpg" placement="inline" class="- topic/image " otherprops="GUID-57376A45-2A46-42D4-912D-11DE309991F2-low.jpg"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Pull out a little bit the Rotor Assembly of the pump. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Position he Rotor Assembly so that the a roller is in top position. 
</p><p class="- topic/p ">Install pump tube [A] between the Rotor Assembly and the curved inner surface [B] of the pump base. 
</p><note id="GUID-AE0E6E15-DD3C-4FDF-A300-5C9E1A80DB9E" class="- topic/note "><p class="- topic/p ">Guide the pump tube over the rotor and exit at the bottom. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C11B07DB-1E01-47F6-8620-95D2211EF2ED" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B2828672-8735-4B44-A9A0-B123105D8C0A-low.png" placement="inline" class="- topic/image " otherprops="GUID-B2828672-8735-4B44-A9A0-B123105D8C0A-low.png"/></fig><fig id="GUID-42D64134-12D0-4159-B636-4649322758C4" class="- topic/fig "><image href="GUID-20284AA4-CDAA-43C5-845C-50B49DD76B70-low.png" placement="inline" class="- topic/image " otherprops="GUID-20284AA4-CDAA-43C5-845C-50B49DD76B70-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the cap of the ink pump. 
</p><note id="GUID-BCC0E0E7-807C-496D-B624-5BF6511028BD" class="- topic/note "><p class="- topic/p ">Clean up the grease from outside the caps and tubes.
</p><p class="- topic/p ">Check all LUER_LOCKS if they are properly tightened.
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-507642F3-7523-4D2D-A116-BEADAF421ADA" class="- topic/fig "><image href="GUID-F1D38E22-A207-4ED7-846A-A131912D1457-low.png" placement="inline" class="- topic/image " otherprops="GUID-F1D38E22-A207-4ED7-846A-A131912D1457-low.png"/></fig><fig id="GUID-B2922812-DDBD-4955-8D33-C0DF464D48D1" class="- topic/fig "><image href="GUID-23604701-2671-449E-A800-78B1DAB9D283-low.jpg" placement="inline" class="- topic/image " otherprops="GUID-23604701-2671-449E-A800-78B1DAB9D283-low.jpg"/></fig><fig id="GUID-75A5D643-A75C-44E2-8220-E9B77BA4D4EE" class="- topic/fig "><title class="- topic/title "/><image href="GUID-8B5412AD-6BAD-4380-8F12-3A0A767F3DA2-low.png" placement="inline" class="- topic/image " otherprops="GUID-8B5412AD-6BAD-4380-8F12-3A0A767F3DA2-low.png"/></fig></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-B389A763-3BDF-47D8-8530-E2CB730B7104.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
