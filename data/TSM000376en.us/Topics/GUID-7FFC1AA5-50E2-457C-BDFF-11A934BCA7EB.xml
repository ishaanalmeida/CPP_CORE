<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-7FFC1AA5-50E2-457C-BDFF-11A934BCA7EB" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-7FFC1AA5-50E2-457C-BDFF-11A934BCA7EB" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Wrinkles</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Diagnostics</category><category class="- topic/category ">Diagnostics</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-50B00AD6-0A38-41AB-B3CF-DCE2951AFA8A" class="- topic/section "><title class="- topic/title "/><table id="GUID-53E5F599-B620-44AD-919D-C7253ABD770C" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="50*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Schematic overview 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Real example 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><fig id="GUID-BA74BBA3-EE47-47C6-BCBC-478122A9D12F" class="- topic/fig "><image href="GUID-EC41E7D8-66F4-4AF9-867A-1D9DAAD620D3-low.png" placement="inline" class="- topic/image " otherprops="GUID-EC41E7D8-66F4-4AF9-867A-1D9DAAD620D3-low.png"/></fig></entry><entry colname="col2" valign="top" class="- topic/entry "><fig id="GUID-686F51FA-A642-460D-91BC-24B0DDAF9BE0" class="- topic/fig "><image href="GUID-AA6AE79F-7C33-4FF0-91BF-1AAC8A867EC5-low.png" placement="inline" class="- topic/image " otherprops="GUID-AA6AE79F-7C33-4FF0-91BF-1AAC8A867EC5-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-EC1EAE23-40EC-4B10-A2C9-83873F76DC70" class="- topic/section "><title class="- topic/title ">Collect</title><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Symptoms</b> 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> Not visible is matt prints
</p></li><li class="- topic/li "><p class="- topic/p "> Matt appearance in gloss prints
</p></li><li class="- topic/li "><p class="- topic/p "> Only visible in areas of mixed colors with high ink coverage.
</p></li><li class="- topic/li "><p class="- topic/p ">The level of banding can be depended of the used media.
</p></li></ul><note id="GUID-B587E5FA-4A27-43F9-B491-55806C2238F5" class="- topic/note "><p class="- topic/p ">In case of a minim amount of wrinkels exists this defect can easily be mistaken by “<b class="+ topic/ph hi-d/b ">Gloss gradient within swath 1 color</b>” 
</p></note></section><section id="GUID-4EA39634-1C04-4B10-8657-E2A909ED5C6F" class="- topic/section "><title class="- topic/title ">Functional logging (if available)</title><p class="- topic/p "> No logging available which can pinpoint to this case.
</p></section><section id="GUID-CBD34CE3-25C7-4352-BCE3-2980204C83CF" class="- topic/section "><title class="- topic/title ">ADAM-triggers</title><p class="- topic/p ">No available ADAM-triggers.
</p></section><section id="GUID-DDCC1BB0-B402-4010-9156-67DB737F3DE5" class="- topic/section "><title class="- topic/title ">Analyze/Repair</title><p class="- topic/p ">Wrinkels can be reduced by adjusting the SmartInkLimits (or OCP-values) in the profile setting. 
</p><p class="- topic/p ">Increasing the OCP-value will reduce the amount of wrinkles. 
</p></section><section id="GUID-2513E5DF-C282-453D-9841-6E539DB0EB51" class="- topic/section "><title class="- topic/title ">Evaluate/Prevention</title><p class="- topic/p ">Use the lowest OCP-value where no wrinkles are visible.
</p></section><section id="GUID-987F83F9-80F0-41BC-B82B-BB16DA268203" class="- topic/section "><title class="- topic/title ">Background info</title><p class="- topic/p ">The middle part of an ink layer always cures first. 
</p><p class="- topic/p ">This can create tension at the top and bottom of the ink layer, which can results in textured surface with a matt appearance.
</p><p class="- topic/p ">
</p><p class="- topic/p ">This effect is more visible at thick ink layers (eg : mixed colors in high coverage). 
</p></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-945E6C60-1212-47DF-9487-92374227D4B4.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Solutions</linktext></link></linkpool></related-links>
