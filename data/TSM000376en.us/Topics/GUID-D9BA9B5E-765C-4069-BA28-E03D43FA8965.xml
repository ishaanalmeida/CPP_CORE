<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-D9BA9B5E-765C-4069-BA28-E03D43FA8965" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-D9BA9B5E-765C-4069-BA28-E03D43FA8965" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Clean the buffer plate</title><abstract class="- topic/abstract " id="GUID-7215E544-19B4-47D8-B7C7-CC2CF8B1023C"><p class="- topic/p ">When the printer is polluting your media with for example uncured ink or glue, check the buffer plate. In case of pollution, you can clean the buffer plate. 
</p><p class="- topic/p ">Video: <ph class="- topic/ph " varid="Video: 19 - Clean the buffer plate"><xref class="- topic/xref " format="html" href="https://sus.cpp.canon/3MB7C41P" scope="external"><?ditaot usertext?> 
<image class="- topic/image " href="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png" placement="inline" otherprops="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png"/> Clean the buffer plate</xref></ph> 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-74ADADE3-AEBB-48B8-8A5C-560DD4ACB3E0" class="- topic/section task/prereq "><p class="- topic/p ">Use <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> prescribed: 
</p><ul id="UL_88FE82F1C6B343028F9B61DB8C430ED7" class="- topic/ul "><li id="LI_F4B9AC154F1445FBAA8F889824E6FD43" class="- topic/li "><p class="- topic/p ">Microflex gloves for handling ink 
</p></li><li id="LI_E6E8F65EDAAD4C49A430C5EE6B66BE55" class="- topic/li "><p class="- topic/p ">Lint free cloths 
</p></li><li id="LI_75F3D3584EDA44A6BE2FEB3B7513627F" class="- topic/li "><p class="- topic/p ">Cleaning liquid (IPA) 
</p></li></ul><note id="GUID-3AD31DDC-18E5-4CB4-9712-0ACD8BB32348" class="- topic/note " type="caution"><p class="- topic/p "> Wear gloves when contact with ink or maintenance materials is possible. Gloves should always overlap sleeves. Wear safety glasses with side shields when handling ink or maintenance materials. Follow the ink related Safety Data Sheets (SDS) guidelines carefully in order to ensure maximum safety. 
</p></note></prereq><steps id="GUID-EA8033CF-A666-403C-BBA7-51F8F3DA56B9" class="- topic/ol task/steps "><step id="d9203e56" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Put on the <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> approved gloves. 
</cmd></step><step id="d9203e62" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Go to the media input side and open the media cover. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d9203e66" class="- topic/fig "><image href="GUID-058F15EB-2DF1-4452-A6F6-CACCA2E38F90-low.png" id="d9203e67" placement="inline" class="- topic/image " otherprops="GUID-058F15EB-2DF1-4452-A6F6-CACCA2E38F90-low.png"/></fig></info></step><step id="d9203e68" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Inspect if the buffer plate is polluted. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d9203e72" class="- topic/fig "><image href="GUID-72427E03-21AE-4B36-A9BB-A78243DA9456-low.png" id="d9203e73" placement="inline" class="- topic/image " otherprops="GUID-72427E03-21AE-4B36-A9BB-A78243DA9456-low.png"/></fig></info></step><step id="d9203e74" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Take a lint free cloth and clean the buffer plate. 
</cmd></step><step id="d9203e77" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dampen the cloth with the cleaning liquid to remove any remaining ink. 
</cmd><info class="- topic/itemgroup task/info "><note type="important" id="d9203e81" class="- topic/note "><p class="- topic/p ">Use the prescribed cleaning liquid. Do not use any other cleaners. 
</p></note></info></step><step id="d9203e84" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dispose the gloves, cloths and pin as chemical waste according to local regulations. 
</cmd></step><step id="d9203e87" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Close the media cover. 
</cmd></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-99B79551-BE67-41AD-95FC-BDB28BED4A4E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
