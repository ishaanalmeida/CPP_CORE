<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-3A9BE0E3-8030-42F2-B61B-7254934DCE6A" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-3A9BE0E3-8030-42F2-B61B-7254934DCE6A" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">How to enable Remote Assistance</title><abstract class="- topic/abstract " id="GUID-3971E95F-7900-4495-B02B-0182D686A815"><p class="- topic/p ">This document describes the setting needed to enable remote assistance.
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Tools</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-C6F5D82A-F632-438B-8744-791BB674167A" class="- topic/section "><title class="- topic/title ">Enable procedure</title><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Click on “System”
</p><fig id="GUID-10F5C2AB-4E6E-4DFE-AFB3-64AEF2AF9317" class="- topic/fig "><title class="- topic/title "/><image href="GUID-8CC868C4-4B8D-45D3-A09E-FC534749E878-low.png" placement="inline" class="- topic/image " otherprops="GUID-8CC868C4-4B8D-45D3-A09E-FC534749E878-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on “Remote Services”.
</p><fig id="GUID-15876AD2-5D33-43C1-B97D-442DE408D2CF" class="- topic/fig "><title class="- topic/title "/><image href="GUID-12ABAEF0-CA42-4715-9335-C58059A16316-low.png" placement="inline" class="- topic/image " otherprops="GUID-12ABAEF0-CA42-4715-9335-C58059A16316-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on “Remote Connection”.
</p><fig id="GUID-12321E91-1140-4DCD-8738-624487354E9C" class="- topic/fig "><title class="- topic/title "/><image href="GUID-83754ADB-A62A-4AD4-8CA3-1CFC60FBAE02-low.png" placement="inline" class="- topic/image " otherprops="GUID-83754ADB-A62A-4AD4-8CA3-1CFC60FBAE02-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on “Blue Door with Arrow”
</p><fig id="GUID-A8DACB9C-7B8A-4619-8709-C0F82B69EB66" class="- topic/fig "><title class="- topic/title "/><image href="GUID-2A3F1284-6AD9-4FA1-88D7-7AF7CB1CB60C-low.png" placement="inline" class="- topic/image " otherprops="GUID-2A3F1284-6AD9-4FA1-88D7-7AF7CB1CB60C-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Type in Password : “71617000” and click on “Log in”.
</p><fig id="GUID-B2DE2224-A211-4899-A063-FE8BD0B66F0E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AD4D46AD-A695-4B50-B117-D0EC43A9FD83-low.png" placement="inline" class="- topic/image " otherprops="GUID-AD4D46AD-A695-4B50-B117-D0EC43A9FD83-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on the box to the right of “Remote assistance” and ENABLE it.
</p><fig id="GUID-EA7D9400-6EC8-4FF5-8076-19C080BA4BBA" class="- topic/fig "><title class="- topic/title "/><image href="GUID-9800E955-7CF6-4155-91C8-23216402A3B0-low.png" placement="inline" class="- topic/image " otherprops="GUID-9800E955-7CF6-4155-91C8-23216402A3B0-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">Click on “Save” to keep the setting you just ENABLED, then “Close”.
</p><fig id="GUID-B1ACB892-8874-4041-884E-35BBA4EFDBF2" class="- topic/fig "><title class="- topic/title "/><image href="GUID-13A61CEF-8586-49B2-8FCA-E502668B7136-low.png" placement="inline" class="- topic/image " otherprops="GUID-13A61CEF-8586-49B2-8FCA-E502668B7136-low.png"/></fig></li></ol></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-DFD95E44-6FE2-4690-855D-446A64ABF90C.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>ORS: On Remote Service</linktext></link></linkpool></related-links>
