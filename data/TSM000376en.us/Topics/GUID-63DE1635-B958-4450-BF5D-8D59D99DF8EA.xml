<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-63DE1635-B958-4450-BF5D-8D59D99DF8EA" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-63DE1635-B958-4450-BF5D-8D59D99DF8EA" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to remove the encoder assembly </title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-AB1FF3F2-EE56-418A-9E2C-98169E865A32" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A32A562039FB485780CA65B069EE577C" class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">A new encoder. 
</p></li><li id="LI_1D9EE245DE6547E09D8CB22E45CFC7A0" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li id="LI_65FC2CCF351049A499AB816911558F9A" class="- topic/li "><p class="- topic/p ">Small screwdriver. 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-ECA2BEBF-BCD5-4A92-8D1F-B5B2DD435686" class="- topic/fig "><image href="GUID-D68CA22E-B1B2-454E-9C9C-6A5F7A39E7EA-low.png" placement="inline" class="- topic/image " otherprops="GUID-D68CA22E-B1B2-454E-9C9C-6A5F7A39E7EA-low.png"/></fig><fig id="FIG_6BEA0AA2C5344ADC8CBE547203C5ED23" class="- topic/fig "/></section><section id="SECTION_C5F64D1EDF374EEFB875A1A706F76154" class="- topic/section "><title class="- topic/title ">How to remove </title><table pgwide="1" id="TABLE_140E4716CCCB45BFB1AD95964307A25A" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the encoder assembly. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C46E36C3-4D49-4787-BD47-0F27D3D54F73" class="- topic/fig "><image href="GUID-D68CA22E-B1B2-454E-9C9C-6A5F7A39E7EA-low.png" placement="inline" class="- topic/image " otherprops="GUID-D68CA22E-B1B2-454E-9C9C-6A5F7A39E7EA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the encoder reader by rotating the black housing 30 degrees clockwise. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A4E6BD98-251D-4D0F-8C16-696CFF3C555F" class="- topic/fig "><image href="GUID-0266472A-48D0-40DC-A1C7-D260D60014E6-low.png" placement="inline" class="- topic/image " otherprops="GUID-0266472A-48D0-40DC-A1C7-D260D60014E6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Pull off the white disk 
<b class="+ topic/ph hi-d/b ">and</b> the encoder pulse disk at once. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-22BEB723-31C2-40B6-ACFE-11DFC738D1EC" class="- topic/fig "><image href="GUID-F28BA54C-D280-4790-A694-73E4E6F6784F-low.png" placement="inline" class="- topic/image " otherprops="GUID-F28BA54C-D280-4790-A694-73E4E6F6784F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> If the encoder need to be replaced, ONLY exchange the loose parts. 
</p><note id="GUID-B339A701-5DAE-478B-95CA-3CF47F5BFE3D" class="- topic/note "><p class="- topic/p "> Do NOT loosen the mounted encoder bracket. This needs a special alignment tool. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E002E25A-12B1-4F17-BB34-6B5DC5645404" class="- topic/fig "><image href="GUID-DFBB3F9F-B6F1-47FF-9A02-5D2BAB06E9B3-low.png" placement="inline" class="- topic/image " otherprops="GUID-DFBB3F9F-B6F1-47FF-9A02-5D2BAB06E9B3-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to replace the encoder and how to install</title><table pgwide="1" id="TABLE_A7B7F2276EC64F88A303AD9C9A521E96" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Position the pulse disk including white spacer in the encoder black housing. 
</p><p class="- topic/p "> This is needed to position the encoder correctly without damaging the encoder sensor or pulse disk. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-477F109E-5522-406B-AA6B-FE687F358624" class="- topic/fig "><image href="GUID-25E8C3DF-C332-45B1-BFD6-BD47E231385E-low.png" placement="inline" class="- topic/image " otherprops="GUID-25E8C3DF-C332-45B1-BFD6-BD47E231385E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><note type="important" id="GUID-BA9B2549-F8DE-4BD6-A11D-2BA424CE9864" class="- topic/note "><p class="- topic/p "> Support the encoder axis before mounting back the pulse disk including encoder housing. 
</p><p class="- topic/p ">Example: Hold the axis against the edge of a table. 
</p><p class="- topic/p "> This is required because the shaft may move partly out of the black bearing house. This will mis-align the encoder pulse disk in combination with the encoder reader in the black housing later on. This will result in due time in an error behavior because the pulse disk will be polluted because of mechanical wear. 
</p></note><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Push the encoder housing towards the end while supporting the shaft (must not move). 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-53D207D1-47AC-4C2A-B1E3-3110D757B68F" class="- topic/fig "><image href="GUID-0166F6A4-F497-4601-BF08-645859349757-low.png" placement="inline" class="- topic/image " otherprops="GUID-0166F6A4-F497-4601-BF08-645859349757-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Rotate the encoder housing 30 degrees counter clockwise so that the encoder pulse wheel in combination with the encoder reading (in the black housing) are correctly aligned. 
</p><p class="- topic/p ">Result: No internal mechanical wear will appear. A small gap (of +/-1mm) must be visible. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7A1BC0CE-D750-45A8-886A-A675F221F62D" class="- topic/fig "><image href="GUID-D624244C-0527-4501-BAFA-8DA9350FBF78-low.png" placement="inline" class="- topic/image " otherprops="GUID-D624244C-0527-4501-BAFA-8DA9350FBF78-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Verify that the pulse wheel is free to move: rotate the larger wheel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in encoder assembly in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B96AB9C-8847-4643-A8CB-09918FE19AAB.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>