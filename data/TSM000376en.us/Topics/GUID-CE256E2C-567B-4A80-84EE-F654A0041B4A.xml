<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-CE256E2C-567B-4A80-84EE-F654A0041B4A" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-CE256E2C-567B-4A80-84EE-F654A0041B4A" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to remove the media drawer 1 roll 2 transmission assembly</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the media drawer 1 roll 2 transmission assembly (gears and drive belts). 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper.
</p></li><li class="- topic/li "><p class="- topic/p ">Open the media loading drawer.
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the media rolls from the media drawer.
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_69BB0AEB395F4E8AB96FD94A4C0C8696" class="- topic/ul "><li id="LI_561D1BF957EA49F8BB49139266A92893" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-D30D3992-1960-42FE-BEBE-36BD852EFF51" class="- topic/fig "><image href="GUID-41737E27-B1AA-47AB-8B8C-451DDB3AED6D-low.png" placement="inline" class="- topic/image " otherprops="GUID-41737E27-B1AA-47AB-8B8C-451DDB3AED6D-low.png"/></fig></section><section id="SECTION_079B9FE753A94ADABD479BD0E018D948" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_604AB09805EC4B89B181B7BA55FA3875" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the right hand side cover of the media drawer (8 screws). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_0F325822542D40B88AE9DACDD568E98C" class="- topic/fig "><image href="GUID-2B369192-18D5-4720-912A-E24070A5DEDF-low.png" id="IMAGE_126C0DAF30FB42DD81DDF2732BC67003" placement="inline" class="- topic/image " otherprops="GUID-2B369192-18D5-4720-912A-E24070A5DEDF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the antistatic brush. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A9AD3327-D4F9-4CB6-9D28-391682F8E511" class="- topic/fig "><image href="GUID-72CF6286-8321-472E-83F6-EBB92321753F-low.png" placement="inline" class="- topic/image " otherprops="GUID-72CF6286-8321-472E-83F6-EBB92321753F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 4 screws of the drive motor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-78671BA3-3781-4CA0-B188-E1FEBD83EC96" class="- topic/fig "><image href="GUID-49DAEE8E-F270-4A2B-9B0B-A87625E83EBC-low.png" placement="inline" class="- topic/image " otherprops="GUID-49DAEE8E-F270-4A2B-9B0B-A87625E83EBC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the spring. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-79A08143-BE60-41AA-9763-FE87D366C409" class="- topic/fig "><image href="GUID-A38AFF1B-74EB-4C1B-9D02-97E34461357F-low.png" placement="inline" class="- topic/image " otherprops="GUID-A38AFF1B-74EB-4C1B-9D02-97E34461357F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the drive belt from the gear of the motor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-81F9060C-AB60-4E95-8B51-8A0020A9575B" class="- topic/fig "><image href="GUID-C5F59557-C33D-4DEC-850B-AFAA5CAD55D6-low.png" placement="inline" class="- topic/image " otherprops="GUID-C5F59557-C33D-4DEC-850B-AFAA5CAD55D6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the transmission assembly (5 screws). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D1E2D9C2-EDE0-4672-A743-6385AD94B023" class="- topic/fig "><image href="GUID-2C0E65B9-1C85-4659-ACD7-4BA87C76B65A-low.png" placement="inline" class="- topic/image " otherprops="GUID-2C0E65B9-1C85-4659-ACD7-4BA87C76B65A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the drive assembly including the gear. 
</p><note id="GUID-CB11680D-A48C-43D2-AF30-AD7F99BBF2CC" class="- topic/note "><p class="- topic/p ">Do not loose the 2 rings. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6D1A37C0-164A-4BC7-BE87-6249A3BA64A5" class="- topic/fig "><image href="GUID-113D3496-EBD7-49CE-9E6F-01A2A1162CF2-low.png" placement="inline" class="- topic/image " otherprops="GUID-113D3496-EBD7-49CE-9E6F-01A2A1162CF2-low.png"/></fig><fig id="GUID-2C363898-41A2-409D-B9C4-067851E645DD" class="- topic/fig "><image href="GUID-F26C24DB-7068-4469-B7DB-60E6D16AFA35-low.png" placement="inline" class="- topic/image " otherprops="GUID-F26C24DB-7068-4469-B7DB-60E6D16AFA35-low.png"/></fig><fig id="GUID-B9A78244-EA5B-4A05-A9FE-84F3DE8C7C7E" class="- topic/fig "><image href="GUID-09449D66-CD84-43C8-A9CB-81096C244873-low.png" placement="inline" class="- topic/image " otherprops="GUID-09449D66-CD84-43C8-A9CB-81096C244873-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Overview assembly: 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-72D9553C-B61C-4713-9C30-8873EA363CD5" class="- topic/fig "><image href="GUID-474A513E-F831-4B34-847B-65C13ABBE2A9-low.png" placement="inline" class="- topic/image " otherprops="GUID-474A513E-F831-4B34-847B-65C13ABBE2A9-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 3 screws. 
</p><p class="- topic/p ">Place the 2 guide rollers to the right hand side (maximum spring tension). 
</p><p class="- topic/p ">Lock the position with the 3 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8E2B5CE0-5B40-4C65-BCBE-7EF33A84716F" class="- topic/fig "><image href="GUID-B0EEF695-B224-4B69-940A-BBA52BC9050D-low.png" placement="inline" class="- topic/image " otherprops="GUID-B0EEF695-B224-4B69-940A-BBA52BC9050D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the drive belt on the gear. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4D503FB0-3708-4948-851D-ADF336372AAE" class="- topic/fig "><image href="GUID-3F39F377-E227-474D-B93C-BB752920FC46-low.png" placement="inline" class="- topic/image " otherprops="GUID-3F39F377-E227-474D-B93C-BB752920FC46-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place the gear assembly with drive belt. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B0731040-79B1-4106-8DDC-F32E2207E548" class="- topic/fig "><image href="GUID-954D55B1-930D-49ED-A06F-385AA3135373-low.png" placement="inline" class="- topic/image " otherprops="GUID-954D55B1-930D-49ED-A06F-385AA3135373-low.png"/></fig><fig id="GUID-14765CB0-B04F-4340-8EF0-3DFF885EA4BB" class="- topic/fig "><image href="GUID-2EFC9CB5-6BC0-4392-BB40-CC7989C9DB6E-low.png" placement="inline" class="- topic/image " otherprops="GUID-2EFC9CB5-6BC0-4392-BB40-CC7989C9DB6E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place the ring over the frame. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FB09ECC7-EB41-4AB4-A8C4-FD4E9CADB4D2" class="- topic/fig "><image href="GUID-6D9177A8-F492-4D35-B22B-8587C1D1C09C-low.png" placement="inline" class="- topic/image " otherprops="GUID-6D9177A8-F492-4D35-B22B-8587C1D1C09C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place the gear assembly. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C1C1E4CC-CD06-44F9-B390-1DF6CB43161C" class="- topic/fig "><image href="GUID-4994E84E-3838-49C9-894F-22A073FE0BC1-low.png" placement="inline" class="- topic/image " otherprops="GUID-4994E84E-3838-49C9-894F-22A073FE0BC1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Guide the drive belt over the gear. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7DF6EEBA-DD69-49B0-B169-FAB3DA00BD4F" class="- topic/fig "><image href="GUID-37CD3DF5-D944-4279-B1C2-8493B2926AD0-low.png" placement="inline" class="- topic/image " otherprops="GUID-37CD3DF5-D944-4279-B1C2-8493B2926AD0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Mount the drive belt (to the motor). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B03E9815-0F6E-4318-94A1-1925B19982DF" class="- topic/fig "><image href="GUID-66F6B86C-B72D-4515-BFB0-4A4A5FC5F47F-low.png" placement="inline" class="- topic/image " otherprops="GUID-66F6B86C-B72D-4515-BFB0-4A4A5FC5F47F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Position the assembly with the 2 bearings in the frame. 
</p><note type="important" id="GUID-95EDC103-C4C4-48DC-AA0D-E3D524753500" class="- topic/note "><p class="- topic/p ">Do not pinch the wires of the bundles. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-752D0DAA-7D4E-4570-AC93-8A6353AE7216" class="- topic/fig "><image href="GUID-FEDE74E6-7A74-44FB-A183-01A97D646CB2-low.png" placement="inline" class="- topic/image " otherprops="GUID-FEDE74E6-7A74-44FB-A183-01A97D646CB2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><note id="GUID-C6058515-24E2-4F86-9867-DE51A5F8DD73" class="- topic/note "><p class="- topic/p ">Make sure the 2 bearings are correctly positioned in the frame of the media drawer. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-538BB849-8866-4B50-89F1-0FDB8FE442FF" class="- topic/fig "><image href="GUID-F7D1AA28-FCA5-47BA-8F77-94FF6B38772A-low.png" placement="inline" class="- topic/image " otherprops="GUID-F7D1AA28-FCA5-47BA-8F77-94FF6B38772A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Lock the assembly with 5 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FE2A029C-C233-4134-A01E-B9A9FA42F26D" class="- topic/fig "><image href="GUID-AE6D1147-7147-45A6-B09B-254CC40E4AE6-low.png" placement="inline" class="- topic/image " otherprops="GUID-AE6D1147-7147-45A6-B09B-254CC40E4AE6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Guide the drive belt over the gear of the motor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4906BD9D-9844-4C30-A103-AC9A08EBD67B" class="- topic/fig "><image href="GUID-4B33E0E1-AC56-43DD-8675-DCE3215DD479-low.png" placement="inline" class="- topic/image " otherprops="GUID-4B33E0E1-AC56-43DD-8675-DCE3215DD479-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen all 3 screw of the gear assembly and then lock them again. 
</p><p class="- topic/p ">The drive belts are now on the correct tension. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CAE2D5F0-5742-4494-B582-D9D52051D3DF" class="- topic/fig "><image href="GUID-58D524AE-AD9E-4725-ACF4-633CC0D2BC71-low.png" placement="inline" class="- topic/image " otherprops="GUID-58D524AE-AD9E-4725-ACF4-633CC0D2BC71-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen all 4 screws of the drive motor and then lock them again. 
</p><p class="- topic/p ">The drive belt of the motor is now on the correct tension. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6370BB1B-D722-4609-AB57-1AE88F8D8225" class="- topic/fig "><image href="GUID-9174B60B-1585-4B82-A9C5-3C10E572BEC0-low.png" placement="inline" class="- topic/image " otherprops="GUID-9174B60B-1585-4B82-A9C5-3C10E572BEC0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the 2 anti static brushes. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C279827D-5C75-4780-903F-E9C840CFD2CA" class="- topic/fig "><image href="GUID-B66C8BC8-353F-4CB8-823F-223C21EB0200-low.png" placement="inline" class="- topic/image " otherprops="GUID-B66C8BC8-353F-4CB8-823F-223C21EB0200-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B96AB9C-8847-4643-A8CB-09918FE19AAB.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>