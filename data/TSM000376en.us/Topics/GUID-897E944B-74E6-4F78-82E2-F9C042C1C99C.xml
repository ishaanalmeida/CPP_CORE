<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-897E944B-74E6-4F78-82E2-F9C042C1C99C" version="3" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-897E944B-74E6-4F78-82E2-F9C042C1C99C" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">05 How to remove the printhead carriage drive belt</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the printhead carriage drive belt. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_70CAACC74DC344648186B41314688C19" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-7215619B-4D8E-42B1-B219-10C1EF6B5FB5" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_64BB077525D643BAA0D00A934918884D" class="- topic/ul "><li id="LI_FEBB1892C37D4D6DA26AFAA9949BAE22" class="- topic/li "><p class="- topic/p ">Pin / small screwdriver. 
</p></li><li id="LI_5CB67A3B73F448B395B5B05C83672D34" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="FIG_B3C19E4610A3489D95D648AB9D2898D2" class="- topic/fig "><image href="GUID-F0A41026-2B8E-4468-B8DF-9CAC0F856E9C-low.png" id="IMAGE_4C3A4F487FF14B83A6A5274C62159C1A" placement="inline" class="- topic/image " otherprops="GUID-F0A41026-2B8E-4468-B8DF-9CAC0F856E9C-low.png"/></fig></section><section id="SECTION_E09162B21D4A488AAA9166DB4B577B86" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_F0BCFF91AFF54AD0AB393BCBD0ECBB69" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Turn the bolt -A- clockwise until it is completely in. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9A4F5C7D-21EF-4080-847D-FA39EA72810E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-FBB423AA-1BF3-4290-A21C-BC4EEF650FFF-low.png" placement="inline" class="- topic/image " otherprops="GUID-FBB423AA-1BF3-4290-A21C-BC4EEF650FFF-low.png"/></fig><fig id="GUID-1C6A5506-8461-4BFD-8B7C-FB47C7EF289A" class="- topic/fig "><image href="GUID-72BC1DEC-D4D6-4701-BA70-C6803D6775DA-low.png" id="IMAGE_CB67C5D682784AFE93225DD297C4918D" placement="inline" class="- topic/image " otherprops="GUID-72BC1DEC-D4D6-4701-BA70-C6803D6775DA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Move the tension bracket -B- (green part) to the right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-523C8533-19CB-4B0D-9DDA-255427874789" class="- topic/fig "><image href="GUID-BDCD6630-28B5-4C87-8831-BC7193941CE2-low.png" placement="inline" class="- topic/image " otherprops="GUID-BDCD6630-28B5-4C87-8831-BC7193941CE2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Press on the tension plate -C- (Aim: The adjustment bolt is pressed together a little bit). 
</p><p class="- topic/p ">Lock the tension bracket with a pin / small screwdriver -D-. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_D204F8DA4F67404EB8126CBA3BF50D31" class="- topic/fig "><image href="GUID-7BF9684F-0B05-444A-9BD1-CA272250BDF5-low.png" id="IMAGE_F2655E43BD4B4C41B72B7E85F499B0C1" placement="inline" class="- topic/image " otherprops="GUID-7BF9684F-0B05-444A-9BD1-CA272250BDF5-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Unhook and remove the printhead carriage drive belt. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_4DE41B22ADE54AD48BB60D4383348E67" class="- topic/fig "><image href="GUID-6288D436-25A9-4441-9642-F188B706A5E4-low.png" id="IMAGE_4753B814762D4A5982CC9FA323A03A3F" placement="inline" class="- topic/image " otherprops="GUID-6288D436-25A9-4441-9642-F188B706A5E4-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_BF222651FDC54D218A4605224C634311" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the carriage all the way to the tensioner side – against the end stop. 
</p><p class="- topic/p ">Grab the free end with both hands and push towards the carriage until is hooked in. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><note id="GUID-BB984554-2766-4C86-9652-34221C954187" class="- topic/note "><p class="- topic/p ">The "End stop" is designed to withstand force. 
</p></note><fig id="GUID-4EA5F13F-CE9E-4729-B821-4DDEC48243B0" class="- topic/fig "><image href="GUID-BFD23EA8-9CDE-4044-A705-47C832E6834A-low.png" placement="inline" class="- topic/image " otherprops="GUID-BFD23EA8-9CDE-4044-A705-47C832E6834A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Adjust the tension of the printhead carriage drive belt. 
</p><p class="- topic/p ">See : 
<xref keyref="05ADJU001" class="- topic/xref " href="GUID-92CE7882-1B62-426A-AC5B-96AA3C0926BD.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 05 How to adjust the tension of the printhead carriage...?>05 How to adjust the tension of the printhead carriage drive belt</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Adjust the alignment of the mirrors of the curing carriage and printhead carriage. 
</p><p class="- topic/p ">See 
<xref keyref="01ADJU005" class="- topic/xref " href="GUID-BFCE5418-CBD6-4B74-8C3D-4193689786ED.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>01 How to adjust the alignment of the mirrors of the curing carriage and printhead carriage (used for matte print mode)</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-413D000D-1733-4578-95D7-CBC36AC62908.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>