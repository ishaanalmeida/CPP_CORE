<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-693F369A-29D7-4702-B9F7-6BF7A867CF37" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-693F369A-29D7-4702-B9F7-6BF7A867CF37" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 Install the cover plate</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-D9DCE01C-7993-49B7-874B-8AFD1ED7259C" class="- topic/section task/prereq "><p class="- topic/p ">The cover plate blocks the light of the curing unit. 
</p><fig id="GUID-7134FBF8-6215-4736-B8AD-4E2DE14D1CB5" class="- topic/fig "><image href="GUID-91A489F4-3283-460C-8A53-5615BB6DBDA8-low.png" placement="inline" class="- topic/image " otherprops="GUID-91A489F4-3283-460C-8A53-5615BB6DBDA8-low.png"/></fig></prereq><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_CA72A11EC2AC4C48863612B5463B3EEE" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-5336C61E-428B-4155-A159-4E02791CDD76" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_840C79ECCB334F8AA1075BBA0086BC39" class="- topic/ul "><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-FC221EB2-F423-43D3-A05C-744002358F67" class="- topic/fig "><title class="- topic/title ">Before</title><image href="GUID-91A489F4-3283-460C-8A53-5615BB6DBDA8-low.png" placement="inline" class="- topic/image " otherprops="GUID-91A489F4-3283-460C-8A53-5615BB6DBDA8-low.png"/></fig><fig id="GUID-D697C82A-0423-4A6D-BF97-AF627CD8D9FE" class="- topic/fig "><title class="- topic/title ">After</title><image href="GUID-E3056C85-819B-4BAA-968C-337508994A15-low.png" placement="inline" class="- topic/image " otherprops="GUID-E3056C85-819B-4BAA-968C-337508994A15-low.png"/></fig></section><section id="SECTION_2ED55A2BDE0B4458AC37B33FC1C7B7AA" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_B5424687F5CB4E4CADC5ABF3E101FBF3" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide the curing carriage to the right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-59CE5481-FE29-4314-B69E-FD7FC9E1D269" class="- topic/fig "><image href="GUID-076C99E6-00B4-430F-8C74-876F1B9C61DC-low.png" placement="inline" class="- topic/image " otherprops="GUID-076C99E6-00B4-430F-8C74-876F1B9C61DC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Take the cover plate (larger opening at the right hand side) and position the cover plate in the hole of the curing beam. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1B2AA81C-9FD7-4831-B070-888D6CFC793F" class="- topic/fig "><image href="GUID-C936E4CE-4E97-422E-AF66-628EDB0BBAFB-low.png" placement="inline" class="- topic/image " otherprops="GUID-C936E4CE-4E97-422E-AF66-628EDB0BBAFB-low.png"/></fig><fig id="GUID-AD8D92FC-CA85-45C1-968F-B58A6F3BC14E" class="- topic/fig "><image href="GUID-A94EFDB8-73DB-44EB-9473-F1D0C7B2CEF4-low.png" placement="inline" class="- topic/image " otherprops="GUID-A94EFDB8-73DB-44EB-9473-F1D0C7B2CEF4-low.png"/></fig><fig id="GUID-D7C87EBF-796B-4C71-9903-AAC479FE9AD0" class="- topic/fig "><image href="GUID-8FAD0171-8189-4FB4-9001-F070C2F8B2AF-low.png" placement="inline" class="- topic/image " otherprops="GUID-8FAD0171-8189-4FB4-9001-F070C2F8B2AF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Hold the cover plate in place. 
</p></li><li class="- topic/li "><p class="- topic/p ">Bend the 3 edges of the cover plate by hand. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4A305833-C26B-4AB5-A304-665390DFDB69" class="- topic/fig "><image href="GUID-2E9A7F58-B4DB-4199-ACD9-39F997C58CC0-low.png" placement="inline" class="- topic/image " otherprops="GUID-2E9A7F58-B4DB-4199-ACD9-39F997C58CC0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Result: The hole in the curing beam is sealed with a cover. The light of the curing unit is blocked. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-895F6129-F3DB-4CCA-AA4D-8E57F2125D98" class="- topic/fig "><image href="GUID-E3056C85-819B-4BAA-968C-337508994A15-low.png" placement="inline" class="- topic/image " otherprops="GUID-E3056C85-819B-4BAA-968C-337508994A15-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">Finalize</title><table pgwide="1" id="TABLE_E3FC7EE10DDC46BA880F87671551C890" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-22D79A6A-2191-46FA-BE14-24F47FE4288E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
