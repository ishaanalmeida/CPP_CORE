<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-544AFD34-4B1B-44CE-AB6D-ABE84AE46EB6" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-544AFD34-4B1B-44CE-AB6D-ABE84AE46EB6" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 Replace the lubricators (technician)</title><abstract class="- topic/abstract " id="GUID-5084D40A-F2FF-435A-916D-655AB1C2CE64"><p class="- topic/p "> 
</p><p class="- topic/p "> The customer can replace the lubricator assy. As a technician you can replace the lubricator only.
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="PREREQ_EE24CF19BBE4443786BF413DF22F356D" class="- topic/section task/prereq "><p class="- topic/p ">Use <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> prescribed: 
</p><ul id="UL_1FD256E79DF940B8A41F66714B60E91B" class="- topic/ul "><li id="LI_0AAC9E2E843E4F0CA1E6ECFE3E027011" class="- topic/li "><p class="- topic/p "> <ph translate="no" class="- topic/ph ">Microflex</ph> gloves for handling ink 
</p></li><li id="LI_706EE85B1EFF415A85FBE7F8FC04ED77" class="- topic/li "><p class="- topic/p ">2 lubricators and pins (2x) 
</p></li><li id="LI_A9492FCBD53A459CB87DBBC0D3B9F4AC" class="- topic/li "><p class="- topic/p ">Torx / Crosshead screwdriver 
</p></li><li id="LI_3CF58D1D3C0B44BABE7AF75493867F88" class="- topic/li "><p class="- topic/p ">Lint free cloth (optional) 
</p></li></ul></prereq><section id="SECTION_645A9026BD3147189B5CD545B19205C3" class="- topic/section "><title class="- topic/title "/><note id="GUID-47FC2F4B-6CD5-42C5-A4A1-E2FEE735416A" type="caution" class="- topic/note "><ul id="UL_56D4B4E4E93346A081251E6163952578" class="- topic/ul "><li id="LI_04778709B142478A9921510E59AD63F1" class="- topic/li "><p class="- topic/p "> Wear the prescribed gloves when contact with ink or maintenance materials is possible. Gloves should always overlap sleeves. Follow the Safety Data Sheets (SDS) guidelines carefully in order to ensure maximum safety. 
</p></li></ul></note></section><steps id="GUID-5A4A9195-B7FA-4057-A865-E0EE34738B7A" class="- topic/ol task/steps "><step id="STEP_9631FD6AC20E45BCB22BCA6F92A8FAB3" class="- topic/li task/step "><cmd class="- topic/ph task/cmd "> On the operator panel tap on the <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Tools</text></uicontrol></ph> icon on the right. 
</cmd></step><step id="STEP_D4B0B9D5473E49FF8D140B2CF99D34F9" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text " translate="yes">You should replace the lubricators</text></uicontrol></ph>. 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_092158EB9271468AAA071E86AD8EE51A" class="- topic/fig "><image href="GUID-F40C5656-D7EA-4D61-B5AE-DA30900C4DFB-low.png" id="IMAGE_E5205106A9A34D7EB9BF33D5DA7E2CBE" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F40C5656-D7EA-4D61-B5AE-DA30900C4DFB-low.png"/></fig></info></step><step id="STEP_85FC53A90DA340F49E8E2A130110E6B3" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Replace</text></uicontrol>. </ph> 
</cmd></step><step id="STEP_0AC2B14C1F954C9389E3816D98E3B485" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Move to the media input side and open the top cover. 
</cmd></step><step id="STEP_E2DBFD188BA3466C8A4E5806CA470B57" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Put on the <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> approved gloves. 
</cmd></step><step id="STEP_2D60B541532746789370974494FE261B" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Carefully push the printhead carriage to the left in manual maintenance position (1). 
</cmd><info class="- topic/itemgroup task/info "><note type="important" id="GUID-25FF4F5D-9616-46A4-BA49-8FDFA3A2E544" class="- topic/note "><p class="- topic/p ">Touch the printhead carriage on the covered area only, otherwise you can damage the printheads. 
</p></note></info><info class="- topic/itemgroup task/info "><fig id="FIG_3BAE3F1ABE354E12B9500AEF6578312F" class="- topic/fig "><image href="GUID-CF19DD7C-1A90-43E0-B7C4-1B8A93EA891C-low.png" id="IMAGE_6D9AEA800E46416E886C19E66E3F74E5" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CF19DD7C-1A90-43E0-B7C4-1B8A93EA891C-low.png"/></fig></info></step><step id="STEP_2B8B2E1909774BC0BF7EF4748382DB3B" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Take a piece of paper and place it in the middle of the platen (2). 
</cmd></step><step id="STEP_F6F02A6AF728456C9FF157B9757161F1" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Carefully push the curing carriage to the middle of the platen over the paper. The paper will prevent any loose parts falling into the printer. 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_B666F7EED35C4181981B4EE53B927E80" class="- topic/fig "><image href="GUID-19F6FBF2-7422-4B9B-97D5-B0D565C36512-low.png" id="IMAGE_20C357E158A14F1EB8354DCBD9C608F2" keyref="" placement="inline" class="- topic/image " otherprops="GUID-19F6FBF2-7422-4B9B-97D5-B0D565C36512-low.png"/></fig></info></step><step id="STEP_412531847BB84CA8A9D3727DDE240136" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Locate the lubricators on the left side of the curing carriage. 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_FACE60DE70D0466FBC61D9400111CA47" class="- topic/fig "><image href="GUID-37B836AF-938C-4B10-8CE7-ABD5E3CE6B01-low.png" id="IMAGE_F142F56C16FF4B678A11E2E4711CCDBB" keyref="" placement="inline" class="- topic/image " otherprops="GUID-37B836AF-938C-4B10-8CE7-ABD5E3CE6B01-low.png"/></fig></info></step><step id="STEP_24A0AD562436407C987CB5AD426DCE29" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Take a pin and place it in the hole of the upper lubricator (1). 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_4CC2E2F50BD04043823E904FB5348DEC" class="- topic/fig "><image href="GUID-CB896274-17A9-42F0-BA22-BDC21F2CDEAF-low.png" id="IMAGE_44EDB0AFF8B343E3AFBC2580A04E2C7C" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CB896274-17A9-42F0-BA22-BDC21F2CDEAF-low.png"/></fig></info></step><step id="STEP_19327E6EE3ED4F8689C19EC16D8BC579" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Take a second pin and place it in the hole of the lower lubricator (2). 
</cmd></step><step id="STEP_7DB8E5AF750946D3933FA088B50D0088" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Unscrew the two screws (1-2) on the lubricators' bracket with a torx / crosshead screwdriver. 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_16503D5D9C1C403B84F579D041556889" class="- topic/fig "><image href="GUID-BDB7B34A-3ADC-47E1-AF46-FDE5886E9897-low.png" id="IMAGE_BEA8E46166CA4D15A8CD245B6B041BB6" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BDB7B34A-3ADC-47E1-AF46-FDE5886E9897-low.png"/></fig></info></step><step id="STEP_EBA4F6ED776D46948694D18209D6BF9A" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Remove the bracket with the lubricators. 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_95D38E4CC3E244FFA9373108F66E44BB" class="- topic/fig "><image href="GUID-D481EDE9-E224-43D0-BBD1-A7555CD71FD8-low.png" id="IMAGE_0A986719BF8A444FA2ADAF485CE0BFCB" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D481EDE9-E224-43D0-BBD1-A7555CD71FD8-low.png"/></fig></info></step><step id="STEP_867B539E569848DE87C298DFBB9B7D91" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Mount the 2 new lubricators in the bracket and place the 2 pins in the lubricators holes. 
</cmd></step><step id="STEP_CC0A2862FEEE449A873988E3157527E4" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Place the bracket with the new lubricators into position. The bracket should fit into the positioning hole. 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_3C96EA378D2E4FBBA0351895476AB201" class="- topic/fig "><image href="GUID-94B07BF8-A71B-4DCF-B696-3B6E3FF4E06E-low.png" id="IMAGE_D6F038E49CF348DF870D01BD84E92226" keyref="" placement="inline" class="- topic/image " otherprops="GUID-94B07BF8-A71B-4DCF-B696-3B6E3FF4E06E-low.png"/></fig></info></step><step id="STEP_7180988B782A46B3913A7272EE5BF59B" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Fasten the two screws, hand tight (1). 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_F06CCEE5EB2940D3AE72FC48B86E8D18" class="- topic/fig "><image href="GUID-CD7CCF0A-2271-479D-B0DF-10E6AFB4AB06-low.png" id="IMAGE_4A7CF384AD4249788BA4D047DB8F8678" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CD7CCF0A-2271-479D-B0DF-10E6AFB4AB06-low.png"/></fig></info></step><step id="STEP_9A9023FBDF9E4D90A9195EFFB85E50A6" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Take the pins out of the lubricators (2). 
</cmd></step><step id="STEP_C8AF0FFB79494B4F849E1D8700F31E0D" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Locate the lubricators on the right side of the curing carriage. 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_8D70C27065E44BB493D5CC8492C3ACDC" class="- topic/fig "><image href="GUID-62E8E8A8-F8A2-405B-9F10-FF480008CEC3-low.png" id="IMAGE_9DD971FDDB994FE6AF838BAF82E3B8A1" keyref="" placement="inline" class="- topic/image " otherprops="GUID-62E8E8A8-F8A2-405B-9F10-FF480008CEC3-low.png"/></fig></info></step><step id="STEP_81771506EB0A4467AB113F16E1796E62" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Repeat steps 10 to 17. 
</cmd></step><step id="STEP_E4EE8302F8E94E96BACF69DDC77CC2E0" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">When the lubricators on both sides have been replaced, remove the paper. 
</cmd></step><step id="STEP_6A166C7FC08747B2A0B2696D34759653" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dispose the gloves as chemical waste according to local regulations. 
</cmd></step><step id="STEP_E74C686574E44AF68DC626BA57151527" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Close the top cover. 
</cmd></step><step id="STEP_677B8C995ABC4C57933C38CA9D1B533F" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">On the operator panel tap <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Replaced</text></uicontrol></ph> to confirm you replaced the lubricators and end the action. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-B3A148F2-F31E-480A-AC19-84726965A071" class="- topic/note "><p class="- topic/p ">When you have replaced the lubricators, some oil can drip on the platen and the platen edge. When oil has spilled: open the top cover when the printer is not printing, put on gloves, clean the oil with a lint free cloth and close the top cover again. 
</p></note><fig id="FIG_F0DC28ACA3454BFD8A84B6F3DB7F2261" class="- topic/fig "><image href="GUID-61A23503-A188-4CB6-AE50-7630C5D6C18C-low.png" id="IMAGE_FFBC5EB900484DF39E8674B1E1F999A0" keyref="" placement="inline" class="- topic/image " otherprops="GUID-61A23503-A188-4CB6-AE50-7630C5D6C18C-low.png"/></fig></info></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-22D79A6A-2191-46FA-BE14-24F47FE4288E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>