<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-86992A46-53DB-4CBA-A0E9-09BE333CCEFA" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-86992A46-53DB-4CBA-A0E9-09BE333CCEFA" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to remove the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Lamp control PBA</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 01PBA03 </compcodenr></comp></title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_5176772B6144483082244285366FC178" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-7215619B-4D8E-42B1-B219-10C1EF6B5FB5" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_BF7CE9B36BC446D897CD6D84C8FE9EBA" class="- topic/ul "><li id="LI_AC9058106BF3408FB35C50B0C64D3001" class="- topic/li "><p class="- topic/p ">Screwdriver 
</p></li><li id="LI_CEA169C1D677475FA4F292A6133F7456" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Spanner or socket wrench 7 mm 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-7EA41B2C-3193-40B9-AEE1-9380E7132C58" class="- topic/fig "><image href="GUID-5AB180F7-495C-4EBE-A4D9-283E2937D658-low.png" placement="inline" class="- topic/image " otherprops="GUID-5AB180F7-495C-4EBE-A4D9-283E2937D658-low.png"/></fig><fig id="FIG_4FBB67F92D41460997E23131D3B2210F" class="- topic/fig "><image href="GUID-0AAA978E-88B8-401B-BA7B-F56003E2ECF9-low.png" id="IMAGE_E532A737FA524D92B9D4A619A65F55B6" placement="inline" class="- topic/image " otherprops="GUID-0AAA978E-88B8-401B-BA7B-F56003E2ECF9-low.png"/></fig></section><section id="SECTION_E545FC4D9965419E81D71AAB9ACCD8AA" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_B9DB35C90B6749CCA5D79F32429226ED" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the small cover below the operator panel (1 screw). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-355DA89A-7B67-479B-877A-46589E5CFC74" class="- topic/fig "><image href="GUID-F4878A10-6C18-43D3-B29C-B89187DFEF21-low.png" placement="inline" class="- topic/image " otherprops="GUID-F4878A10-6C18-43D3-B29C-B89187DFEF21-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the 2 connectors. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B4F66F28-E79D-421B-B749-14492E8DB14B" class="- topic/fig "><image href="GUID-5FD7E6FA-5B3B-4B48-BC91-50AD59BB8F39-low.png" placement="inline" class="- topic/image " otherprops="GUID-5FD7E6FA-5B3B-4B48-BC91-50AD59BB8F39-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide the curing carriage to the right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CEECFDDE-73EA-44AA-98E5-37127A0E3BF3" class="- topic/fig "><image href="GUID-7F380931-91A9-452F-9597-46295CFFA256-low.png" placement="inline" class="- topic/image " otherprops="GUID-7F380931-91A9-452F-9597-46295CFFA256-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 3 screws (at the curing carriage side). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A3DBADFD-9B03-4A9D-9FF5-B1C2BE30A61F" class="- topic/fig "><image href="GUID-4A707119-DFEB-4490-B769-A0DAD21823E0-low.png" placement="inline" class="- topic/image " otherprops="GUID-4A707119-DFEB-4490-B769-A0DAD21823E0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide the PBA assembly to the top and disconnect the 2 connectors. 
</p><note type="important" id="GUID-8777CC5F-2607-4487-B22E-1F5A5ED60EBF" class="- topic/note "><p class="- topic/p ">Mark the position of the connectors on the PBA. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5A236003-FB68-4723-BF4F-2760F30ECA35" class="- topic/fig "><image href="GUID-76FB125B-CB92-4970-A0F7-210974E17E78-low.png" placement="inline" class="- topic/image " otherprops="GUID-76FB125B-CB92-4970-A0F7-210974E17E78-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the PBA assembly. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_41B34280ED634014820B3C7F7AC35AE3" class="- topic/fig "><image href="GUID-C488D4BB-638D-49D5-A3A5-CE8F43334688-low.png" id="IMAGE_F2FD292B78FD4D67BB6C68E6C81BFDF1" placement="inline" class="- topic/image " otherprops="GUID-C488D4BB-638D-49D5-A3A5-CE8F43334688-low.png"/></fig><fig id="FIG_F35D88A1D1584661A0402F9D84EFE01D" class="- topic/fig "><image href="GUID-0AAA978E-88B8-401B-BA7B-F56003E2ECF9-low.png" id="IMAGE_5D263AD6404748BC8B22DC8B90C42EF2" placement="inline" class="- topic/image " otherprops="GUID-0AAA978E-88B8-401B-BA7B-F56003E2ECF9-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-22D79A6A-2191-46FA-BE14-24F47FE4288E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
