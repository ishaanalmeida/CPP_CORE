<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-DC00B079-5A4D-415E-A896-603C50CE6C56" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-DC00B079-5A4D-415E-A896-603C50CE6C56" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title translate="no" class="- topic/title ">21-6-004 Measure print characteristics [Special Tests]</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">SDS</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-2BD8C3DB-27B0-44E5-B999-CF486EF1CE0D" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">SDS</ph></title><p class="- topic/p "> 
<object id="GUID-985D3864-D1DF-408F-B7A9-84032C917994" class="- topic/object "><desc class="- topic/desc "><p class="- topic/p "> Measure print characteristics </p></desc><param name="testid" value="216004" class="- topic/param "/><param name="target" value="NIL" class="- topic/param "/><param name="axmodule" value="None" class="- topic/param "/></object> 
</p></section><section id="GUID-1156E15C-FA11-42F7-80CE-F9823F371FA9" class="- topic/section "><title class="- topic/title ">Function</title><p class="- topic/p "> 
</p><p class="- topic/p "> The test is used for "escalation purpose" if the test 21-6-011 is showing artifacts. 
</p><p class="- topic/p "> This test measures all deviations in y-direction. 
</p><p class="- topic/p ">If the test finishes successful, if the patterns are printed and measured correctly. 
</p><p class="- topic/p ">This does not mean that the print characteristics are successful. 
</p><p class="- topic/p ">At this moment, the test results can only be analyzed off-line. The test takes about 10-15 minutes. 
</p><p class="- topic/p "> When the tests reports failed: check in SDS via the "Error Analysis" tile if a cause is reported for this. 
</p><note id="GUID-88B504FD-35C9-4BFB-913F-2C0F7D2753B1" class="- topic/note "><p class="- topic/p "> 
</p></note></section><section id="GUID-BC0B8BAC-5352-4047-ACDB-6FB497286FC0" class="- topic/section "><title class="- topic/title ">Precondition</title><p class="- topic/p "> SDS test 21-6-011 shows artifacts. 
</p></section><section id="GUID-A72FF491-D6BB-46AD-8E99-5FF66AB11223" class="- topic/section "><title class="- topic/title ">Description</title><p class="- topic/p "> The test prints mono color CMYK gradients which are measured to determine: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">y-errors per nozzle 
</p></li><li class="- topic/li "><p class="- topic/p ">y-errors due to array to array errors 
</p></li><li class="- topic/li "><p class="- topic/p "> y-errors due to chip to chip errors| 
</p></li><li class="- topic/li "><p class="- topic/p ">y-errors due to head rotation. 
</p></li></ul></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-3AD12DA3-F651-4B11-BEB9-FD79AA9649BB.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>SDS</linktext></link></linkpool></related-links>
