<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-57A01ACA-65B0-4E2F-80A5-827A80DA7A2F" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-57A01ACA-65B0-4E2F-80A5-827A80DA7A2F" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Clean the platen</title><abstract class="- topic/abstract " id="GUID-DAC521FD-E03E-41BD-AD12-5D714F339050"><p class="- topic/p ">When you see pollution on the platen or on the back of your print, immediately clean the platen. 
</p><p class="- topic/p "> It is advised to clean the platen regularly to keep the printer in the best condition. 
</p><p class="- topic/p "> Video: <ph class="- topic/ph " varid="Video: 6 - Clean the platen"><xref class="- topic/xref " format="html" href="https://sus.cpp.canon/0Q4XB30R" scope="external"><?ditaot usertext?> 
<image class="- topic/image " href="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png" placement="inline" otherprops="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png"/> Clean the platen</xref></ph> 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="PREREQ_4A7484C23E5E46BA8D46F5927CC3D1A5" class="- topic/section task/prereq "><p class="- topic/p ">Use <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> prescribed: 
</p><ul id="UL_F7D24440ECD14DC3855D62229C39E403" class="- topic/ul "><li id="LI_F25E77D536FB4B799C750062564C45BC" class="- topic/li "><p class="- topic/p "><ph translate="no" class="- topic/ph ">Microflex</ph> gloves for handling ink 
</p></li><li id="LI_E6E8F65EDAAD4C49A430C5EE6B66BE55" class="- topic/li "><p class="- topic/p ">Lint free cloths 
</p></li><li class="- topic/li "><p class="- topic/p ">Rough lint free cloths 
</p></li><li id="LI_75F3D3584EDA44A6BE2FEB3B7513627F" class="- topic/li "><p class="- topic/p ">Cleaning liquid (IPA) 
</p></li><li class="- topic/li "><p class="- topic/p ">Compressed air duster 
</p></li><li class="- topic/li "><p class="- topic/p ">Micro cleaning brushes (2,5 mm / 0.1 inch) 
</p></li><li class="- topic/li "><p class="- topic/p ">Scraper
</p></li></ul></prereq><section id="SECTION_D0733117B373496C80C08866542BBEDF" class="- topic/section "><title class="- topic/title "/><note id="GUID-16B554D0-ACE9-40FC-AB3B-182DD41ABC4B" class="- topic/note " type="caution"><p class="- topic/p "> Wear gloves when contact with ink or maintenance materials is possible. Gloves should always overlap sleeves. Wear safety glasses with side shields when handling ink or maintenance materials. Follow the ink related Safety Data Sheets (SDS) guidelines carefully in order to ensure maximum safety. 
</p></note><note id="GUID-3D38017E-CE45-4D24-8CE5-6DBD1A047EBB" class="- topic/note " type="caution"><p class="- topic/p ">Do not use compressed air duster in any way other than described in this procedure. 
</p></note></section><steps id="GUID-3BDB9201-C1F8-4666-82D4-C65047E6568B" class="- topic/ol task/steps "><step id="STEP_D9D8CC11CCB241E6AD09C94070FBCFAA" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Start the maintenance action via the operator panel. For more information, see 
<xref keyref="07USER005" class="- topic/xref " href="GUID-3489F2DA-A0B3-48F6-BA46-CB3C83BB335E.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 07 Start manual maintenance?>07 Start manual maintenance</xref> or 
<xref keyref="07_Start_periodic_maintenance" class="- topic/xref " href="GUID-71890032-A0EB-41FD-B5D8-6E897C19CA25.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text Start periodic maintenance?>Start periodic maintenance</xref>. 
</cmd></step><step id="STEP_B29030E1E27D43F180EB17F4B5D97808" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Put on the <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> approved gloves. 
</cmd></step><step id="STEP_4B134F02EFF44307B77208233EE344ED" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Open the top cover from the media input side. 
</cmd></step><step id="STEP_1789228AE5274F48A1CBE467B05426D0" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">If present, remove the media from the paper path.
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Examine the platen: 
</cmd><choices class="- topic/ul task/choices "><choice class="- topic/li task/choice "><p class="- topic/p ">When you see uncured ink on the platen, dab the area with a lint free cloth to avoid rubbing ink into the suction holes. 
</p></choice><choice class="- topic/li task/choice "><p class="- topic/p ">When you see cured ink residue, use a scraper to remove the ink carefully. 
</p></choice></choices></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Use the compressed air duster to open the suction holes. 
</cmd><info class="- topic/itemgroup task/info "><fig id="GUID-53146D48-ECAC-42F0-B1A0-2227B49B7865" class="- topic/fig "><image href="GUID-332F3F9B-32F3-4AB4-B59C-952ABBDA01E1-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-332F3F9B-32F3-4AB4-B59C-952ABBDA01E1-low.png"/></fig></info><info class="- topic/itemgroup task/info "><note id="GUID-0FD030D6-D563-4F56-BD7D-FDD091521D37" class="- topic/note "><p class="- topic/p "> If necessary, you can also use a 2,5 mm (0.1 inch) micro cleaning brush. 
</p></note></info></step><step id="STEP_9A2B2058AC7E45BCAEB8321427213CFE" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dampen a rough lint free cloth with the cleaning liquid and clean the complete platen area. If necessary, you can clean the area surrounding the maintenance station as well. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-182D0879-C33F-47C7-BC4C-F450AEE86CDC" type="important" class="- topic/note "><ul id="UL_2BD801D8EC694A708CE03813EC3054B1" class="- topic/ul "><li id="LI_6B2477CA6A9347049F14C8780BE77E80" class="- topic/li "><p class="- topic/p ">Use the prescribed cleaning liquid. Do not use any other cleaners. 
</p></li><li id="LI_5E3536A44A624EF88E7569D2B1E32CDB" class="- topic/li "><p class="- topic/p ">Do not wet the platen directly, as you can damage the printheads. 
</p></li><li class="- topic/li "><p class="- topic/p ">Do not clean outside the indicated area to avoid damaging the system. 
</p></li></ul><fig id="FIG_09184B3143F5497C997802F1B3BC38FB" class="- topic/fig "><image href="GUID-56F2AE5A-6385-4921-8610-586D1517CDB3-low.png" id="IMAGE_56BC610EA7D14161BD29206DF8835DA7" keyref="" placement="inline" class="- topic/image " otherprops="GUID-56F2AE5A-6385-4921-8610-586D1517CDB3-low.png"/></fig></note></info></step><step id="STEP_9656026F615546919EE38264F34D0DF0" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">When all residue ink is removed, take a new and clean lint free cloth to wipe the complete platen. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-891F0E17-240C-4686-904D-37418AABED1D" type="important" class="- topic/note "><p class="- topic/p ">Do not clean the transport rollers. When the rollers are polluted call your local service representative. 
</p><fig id="FIG_92A150619F4144F9830E74B4AE60430E" class="- topic/fig "><image href="GUID-4B1DC43B-2420-4E3B-AA82-7DC0871D7379-low.png" id="IMAGE_1AD0DD5BAAAB48F0989D43E2DF9061D6" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4B1DC43B-2420-4E3B-AA82-7DC0871D7379-low.png"/></fig></note></info></step><step id="STEP_EBEBDEC595AB4585A28F21EBAEE0178B" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dispose the gloves, cloths, and micro cleaning brushes as chemical waste according to local regulations. 
</cmd></step><step id="STEP_7194D741D602410E8E30E901692E5F93" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Close the top cover. 
</cmd></step><step id="STEP_171FF2C9F334469C93A6F7E231FFC777" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">On the operator panel tap <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text id="COMPLETED_BUTTON" class="- topic/text ">Completed</text></uicontrol></ph> to end the maintenance action. 
</cmd></step></steps><postreq id="POSTREQ_E8DC9A3B917F444BAC569DCC4DF331C0" class="- topic/section task/postreq "><p class="- topic/p ">Reload the media. 
</p></postreq></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-99B79551-BE67-41AD-95FC-BDB28BED4A4E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
</task>