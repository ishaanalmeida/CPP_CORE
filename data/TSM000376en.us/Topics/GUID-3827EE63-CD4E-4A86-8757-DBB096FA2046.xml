<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-3827EE63-CD4E-4A86-8757-DBB096FA2046" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-3827EE63-CD4E-4A86-8757-DBB096FA2046" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">11 How to open and close the covers of the <ph varref="controller" class="- topic/ph ">Windows controller</ph></title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="M140819-B66" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Power off the system</b>: 
</p><p class="- topic/p ">On the operator panel, tap on the [System] icon on the right. Tap on [Power management]. Tap on [Power off]. The system shuts down. 
</p></li><li class="- topic/li "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Switch off the power supply</b>: 
</p><p class="- topic/p ">When the system has shut down, pull to open the cover under the roll winder. Switch the power switch to the 'off' position. 
</p></li><li id="LI_AA82ABC1F4464D50874D6E2846837DDC" class="- topic/li "><p class="- topic/p ">Remove the windows controller. 
</p><p class="- topic/p ">See : 
<xref keyref="20DISA-CONTROLLER" class="- topic/xref " href="GUID-A1843CF6-5762-4FEC-9CF3-EF86B7960A0F.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 11 How to remove the Windows Controller?>11 How to remove the Windows controller (11pba04)</xref>. 
</p></li></ol></prereq><section id="GUID-F56DEEE4-F746-4C5E-B808-E951147DF22A" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Caution:</ph></title><p class="- topic/p ">After you open the cover, use antistatic precautions to prevent damage to the hardware. 
</p></section><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A32A562039FB485780CA65B069EE577C" class="- topic/ul "><li id="LI_1D9EE245DE6547E09D8CB22E45CFC7A0" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li></ul></section><section id="M140819-B69" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Illustration</ph></title><fig outputclass="figure" id="M140819-F70" class="- topic/fig "><image href="IL041738-low.jpg" id="M140819-SH71" placement="inline" class="- topic/image " otherprops="IL041738-low.jpg"/></fig></section><section id="SECTION_8E9846E44F864A7997F0934846FF338A" class="- topic/section "><title class="- topic/title ">To open the cover.</title><table pgwide="1" id="TABLE_3E50B37D869F47EB9155BD0410C2A439" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the controller on a flat surface. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 6 indicated torx screws from the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_0B32764F044F4403872C1FE3565621A5" class="- topic/fig "><image href="GUID-C9ACB6D6-C147-40CC-A440-324AF095E123-low.png" id="IMAGE_2793EA25C6AE4C18A3ACC96A92785C22" placement="inline" class="- topic/image " otherprops="GUID-C9ACB6D6-C147-40CC-A440-324AF095E123-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift the top cover and remove it. 
</p><fig id="GUID-99578C01-5C3F-40C9-A12B-2FA8F5815F61" class="- topic/fig "><image href="GUID-EC4BCBEB-94E0-4A06-82E4-94CC5E901BBA-low.png" placement="inline" class="- topic/image " otherprops="GUID-EC4BCBEB-94E0-4A06-82E4-94CC5E901BBA-low.png"/></fig><note id="GUID-B8514ECA-FBF3-432A-A915-C80806AB8DF4" class="- topic/note "><p class="- topic/p ">Note: both the red marked areas contain the serial number of the controller.
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_B217EDECA7694AC78549962D8E89D616" class="- topic/fig "><image href="GUID-2DE07059-4CD7-4929-873C-7CBAF4E7A449-low.png" id="IMAGE_228529EDC3C44C05960DA99EB71C403C" placement="inline" class="- topic/image " otherprops="GUID-2DE07059-4CD7-4929-873C-7CBAF4E7A449-low.png"/></fig><fig id="FIG_26B87CD1A68343F398D8BD767D1B8409" class="- topic/fig "><image href="GUID-CE2EBBE3-F4CF-4213-9AC7-AB06FF99DC64-low.png" id="IMAGE_0EE2F14CF91844768E790194065B156F" placement="inline" class="- topic/image " otherprops="GUID-CE2EBBE3-F4CF-4213-9AC7-AB06FF99DC64-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="SECTION_9DC6AAEAA9874830B25C3108486F74E1" class="- topic/section "><title class="- topic/title ">To close the cover.</title><table pgwide="1" id="TABLE_ACF13DA9FE644D918F208B88A72C6076" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the top cover with the ventilation holes oriented towards the system board. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><note type="important" id="GUID-4C05BD1A-897C-4815-ACFB-BFBB3D233676" class="- topic/note "><p class="- topic/p ">Make sure that no tools or additional parts are left inside the controller. 
</p></note></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount and tighten the 6 torx screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-39F03561-726E-48AE-8499-199AA586A300.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
