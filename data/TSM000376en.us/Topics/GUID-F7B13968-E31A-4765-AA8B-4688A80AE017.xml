<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-F7B13968-E31A-4765-AA8B-4688A80AE017" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-F7B13968-E31A-4765-AA8B-4688A80AE017" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Transport media by manual control</title><abstract class="- topic/abstract " id="GUID-EFE87B7C-BC79-4BBD-9A3C-6B6D0DE9D42E"><p class="- topic/p ">You can move the media before and between jobs. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><steps id="GUID-A62ECE84-C54C-4A0D-BF12-3A93B521E737" class="- topic/ol task/steps "><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">On the operator panel tap on the <uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Output</text></uicontrol> icon. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d106081e26" class="- topic/fig "><image href="GUID-3C7FF9F6-D71E-4AD1-B9D3-A8BA597A1F85-low.png" placement="inline" class="- topic/image " otherprops="GUID-3C7FF9F6-D71E-4AD1-B9D3-A8BA597A1F85-low.png"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Select <uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Manual control</text></uicontrol> as <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Transport mode</text></uicontrol></ph>. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Select the transport direction. 
</cmd><info class="- topic/itemgroup task/info "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Forward</text> </uicontrol> will transport the media towards the winder. 
</p></li><li class="- topic/li "><p class="- topic/p "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Backward</text> </uicontrol> will transport the media back in the direction of the drawer. 
</p></li></ul></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Start</text></uicontrol>.</ph> 
</cmd><info class="- topic/itemgroup task/info "><p class="- topic/p ">The media will move in the direction you selected. A stop option becomes available. 
</p><note type="important" id="d106081e67" class="- topic/note "><p class="- topic/p ">When media transport is started in the forward direction, the system will keep spooling media until the roll is empty. 
</p></note><note id="d106081e70" class="- topic/note "><p class="- topic/p ">Backward transport is limited by the available media on the platen and the winder. No media will be removed from the winder. 
</p><p class="- topic/p ">It is not possible to move printed media back into the drawer. 
</p></note></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Stop</text></uicontrol> to stop the transport.</ph> 
</cmd><info class="- topic/itemgroup task/info "><note id="d106081e85" class="- topic/note "><p class="- topic/p ">Depending on the settings <ph translate="no" class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol ">Moist sensitivity</uicontrol></ph> and <ph translate="no" class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol ">Auto media advance</uicontrol></ph> the actual print position can vary. <ph translate="no" class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol ">Moist sensitivity</uicontrol></ph> timers are restarted after the movement has been stopped. 
</p></note></info></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B8E84B8-092A-4B76-84E3-AA295749E97E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
