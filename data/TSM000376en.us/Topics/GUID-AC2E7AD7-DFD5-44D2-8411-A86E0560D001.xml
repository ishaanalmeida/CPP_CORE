<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-AC2E7AD7-DFD5-44D2-8411-A86E0560D001" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-AC2E7AD7-DFD5-44D2-8411-A86E0560D001" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">21 How to remove the <ph varid="Econtroller" class="- topic/ph ">Embedded controller</ph> box</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-EAE9688E-0949-4747-A18B-A892EA3F0C4E" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Power off the system</b>: 
</p><p class="- topic/p ">On the operator panel, tap on the [System] icon on the right. Tap on [Power management]. Tap on [Power off]. The system shuts down. 
</p></li><li class="- topic/li "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Switch off the power supply</b>: 
</p><p class="- topic/p ">When the system has shut down, pull to open the cover under the roll winder. Switch the power switch to the 'off' position. 
</p></li><li id="LI_719C03885B0C4EF3B8A90E91E1F7C293" class="- topic/li "><p class="- topic/p ">Disconnect the printing system from mains. 
</p></li><li id="LI_C4E6554D4D1E4A458BEF9A08F728017A" class="- topic/li "><p class="- topic/p ">Open the chiller to get access to the controller. 
</p><p class="- topic/p ">See : 
<xref keyref="06DISA003V2" class="- topic/xref " href="GUID-BF384AC4-FF34-48F3-9D8C-4DB12B517E06.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06 How to open the Chiller (V2)?>06 How to open the Chiller (V2)</xref> 
</p></li></ol><note type="important" id="GUID-C5DDA43B-326C-49A5-A87F-C6D341BD4C04" class="- topic/note "><p class="- topic/p ">Disconnect the optical connection from the <ph varid="Econtroller" class="- topic/ph ">Embedded controller</ph> and put the end caps on the cable. 
</p><p class="- topic/p ">If anything goes wrong this cable gets damaged easily and it takes a lot of work to replace. 
</p></note></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_5232B115C44C4A13A0F0FA8D704DDD74" class="- topic/ul "><li id="LI_9BF138AF80F34359907B618BBA28D88F" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_74B34E5D503541589EF0DF496897EA75" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="FIG_69C1EAA7F58C4BF999C0D3928459EF44" class="- topic/fig "><image href="GUID-CA7D1606-7DDB-4ACD-A201-0097168D621A-low.png" id="IMAGE_45F5CDDD5E844546A5744FD589537B57" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CA7D1606-7DDB-4ACD-A201-0097168D621A-low.png"/></fig></section><section id="SECTION_F9B116EF74204DA981055094F2F89A8C" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_E396294170254881A05F6C6D75A63922" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Loosen the 2 screws 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_739E94FD5A7B42968541BA79B390786E" class="- topic/fig "><image href="GUID-F849AB02-2D9B-4EC8-9077-9E6A2B3B6F90-low.png" id="IMAGE_D3C4A6075FBB4150A385406A3CA7F3AB" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F849AB02-2D9B-4EC8-9077-9E6A2B3B6F90-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 2 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_54B188525C6043E1A7D44EABCB2464C7" class="- topic/fig "><image href="GUID-6D8D0C7B-9B82-45BB-8A65-EAAE0988527A-low.png" id="IMAGE_26FBE8E2C37D4BD79236C1E76C8B0391" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6D8D0C7B-9B82-45BB-8A65-EAAE0988527A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Lift the box and place it on the frame. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_156DAB7096084A46B24239646CEDEF8D" class="- topic/fig "><image href="GUID-6EE914B1-E81F-4E80-891F-04C030847E59-low.png" id="IMAGE_7CC68153C323486E8150CDB94D1539FF" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6EE914B1-E81F-4E80-891F-04C030847E59-low.png"/></fig><fig id="FIG_298EE0406FE2476087BF5D9FE4087EB8" class="- topic/fig "><image href="GUID-E2957DAE-29F9-4942-B814-C2CE2C107258-low.png" id="IMAGE_6A060E154EDF48DFABF83D9556304F48" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E2957DAE-29F9-4942-B814-C2CE2C107258-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connectors at the left hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_56988B410E364C9CB38672572652E152" class="- topic/fig "><image href="GUID-A97BBE86-714C-41F6-9E94-A1547717297F-low.png" id="IMAGE_E962293AB29E4BCA882F383DB055D07E" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A97BBE86-714C-41F6-9E94-A1547717297F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the unit on the floor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_7230E0D0D06C49FFA0F2194B010F6D50" class="- topic/fig "><image href="GUID-CA7D1606-7DDB-4ACD-A201-0097168D621A-low.png" id="IMAGE_EEDB8183B5E143EBA282B40960EA0741" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CA7D1606-7DDB-4ACD-A201-0097168D621A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the top cover (6 screws). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_A6415926C28E41B38297105BC983B9EB" class="- topic/fig "><image href="GUID-9D8E0474-6C57-4CF6-9E22-0BF02623CDF6-low.png" id="IMAGE_29358022303246C698513F8FD5DC9774" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9D8E0474-6C57-4CF6-9E22-0BF02623CDF6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_378601F6196F436AB6E64EDD34ABACB9" class="- topic/fig "><image href="GUID-FFE84391-AB34-4024-B2D3-537F1FD76513-low.png" id="IMAGE_40A0C874E8CF4133A1B706D4DE237339" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FFE84391-AB34-4024-B2D3-537F1FD76513-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connector of the blue cable. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_DE5C5228F3D64EC6A3D4BBD0FCD5422B" class="- topic/fig "><image href="GUID-BF8D340D-5A50-430F-891A-536F205E5E7F-low.png" id="IMAGE_AD68E486CA1046A4BFDF98A24993FF9D" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BF8D340D-5A50-430F-891A-536F205E5E7F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place the unit on a table. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_C0D69F0D429A42D9AF656D01CDD64255" class="- topic/fig "><image href="GUID-D7ADD749-1CEC-459A-8900-33C4C17D5160-low.png" id="IMAGE_00AAEDA66626430DAD926D8219481941" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D7ADD749-1CEC-459A-8900-33C4C17D5160-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_97BC00975228435B8A284A8C547372BA" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check if the ON/OFF switch of the <ph varid="Econtroller" class="- topic/ph ">Embedded controller</ph> is in the ON position. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-6C63EF43-7F31-48D5-A8F0-5338D21560E2.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
