<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-3C378CEF-8BD5-4962-B1D3-3085A8622216" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-3C378CEF-8BD5-4962-B1D3-3085A8622216" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">02 How to remove the ink low sensor (02B1/3/5/7) </title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the following ink low sensors: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname "> Ink system Yellow low</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02B1 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_2_LOW_SE</compsignal></comp> 
</p></li><li class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname "> Ink system Cyan low sensor</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02B3 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_3_LOW_SE</compsignal></comp> 
</p></li><li class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname "> Ink system Magenta low sensor</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02B5 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_4_LOW_SE</compsignal></comp> 
</p></li><li class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname "> Ink system Black low sensor</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02B7 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_5_LOW_SE</compsignal></comp> 
</p></li><li class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname "> Ink system White low sensor</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02B50 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_6_LOW_SE</compsignal></comp>
</p></li></ul></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ul id="UL_ED1E57E435C04FED8E5EC56505FB661D" class="- topic/ul "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_B00BCB492EC546EE98CD25996779F334" class="- topic/li "><p class="- topic/p ">Remove the lower cover of the ink system. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA052" class="- topic/xref " href="GUID-3EA4F7FC-3249-452F-A681-38FC94D794B9.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the lower cover of the ink system?>24 How to remove the lower cover of the ink system</xref> 
</p></li></ul></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_08748A8587B8482A9E9DEA2653E49E12" class="- topic/ul "><li id="LI_8EE72955CE55481BA4D4C3554D480CA4" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-E99203E3-CECE-4EB2-8DA0-613B909D1169" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-E9EC8D7F-7A51-4201-BEBC-31CE4A493156" class="- topic/fig "><title class="- topic/title "/><image href="GUID-C94DCFA7-A0B2-4A09-856C-8EB9A00F40ED-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C94DCFA7-A0B2-4A09-856C-8EB9A00F40ED-low.png"/></fig><fig id="FIG_CE629144DC724BBEBAB0BD04FC17B295" class="- topic/fig "><image href="GUID-3374DCEC-6533-45D5-A311-FA8BE9A16AFE-low.png" id="IMAGE_2C36A0BCAC464F74B5D1BA462A046EC7" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3374DCEC-6533-45D5-A311-FA8BE9A16AFE-low.png"/></fig></section><section id="SECTION_2F7F0CBAA76D443290F80A50625B0D66" class="- topic/section "><title class="- topic/title ">How to remove</title><table id="TABLE_4054F2BDDF184343A0DC2589CCC5F48F" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 3 x T20 screws of the cover with the PBA. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_8DFFDCC92E654C95A5FE98B3E3E0C1D0" class="- topic/fig "><image href="GUID-354B587A-D035-4D4B-9EF0-BDABB367EDA8-low.png" id="IMAGE_0EAC527E8EC2412DB4E2559F815EC0A9" keyref="" placement="inline" class="- topic/image " otherprops="GUID-354B587A-D035-4D4B-9EF0-BDABB367EDA8-low.png"/></fig><fig id="FIG_168CE1632DD843F98759E6E29689CF6B" class="- topic/fig "><image href="GUID-71C672C3-BB0D-40DC-B014-B373B426720F-low.png" id="IMAGE_13830660C36C4474AD42620969E0A253" keyref="" placement="inline" class="- topic/image " otherprops="GUID-71C672C3-BB0D-40DC-B014-B373B426720F-low.png"/></fig><fig id="GUID-40251B44-D4CA-4D7F-9B99-6F3868AC8E17" class="- topic/fig "><image href="GUID-47E7D524-55D6-4B44-8E83-09F4C26421EC-low.png" id="IMAGE_03A4E2845A6B47079E20F930FF3B3337" keyref="" placement="inline" class="- topic/image " otherprops="GUID-47E7D524-55D6-4B44-8E83-09F4C26421EC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the cover carefully. 
</p><note id="GUID-1092C479-E5FB-4149-B8C5-9BF0B5D4D4DB" class="- topic/note "><p class="- topic/p ">Lift the cover a littlebit, so you do not damage the ink leakage sensor. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_109E9DC3A6024E459C468D8449B4608D" class="- topic/fig "><image href="GUID-20E16780-2C0F-4B78-8428-B4765AE83056-low.png" id="IMAGE_F8F6FAC72F8E4965BE91350441F83300" keyref="" placement="inline" class="- topic/image " otherprops="GUID-20E16780-2C0F-4B78-8428-B4765AE83056-low.png"/></fig><fig id="GUID-220B9533-767A-43EE-9289-16C4E749F95A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-C94DCFA7-A0B2-4A09-856C-8EB9A00F40ED-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C94DCFA7-A0B2-4A09-856C-8EB9A00F40ED-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 4 x T10 screws of the sensor assembly of the required color. Example: black color. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-05721FDC-6F16-47A8-84FD-2F52E8441575" class="- topic/fig "><title class="- topic/title "/><image href="GUID-E5DEBFAE-73F4-454F-8A4E-FF50668F0B95-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E5DEBFAE-73F4-454F-8A4E-FF50668F0B95-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Take the assembly. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-82B16746-BAB4-4CF7-8FFD-7EF61399FBDA" class="- topic/fig "><title class="- topic/title "/><image href="GUID-6BD964C1-338E-4C25-ADDE-BA44368D4BD9-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6BD964C1-338E-4C25-ADDE-BA44368D4BD9-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the 2 screws of the low sensor. 
</p><p class="- topic/p ">The top sensor is the high level sensor and the lower is the low level sensor. 
</p><note id="GUID-04BCFD2B-4DD7-4792-AF58-AF8A1373114B" class="- topic/note "><p class="- topic/p ">2 small nuts are positioned on the rear side of the sensor. Do not loosen them. 
</p></note></li><li class="- topic/li "><p class="- topic/p ">Disconnect the connector. 
</p></li><li class="- topic/li "><p class="- topic/p "> Remove the sensor. 
</p><note id="GUID-C4DD49A4-0E82-4623-ABAF-D559E5026C5B" class="- topic/note "><p class="- topic/p ">Never turn the adjustment screw on the sensor. The sensors are calibrated. 
</p></note></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3DB07968-12AC-48EF-85D1-68FF8AEACBC4" class="- topic/fig "><title class="- topic/title "/><image href="GUID-EE1494BC-2503-4799-A480-814044FCCF3B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EE1494BC-2503-4799-A480-814044FCCF3B-low.png"/></fig><fig id="GUID-9412C6A3-2535-446A-85F1-239619D20CFD" class="- topic/fig "><image href="GUID-3374DCEC-6533-45D5-A311-FA8BE9A16AFE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3374DCEC-6533-45D5-A311-FA8BE9A16AFE-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-1CE85252-F6D3-4421-930B-8AE723FFB49C.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
