<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-D4EA7871-A68B-4AFC-A427-E7F83D8CF988" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-D4EA7871-A68B-4AFC-A427-E7F83D8CF988" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 Configure the FLXfinish<sup class="+ topic/ph hi-d/sup ">+</sup> kit in Onyx</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes the configuration of the FLXfinish<sup class="+ topic/ph hi-d/sup ">+</sup> kit in Onyx. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Configuration</title><fig id="GUID-02547609-B953-4AE2-B1D8-552227A10A0B" class="- topic/fig "><image href="GUID-813B37C4-C65D-4A08-908D-FE570862A1E8-low.png" placement="inline" class="- topic/image " otherprops="GUID-813B37C4-C65D-4A08-908D-FE570862A1E8-low.png"/></fig><p class="- topic/p ">Select 'Canon Colorado M-series' 
</p><p class="- topic/p ">Click 'Configure Printer' 
</p><fig id="GUID-3A249B24-C32D-4745-9246-709BB938F20A" class="- topic/fig "><image href="GUID-5F1628BD-0034-44E4-B0B4-27AD8B1996F4-low.png" placement="inline" class="- topic/image " otherprops="GUID-5F1628BD-0034-44E4-B0B4-27AD8B1996F4-low.png"/></fig><p class="- topic/p ">Select 'Device tab' 
</p><p class="- topic/p ">Select 'Canon Colorado M-series' 
</p><p class="- topic/p ">Click 'features...' 
</p><fig id="GUID-4B58D511-7D3E-4A3A-8B69-F3A97CA9518A" class="- topic/fig "><image href="GUID-B2C277BD-B1B9-4E64-93B4-910CBCF9D9B9-low.png" placement="inline" class="- topic/image " otherprops="GUID-B2C277BD-B1B9-4E64-93B4-910CBCF9D9B9-low.png"/></fig><p class="- topic/p ">Select 'Global Printer Options' 
</p><p class="- topic/p ">Click 'Configure...' 
</p><fig id="GUID-A3E8322F-3154-4080-8043-1334DBD619DD" class="- topic/fig "><image href="GUID-6DED795C-5B4E-4106-B501-3FB57F11EB55-low.png" placement="inline" class="- topic/image " otherprops="GUID-6DED795C-5B4E-4106-B501-3FB57F11EB55-low.png"/></fig><p class="- topic/p ">Enable checkmark 'Printing with FLXfinish+ and matte print modes' 
</p><p class="- topic/p ">Enable checkmark 'Printing with with white ink' (in case the printer has White ink)
</p><p class="- topic/p ">click 'ok' 
</p></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-85BBDF53-3072-4F26-AB81-F8A265B585A8.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
