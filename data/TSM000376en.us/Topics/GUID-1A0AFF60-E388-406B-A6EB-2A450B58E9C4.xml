<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-1A0AFF60-E388-406B-A6EB-2A450B58E9C4" version="1" lang="en-US"?><concept xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-1A0AFF60-E388-406B-A6EB-2A450B58E9C4" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic concept)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c concept oceConcept-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic concept/concept "><title class="- topic/title ">How to setup Chrome to use an external PDF viewer</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Frequently Asked Question</category></metadata></prolog><conbody class="- topic/body  concept/conbody "><section id="GUID-C0A36A90-0495-47CC-8DFB-93065E0B36A5" class="- topic/section "><title class="- topic/title ">Introduction</title><p class="- topic/p ">By default Chrome uses its internal PDF viewer. 
</p><p class="- topic/p ">This internal reader does not provide the same functionality as for instance Acrobat reader. 
</p><p class="- topic/p ">One of the important things missing is the view of attachments in the PDF commonly used in this TSM. 
</p><p class="- topic/p ">. 
</p><p class="- topic/p ">This document describes how to setup your system to use an external viewer for PDF files in Chrome. 
</p><p class="- topic/p ">After this setup Chrome will show the regular download dialogue and from there you can open the PDF with Acrobat reader for instance. 
</p></section><section id="GUID-88843D14-6C38-4CFF-97B6-A195F5500044" class="- topic/section "><title class="- topic/title ">Step 1 : Use Windows Settings to select the default program for files with a .PDF extension</title><table id="GUID-1921F4A8-4B4C-4928-A1B2-69BF64B0FC7F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="20*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="70*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Start windows "Settings". 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FDCD1CCA-50A8-4428-A3DF-9B70A53ED8C5" class="- topic/fig "><title class="- topic/title ">Settings button in start menu</title><image href="GUID-34F6F6E4-F3AB-4B3E-A6AF-8C960522C32C-low.png" placement="inline" class="- topic/image " otherprops="GUID-34F6F6E4-F3AB-4B3E-A6AF-8C960522C32C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Click the "Apps" button. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8569BFF1-C1E8-43A2-B786-90A93A642680" class="- topic/fig "><title class="- topic/title ">Apps button</title><image href="GUID-329EF691-B4FC-48E4-A39B-4D4D327CCBAF-low.png" placement="inline" class="- topic/image " otherprops="GUID-329EF691-B4FC-48E4-A39B-4D4D327CCBAF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Select "Default apps". 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-DD57A620-8660-4B00-B6EC-B0FE6A5ED077" class="- topic/fig "><title class="- topic/title ">Default apps</title><image href="GUID-2F725504-10D3-4640-884E-A2D7917B1C2B-low.png" placement="inline" class="- topic/image " otherprops="GUID-2F725504-10D3-4640-884E-A2D7917B1C2B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Select "Choose default apps by file type". 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-267A9E01-E37B-402A-A249-71180B3BBD62" class="- topic/fig "><title class="- topic/title ">Choose default apps by file type</title><image href="GUID-2398CD51-3E57-4214-8A2B-2BEB69BB7513-low.png" placement="inline" class="- topic/image " otherprops="GUID-2398CD51-3E57-4214-8A2B-2BEB69BB7513-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">At the entry for .pdf choose the app you like to use for PDF files. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3D30C921-73D8-4926-A8A2-38E74B2D7485" class="- topic/fig "><title class="- topic/title ">Acrobat reader selected</title><image href="GUID-470368DE-A38F-41AD-AA13-FA05F5312818-low.png" placement="inline" class="- topic/image " otherprops="GUID-470368DE-A38F-41AD-AA13-FA05F5312818-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Leave settings 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-C053E121-D8A2-4FA5-B051-EA7F8053D458" class="- topic/section "><title class="- topic/title ">Step 2 : Use the Chrome settings to set the correct site permissions.</title><table id="GUID-977DDCAF-8439-44FC-BDA8-30CF7A225F12" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="20*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="70*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open Settings in Chrome. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Click the 3 dots in the top right hand corner. 
</p></li><li class="- topic/li "><p class="- topic/p ">Click settings in the menu. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1304847E-C2EC-48F3-A718-3E2F24BB0CFF" class="- topic/fig "><title class="- topic/title "/><image href="GUID-11870C06-AC6F-4738-B66A-F4FDC7EABE1B-low.png" placement="inline" class="- topic/image " otherprops="GUID-11870C06-AC6F-4738-B66A-F4FDC7EABE1B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Click "Privacy and security". 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EC066206-5ADD-4601-A5CD-3EBFCB98C9F7" class="- topic/fig "><title class="- topic/title "/><image href="GUID-0F6CFA18-22E0-49D6-9894-36A5044F93AE-low.png" placement="inline" class="- topic/image " otherprops="GUID-0F6CFA18-22E0-49D6-9894-36A5044F93AE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Click "Site settings". 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-528370AC-B732-4361-BDE3-5B094E091517" class="- topic/fig "><title class="- topic/title "/><image href="GUID-7325F2F8-2D79-4DD0-82B2-615D528854BB-low.png" placement="inline" class="- topic/image " otherprops="GUID-7325F2F8-2D79-4DD0-82B2-615D528854BB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Click "Additional content settings" at the bottom of the page. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6648F7A9-BA6A-42B6-A794-396C1025BBC8" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B1C3F3E9-1318-41FA-8F25-30E2C54286F0-low.png" placement="inline" class="- topic/image " otherprops="GUID-B1C3F3E9-1318-41FA-8F25-30E2C54286F0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Click "PDF documents". 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F9135B93-9CBA-4B1F-A655-999D355F0B83" class="- topic/fig "><title class="- topic/title "/><image href="GUID-9DF5495D-388D-4509-A7F0-9F312AA1E0AD-low.png" placement="inline" class="- topic/image " otherprops="GUID-9DF5495D-388D-4509-A7F0-9F312AA1E0AD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Select "Download PDFs". 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0612EEBC-9D01-487F-A9AB-AEDA36CF113E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-2EC6841E-A13A-4E4B-8944-403D8ACE3BFB-low.png" placement="inline" class="- topic/image " otherprops="GUID-2EC6841E-A13A-4E4B-8944-403D8ACE3BFB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Leave settings. (Close the settings window) 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></conbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-A0CF852B-8B0E-4383-A7DF-C2694332F401.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Frequently Asked Question</linktext></link></linkpool></related-links>
