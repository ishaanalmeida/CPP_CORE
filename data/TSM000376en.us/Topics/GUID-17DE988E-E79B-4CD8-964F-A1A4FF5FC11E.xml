<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-17DE988E-E79B-4CD8-964F-A1A4FF5FC11E" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-17DE988E-E79B-4CD8-964F-A1A4FF5FC11E" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to remove the lower MLO roller (media feed of roll position 2)</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_34F2C03C97F249649B92631C09DBB41B" class="- topic/li "><p class="- topic/p ">Open the media loading drawer. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the media in the media loading drawer. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_69BB0AEB395F4E8AB96FD94A4C0C8696" class="- topic/ul "><li id="LI_06B1AE50C8584502AA32D102711C1229" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li id="LI_561D1BF957EA49F8BB49139266A92893" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T30. 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver 
</p></li><li id="LI_B784B59E966743309622F0F98A079F05" class="- topic/li "><p class="- topic/p ">2 x Open ended spanner 13. 
</p></li><li class="- topic/li "><p class="- topic/p ">2 pieces of tape or a sheet of media. 
</p></li><li class="- topic/li "><p class="- topic/p ">Torx 30 screw (used e.g in the hinge of the top cover). 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-65CFA031-AB17-495C-803A-89CF8C3311C9" class="- topic/fig "><title class="- topic/title ">MLO roller</title><image href="GUID-2A1B8D51-FCC7-449C-B357-F59403920F0B-low.png" placement="inline" class="- topic/image " otherprops="GUID-2A1B8D51-FCC7-449C-B357-F59403920F0B-low.png"/></fig></section><section id="SECTION_878FB6D82409436DB8132AB7ADFA1807" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_2D6BD70DB77E4579ACF13DF02715F1F6" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the cover (8 screws) at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8661E45D-7C56-4E99-A9D8-45882F254B0A" class="- topic/fig "><image href="GUID-06E69570-CDC3-48BD-ADFA-2B7118E33F64-low.png" placement="inline" class="- topic/image " otherprops="GUID-06E69570-CDC3-48BD-ADFA-2B7118E33F64-low.png"/></fig><fig id="GUID-D573907F-2A43-46C0-B997-42F943FF57D2" class="- topic/fig "><image href="GUID-40E67322-D9BF-49F8-BD8D-91F0B7792871-low.png" placement="inline" class="- topic/image " otherprops="GUID-40E67322-D9BF-49F8-BD8D-91F0B7792871-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the end stop of the vertical transport at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-65031544-D78D-479E-8CD8-58746C6D0531" class="- topic/fig "><image href="GUID-8D855FFD-7CE3-497E-8C02-4D62D15F7E15-low.png" placement="inline" class="- topic/image " otherprops="GUID-8D855FFD-7CE3-497E-8C02-4D62D15F7E15-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the vertical transport. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-60AE764E-40D2-4F89-9914-B91A97BA6C10" class="- topic/fig "><image href="GUID-41BA6F5C-E73A-44BB-AC30-40E2B5C1164C-low.png" placement="inline" class="- topic/image " otherprops="GUID-41BA6F5C-E73A-44BB-AC30-40E2B5C1164C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the lower screw and loosen the upper screw of the guide plate at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B688850B-5FEA-43D1-B9F6-5B325A8A88A9" class="- topic/fig "><image href="GUID-7F633886-915E-459B-95DF-314588A5D323-low.png" placement="inline" class="- topic/image " otherprops="GUID-7F633886-915E-459B-95DF-314588A5D323-low.png"/></fig><fig id="GUID-BC6EFB39-788F-4CFB-BCAF-9189D7D98A14" class="- topic/fig "><image href="GUID-E15EB8BB-2B7D-4C76-82D3-BA57FC95746F-low.png" placement="inline" class="- topic/image " otherprops="GUID-E15EB8BB-2B7D-4C76-82D3-BA57FC95746F-low.png"/></fig><fig id="GUID-67964CC6-9561-4A01-8871-3DB13E39D41D" class="- topic/fig "><image href="GUID-B339AEE4-7CE1-486D-89A4-3D56F9549304-low.png" placement="inline" class="- topic/image " otherprops="GUID-B339AEE4-7CE1-486D-89A4-3D56F9549304-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the guide plate: lift it, by moving the bolt upwards, with a screwdriver. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-96029605-0420-4FC4-A44E-0AF66B6DF4C7" class="- topic/fig "><image href="GUID-57DB8406-D46D-4D32-B599-20DA8714FD41-low.png" placement="inline" class="- topic/image " otherprops="GUID-57DB8406-D46D-4D32-B599-20DA8714FD41-low.png"/></fig><fig id="GUID-CDB1C864-4A44-4DE5-B3B1-55CEA59F9DAD" class="- topic/fig "><image href="GUID-FED10BF6-29EB-422F-A579-1FF706938330-low.png" placement="inline" class="- topic/image " otherprops="GUID-FED10BF6-29EB-422F-A579-1FF706938330-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place a open ended spanner to keep the vertical transport in place. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1CF8E929-2315-44A0-9142-FFF5700DEA12" class="- topic/fig "><image href="GUID-EEA7BAD9-443C-4069-A346-512FF7EACDDB-low.png" placement="inline" class="- topic/image " otherprops="GUID-EEA7BAD9-443C-4069-A346-512FF7EACDDB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Loosen the tension of the drive belt (loosen 2 screws). 
</p><p class="- topic/p ">Remove the spring. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-996D7E41-BBB6-4CE9-8F66-28DF1503B30A" class="- topic/fig "><image href="GUID-20CB6012-7DCC-4D2D-9F47-6CCEF4AD61E5-low.png" placement="inline" class="- topic/image " otherprops="GUID-20CB6012-7DCC-4D2D-9F47-6CCEF4AD61E5-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the screw of the gear. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0AB4ACEF-1305-409B-BCF3-67C8992F6A0A" class="- topic/fig "><image href="GUID-B0EB6FCB-396E-491F-921C-D6E4C0F8E45A-low.png" placement="inline" class="- topic/image " otherprops="GUID-B0EB6FCB-396E-491F-921C-D6E4C0F8E45A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the drive belt. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the gear from the axis (conical). 
</p><p class="- topic/p ">Use a Torx T30 screw. Insert it the center of the gear. Lock it and the gear is released from the axis. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-64EEDC4F-9011-4470-98F7-A9A4CD00F4D8" class="- topic/fig "><image href="GUID-46674E32-696B-422C-A0B8-3DE79CB872EC-low.png" placement="inline" class="- topic/image " otherprops="GUID-46674E32-696B-422C-A0B8-3DE79CB872EC-low.png"/></fig><fig id="GUID-313BAD25-046B-4AB2-B913-F816F37AEE5A" class="- topic/fig "><image href="GUID-F767B4EE-849D-4A92-B51C-73C682222915-low.png" placement="inline" class="- topic/image " otherprops="GUID-F767B4EE-849D-4A92-B51C-73C682222915-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Turn the position ring of the axis till it is free from the bracket. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7173F142-D09E-4BF9-93B5-B555261D3277" class="- topic/fig "><image href="GUID-16CE6176-78F9-43EA-B579-26DAA8F07A77-low.png" placement="inline" class="- topic/image " otherprops="GUID-16CE6176-78F9-43EA-B579-26DAA8F07A77-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Push the axis to the right hand side 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-927A4EE7-BAAB-4E36-ADA0-ADE201F50FFC" class="- topic/fig "><image href="GUID-0B286115-7DAD-4363-ACA0-B9DD4FF48036-low.png" placement="inline" class="- topic/image " otherprops="GUID-0B286115-7DAD-4363-ACA0-B9DD4FF48036-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Unhook the cable from the cable guides. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-655AC2DE-478C-4883-B262-AC7E376C98F8" class="- topic/fig "><image href="GUID-EA41806D-671F-4D31-9EE3-D1F43CBF3F5C-low.png" placement="inline" class="- topic/image " otherprops="GUID-EA41806D-671F-4D31-9EE3-D1F43CBF3F5C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the sensor (1 screw). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B13D4674-5CCD-43F0-996F-F64D7E139B1B" class="- topic/fig "><image href="GUID-8B40E52F-11B9-4681-9156-83FB93D1D671-low.png" placement="inline" class="- topic/image " otherprops="GUID-8B40E52F-11B9-4681-9156-83FB93D1D671-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 cable guides (to get a better view on the sides of the roller). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-11516113-199F-40D0-AB82-178E31F36AB0" class="- topic/fig "><image href="GUID-C6E1915A-51A5-49A1-B157-2B9C4AD13420-low.png" placement="inline" class="- topic/image " otherprops="GUID-C6E1915A-51A5-49A1-B157-2B9C4AD13420-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place a piece of tape or a sheet of media over the opening of the bracket. This to prevent that the E-clips drops into the frame. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-44987395-C21E-40F7-B8D3-7148803C422B" class="- topic/fig "><image href="GUID-0DCBD911-E83E-4A9C-987E-4B741E986146-low.png" placement="inline" class="- topic/image " otherprops="GUID-0DCBD911-E83E-4A9C-987E-4B741E986146-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the E-clips at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5ABA4F00-D71A-494D-8927-8699F359E8B9" class="- topic/fig "><image href="GUID-0A0C0976-BDFF-4771-8705-FD6C408BC8D2-low.png" placement="inline" class="- topic/image " otherprops="GUID-0A0C0976-BDFF-4771-8705-FD6C408BC8D2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 bearings and roller. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0F99599D-A973-41B2-B299-681012B32202" class="- topic/fig "><image href="GUID-9D88A08A-1FFF-4A3D-A478-491B1B94B71B-low.png" placement="inline" class="- topic/image " otherprops="GUID-9D88A08A-1FFF-4A3D-A478-491B1B94B71B-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p><note id="GUID-956A624A-8538-43A7-8D30-FE3375992BAC" class="- topic/note "><p class="- topic/p ">Watch the position of the guide plate. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-AF30AA42-1168-450E-B997-1299E2468DEE" class="- topic/fig "><image href="GUID-1F89EA8C-96AB-4B1E-AD65-39FD79498235-low.png" placement="inline" class="- topic/image " otherprops="GUID-1F89EA8C-96AB-4B1E-AD65-39FD79498235-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B96AB9C-8847-4643-A8CB-09918FE19AAB.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>