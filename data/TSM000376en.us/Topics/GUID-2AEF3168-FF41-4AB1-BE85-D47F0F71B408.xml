</p></li><li id="LI_22361858FDA043B6A9F9C4A3C0BBD08B" class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">49.5 VDC Supply Printhead</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 22G05 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">49.5V_PH</compsignal></comp> 
</p></li><li id="LI_2C9833D0902F472F88A7174C46385024" class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">AC Switch</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 22PBA01 </compcodenr></comp> 
