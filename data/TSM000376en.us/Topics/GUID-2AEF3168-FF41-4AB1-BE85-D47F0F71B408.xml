</p><ul id="UL_D6BD39218D95435F951123A1F00ADF9C" class="- topic/ul "><li id="LI_4F8084D516324249AA63639851A88F06" class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">24 VDC Supply</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 22G02 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">P_24V_1</compsignal></comp> 
