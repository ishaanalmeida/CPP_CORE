<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-BD0FE76F-ABDE-4AA4-A8EA-F6A9F82AC17B" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-BD0FE76F-ABDE-4AA4-A8EA-F6A9F82AC17B" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 MOD03: Media loading Sensor Improvement Kit for weak Transparent Media</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_34F2C03C97F249649B92631C09DBB41B" class="- topic/li "><p class="- topic/p ">Open the media loading drawer. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_69BB0AEB395F4E8AB96FD94A4C0C8696" class="- topic/ul "><li id="LI_06B1AE50C8584502AA32D102711C1229" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li id="LI_561D1BF957EA49F8BB49139266A92893" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li id="LI_B784B59E966743309622F0F98A079F05" class="- topic/li "><p class="- topic/p ">Open ended spanner 13. 
</p></li><li class="- topic/li "><p class="- topic/p ">Tweezers. 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-FB485AF9-9233-4334-8327-36579A3D2042" class="- topic/fig "><title class="- topic/title "/><image href="GUID-00BA4D8E-720F-4386-B330-C6D8B122C3F0-low.png" placement="inline" class="- topic/image " otherprops="GUID-00BA4D8E-720F-4386-B330-C6D8B122C3F0-low.png"/></fig></section><section id="SECTION_9A4E31FC8A1D474082EB98039B353FF0" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_BC6D1128E6D045B0884B679CB3343E94" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cover (8 screws) at the left and right hand side.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2D219F1A-43C9-4221-99B9-D69797985A92" class="- topic/fig "><image href="GUID-1404CA69-8817-49F7-A67B-D1E48AE17F1F-low.png" placement="inline" class="- topic/image " otherprops="GUID-1404CA69-8817-49F7-A67B-D1E48AE17F1F-low.png"/></fig><fig id="GUID-665111F2-7377-493C-B6CD-6FF3C063E63F" class="- topic/fig "><image href="GUID-54358BAE-A3B8-439D-8DB4-E26C2B0B9283-low.png" placement="inline" class="- topic/image " otherprops="GUID-54358BAE-A3B8-439D-8DB4-E26C2B0B9283-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the end stop of the vertical transport at the left and right hand side.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-586FBE04-4492-4B89-B9A1-CB51D260C4D9" class="- topic/fig "><image href="GUID-30D1AAFC-2B87-441A-AEDE-D4300DBF7E2E-low.png" placement="inline" class="- topic/image " otherprops="GUID-30D1AAFC-2B87-441A-AEDE-D4300DBF7E2E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the indicated screw and nut of the mounting of the cover over the first pinch.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-ACB587DA-94E9-41A8-93AF-E190E57AE026" class="- topic/fig "><image href="GUID-36C51412-5934-4D5D-B940-7E17CB58AC82-low.png" placement="inline" class="- topic/image " otherprops="GUID-36C51412-5934-4D5D-B940-7E17CB58AC82-low.png"/></fig><fig id="GUID-479E6B82-6296-4CDD-B379-B1E82DF076CF" class="- topic/fig "><image href="GUID-046F78BB-268D-4738-B3B1-FBCF67C55A15-low.png" placement="inline" class="- topic/image " otherprops="GUID-046F78BB-268D-4738-B3B1-FBCF67C55A15-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Release the green lever and open the pinch.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-446A4775-A8D1-4A25-BDE4-52C592723448" class="- topic/fig "><image href="GUID-076AAE17-5B1C-496D-91F9-26440ED4F1CF-low.png" placement="inline" class="- topic/image " otherprops="GUID-076AAE17-5B1C-496D-91F9-26440ED4F1CF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws of the cover.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-91631EC4-6D96-411F-8323-3693E41C7321" class="- topic/fig "><image href="GUID-A67AAD7B-7E41-4D26-B0DE-EF8CA914C297-low.png" placement="inline" class="- topic/image " otherprops="GUID-A67AAD7B-7E41-4D26-B0DE-EF8CA914C297-low.png"/></fig><fig id="GUID-F7A96258-3B78-4A06-A470-8E6A284DF872" class="- topic/fig "><image href="GUID-AFF900F7-D5A9-4250-83F0-7C16B9F6F627-low.png" placement="inline" class="- topic/image " otherprops="GUID-AFF900F7-D5A9-4250-83F0-7C16B9F6F627-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the top cover.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FFDEE48E-5D76-48A9-AFB8-E6B1438CC90F" class="- topic/fig "><image href="GUID-36256803-FA55-4B6D-8003-2DE47D0260CF-low.png" placement="inline" class="- topic/image " otherprops="GUID-36256803-FA55-4B6D-8003-2DE47D0260CF-low.png"/></fig><fig id="GUID-5A115556-8DD2-4C7C-B83D-47BCD6E358B4" class="- topic/fig "><image href="GUID-ED0CB680-B89A-450C-A0C2-0D3BB2F27FE3-low.png" placement="inline" class="- topic/image " otherprops="GUID-ED0CB680-B89A-450C-A0C2-0D3BB2F27FE3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the lower screw and loosen the upper screw of the guide plate at the left and right hand side.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-419496A0-9AEA-4B6D-9D9D-E3904FC9BA3F" class="- topic/fig "><image href="GUID-58B289F7-FE76-42EF-8AA3-176A5B3E34A4-low.png" placement="inline" class="- topic/image " otherprops="GUID-58B289F7-FE76-42EF-8AA3-176A5B3E34A4-low.png"/></fig><fig id="GUID-9B2E79D0-A638-4B9E-8707-2B591B6D0FEC" class="- topic/fig "><image href="GUID-9156DDCF-7AC7-4124-B461-980BDDE070E6-low.png" placement="inline" class="- topic/image " otherprops="GUID-9156DDCF-7AC7-4124-B461-980BDDE070E6-low.png"/></fig><fig id="GUID-5330A6E7-2B2B-4B1E-AA29-78E823A3B065" class="- topic/fig "><image href="GUID-BE3C8945-1925-464F-8629-2150227180DC-low.png" placement="inline" class="- topic/image " otherprops="GUID-BE3C8945-1925-464F-8629-2150227180DC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the guide plate: lift it by moving the bolt upwards with a screw driver.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-739BD65E-A8AE-4FD1-A550-4BC10566EEF2" class="- topic/fig "><image href="GUID-49915805-2114-478D-AC5C-237D2C214E2D-low.png" placement="inline" class="- topic/image " otherprops="GUID-49915805-2114-478D-AC5C-237D2C214E2D-low.png"/></fig><fig id="GUID-9182A382-224B-4372-B22C-85C984F6D68F" class="- topic/fig "><image href="GUID-E06F9501-80A8-41D7-9A0B-2393EEBF01BC-low.png" placement="inline" class="- topic/image " otherprops="GUID-E06F9501-80A8-41D7-9A0B-2393EEBF01BC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Put the guide plate on the table and use tweezers to position the reflective sticker in the correct position as indicated in the picture.
</p><note id="GUID-655B3BC9-C2C9-4560-BAD1-601FE53830E4" class="- topic/note "><p class="- topic/p ">The sticker may not be above the edge of the guide plate.
</p><p class="- topic/p ">When the sticker is in the correct position firmly press the sticker to assure proper adhesion.
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9D4056B8-3880-41AA-B7A4-D4E6D92B3927" class="- topic/fig "><image href="GUID-97F99026-E2B7-49DF-A66A-E4FB763C602B-low.png" placement="inline" class="- topic/image " otherprops="GUID-97F99026-E2B7-49DF-A66A-E4FB763C602B-low.png"/></fig><fig id="GUID-E9954635-32E7-4286-821D-7F08FAEC3EC0" class="- topic/fig "><image href="GUID-5B0D3C0B-AEA1-4B3A-9451-F98DD43FE144-low.png" placement="inline" class="- topic/image " otherprops="GUID-5B0D3C0B-AEA1-4B3A-9451-F98DD43FE144-low.png"/></fig><fig id="GUID-07766FA1-DB0A-4CD6-A3B0-D221BD4865B2" class="- topic/fig "><image href="GUID-F1C9AC24-1CD0-415E-B847-0CA794574998-low.png" placement="inline" class="- topic/image " otherprops="GUID-F1C9AC24-1CD0-415E-B847-0CA794574998-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the screw from the bracket. 
</p><note id="GUID-7A5BBE19-0389-4863-BD92-EF86383AC322" class="- topic/note "><p class="- topic/p ">The difference between the old and the new bracket is the position of the sensor mounting holes.
</p><p class="- topic/p ">With the new bracket the sensor is positioned closer to the media for a more accurate media detection. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9DCCA8BB-A84D-42DE-AC14-D6541962796A" class="- topic/fig "><image href="GUID-8D04575A-AB88-4B9B-B1D2-ACA09711A974-low.png" placement="inline" class="- topic/image " otherprops="GUID-8D04575A-AB88-4B9B-B1D2-ACA09711A974-low.png"/></fig><fig id="GUID-75476805-E054-45B1-8E09-E227FFD0DD06" class="- topic/fig "><image href="GUID-91A5498F-E7F6-402F-B957-D8273DBC9B53-low.png" placement="inline" class="- topic/image " otherprops="GUID-91A5498F-E7F6-402F-B957-D8273DBC9B53-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove both sensors.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B58D68A8-8301-43B1-AC0A-7E3FE705338B" class="- topic/fig "><image href="GUID-ED3093CE-6B2C-47CB-86C7-0C3DCC09EF98-low.png" placement="inline" class="- topic/image " otherprops="GUID-ED3093CE-6B2C-47CB-86C7-0C3DCC09EF98-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the sensors on the new bracket.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E0A57116-2E84-4F06-A66F-F60AA8D572F3" class="- topic/fig "><title class="- topic/title "/><image href="GUID-F7F6FAC1-B3C4-435E-B178-9D2AF6876216-low.png" placement="inline" class="- topic/image " otherprops="GUID-F7F6FAC1-B3C4-435E-B178-9D2AF6876216-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install bracket incl sensors and harness on the guides.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E0E458EC-BF75-4248-A659-43858CBC08CD" class="- topic/fig "><image href="GUID-8D61848C-E21F-49DB-9A52-B32829556A13-low.png" placement="inline" class="- topic/image " otherprops="GUID-8D61848C-E21F-49DB-9A52-B32829556A13-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Modification Roll 2. 
</b> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cover of the media drawer.
</p><p class="- topic/p ">Remove 2 x 2 screws at the left and the right hand side.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D762FCFF-D6EC-4BA7-AF55-E8F33E301985" class="- topic/fig "><image href="GUID-3E319137-C05C-4666-9F7F-F7B79D259EF7-low.png" placement="inline" class="- topic/image " otherprops="GUID-3E319137-C05C-4666-9F7F-F7B79D259EF7-low.png"/></fig><fig id="GUID-EB104AFD-68E6-4E66-89C3-1DE4F3B60DFE" class="- topic/fig "><image href="GUID-0D07E1DD-DC14-46F8-AA15-E77F28121C31-low.png" placement="inline" class="- topic/image " otherprops="GUID-0D07E1DD-DC14-46F8-AA15-E77F28121C31-low.png"/></fig><fig id="GUID-8B4A02BD-4722-4E66-AA14-621A3A8E4B0D" class="- topic/fig "><image href="GUID-90DD64DD-952C-4959-80B1-E5AAAE1B8113-low.png" placement="inline" class="- topic/image " otherprops="GUID-90DD64DD-952C-4959-80B1-E5AAAE1B8113-low.png"/></fig><fig id="GUID-9D5F49AC-6BFE-4248-BD2C-F024AB3FDB17" class="- topic/fig "><image href="GUID-5A84C508-DA5F-4544-BF6C-6BB9EEC4F0C2-low.png" placement="inline" class="- topic/image " otherprops="GUID-5A84C508-DA5F-4544-BF6C-6BB9EEC4F0C2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift the cover and remove the cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-091F2687-D164-4922-BC56-7912D8073E38" class="- topic/fig "><image href="GUID-97FFBE71-0565-4404-9D50-B2C8AC369C01-low.png" placement="inline" class="- topic/image " otherprops="GUID-97FFBE71-0565-4404-9D50-B2C8AC369C01-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen 2 screws that fixate the LED-pba and detach the harness.
</p><p class="- topic/p ">Take the LED-pba and harness out of the inner guide plate and place it on a save position.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B0A9F601-3BD3-4A4B-BF85-9974F7310045" class="- topic/fig "><image href="GUID-A20AC92B-FDDD-43C0-B22B-553BFEE9077C-low.png" placement="inline" class="- topic/image " otherprops="GUID-A20AC92B-FDDD-43C0-B22B-553BFEE9077C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Rotate inner media guide plate upwards and put it on top of the media drawer. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C847BBB4-217B-4F07-8CB9-06C39FC5E6C6" class="- topic/fig "><image href="GUID-4433F69C-E1A0-4870-A18B-1E9F0763E767-low.png" placement="inline" class="- topic/image " otherprops="GUID-4433F69C-E1A0-4870-A18B-1E9F0763E767-low.png"/></fig><fig id="GUID-0FF4124F-E9DB-44D7-9EEC-ECD3FB5941EE" class="- topic/fig "><image href="GUID-63D0BBEA-73E9-4A24-8610-B8911EA70AD4-low.png" placement="inline" class="- topic/image " otherprops="GUID-63D0BBEA-73E9-4A24-8610-B8911EA70AD4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use tweezers to place the reflective sticker on the position as indicated in the picture.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B3E529D8-5A8F-4874-B1F5-E31A59C9BF5E" class="- topic/fig "><image href="GUID-793A69FB-118F-4DB3-B7FA-E513E3BADD8C-low.png" placement="inline" class="- topic/image " otherprops="GUID-793A69FB-118F-4DB3-B7FA-E513E3BADD8C-low.png"/></fig><fig id="GUID-C6EA2245-F5AE-414A-A893-67F3826FEF9E" class="- topic/fig "><image href="GUID-4D15BE19-C7D8-4DCF-922B-65AF5781BC31-low.png" placement="inline" class="- topic/image " otherprops="GUID-4D15BE19-C7D8-4DCF-922B-65AF5781BC31-low.png"/></fig><fig id="GUID-EB1D5459-21C5-4F2F-ADB5-FE1D23BAFB9D" class="- topic/fig "><image href="GUID-A537B869-8167-43A9-B280-C2764A37C3E4-low.png" placement="inline" class="- topic/image " otherprops="GUID-A537B869-8167-43A9-B280-C2764A37C3E4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Replace sensor bracket of roll 2 similar to roll 1 replacement 
