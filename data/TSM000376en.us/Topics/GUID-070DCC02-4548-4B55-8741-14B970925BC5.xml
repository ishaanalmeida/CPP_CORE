<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-070DCC02-4548-4B55-8741-14B970925BC5" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-070DCC02-4548-4B55-8741-14B970925BC5" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">How to get the datalog file</title><abstract class="- topic/abstract " id="GUID-9C631935-A322-4774-A553-6D0B52308454"><p class="- topic/p ">The Datalog file logs all the important printer events and can then be used for troubleshooting. 
</p><p class="- topic/p ">Datalog information is also available locally (on the control panel via ADAM) or remotely at the back office (with ORS). 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Diagnostics</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-BD13EB05-ECF9-4C06-9D86-8AB9C82D2DE9" class="- topic/section "><title class="- topic/title ">Choose the correct procedure</title><p class="- topic/p "> There are 5 procedures to retrieve the Datalog file 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">3 On site procedures: 
</p><p class="- topic/p ">- On site procedure 1 with a web browser 
</p><p class="- topic/p ">- On site procedure 2 with settings editor 
</p><p class="- topic/p ">- On site procedure 3 on the operator panel 
</p></li><li class="- topic/li "><p class="- topic/p ">2 Back office procedures: 
</p><p class="- topic/p ">- Back office procedure 1 via ORS 
</p><p class="- topic/p ">- Back office procedure 2 via ORS Remote Assistance VPN. 
</p></li></ul></section><section id="GUID-0B2C7E1F-C780-4F39-83CE-384DBC2235D7" class="- topic/section "><title class="- topic/title ">On site procedure 1 with a web browser</title><table pgwide="1" id="GUID-DDFF6F7E-CEA4-4B5F-9AC7-0288D2C24DDD" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="20*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="80*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Do one of the following 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Connect your laptop to the customer network. 
</p></li><li class="- topic/li "><p class="- topic/p ">Or use a customer workstation 
</p></li></ul></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Start a web browser 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "/><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Type in the following URL: 
</p><p class="- topic/p "> http://&lt;printer_name_or_IP_address&gt;/OceService/CreateDataLog 
</p><fig id="GUID-465EEE72-7E60-4E36-9560-6F8B70E621BA" class="- topic/fig "><desc class="- topic/desc "><p class="- topic/p ">Example 
</p></desc><image href="GUID-28E92FA8-1638-46E2-8426-7C5A4F99FD28-low.png" placement="inline" class="- topic/image " otherprops="GUID-28E92FA8-1638-46E2-8426-7C5A4F99FD28-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">After a short time the Datalog is downloaded to the default directory of your browser. 
</p><fig id="GUID-A43D8E8B-A1EE-4E79-991B-4BEC3C2E56F3" class="- topic/fig "><desc class="- topic/desc "><p class="- topic/p ">Example Datalog 
</p></desc><image href="GUID-27D4B22B-D385-4B44-91F1-5B614B402DB5-low.png" placement="inline" class="- topic/image " otherprops="GUID-27D4B22B-D385-4B44-91F1-5B614B402DB5-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-CC2486E9-E593-4DE9-907E-7BF8FE167E9F" class="- topic/section "><title class="- topic/title ">On site procedure 2 with Settings Editor</title><note id="GUID-12E9CDE9-C64B-42E4-8440-C0EADD09F2D7" class="- topic/note "><p class="- topic/p ">You need the System Administrator login information (password required) 
</p></note><table pgwide="1" id="GUID-E8683A97-CFAA-42AC-B15B-8375DE8C5137" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="20*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="80*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Open the Settings Editor. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Browse to : Support &gt; Troubleshooting: 
</p><fig id="GUID-0DB15AA4-77F0-40AA-ADAB-A06EC7E66498" class="- topic/fig "><image href="GUID-7ECA35C5-F956-422D-8519-48207CEE4BCB-low.png" placement="inline" class="- topic/image " otherprops="GUID-7ECA35C5-F956-422D-8519-48207CEE4BCB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Click "Create log file with report files". 
</p><p class="- topic/p ">The System Administrator login window displays: 
</p><fig id="GUID-EF80E33C-8463-4E04-983E-17E8D33CC0C3" class="- topic/fig "><image href="GUID-7D4C8203-373C-41D3-AB22-703719691BA1-low.png" placement="inline" class="- topic/image " otherprops="GUID-7D4C8203-373C-41D3-AB22-703719691BA1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Type in the System Administrator password. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Click Log in. 
</p><p class="- topic/p ">The "Log file with report files" displays: 
</p><fig id="GUID-BD7CE117-B787-42FE-8D71-2ABB87727173" class="- topic/fig "><image href="GUID-C8B51E54-2C9E-4B3A-ACEA-008359DB80B6-low.png" placement="inline" class="- topic/image " otherprops="GUID-C8B51E54-2C9E-4B3A-ACEA-008359DB80B6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Click "Create log file with report files" to create a new report file. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Click the name of the .zip file and download the file to the location on the hard disk. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Unzip/open the saved file. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">In the saved zip file a file with the name datadump.zip is present. Extract the datadump.zip from the zip file. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> In the datadump.zip the datalog.xml is present. Extract the datalog.xml from this zip file. 
</p></entry></row></tbody></tgroup></table></section><section id="GUID-633329CA-CF4D-48D8-8B91-F4E9B2CD0F65" class="- topic/section "><title class="- topic/title ">On site procedure 3 on the operator panel</title><p class="- topic/p ">The datalog file will be stored on an USB key as part of the created trace file. 
</p><note id="GUID-8D9C089A-3342-40F9-B433-E3C83DE51CE3" class="- topic/note "><p class="- topic/p ">You need the System Administrator login information (password required) 
</p></note><note id="GUID-60E27C99-8DBC-4D04-B0F3-AAFBEC065AC0" class="- topic/note "><p class="- topic/p "> To only retrieve the datalog.xml; this will take the most time as also a tracefile is created. 
</p></note><table pgwide="1" id="GUID-0E8C4D94-CBE1-4291-A6E3-D8B6DF7EFD71" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="20*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="80*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">On the operator pane tap the system button. 
</p><fig id="GUID-48BB5CCF-DC89-4887-8C82-22493E0BC897" class="- topic/fig "><image href="GUID-C352B384-701C-4F86-AE63-075C979D709F-low.png" placement="inline" class="- topic/image " otherprops="GUID-C352B384-701C-4F86-AE63-075C979D709F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap on Service. 
</p><fig id="GUID-0D428000-DCF8-41D1-B506-A488F133D602" class="- topic/fig "><image href="GUID-B10EFB59-C703-429D-83F8-80D6202FE105-low.png" placement="inline" class="- topic/image " otherprops="GUID-B10EFB59-C703-429D-83F8-80D6202FE105-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap the login as system administrator button and login. 
</p><fig id="GUID-C88616B4-0A40-4C7D-B501-7E95832CAF18" class="- topic/fig "><image href="GUID-38995044-B78F-4E6B-9E45-F4F1E9945B2D-low.png" placement="inline" class="- topic/image " otherprops="GUID-38995044-B78F-4E6B-9E45-F4F1E9945B2D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">If not done already insert an USB key in the USB connector under the operator panel. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap on export diagnostics to USB. 
</p><fig id="GUID-B905B7E2-7BE1-41DE-8E6C-3A9313956BC3" class="- topic/fig "><image href="GUID-99AAA3DB-6A78-498E-8AF4-F04B03B6A469-low.png" placement="inline" class="- topic/image " otherprops="GUID-99AAA3DB-6A78-498E-8AF4-F04B03B6A469-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">The datalog and functional logfiles are now stored as part of the tracedata on the USB key as a zipfile. 
</p><fig id="GUID-0432B2B7-EB9F-4E9D-8F9F-16BD19C445C3" class="- topic/fig "><image href="GUID-D474525D-A2D2-401C-B7BF-8A5FE030F20A-low.png" placement="inline" class="- topic/image " otherprops="GUID-D474525D-A2D2-401C-B7BF-8A5FE030F20A-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-927D8150-DC01-4AAE-ADD7-1BBAA576B164" class="- topic/section "><title class="- topic/title "> Back office procedure 1 via ORS</title><table pgwide="1" id="GUID-FECA7A75-12AF-4F00-A7C2-75CDD9DD6C6C" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="20*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="80*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Connect to the ORS portal (<xref href="https://service.cpp.canon" format="html" scope="external" class="- topic/xref "><?ditaot gentext?>https://service.cpp.canon</xref>). 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Find the printer in Search Configurations. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">In the Configuration details, select Diagnostic data &gt; Worklist 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Request the diagnostics data dump from the device by clicking the “I” icon: 
</p><fig id="GUID-139CB793-3F7C-4FEC-84F7-109753833E38" class="- topic/fig "><image href="GUID-2684ED00-A278-44BC-A3B9-EECB561AEA4C-low.png" placement="inline" class="- topic/image " otherprops="GUID-2684ED00-A278-44BC-A3B9-EECB561AEA4C-low.png"/></fig><p class="- topic/p "> The following message displays and the "I" icon becomes greyed out : 
</p><fig id="GUID-DED13748-FA81-4914-8425-4665AC8EC5FE" class="- topic/fig "><image href="GUID-5758F9A7-33E0-4CC3-9339-35E65152699B-low.png" placement="inline" class="- topic/image " otherprops="GUID-5758F9A7-33E0-4CC3-9339-35E65152699B-low.png"/></fig><p class="- topic/p ">Click "Ok" 
</p></entry></row><row class="- topic/row "><entry colname="col1" morerows="1" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">After a short time, the diagnostic data dump is available ( “I” icon not greyed out anymore) 
</p></entry></row><row class="- topic/row "><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Download it by clicking the Download diagnostic data icon: 
</p><fig id="GUID-A8FDE056-7DEE-4827-8F09-095062D447E6" class="- topic/fig "><image href="GUID-8F4E51D9-3006-4706-B4BF-2EAA3D52CC46-low.png" placement="inline" class="- topic/image " otherprops="GUID-8F4E51D9-3006-4706-B4BF-2EAA3D52CC46-low.png"/></fig><p class="- topic/p "> The file is downloaded to the default download location of your browser. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Open the diagnostic data dump file with for example 7-Zip: 
</p><fig id="GUID-E8A40530-DF00-445E-ABAF-86D49AD4AD95" class="- topic/fig "><image href="GUID-D6551091-383D-4BB1-BA3B-1E24D369E455-low.png" placement="inline" class="- topic/image " otherprops="GUID-D6551091-383D-4BB1-BA3B-1E24D369E455-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Extract the datalog.xml file from the zip file. 
</p></entry></row></tbody></tgroup></table></section><section id="GUID-EC173FB1-2BAB-4693-804E-B0C5C6886F74" class="- topic/section "><title class="- topic/title ">Back office procedure 2 via ORS Remote Assistance VPN</title><table pgwide="1" id="GUID-8D0FA562-08EE-4BCB-8539-217010D43BC3" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="20*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="80*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Connect to the ORS portal (<xref href="https://service.cpp.canon" format="html" scope="external" class="- topic/xref "><?ditaot gentext?>https://service.cpp.canon</xref>). 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Find the printer in Search Configurations. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Ask the customer to enable Remote Assistance. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> In the Remote data tab select VPN. 
</p><fig id="GUID-216FE1A7-A91F-408B-9815-31AE2185BC71" class="- topic/fig "><image href="GUID-45841EFE-3540-43B2-9881-10CFDE719DA4-low.png" placement="inline" class="- topic/image " otherprops="GUID-45841EFE-3540-43B2-9881-10CFDE719DA4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Select the double arrow symbol. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Remote Assistance download window opens. 
</p><fig id="GUID-E0FC60EB-5431-4FF7-8952-5BF42B3F9AF1" class="- topic/fig "><image href="GUID-DDCB065B-91B7-4BCD-9D90-B1C89F7996D1-low.png" placement="inline" class="- topic/image " otherprops="GUID-DDCB065B-91B7-4BCD-9D90-B1C89F7996D1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Select this window. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> The login screen opens. 
</p><fig id="GUID-DA2126C5-2F03-48D7-93DC-51004B88EE2C" class="- topic/fig "><image href="GUID-A2491616-80C5-4DAE-9992-FDF75605CCED-low.png" placement="inline" class="- topic/image " otherprops="GUID-A2491616-80C5-4DAE-9992-FDF75605CCED-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Enter the password. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> The VPN window opens. 
</p><fig id="GUID-545B2326-D606-4CBD-8223-A453EF65F3CA" class="- topic/fig "><image href="GUID-ACFB5C10-A2C3-46FC-8776-7334342936B3-low.png" placement="inline" class="- topic/image " otherprops="GUID-ACFB5C10-A2C3-46FC-8776-7334342936B3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">11 
