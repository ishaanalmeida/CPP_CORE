<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-2388CE18-EA64-412B-9157-B31DB3FD34CE" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-2388CE18-EA64-412B-9157-B31DB3FD34CE" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">04 How to install the printheads</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes the installation of 4 or 5 new printheads and 4 or 3 dummy printheads. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ul id="UL_B1463683E2BA49668D370C3F7729CCCB" class="- topic/ul "><li id="LI_57D0F61FB24A4B47AAF99D88FCD26D56" class="- topic/li "><p class="- topic/p ">Place the top cover in the service position. 
</p><p class="- topic/p ">See 
<xref keyref="24DISA060" class="- topic/xref " href="GUID-120956FD-BCBD-4084-9823-BCEEFB44C508.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>24 How to place the top cover in the service position</xref> 
</p></li></ul></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_CEA4CD427612471CA3540AD5430B21C2" class="- topic/ul "><li id="LI_B007BBFF5E5743C89A24651737F64808" class="- topic/li "><p class="- topic/p ">4 Printheads and 4 dummy printheads (In case of White ink, 5 printheads and 3 dummy printheads) 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Antistatic wrist strap 
</p></li><li class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex 
</b> 93-260 gloves 
</p></li><li id="LI_35830C7E3E0240DBB3BF6417F3FFD48B" class="- topic/li "><p class="- topic/p ">Empty blister = storage unit 
</p></li><li id="LI_856CDDC7431149C9B79FD5C51D21B2AC" class="- topic/li "><p class="- topic/p ">Lint free cloth 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-2D7D94A0-B26C-4C0B-B6A3-20C8621663A2" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note><note type="important" id="GUID-19212FE1-0739-4D36-AE4D-49667AC5A182" class="- topic/note "><p class="- topic/p ">Use an antistatic wrist strap. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-82B8CD74-503C-463D-A44E-27281C602E46" class="- topic/fig "><image href="GUID-9C7D4E63-057E-4C50-B753-3AA5A8854BEE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9C7D4E63-057E-4C50-B753-3AA5A8854BEE-low.png"/></fig></section><section id="SECTION_83EFA574E57B4B64A0DD595529E957E2" class="- topic/section "><title class="- topic/title ">Preparation</title><table pgwide="1" id="TABLE_B0B9EAFB44A1495897BD13F6422F5B24" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Prepare the components and tools for the installation. 
</p><p class="- topic/p ">Aim: easy workflow. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5ED3A8FE-70BA-4AC5-9305-290ABA1FE90F" class="- topic/fig "><image href="GUID-FDD4BA8B-A4A1-4EFA-A56B-43A44EB8732F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FDD4BA8B-A4A1-4EFA-A56B-43A44EB8732F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Remove the plastic bag from the printhead carriage. 
</p><p class="- topic/p ">Take the components out of the plastic bag: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">5 flex cables 
</p></li><li class="- topic/li "><p class="- topic/p "> 2 small protection caps 
</p></li><li class="- topic/li "><p class="- topic/p ">1 service jumper 
</p></li></ul></li><li class="- topic/li "><p class="- topic/p ">Place the 2 small protection caps (of the glass fiber) in a plastic bag in the service box. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-BEFE04A5-32E0-4BB6-ACED-7D948C853D6C" class="- topic/fig "><image href="GUID-E11ED0C2-8574-4F82-A016-C2C72FA760B2-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E11ED0C2-8574-4F82-A016-C2C72FA760B2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the service jumper on the power box. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C3372D3A-E775-459D-9EBE-604C3618F734" class="- topic/fig "><image href="GUID-795B19CB-F1D9-43C1-A7C6-47F0336D7FD4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-795B19CB-F1D9-43C1-A7C6-47F0336D7FD4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Unpack the box with the printheads: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">4 printheads in blisters and bag. (In case of the white printhead, 5 printheads) 
</p></li><li class="- topic/li "><p class="- topic/p ">feedback form. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0D177CEE-603C-4AFD-BDFB-252FD7F6FF4F" class="- topic/fig "><image href="GUID-72425E6C-3C14-47CE-BB3E-9E111E9A9757-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-72425E6C-3C14-47CE-BB3E-9E111E9A9757-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Cut the bag near the seal (at the top). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-99D7120E-F046-4DB3-BFEE-0A1A261D9893" class="- topic/fig "><image href="GUID-2EC298E5-CAF5-41C0-9CDE-383E7B91F133-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2EC298E5-CAF5-41C0-9CDE-383E7B91F133-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Open the blisters of the printheads. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the green protection cap of the printhead. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-83490321-8101-4509-B2EA-66CBEAB77397" class="- topic/fig "><image href="GUID-EA9E3038-E30D-4C02-AF7A-EFF89A5DE8D6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EA9E3038-E30D-4C02-AF7A-EFF89A5DE8D6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Take the 4 dummy printheads out of the box. (in case of the white printhead, 3 dummy printheads) 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the shield (for stray light prevention). 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Loosen the 4 screws (T10) . 
</p></li><li class="- topic/li "><p class="- topic/p "> Lift and remove the shield. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p><fig id="GUID-A2BB8070-635D-473F-B4EC-64E36FD41D3B" class="- topic/fig "><image href="GUID-EFE9D7BE-04DE-44DE-A836-70DAF4F7CE84-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EFE9D7BE-04DE-44DE-A836-70DAF4F7CE84-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 4 screws and remove the bracket to the top. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EA676652-7CD3-49C3-9F6A-B4DBD0B21435" class="- topic/fig "><image href="GUID-B1F9523E-EA27-4B4B-83FA-40E36B669589-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B1F9523E-EA27-4B4B-83FA-40E36B669589-low.png"/></fig><fig id="GUID-2466871F-A493-410C-9FFB-8746D3E4A472" class="- topic/fig "><image href="GUID-C9341357-2206-44A4-AA3A-EE917F4211E4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C9341357-2206-44A4-AA3A-EE917F4211E4-low.png"/></fig><fig id="GUID-3282DEC0-0284-4AA7-968C-516EB12E335E" class="- topic/fig "><image href="GUID-737DA8FE-BDDF-4BAA-9D02-6EF7764F508B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-737DA8FE-BDDF-4BAA-9D02-6EF7764F508B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the screw and the bracket. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CA28E213-8DC6-41CF-801A-262CD0E0EFBE" class="- topic/fig "><image href="GUID-93E0944A-2C39-428C-858E-D30F099B495F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-93E0944A-2C39-428C-858E-D30F099B495F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b "> Loosen</b> the 2 screws (Torx T10) of the air duct. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0A641DBB-5EE6-427B-A38D-977A9D1A4FC1" class="- topic/fig "><image href="GUID-B1070F7A-5F99-4636-94E2-7DC8A9F851D8-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B1070F7A-5F99-4636-94E2-7DC8A9F851D8-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Pull at the air duct: a gap is created between the sponge and the printheads. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-46C1590A-C57B-41FF-9416-BCDD3762B38F" class="- topic/fig "><image href="GUID-BE305F2B-9989-4434-B7FF-2A666656B1D8-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BE305F2B-9989-4434-B7FF-2A666656B1D8-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Unlock (squeeze and rotate) the printhead locking handle. 
</p><p class="- topic/p ">Push the locking handle till the end: positioned in a secured position. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-DFA7C7E1-7A35-4B01-80C0-692964400809" class="- topic/fig "><image href="GUID-DF43B35F-5AC7-4D97-9517-FC7C37A28CDD-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-DF43B35F-5AC7-4D97-9517-FC7C37A28CDD-low.png"/></fig><fig id="GUID-3A7415FE-9F3D-4380-BE76-1781CD307BB1" class="- topic/fig "><image href="GUID-3E029623-83AF-404A-B0B2-4D82FD4AE9DC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3E029623-83AF-404A-B0B2-4D82FD4AE9DC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">When installing the optionally white ink; Remove the “Plug Air Duct” from the air duct of position 1. 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Squeeze the two pins of the "Plug air duct" together and hold them firmly. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the “Plug Air Duct”. 
</p></li></ol><fig id="GUID-AF22DEC1-F183-4944-AF65-61C64E67E445" class="- topic/fig "><image href="GUID-BFBC3E6B-1E25-4840-A00B-86FD608FD91F-low.png" placement="inline" class="- topic/image " otherprops="GUID-BFBC3E6B-1E25-4840-A00B-86FD608FD91F-low.png"/></fig><p class="- topic/p ">Put it in the plastic bag in the service box 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D8047E1F-F160-40F3-9551-3DE8992FE34F" class="- topic/fig "><image href="GUID-AF2D6222-4595-4FF0-A3D5-7CF46D2964EB-low.png" placement="inline" class="- topic/image " otherprops="GUID-AF2D6222-4595-4FF0-A3D5-7CF46D2964EB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Overview Printheads 
</p><fig id="GUID-CBDCF044-4228-42E6-ACEB-FFA693AE9FC8" class="- topic/fig "><image href="GUID-FB007FB4-A5B1-43DD-BEDC-5CF840F1E6F8-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FB007FB4-A5B1-43DD-BEDC-5CF840F1E6F8-low.png"/></fig><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">White (optional 
</p></li><li class="- topic/li "><p class="- topic/p ">Dummy 
</p></li><li class="- topic/li "><p class="- topic/p ">Magenta 
</p></li><li class="- topic/li "><p class="- topic/p ">Yellow 
</p></li><li class="- topic/li "><p class="- topic/p ">Black 
</p></li><li class="- topic/li "><p class="- topic/p ">Cyan 
</p></li><li class="- topic/li "><p class="- topic/p ">Dummy 
</p></li><li class="- topic/li "><p class="- topic/p ">Dummy 
</p></li></ol><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Slide/Place the dummy printhead at position 8. 
</p><p class="- topic/p ">Check the position of the positioning balls in the matrix plate. 
</p></li><li class="- topic/li "><p class="- topic/p ">Slide/Place the dummy printhead at position 7. 
</p><p class="- topic/p ">Check the position of the positioning balls in the matrix plate. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C62A6F4A-B54F-48EB-B71E-527C96B17F74" class="- topic/fig "><image href="GUID-07475881-4631-4944-9D29-BE1A9414FAC6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-07475881-4631-4944-9D29-BE1A9414FAC6-low.png"/></fig><fig id="GUID-DEA93646-2FD4-4324-973B-2AEA30005E77" class="- topic/fig "><image href="GUID-EA19D3EF-B97A-447A-8D2E-38B55EC81206-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EA19D3EF-B97A-447A-8D2E-38B55EC81206-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Take the printhead from the blister. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the green protection cover 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-AD59F6C3-351E-4C07-A15C-F757610E3A6D" class="- topic/fig "><image href="GUID-EA9E3038-E30D-4C02-AF7A-EFF89A5DE8D6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EA9E3038-E30D-4C02-AF7A-EFF89A5DE8D6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Connect the pre-folded flex cable to the printhead. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C13D1417-FC08-4E18-8295-5E743BEBFBE9" class="- topic/fig "><image href="GUID-C7889529-253B-415E-930B-6BE64D65EFCC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C7889529-253B-415E-930B-6BE64D65EFCC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place/Slide the 1<sup class="+ topic/ph hi-d/sup ">st</sup> printhead at position 
<b class="+ topic/ph hi-d/b ">6</b> (at the left hand side of the printhead carriage). 
</p><p class="- topic/p ">Check the position of the positioning balls in the matrix plate. 
</p><note id="GUID-959BFBB4-D50F-4726-9879-AF3F183F30FC" class="- topic/note "><p class="- topic/p ">The numbers of the printheads are also indicated on the Carriage PBA (05PBA07). 
</p><fig id="FIG_0B24BF8D199746BF804369F01DDFF4FC" class="- topic/fig "><image href="GUID-7C3E3996-24B1-46EE-B76A-A5D255689FD8-low.png" id="IMAGE_80FEBA485E634E6BAFE306E3357A365B" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7C3E3996-24B1-46EE-B76A-A5D255689FD8-low.png"/></fig></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FEC6D273-3A3B-4CD4-AF2D-DDF7E85F3CD6" class="- topic/fig "><image href="GUID-2BF47676-8016-46C4-BE0C-60DF6E454F2D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2BF47676-8016-46C4-BE0C-60DF6E454F2D-low.png"/></fig><fig id="GUID-F28B7C46-ACD2-4E57-A46F-145747274A30" class="- topic/fig "><image href="GUID-B2DBA04D-15C6-4C4A-B2A5-F28FA8934722-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B2DBA04D-15C6-4C4A-B2A5-F28FA8934722-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Connect the flex cable to the Carriage PBA (05PBA07) at positions 6. 
</p><note id="GUID-9E6E02FF-FF66-492D-81BF-0621FF94BA92" class="- topic/note "><p class="- topic/p "> Push the flex cable to the left so that it is not in the way when you place the next printhead. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E1927F9F-D851-4933-830F-2FAA08633243" class="- topic/fig "><title class="- topic/title "/><image href="GUID-BE245E3F-024B-4F7C-B019-AE0907AEA71D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BE245E3F-024B-4F7C-B019-AE0907AEA71D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Close the clamps of the<b class="+ topic/ph hi-d/b "> air tubes</b> 
</p></li><li class="- topic/li "><p class="- topic/p "> Remove the red caps from the 
<b class="+ topic/ph hi-d/b ">air tubes</b>: 
</p><ul id="UL_0665D1761B8545CE88137ACC58F502CD" class="- topic/ul "><li id="LI_C57782D225224819B8BBEC4403AD5EAC" class="- topic/li "><p class="- topic/p "> One at the carriage side. 
</p></li><li id="LI_B1A48A81DEC742B0A7477C756393CA56" class="- topic/li "><p class="- topic/p "> One at the printhead side. 
</p></li></ul></li><li class="- topic/li "><p class="- topic/p "> Connect the air tube to the filter. 
</p></li><li class="- topic/li "><p class="- topic/p ">Put the red caps in a plastic bag in the service box. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8603F332-F153-410C-889B-CCDCDADB220B" class="- topic/fig "><image href="GUID-028DC85F-B86D-4774-B873-060F51D23520-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-028DC85F-B86D-4774-B873-060F51D23520-low.png"/></fig><fig id="GUID-2983F292-B92C-4EEB-826A-2B928B26AEF1" class="- topic/fig "><image href="GUID-510FDDE3-6710-4E3D-ACDD-E9C8E24F916F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-510FDDE3-6710-4E3D-ACDD-E9C8E24F916F-low.png"/></fig><fig id="GUID-274A00FA-948F-4745-B5B0-7367B9CBBD98" class="- topic/fig "><image href="GUID-DEBB1010-EB38-4BC6-ACBC-8D27BC000FB1-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-DEBB1010-EB38-4BC6-ACBC-8D27BC000FB1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Open the clamp of the air tube. 
</p></li><li class="- topic/li "><p class="- topic/p ">Squeeze the air tubes to protect that the tube sticks together. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9079C7AC-FD58-4E60-B645-F798B314B077" class="- topic/fig "><image href="GUID-C40804D0-6897-4093-84A9-66149D3620E8-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C40804D0-6897-4093-84A9-66149D3620E8-low.png"/></fig><fig id="GUID-E14F01CF-EB96-448B-AAA3-D1137FCFAD61" class="- topic/fig "><image href="GUID-05A04E3D-0A1A-429F-ACBD-84723E79BAD8-low.png" placement="inline" class="- topic/image " otherprops="GUID-05A04E3D-0A1A-429F-ACBD-84723E79BAD8-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Remove the red caps from the 
<b class="+ topic/ph hi-d/b ">ink tubes</b>: 
</p><ul id="UL_1991E21D84C1446C8B857C1294127517" class="- topic/ul "><li id="LI_B770D30BD99844D9BD63AFF2F7FDC16B" class="- topic/li "><p class="- topic/p "> One at the carriage side. 
</p></li><li id="LI_4D062FBFB88B4402BBBA0FAEB91F1842" class="- topic/li "><p class="- topic/p "> One at the printhead side. 
</p></li></ul></li><li class="- topic/li "><p class="- topic/p "> Connect the ink tube of the printhead and the printhead carriage on position 6. 
</p></li><li class="- topic/li "><p class="- topic/p ">Put the red caps in a plastic bag in the service box. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_F013DD169BC4467E9CF115DF559C4D27" class="- topic/fig "><image href="GUID-7FB33AEB-2A1D-42E3-B61E-51B38217C40A-low.png" id="IMAGE_DD57C4A8848948A8B207A74E15D39E28" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7FB33AEB-2A1D-42E3-B61E-51B38217C40A-low.png"/></fig><fig id="GUID-FFA2DAA8-26B5-498A-8CEF-A79CA7D645DB" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3D7CE89F-809E-45CE-874B-6CE0B00C80ED-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3D7CE89F-809E-45CE-874B-6CE0B00C80ED-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the connected tubes back in the clamp of the printhead carriage. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_676376B3291C429A852E2EFB463BCD5C" class="- topic/fig "><image href="GUID-D8FCBE44-D7FF-4831-85FB-B44A64A45C6F-low.png" id="IMAGE_382A2A4B1F5D4A66861473A132FD6BD2" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8FCBE44-D7FF-4831-85FB-B44A64A45C6F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open (= rotate to vertical position) the 2 ink valves. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_11A469C4DC0340A99DB840DCD264256F" class="- topic/fig "><image href="GUID-2BA3FE7D-D677-4B87-B891-00702C6D47A0-low.png" id="IMAGE_6683D73393F94FEF9B1FC70FF9C1B02D" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2BA3FE7D-D677-4B87-B891-00702C6D47A0-low.png"/></fig><fig id="FIG_23A97A1999964EB0B47BB8DB6CD95C69" class="- topic/fig "><image href="GUID-2E8D2941-A4A9-4C3C-90DD-EC5F72238FD2-low.png" id="IMAGE_802CB457977640BB8CC84E210D3CFD45" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2E8D2941-A4A9-4C3C-90DD-EC5F72238FD2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Install the other printheads (5,4,3) in the same way: repeat steps 8 ... 16 again). 
</b> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-26B87CAE-783F-4604-ACD5-29F755B7A814" class="- topic/fig "><title class="- topic/title "/><image href="GUID-5563A6FE-4945-4665-82F9-AB546182CDE4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5563A6FE-4945-4665-82F9-AB546182CDE4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Slide/Place the dummy printhead at position 2. 
</p><p class="- topic/p ">Check the position of the positioning balls in the matrix plate. 
</p></li><li class="- topic/li "><p class="- topic/p ">Slide/Place the dummy printhead at position 1. 
</p><p class="- topic/p ">Check the position of the positioning balls in the matrix plate. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1C6E1BD0-52F8-406C-94B9-D6D10244551C" class="- topic/fig "><title class="- topic/title "/><image href="GUID-7E526CA7-43F4-4DC7-9628-B536F5CE9C1B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7E526CA7-43F4-4DC7-9628-B536F5CE9C1B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Check visually if all 4 printheads and 4 dummy printheads are in-line and the spring is on-top of the printhead hooks. (In case of the white printhead, 5 printheads and 3 dummy printheads) 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F2132B14-AFD3-40C1-9E99-7E0EEAB0C500" class="- topic/fig "><image href="GUID-17EA8842-563A-4F97-BD86-BE8981CCBEBC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-17EA8842-563A-4F97-BD86-BE8981CCBEBC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">21 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Close the printhead locking handle. 
</p><note id="GUID-C8EC0951-47D1-46C9-8C83-E46486577F0E" class="- topic/note "><p class="- topic/p ">Make sure the handle does not touch the screw. Position it beside the screw. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-07D307A8-267B-4CBF-A0DD-6F80714C7FCD" class="- topic/fig "><title class="- topic/title "/><image href="GUID-181CD0AD-A04A-4F54-B6B8-B35B2B599389-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-181CD0AD-A04A-4F54-B6B8-B35B2B599389-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">22 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check again visually if all 4 printheads and 4 dummy printheads are in-line and the spring is on top of the printhead hooks. (In case of the white printhead, 5 printheads and 3 dummy printheads) 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2294279C-E822-42F4-A12B-C00DD343EA4F" class="- topic/fig "><image href="GUID-17EA8842-563A-4F97-BD86-BE8981CCBEBC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-17EA8842-563A-4F97-BD86-BE8981CCBEBC-low.png"/></fig><fig id="FIG_EEA10603A3CE44AFBACE11A78ED1753B" class="- topic/fig "><image href="GUID-70AA5F99-BDA4-48B3-B177-863850F6D818-low.png" id="IMAGE_68C05063758F43C18E18C1961E192BF0" keyref="" placement="inline" class="- topic/image " otherprops="GUID-70AA5F99-BDA4-48B3-B177-863850F6D818-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">23 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check the positions of the 4 or 5 printheads and dummy printheads: 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Move the printhead carriage manually above the manual maintenance position. 
</p></li><li class="- topic/li "><p class="- topic/p ">Check the position of each printhead. Use a cell phone. 
</p><note type="important" id="GUID-384F0761-4CB0-4B86-835E-5DF4C2E6A6C1" class="- topic/note "><p class="- topic/p ">If it is dark don't use LED or UV lamps. 
</p></note></li><li class="- topic/li "><p class="- topic/p ">If needed adapt the position. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5B30ED33-48B1-411E-9287-B2C9DB2FAE20" class="- topic/fig "><image href="GUID-8780E24D-2AC8-4807-B6AA-9F4DDACC0C37-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8780E24D-2AC8-4807-B6AA-9F4DDACC0C37-low.png"/></fig><fig id="GUID-58BCDF72-700C-4CE6-B388-8A37B0AA2DE0" class="- topic/fig "><image href="GUID-EE1715F8-8A39-4D05-A43D-8DB1E85B29FC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EE1715F8-8A39-4D05-A43D-8DB1E85B29FC-low.png"/></fig><fig id="GUID-88172780-D476-4A94-AA26-51279CEA2790" class="- topic/fig "><image href="GUID-30D6C0D8-099E-4611-A495-7D97A78908F0-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-30D6C0D8-099E-4611-A495-7D97A78908F0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">24 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Push the air duct in the direction of the printheads. 
</p></li><li class="- topic/li "><p class="- topic/p "> Lock the air duct with 2 screws (T10). 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-40978937-3C1D-4049-ADC5-49A2CF9FB33F" class="- topic/fig "><image href="GUID-4632A651-91FF-40E6-B581-116923012A0D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4632A651-91FF-40E6-B581-116923012A0D-low.png"/></fig><fig id="GUID-B5DFE33E-84D0-4EB5-BA94-1BB9718662C2" class="- topic/fig "><image href="GUID-475403F9-6304-4385-A5BC-A87695659BF3-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-475403F9-6304-4385-A5BC-A87695659BF3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">25 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the bracket and lock it with 1 screw. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0A5CE9A5-A29D-4EEB-9692-643AECA0D180" class="- topic/fig "><title class="- topic/title "/><image href="GUID-43D193E0-DA14-4162-BC59-EDEB83940819-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-43D193E0-DA14-4162-BC59-EDEB83940819-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">26 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the locking bracket and lock it with 4 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-BB272C15-29C7-4B9F-805C-93364E070C8F" class="- topic/fig "><title class="- topic/title "/><image href="GUID-2BFF2814-334F-435E-B535-A162AF97121B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2BFF2814-334F-435E-B535-A162AF97121B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">27 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Result: 
</p><p class="- topic/p "> Assembled printhead carriage including 4 or 5 printheads. (In case of the white printhead, 5 printheads, see picture) 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3D88242B-C5FF-446C-8071-2F6D42F7A569" class="- topic/fig "><image href="GUID-9C7D4E63-057E-4C50-B753-3AA5A8854BEE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9C7D4E63-057E-4C50-B753-3AA5A8854BEE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">28 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check: 
</p><p class="- topic/p "> Double check all 
<b class="+ topic/ph hi-d/b ">ink tube connections</b> if they are properly connected. Make sure the ink tubes are not interchanged or do cross each other. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-DEB05460-811F-417B-8CE3-C61C7212C4ED" class="- topic/fig "><title class="- topic/title "/><image href="GUID-4CB5FA18-6C61-4C0E-B158-9A7DF21DE594-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4CB5FA18-6C61-4C0E-B158-9A7DF21DE594-low.png"/></fig><fig id="GUID-9196DAA1-3695-4656-BB65-835AD7DED893" class="- topic/fig "><image href="GUID-E95E34C9-6FBC-4F19-A7C6-B55E46014992-low.png" placement="inline" class="- topic/image " otherprops="GUID-E95E34C9-6FBC-4F19-A7C6-B55E46014992-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">29 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check: 
</p><p class="- topic/p "> Double check all 
<b class="+ topic/ph hi-d/b ">air tube connections</b>. Clamps need to be opened. Make sure the air tubes are not interchanged or do cross each other. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-72978D10-3608-4E9A-9CDB-2B867B0E6BF5" class="- topic/fig "><title class="- topic/title "/><image href="GUID-0498293D-25E7-4571-9205-EDA89538E8B7-low.png" placement="inline" class="- topic/image " otherprops="GUID-0498293D-25E7-4571-9205-EDA89538E8B7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">30 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check: 
</p><p class="- topic/p "> Double check all 
<b class="+ topic/ph hi-d/b ">flex cable connections</b>. Make sure the flex cables are not interchanged or do cross each other. Check if the connectors are completely pressed in. 
