<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-C7CD297B-5F83-4EE0-85D2-E388D7CF879B" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-C7CD297B-5F83-4EE0-85D2-E388D7CF879B" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">02 How to remove the white ink 3-way valve</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ul id="UL_D9B0EC7EDDFE404ABC82A4F6A6670CD1" class="- topic/ul "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li></ul></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_E753369EFDC5426BBE20201BB8995B3D" class="- topic/ul "><li id="LI_84D449C8FB0C4465BCFF2032F7DB131F" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260. 
</p></li><li class="- topic/li "><p class="- topic/p ">Cleaning cloths lint free 
</p></li><li class="- topic/li "><p class="- topic/p ">Tie-wraps 3.6 x 143 mm 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-3B06D3E1-C4A2-42A3-9212-6DE96DA4938F" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-4EF9A989-84CD-495E-BA5C-995E9202B0DF" class="- topic/fig "><title class="- topic/title "/><image href="GUID-291B6C4C-F0D9-49B5-97A7-9C0E0F33F16D-low.png" placement="inline" class="- topic/image " otherprops="GUID-291B6C4C-F0D9-49B5-97A7-9C0E0F33F16D-low.png"/></fig><fig id="GUID-E5748358-9D9D-46CE-8DED-FD40E36E9B47" class="- topic/fig "><title class="- topic/title "/><image href="GUID-068A2BFE-9A08-46A9-96A7-22AE855C4B5D-low.jpg" keyref="" placement="inline" class="- topic/image " otherprops="GUID-068A2BFE-9A08-46A9-96A7-22AE855C4B5D-low.jpg"/></fig><fig id="GUID-12FFB1C0-5EF8-415E-9062-20B176917B97" class="- topic/fig "><title class="- topic/title "/><image href="GUID-900D1367-96C7-46EE-9D20-9B65B6A7087B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-900D1367-96C7-46EE-9D20-9B65B6A7087B-low.png"/></fig></section><section id="SECTION_7BCF39D178844448B3A21E7E56376710" class="- topic/section "><title class="- topic/title ">How to remove</title><table id="TABLE_5FBEFB7447DE4A1D819BDF873A72E3DB" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the cover 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3910FFA1-A6C4-44EB-BA31-41B1100B7306" class="- topic/fig "><title class="- topic/title "/><image href="GUID-E6CEE49C-91CB-401F-BA1B-37C9759210C4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E6CEE49C-91CB-401F-BA1B-37C9759210C4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the carriage to the right above the maintenance tray. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the black cover of the carriage unit. 
</p><p class="- topic/p ">See: 
<xref keyref="05DISA002" class="- topic/xref " href="GUID-F9FDA7D9-BA95-4871-8DF6-98726C3BC391.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 05 How to open the cover of the carriage unit?>05 How to open the cover of the carriage unit</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connector. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E0DCD64C-03AA-481A-BB37-B319CE9AFFE1" class="- topic/fig "><title class="- topic/title "/><image href="GUID-9BBA1585-16DD-45C6-8145-1C4D389718E3-low.png" placement="inline" class="- topic/image " otherprops="GUID-9BBA1585-16DD-45C6-8145-1C4D389718E3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the 3-way valve connector (Yellow cable) from the PBA. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-76DA070C-DDBD-48A1-8BF8-7E598FE915EB" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AC088B95-2531-405A-ADDB-67A7C36C6CE1-low.png" placement="inline" class="- topic/image " otherprops="GUID-AC088B95-2531-405A-ADDB-67A7C36C6CE1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Cut the tie-wraps to release the yellow cable. 
</p><p class="- topic/p ">Cut the tie-wraps to release the 3-way valve with ink tubes 
</p><p class="- topic/p ">Open the clamps of the 3-way valve ink tubes . 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6F0F4AD7-8963-40FF-8E73-789556AD7956" class="- topic/fig "><title class="- topic/title "/><image href="GUID-9E395BAC-4D00-46F0-9C86-A5B929E6D4EE-low.png" placement="inline" class="- topic/image " otherprops="GUID-9E395BAC-4D00-46F0-9C86-A5B929E6D4EE-low.png"/></fig><fig id="GUID-C7CE8C13-584C-4CE6-AD16-EDFA88A93603" class="- topic/fig "><title class="- topic/title "/><image href="GUID-7F6DB8D7-6F74-492A-9DBA-4A7CC4A8B09D-low.png" placement="inline" class="- topic/image " otherprops="GUID-7F6DB8D7-6F74-492A-9DBA-4A7CC4A8B09D-low.png"/></fig><fig id="GUID-E8A866C2-115C-4DD1-B33F-5C2D373DD845" class="- topic/fig "><title class="- topic/title "/><image href="GUID-7173DC5C-AF33-4884-87D8-D97265E4336F-low.png" placement="inline" class="- topic/image " otherprops="GUID-7173DC5C-AF33-4884-87D8-D97265E4336F-low.png"/></fig><fig id="GUID-60FE5A2C-CAAE-4082-A001-CB795429380E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-5C17B1AB-73E1-4DE6-99CF-4918879734B1-low.png" placement="inline" class="- topic/image " otherprops="GUID-5C17B1AB-73E1-4DE6-99CF-4918879734B1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">After removing the 3 screws remove the 3-way-valve assy. 
</p><p class="- topic/p ">To avoid any ink leakage be sure the Vane of the White ink tube is closed. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2602D421-839E-4D47-B2B4-A550948F16DC" class="- topic/fig "><title class="- topic/title "/><image href="GUID-24A6C818-AF58-4D92-A873-4872DC9FED56-low.png" placement="inline" class="- topic/image " otherprops="GUID-24A6C818-AF58-4D92-A873-4872DC9FED56-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The new 3-way-valve assy comes without the bracket as shown in the picture. 
</p><p class="- topic/p ">Remove the bracket and mount it on the new 3-way valve. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5292ED99-F175-409F-B7B5-F62019B24AF4" class="- topic/fig "><title class="- topic/title "/><image href="GUID-C1CC9556-A22B-4E8F-82FE-2B65D7FBF645-low.png" placement="inline" class="- topic/image " otherprops="GUID-C1CC9556-A22B-4E8F-82FE-2B65D7FBF645-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Before loosening the ink tubes arrange lint free cloths to avoid ink leakage. 
</p><p class="- topic/p ">Loosen the ink tubes and use the red caps to seal the tubes. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Flush white ink from recirculation tube (Optional for (expired) white ink option).</b> 
</p><p class="- topic/p ">Cut the tie-wrap 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><fig id="GUID-9E1A62B2-50F8-4228-B175-BA26AD5CDCE0" class="- topic/fig "><title class="- topic/title "/><image href="GUID-62C599E1-91A8-4881-9554-BFCC211A309E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-62C599E1-91A8-4881-9554-BFCC211A309E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the green luer. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><fig id="GUID-79545FEC-1594-4AD6-9D44-6E3615D42896" class="- topic/fig "><title class="- topic/title "/><image href="GUID-D522E405-5453-4B8E-A266-A6F9195F79CC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D522E405-5453-4B8E-A266-A6F9195F79CC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Guide the recirculation tube into a waste tray. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><fig id="GUID-E36FA150-E274-4594-8AA6-050DA0424FED" class="- topic/fig "><title class="- topic/title "/><image href="GUID-A28BD783-9D38-47F9-8B43-C12261355384-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A28BD783-9D38-47F9-8B43-C12261355384-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Start SDS 2-6-010 for 400 seconds. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><note id="GUID-9621A58C-D967-47DB-A7B2-FD4292A5FDC7" class="- topic/note "><p class="- topic/p ">Stirring starts first for 120 seconds. 
</p></note></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">After flushing completed, guide the tube behind the metal (no tie-wrap needed) 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><fig id="GUID-6E3D87BA-3445-453C-891F-7E883720AE60" class="- topic/fig "><title class="- topic/title "/><image href="GUID-CB6D3E85-6343-413B-B64D-A425EF669B34-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CB6D3E85-6343-413B-B64D-A425EF669B34-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_E3FC7EE10DDC46BA880F87671551C890" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-1CE85252-F6D3-4421-930B-8AE723FFB49C.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
