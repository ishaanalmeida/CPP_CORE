<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-54875823-0D56-4A0A-A408-78B70D82B6BD" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-54875823-0D56-4A0A-A408-78B70D82B6BD" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Humidity temperature</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Diagnostics</category><category class="- topic/category ">Diagnostics</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-0D85DF78-34BB-4100-87FA-328B320B64CF" class="- topic/section "><title class="- topic/title "/><fig id="GUID-2CE5B4C4-15AE-468E-82A7-8393305C7256" class="- topic/fig "><title class="- topic/title ">Humidity temperature</title><image href="GUID-5F3535F8-0E54-463E-94BA-3F9FCE399FB5-low.png" placement="inline" class="- topic/image " otherprops="GUID-5F3535F8-0E54-463E-94BA-3F9FCE399FB5-low.png"/></fig><p class="- topic/p ">Ambient climate conditions of the device. Three different graphs are displayed: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Ambient Temperature 
</p></li><li class="- topic/li "><p class="- topic/p ">Ambient Humidity 
</p></li><li class="- topic/li "><p class="- topic/p ">Condensation temperature margin. 
</p></li></ul><p class="- topic/p "> The recommended operating environment conditions are given in the user manual. 
</p><table id="GUID-53E5F599-B620-44AD-919D-C7253ABD770C" class="- topic/table "><tgroup cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="40*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="40*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="20*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Schematic overview 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Schematic overview Observations 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Solution document 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><fig id="GUID-18056643-C3F1-4C59-93C8-CC75068541EE" class="- topic/fig "><title class="- topic/title "/><image href="GUID-5A3D171B-6E4F-4FE2-B602-9FBBED0F77F0-low.png" placement="inline" class="- topic/image " otherprops="GUID-5A3D171B-6E4F-4FE2-B602-9FBBED0F77F0-low.png"/></fig><fig id="GUID-957D477A-2E07-46E5-94BD-A6513872492F" class="- topic/fig "><title class="- topic/title "/><image href="GUID-9A3A726D-814E-4BFC-83D1-2B89CE23B5CE-low.png" placement="inline" class="- topic/image " otherprops="GUID-9A3A726D-814E-4BFC-83D1-2B89CE23B5CE-low.png"/></fig><fig id="GUID-8493C130-2DC9-475B-AB0A-6734826889BF" class="- topic/fig "><title class="- topic/title "/><image href="GUID-78C41A1E-522F-4EE1-AC60-0CA0479544BF-low.png" placement="inline" class="- topic/image " otherprops="GUID-78C41A1E-522F-4EE1-AC60-0CA0479544BF-low.png"/></fig></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">All graphs are mainly in the green area. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">The environment is within specification. No action required. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><fig id="GUID-4E64E6DA-52DC-469C-9863-B7441117F73C" class="- topic/fig "><title class="- topic/title "/><image href="GUID-E1F4EFF9-F4F7-4DF1-BF03-B37DD7D28680-low.png" placement="inline" class="- topic/image " otherprops="GUID-E1F4EFF9-F4F7-4DF1-BF03-B37DD7D28680-low.png"/></fig><fig id="GUID-385CA78E-2793-4F34-9142-867A324D9459" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AA1BC754-CF49-49B8-A02C-1CF721F332FC-low.png" placement="inline" class="- topic/image " otherprops="GUID-AA1BC754-CF49-49B8-A02C-1CF721F332FC-low.png"/></fig><fig id="GUID-1056A4C6-E7AB-44E7-A1DD-0DB2DD5C353C" class="- topic/fig "><title class="- topic/title "/><image href="GUID-9F7C0903-8424-4587-AC49-D9A6591861FC-low.png" placement="inline" class="- topic/image " otherprops="GUID-9F7C0903-8424-4587-AC49-D9A6591861FC-low.png"/></fig></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> The humidity graph is often out of spec. 
</p><p class="- topic/p ">The margin to the condensation point is critical ( almost zero). 
</p><p class="- topic/p ">There is a considerable chance of condensation in the engine, resulting in unreliable behavior and/or defects. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> Inform the customer that the engine is operating outside the required environment specifications. 
</p></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="task" href="GUID-17E03B46-02EC-4F60-8364-45837BC8CE84.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Advanced technical views</linktext></link></linkpool></related-links>
