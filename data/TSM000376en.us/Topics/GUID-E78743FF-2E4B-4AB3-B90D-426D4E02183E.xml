<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-E78743FF-2E4B-4AB3-B90D-426D4E02183E" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-E78743FF-2E4B-4AB3-B90D-426D4E02183E" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Clean the MC scanner</title><abstract class="- topic/abstract " id="GUID-DAC521FD-E03E-41BD-AD12-5D714F339050"><p class="- topic/p "><ph class="- topic/ph "><indexterm class="- topic/indexterm ">Clean the MC scanner</indexterm><indexterm class="- topic/indexterm ">Clean uncured ink<indexterm class="- topic/indexterm ">MC Scanner</indexterm></indexterm></ph> 
</p><p class="- topic/p "> The MC scanner is used for the measurement of printed test patterns. The MC scanner must be cleaned regularly. 
</p><p class="- topic/p ">When you see pollution on the MC scanner, immediately clean the scanner. 
</p><p class="- topic/p "> Cleaning the MC scanner has to be done at least once a month. 
</p><p class="- topic/p ">Video: <ph class="- topic/ph " varid="Video: 14 - Clean the M&amp;C scanner"><xref class="- topic/xref " format="html" href="https://sus.cpp.canon/8KKT517K" scope="external"><?ditaot usertext?> 
<image class="- topic/image " href="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png" placement="inline" otherprops="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png"/> Clean the M&amp;C scanner</xref></ph> 
</p><note class="- topic/note " id="GUID-FC0D61E5-4EF1-47B6-9E55-3F4FF4729872"><p class="- topic/p ">When you get error 
<msgph class="+ topic/ph sw-d/msgph ">5713: advance media correction not working</msgph>, most probably the MC scanner is polluted, clean the scanner. 
</p></note></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="PREREQ_4A7484C23E5E46BA8D46F5927CC3D1A5" class="- topic/section task/prereq "><p class="- topic/p ">Use <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> prescribed: 
</p><ul id="UL_F7D24440ECD14DC3855D62229C39E403" class="- topic/ul "><li id="LI_F25E77D536FB4B799C750062564C45BC" class="- topic/li "><p class="- topic/p "><ph translate="no" class="- topic/ph ">Microflex</ph> gloves for handling ink 
</p></li><li id="LI_E6E8F65EDAAD4C49A430C5EE6B66BE55" class="- topic/li "><p class="- topic/p ">Lint free cloths 
</p></li><li id="LI_75F3D3584EDA44A6BE2FEB3B7513627F" class="- topic/li "><p class="- topic/p ">Cleaning liquid (IPA) 
</p></li></ul></prereq><section id="SECTION_D0733117B373496C80C08866542BBEDF" class="- topic/section "><title class="- topic/title "/><note id="GUID-CE56DE7E-50E2-45B8-BDA4-0A1DFCB130C7" class="- topic/note " type="caution"><p class="- topic/p "> Wear gloves when contact with ink or maintenance materials is possible. Gloves should always overlap sleeves. Wear safety glasses with side shields when handling ink or maintenance materials. Follow the ink related Safety Data Sheets (SDS) guidelines carefully in order to ensure maximum safety. 
</p></note></section><steps id="GUID-3BDB9201-C1F8-4666-82D4-C65047E6568B" class="- topic/ol task/steps "><step id="STEP_D9D8CC11CCB241E6AD09C94070FBCFAA" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Start the maintenance action via the operator panel. For more information, see 
<xref keyref="07USER005" class="- topic/xref " href="GUID-3489F2DA-A0B3-48F6-BA46-CB3C83BB335E.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 07 Start manual maintenance?>07 Start manual maintenance</xref> or 
<xref keyref="07_Start_periodic_maintenance" class="- topic/xref " href="GUID-71890032-A0EB-41FD-B5D8-6E897C19CA25.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text Start periodic maintenance?>Start periodic maintenance</xref>. 
</cmd></step><step id="STEP_B29030E1E27D43F180EB17F4B5D97808" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Put on the <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> approved gloves. 
</cmd></step><step id="STEP_93E05ACA63C543C2A891096692AF80A9" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Go to the media input side and locate the manual maintenance door on the left. 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_A4A46D5F39D446D69F2FB5FD35EAE73B" class="- topic/fig "><image href="GUID-FC882054-A59D-4AE0-8CB1-C4305AC9E512-low.png" id="IMAGE_9DBB3FC618A04C2D865668F2E289BA08" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FC882054-A59D-4AE0-8CB1-C4305AC9E512-low.png"/></fig></info></step><step id="STEP_5732956B832B443C9233D7DA0112A90F" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Open the media cover (1) and lift the lever of the manual maintenance door on the left (2). 
</cmd><info class="- topic/itemgroup task/info "><fig id="FIG_2254A7BD56A744D785BE3BD4C4DB07CF" class="- topic/fig "><image href="GUID-688D946B-F927-42F9-BB8D-DF825978318D-low.png" id="IMAGE_66BAB896036D439DBE1A2041FF5EC4FB" keyref="" placement="inline" class="- topic/image " otherprops="GUID-688D946B-F927-42F9-BB8D-DF825978318D-low.png"/></fig></info></step><step id="STEP_612BA1CF3D804FDCA0F91F297D5FDB56" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Open the manual maintenance door (3). A light is switched on. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-9E230E33-87E1-404D-8809-F72E10D6A1C8" class="- topic/note " type="important"><p class="- topic/p ">Do not use any external light source to prevent curing of the ink and damage to the printheads. 
</p></note></info></step><step id="STEP_A7588866B6A041DA993C49AAEE2EF833" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Locate the MC scanner (indicated by the yellow circle) next to the matrix plate in the compartment. 
</cmd><info class="- topic/itemgroup task/info "><fig id="GUID-0B86C936-C95A-4EB0-B583-7D2814B03EAB" class="- topic/fig "><image href="GUID-E25FACDE-59B9-4211-A7A5-F64704E2B373-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E25FACDE-59B9-4211-A7A5-F64704E2B373-low.png"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dampen a lint free cloth with the cleaner IPA and clean then glass plate in front of the MC scanner. 
</cmd><info class="- topic/itemgroup task/info "><note type="important" id="GUID-18D2ECAF-40B8-455D-8D00-D99905BF5A90" class="- topic/note "><p class="- topic/p ">Only clean the glass plate of the MC scanner. Do not touch the nozzle areas of the printhead. When you touch the nozzle areas you can damage the printhead. 
</p></note><note id="GUID-8CAE28A7-8D68-4BD8-9FF2-CA1AE8EF8EA8" class="- topic/note " type="important"><p class="- topic/p "> Use the prescribed cleaning liquid. Do not use any other cleaners. 
</p></note><note id="GUID-7BB2C217-2A35-4D2C-AA12-F8AD1CA1CFDE" class="- topic/note " type="important"><p class="- topic/p ">This cleaning liquid (IPA) is not used for cleaning the maintenance drawer and heated parts of the maintenance station. 
</p></note></info></step><step id="STEP_76F0A63D8AB445668557A31E2651D569" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Make sure that all residue ink is removed. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Carefully wipe the glass plate dry. 
</cmd></step><step id="STEP_35C3785E62BC448082B0538C8BC39C00" class="- topic/li task/step "><cmd class="- topic/ph task/cmd "> Dispose the gloves and cloths as chemical waste according to local regulations. 
</cmd></step><step id="STEP_EDB5D008E6AA419A88A6A64BD3DA41BD" class="- topic/li task/step "><cmd class="- topic/ph task/cmd "> Close the manual maintenance door and the media cover. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-6150777A-4F83-46C3-8E38-D690D0F1ABFF" class="- topic/note " type="important"><p class="- topic/p ">Make sure all covers are closed correctly to prevent cured ink in your system. 
</p></note></info></step><step id="STEP_171FF2C9F334469C93A6F7E231FFC777" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">On the operator panel tap <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Completed</text></uicontrol></ph> to end the maintenance action. 
</cmd></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-412C614D-9E31-4E8D-B644-52D11B3C77FC.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
</task>