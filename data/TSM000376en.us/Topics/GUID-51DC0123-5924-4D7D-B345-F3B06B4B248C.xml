<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-51DC0123-5924-4D7D-B345-F3B06B4B248C" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-51DC0123-5924-4D7D-B345-F3B06B4B248C" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">11 How to create an installation USB Key </title><abstract class="- topic/abstract " id="M140828-B205"><p class="- topic/p ">This procedure describes the how to create an installation USB key in order to install the software of the system. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="M140828-B207" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Required tools</ph></title><ul id="UL_722C828A7C8B49C38ED1C503C2455D18" class="- topic/ul "><li id="LI_762E1C1CD22645E18F423FA4CA460DC0" class="- topic/li "><p class="- topic/p ">A Workstation with the CreateUSB tool installed. 
</p><p class="- topic/p ">See: 
<xref keyref="INSTCON0003" class="- topic/xref " href="GUID-A692F06D-10A9-4160-8CBC-E345ED636C31.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>11 How to install the CreateUSB tool</xref>. 
</p></li><li id="LI_70823025158640D4BAD3750FB9B3FF78" class="- topic/li "><p class="- topic/p ">A USB key. See 
<xref keyref="GENINST_PREF_USB" class="- topic/xref " href="GUID-50B2AB5E-C93E-443B-9588-1C956EB6F1B2.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>Overview preferred USB keys</xref>.
</p></li><li id="LI_E1447E06614F4890ABBA8B44CCB13C24" class="- topic/li "><p class="- topic/p ">The downloaded software packages (iso) on the laptop. 
</p><p class="- topic/p ">See: 
<xref keyref="DownloadAndPrepareUSBkeyinstallation" class="- topic/xref " href="GUID-BBED23FE-4C3C-4B89-B9AA-CBF2EAFBB049.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>11 Download and prepare the software packages for a USB key installation</xref>. 
</p></li></ul></section><section id="M140828-B208" class="- topic/section "><title class="- topic/title "/><note id="M140828-NOE211" type="note" class="- topic/note "><p class="- topic/p ">This procedure takes approximately 30 minutes. 
</p><p class="- topic/p ">You need administrator rights on the workstation. 
</p></note></section><section id="SECTION_8B2EDF5F2405440097F73F1429FA79F0" class="- topic/section "><title class="- topic/title ">Create an installation USB Key</title><table id="GUID-44E51CAE-2EF5-431B-BFBB-AE0F0810C645" pgwide="1" class="- topic/table "><tgroup cols="2" align="left" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" align="left" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="90*" class="- topic/colspec "/><thead class="- topic/thead "><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Insert the USB key into one of the USB ports on the workstation. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Start the CreateUSB-tool. 
</p><p class="- topic/p ">Enter the administrator password when requested. 
</p><p class="- topic/p ">A popup will appear: 
</p><fig id="GUID-7BA2B644-FDCE-4A88-B52B-67544F81FEC5" class="- topic/fig "><title class="- topic/title "/><image href="GUID-177FEDCA-D179-468F-A74E-F8A993DCF34D-low.png" placement="inline" class="- topic/image " otherprops="GUID-177FEDCA-D179-468F-A74E-F8A993DCF34D-low.png"/></fig><p class="- topic/p "> Select "Yes" to continue. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">The application main window displays: 
</p><fig id="GUID-A3B48646-496D-4D00-A17D-FBF4082A3B1A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-4F41B859-E43D-4982-A220-8F46125CE884-low.png" placement="inline" class="- topic/image " otherprops="GUID-4F41B859-E43D-4982-A220-8F46125CE884-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">In the Installation media section, click Browse. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Browse to the directory where the system software .iso files are located and select the file ending with "-APPL-WIN10.iso" 
</p><fig id="GUID-6ACD3247-EEDA-43FD-939F-28C2FE19AEFF" class="- topic/fig "><title class="- topic/title "/><image href="GUID-4AD041D5-39CE-4AF6-848E-8DCBC3BC2859-low.png" placement="inline" class="- topic/image " otherprops="GUID-4AD041D5-39CE-4AF6-848E-8DCBC3BC2859-low.png"/></fig><note id="GUID-E8ADEBFF-62CE-4013-9978-06BA338CC9F8" class="- topic/note "><p class="- topic/p ">Where a.b.c.d is the software number (for instance, “3.0.0.0” for R3.0.0.0). 
</p></note></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">If not already selected, select the correct product (Example: Colorado 1630 …) In the Product section. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">In the Installation of GPL media section, click Browse. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Browse to the directory where the system software .iso files are located and select the file ending "-GPL-WIN10.iso" 
</p><fig id="GUID-9F0FA67D-6F0A-4F60-8BF3-4A9C6DE50F5B" class="- topic/fig "><title class="- topic/title "/><image href="GUID-87C71828-D382-4CA0-BF53-9BB53105468F-low.png" placement="inline" class="- topic/image " otherprops="GUID-87C71828-D382-4CA0-BF53-9BB53105468F-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> In the USB drive to use section, select the installation USB key. 
</p><fig id="GUID-C07CBDF1-3326-47E1-9F1C-C0D871C63319" class="- topic/fig "><title class="- topic/title "/><image href="GUID-2DA29800-B435-4E49-B2D7-56FC06F06917-low.png" placement="inline" class="- topic/image " otherprops="GUID-2DA29800-B435-4E49-B2D7-56FC06F06917-low.png"/></fig><note type="note" id="GUID-648EE42D-DAB0-40F7-AE0B-B2711749EFE5" class="- topic/note "><p class="- topic/p "> Be careful because the selected drive will be completely erased ! 
</p></note></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Leave the Legacy file system checkbox unchecked. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Click Start. 
</p><p class="- topic/p "> The following window displays the keepsettings dialog: 
</p><fig id="GUID-25155BD2-76D2-4974-86AF-7C237B748F20" class="- topic/fig "><image href="GUID-1791C2C9-44E1-4711-8599-76AD543EEF29-low.png" placement="inline" class="- topic/image " otherprops="GUID-1791C2C9-44E1-4711-8599-76AD543EEF29-low.png"/></fig><p class="- topic/p "> Select 'Yes' (keepsettings=yes). 
</p><p class="- topic/p ">All the settings and jobs present on the printer are restored at the end of the process. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Click Yes or No to start the USB key creation. 
</p><p class="- topic/p "> The following window displays: 
</p><fig id="GUID-66DA3FC6-EC01-4C17-96AE-8227B42B1C34" class="- topic/fig "><title class="- topic/title "/><image href="GUID-97ED2802-A34D-42FE-955A-A120519EFAC8-low.png" placement="inline" class="- topic/image " otherprops="GUID-97ED2802-A34D-42FE-955A-A120519EFAC8-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Click Yes. 
</p><p class="- topic/p "> The key creation process starts. 
</p><p class="- topic/p "> Progress Information is displayed in the Start button: 
</p><fig id="GUID-6215CAC4-7E4F-4D39-85E1-24AA5CA9BC13" class="- topic/fig "><title class="- topic/title "/><image href="GUID-51BCE216-5C4E-46A5-9322-33347FD691C7-low.png" placement="inline" class="- topic/image " otherprops="GUID-51BCE216-5C4E-46A5-9322-33347FD691C7-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Wait until the CreateUSB tool indicates that the process has completed. 
</p><p class="- topic/p "> The USB key can now be safely removed. 
</p><fig id="GUID-76A914D8-3E02-49CD-AB91-E0B35DE97896" class="- topic/fig "><title class="- topic/title "/><image href="GUID-1B371D60-02C5-4352-A02C-4A305BDA41CD-low.png" placement="inline" class="- topic/image " otherprops="GUID-1B371D60-02C5-4352-A02C-4A305BDA41CD-low.png"/></fig><note id="GUID-EF4F762F-AB00-4A52-AE01-166FFF21902C" class="- topic/note "><p class="- topic/p "> If anything goes wrong see: 
<xref keyref="11UsbKeyCreateProblem" class="- topic/xref " href="GUID-80D53CA7-611A-4EEC-9FAA-0F44C8811C9D.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>11 Troubleshooting installation USB key creation issues</xref> 
</p></note></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Click OK. 
</p><p class="- topic/p "> The installation key is ready for use and its name is now OCEINSTALL. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Remove the USB key. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Close CreateUSB. 
</p></entry></row></tbody></tgroup></table></section><section id="GUID-0230D940-98C4-4808-8F77-A678542F3168" class="- topic/section "><title class="- topic/title ">How to reactivate an used install USB key</title><p class="- topic/p ">After an installation USB key has been used, it is renamed as USEDKEY. It is no longer bootable and cannot be used to perform an installation. 
</p><p class="- topic/p ">This section describes how to reactivate the USB key. 
</p><table id="GUID-72FF3611-5F86-4D79-A878-F15214BAB066" pgwide="1" class="- topic/table "><tgroup cols="2" align="left" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="20*" align="left" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="80*" class="- topic/colspec "/><thead class="- topic/thead "><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Insert the USB key into a USB port on your workstation. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Open File Explorer and browse to the USB key root directory: 
</p><fig id="GUID-E625E140-A0C9-4EFF-BBB3-77A1E76F1418" class="- topic/fig "><title class="- topic/title "/><image href="GUID-5BB6BD96-0116-47D2-B9F5-109F44E51A2F-low.png" placement="inline" class="- topic/image " otherprops="GUID-5BB6BD96-0116-47D2-B9F5-109F44E51A2F-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Double click the 
<b class="+ topic/ph hi-d/b ">ReUseKey.bat</b> file: 
</p><p class="- topic/p "> The key name is changed into OCEINSTALL and the key is now ready for a new clean installation: 
</p><fig id="GUID-80513400-F9CF-4CA1-9561-7172D7944700" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3ECCC136-76FF-4970-8CCF-3D8AB46B80FA-low.png" placement="inline" class="- topic/image " otherprops="GUID-3ECCC136-76FF-4970-8CCF-3D8AB46B80FA-low.png"/></fig></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-724C7F1C-09E3-4D8F-B77B-2B159E768314.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
</task>