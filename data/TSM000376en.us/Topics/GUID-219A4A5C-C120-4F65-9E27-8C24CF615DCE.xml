<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-219A4A5C-C120-4F65-9E27-8C24CF615DCE" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-219A4A5C-C120-4F65-9E27-8C24CF615DCE" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Clean the maintenance station</title><abstract class="- topic/abstract " id="GUID-877717ED-2ADB-46B6-B00B-23C40B11FD41"><p class="- topic/p "><draft-comment class="- topic/draft-comment " translate="no">Dit topic moet nog aangepast/aangevuld worden als duidelijk is wat er gepoetst moet worden</draft-comment> 
</p><p class="- topic/p "> The maintenance station plays an important role to keep the printheads optimally cleaned. 
</p><p class="- topic/p "> Video: <ph class="- topic/ph " varid="Video: 4-Clean the maintenance station"><xref class="- topic/xref " format="html" href="https://sus.cpp.canon/6B0TNB1P" scope="external"><?ditaot usertext?> 
<image class="- topic/image " href="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png" placement="inline" otherprops="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png"/> Clean the maintenance station</xref></ph> 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-31D34DB9-8D62-46C7-925C-D8A71AEBA2F4" class="- topic/section task/prereq "><p class="- topic/p "><ph class="- topic/ph "><indexterm class="- topic/indexterm ">Printhead maintenance</indexterm><indexterm class="- topic/indexterm ">Maintain the print quality</indexterm><indexterm class="- topic/indexterm ">Clean maintenance station</indexterm></ph> 
</p><p class="- topic/p ">Use <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> prescribed: 
</p><ul id="UL_88FE82F1C6B343028F9B61DB8C430ED7" class="- topic/ul "><li id="LI_F4B9AC154F1445FBAA8F889824E6FD43" class="- topic/li "><p class="- topic/p "><ph translate="no" class="- topic/ph ">Microflex</ph> gloves for handling ink 
</p></li><li id="LI_6FA5A3A7E0FE4587B6D4539C231C8B45" class="- topic/li "><p class="- topic/p ">Lint free cloths and swabs 
</p></li><li id="LI_0F605234E9F649A6834D48B07AD88CF9" class="- topic/li "><p class="- topic/p ">Cleaning liquid (Cleaner MB - Methyl benzoate) 
</p></li><li class="- topic/li "><p class="- topic/p ">Cleaning liquid (IPA) 
</p></li></ul><note id="GUID-153CC759-3960-41C2-B43D-821B59856AAF" class="- topic/note "><p class="- topic/p ">For information on the prescribed maintenance materials. 
</p></note></prereq><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-9848D934-FF3E-4AC9-BA07-69028FA44036" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-A5623001-6625-48BF-9250-9DFE11206564" class="- topic/section "><title class="- topic/title "/><note type="caution" id="d10604e63" class="- topic/note "><ul id="d10604e64" class="- topic/ul "><li id="d10604e65" class="- topic/li "><p class="- topic/p "> Wear the prescribed gloves when contact with ink or maintenance materials is possible. Gloves should always overlap sleeves. Follow the Safety Data Sheets (SDS) guidelines carefully in order to ensure maximum safety. 
</p></li></ul></note><note id="GUID-BB1519B1-067D-4EFA-B60A-370379803111" class="- topic/note " type="important"><p class="- topic/p "> Use the prescribed cleaning liquid. Do not use any other cleaners. 
</p></note></section><steps id="GUID-4C40AD14-2A50-4DCA-9438-54C64F3AAF26" class="- topic/ol task/steps "><step id="STEP_1D69CFEC1EEC4F88B576BC0326F1EC67" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Start the maintenance action via the operator panel. 
</cmd></step><step id="STEP_B03E532FAA3F4E05B170FCD884D9433E" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Put on the <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> approved gloves. 
</cmd></step><step id="STEP_8B2E451B561A490A8C9644C7FB2B089F" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Open the top cover from the media input side. 
</cmd></step><step id="STEP_B7661A3242734219B188DA75447C5453" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Locate the purge tray on the right-hand side. 
</cmd><info class="- topic/itemgroup task/info "><p class="- topic/p ">The purge tray is located in the maintenance station. 
</p><fig id="GUID-A932CFF2-3165-44FC-8C2E-E66A954AB923" class="- topic/fig "><image href="GUID-E47F239F-47A5-4495-9B96-3A65C8AC9862-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E47F239F-47A5-4495-9B96-3A65C8AC9862-low.png"/></fig></info></step><step id="STEP_6BEE88329619459A9826E4651D1F61EA" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Take a lint free cloth and clean the purge tray. Clean until all residue ink is gone. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-52696A86-699F-48C8-9BC2-7F664AF9290A" class="- topic/note " type="caution"><p class="- topic/p ">Be careful to touch, the purge tray can be hot. Allow 5 minutes to cool down before cleaning. 
</p></note><fig id="GUID-127C667F-4D13-45A9-A24F-072FAAD64025" class="- topic/fig "><image href="GUID-ED204E2C-F877-4969-B691-4358800C0310-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-ED204E2C-F877-4969-B691-4358800C0310-low.png"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">If necessary, dampen a lint free cloth with cleaner IPA to remove any remaining ink. 
</cmd></step><step id="STEP_405F1ECDD9134025B057B1CC2EEBF2AB" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dispose the gloves, cloths and swabs as chemical waste according to local regulations. 
</cmd></step><step id="STEP_40BEA6EB4D2244F696407D4421997E74" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Close the top cover. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-5D6A0AEF-4DA9-434F-B281-61551A1E4776" class="- topic/note " type="important"><p class="- topic/p ">Make sure all covers are closed correctly to prevent cured ink in your system. 
</p></note></info></step><step id="STEP_B5CD40F3FB5A45AA821C9DE3DF066634" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">On the operator panel tap <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Completed</text></uicontrol></ph> to end the maintenance action or continue to the next action, 
<xref keyref="Clean_the_matrix_plate_area_and_the_black_protection_cover" class="- topic/xref " href="GUID-437CF38A-538E-4CA8-9529-D3992775BBB1.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text Clean the matrix plate area and the black protection cover?>Clean the matrix plate area and the black protection cover</xref>. 
</cmd></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-EAB54A10-F7C3-4675-BFDD-94735EBEE8B0.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
