<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-E30D0D63-1649-498E-8E93-E4D51B79CDB8" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-E30D0D63-1649-498E-8E93-E4D51B79CDB8" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to adjust the distance between the curing carriage and the printhead carriage</title><abstract class="- topic/abstract " id="GUID-173AF84C-D126-4DD5-8ABA-ADD08113B9D4"><p class="- topic/p ">With this adjustment you can check and adjust the distance between the curing carriage and the printhead carriage. Aim: no touch between the 2 carriages. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Adjustment</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A392D23B9FA5434A8095E72A33F001E1" class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Caliper / feeler gauges 
</p><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-75EFABA1-AEC9-458A-865A-1BBB3BCE8DE3" class="- topic/fig "><image href="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png" placement="inline" class="- topic/image " otherprops="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png"/></fig></section><section id="GUID-C4CC5A0E-358E-4191-A77A-D419335CB771" class="- topic/section "><title class="- topic/title ">How to check</title><table pgwide="1" id="GUID-629F58CA-E2C0-44BB-9002-79969014A363" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Do SDS test 
<xref keyref="SDS01-6-001" class="- topic/xref " href="GUID-D8E038CE-9D98-45E8-B362-A1C9227FCAE7.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 01-6-001 Align the mirrors of the printhead and curing carriage [Special Tests]?>01-6-001 Align the mirrors of the printhead and curing carriage [Special Tests]</xref> 
</p><p class="- topic/p ">Position the curing carriage (with the mirror) in the middle of the platen (print surface). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D4DAFD04-6758-470D-BDC0-90A82C3F3DB3" class="- topic/fig "><image href="GUID-43DAAA38-FF82-4C11-AC24-CE2143D285B6-low.png" placement="inline" class="- topic/image " otherprops="GUID-43DAAA38-FF82-4C11-AC24-CE2143D285B6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Align the printhead carriage with the curing carriage: specification 0 +/- 1 mm. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6F8EF468-674E-43FC-8FA3-00C64FD114C9" class="- topic/fig "><image href="GUID-BCA00EFD-ECF9-4EEF-920A-19A1E20457B1-low.png" placement="inline" class="- topic/image " otherprops="GUID-BCA00EFD-ECF9-4EEF-920A-19A1E20457B1-low.png"/></fig><fig id="GUID-3C770FFE-5BB0-485A-AAE5-F2B67B06A20E" class="- topic/fig "><image href="GUID-0463D05B-8659-46AD-80AB-2FFA232D8A3F-low.png" placement="inline" class="- topic/image " otherprops="GUID-0463D05B-8659-46AD-80AB-2FFA232D8A3F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Check</b>: Specification distance between the curing carriage glass plate and printhead carriage at a height of 60 +/- 5 mm: 5 +1/-0 mm. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8F2BFA38-3419-4E50-8BE6-53AAB5858C81" class="- topic/fig "><image href="GUID-F0240404-AD43-4650-8D67-9AA3FC4AA026-low.png" placement="inline" class="- topic/image " otherprops="GUID-F0240404-AD43-4650-8D67-9AA3FC4AA026-low.png"/></fig><fig id="GUID-F62A53A6-DD5D-4123-86F7-4D0B1F8A6A45" class="- topic/fig "><image href="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png" placement="inline" class="- topic/image " otherprops="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to adjust</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 4 screws [A]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1E465B8F-1787-40DC-9566-462ED3CC2341" class="- topic/fig "><image href="GUID-7D3D4C8A-2ED5-4458-B578-D9B8AFA5BF57-low.png" placement="inline" class="- topic/image " otherprops="GUID-7D3D4C8A-2ED5-4458-B578-D9B8AFA5BF57-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Adjust the distance between the curing carriage glass plate and printhead carriage at a height of 60 +/- 5 mm to: 5 +1/-0 mm. 
</p><note id="GUID-278650C7-E77E-4276-BC24-D2CA264EEB90" class="- topic/note "><p class="- topic/p ">If you cannot reach 5 mm then use the highest possible distance. 
</p></note></li><li class="- topic/li "><p class="- topic/p ">Lock the 4 screws [A]. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3D6B3534-22AD-4A34-826E-E058547F350C" class="- topic/fig "><image href="GUID-F0240404-AD43-4650-8D67-9AA3FC4AA026-low.png" placement="inline" class="- topic/image " otherprops="GUID-F0240404-AD43-4650-8D67-9AA3FC4AA026-low.png"/></fig><fig id="GUID-56C22014-CBD7-44BF-B989-EC2E7CF960A4" class="- topic/fig "><image href="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png" placement="inline" class="- topic/image " otherprops="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png"/></fig><fig id="GUID-B82B1F23-BCEA-480D-888C-E526AE28468B" class="- topic/fig "><image href="GUID-7D3D4C8A-2ED5-4458-B578-D9B8AFA5BF57-low.png" placement="inline" class="- topic/image " otherprops="GUID-7D3D4C8A-2ED5-4458-B578-D9B8AFA5BF57-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">After the adjustment always check if the mirrors do not touch: 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Move both carriages to the left hand position and check. 
</p></li><li class="- topic/li "><p class="- topic/p ">Move both carriages to the right hand position and check. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D2EDFDDE-0B31-4096-903E-FAD25C756227" class="- topic/fig "><image href="GUID-D9067578-EE0C-4121-ACF9-6C51652259DD-low.png" placement="inline" class="- topic/image " otherprops="GUID-D9067578-EE0C-4121-ACF9-6C51652259DD-low.png"/></fig><fig id="GUID-8FC2D866-82DE-4FA4-98F9-5299FB0E0CE8" class="- topic/fig "><image href="GUID-C40C24BF-7034-47ED-A851-CB2D5E44C269-low.png" placement="inline" class="- topic/image " otherprops="GUID-C40C24BF-7034-47ED-A851-CB2D5E44C269-low.png"/></fig></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-1F897B6A-3B52-4EA1-AC18-9626A9B429D4.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Adjustment</linktext></link></linkpool></related-links>
