<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-EE605FAD-64BF-4FF5-AAD6-66BFAF4EC385" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-EE605FAD-64BF-4FF5-AAD6-66BFAF4EC385" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 Align media from jumbo roll and printer</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-4151C728-63C5-4EE3-9349-BB69D350F074" class="- topic/section task/prereq "><p class="- topic/p "><indexterm class="- topic/indexterm ">Jumbo roll unwinder<indexterm class="- topic/indexterm ">Align media</indexterm></indexterm> 
</p><p class="- topic/p ">Load media from the jumbo roll, see 
<xref keyref="12USER002" class="- topic/xref " href="GUID-6C2B532F-74A2-4840-B033-896FAC40D873.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>12 Load media from the jumbo roll</xref>. 
</p></prereq><steps id="GUID-65CDF500-6B59-4D20-B91B-9336C9EE5F12" class="- topic/ol task/steps "><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">If a job is waiting to be printed, pause that job. Select the loaded media at the operator panel and select <uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Feed</text></uicontrol>. 
</cmd><info class="- topic/itemgroup task/info "><p class="- topic/p ">Pay attention to the position of the media edge. Compare for example to an Xtran roller. This is your reference position. 
</p><fig id="GUID-4F534E28-4920-41EF-AE2D-A24A335CCC13" class="- topic/fig "><image href="GUID-4C86495D-4DF9-4EF1-8B66-A02266C030EC-low.png" placement="inline" class="- topic/image " otherprops="GUID-4C86495D-4DF9-4EF1-8B66-A02266C030EC-low.png"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd "><i class="+ topic/ph hi-d/i ">In case of software version 2.3 or higher 
</i> 
</cmd><substeps class="- topic/ol task/substeps "><substep class="- topic/li task/substep "><cmd class="- topic/ph task/cmd "> Select <uicontrol class="+ topic/ph ui-d/uicontrol ">Free fall</uicontrol> on the operator panel. 
</cmd></substep><substep class="- topic/li task/substep "><cmd class="- topic/ph task/cmd ">Set the media transport distance to 700 mm (27.55 inch). 
</cmd></substep><substep class="- topic/li task/substep "><cmd class="- topic/ph task/cmd ">Check the position of the media edge compared to the reference position. 
</cmd></substep><substep class="- topic/li task/substep "><cmd class="- topic/ph task/cmd ">Repeat the previous steps 2 and 3 until the difference during one media feed of 700 mm (27.55 inch) is smaller than 1 mm (0.039 inch). 
</cmd></substep><substep class="- topic/li task/substep "><cmd class="- topic/ph task/cmd "> Select <uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Cut</text></uicontrol> to cut the media. 
</cmd><info class="- topic/itemgroup task/info "><p class="- topic/p ">The media will spool back to the load media interface. 
</p></info></substep></substeps></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd "><i class="+ topic/ph hi-d/i ">In case of software release 2.2. or lower 
</i> 
</cmd><substeps class="- topic/ol task/substeps "><substep class="- topic/li task/substep "><cmd class="- topic/ph task/cmd "> Select <uicontrol class="+ topic/ph ui-d/uicontrol ">Print to output roll</uicontrol> on the operator panel. 
</cmd></substep><substep class="- topic/li task/substep "><cmd class="- topic/ph task/cmd ">Feed the media manually 700 mm (27.55 inch). 
</cmd></substep><substep class="- topic/li task/substep "><cmd class="- topic/ph task/cmd ">Check the position of the media edge compared to the reference position. 
</cmd></substep><substep class="- topic/li task/substep "><cmd class="- topic/ph task/cmd ">Repeat the previous steps 2 and 3 until the difference during one media feed of 700 mm (27.55 inch) is smaller than 1 mm (0.039 inch). 
</cmd></substep></substeps></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Perform a media calibration. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">If required, select 
<menucascade class="+ topic/ph ui-d/menucascade "><uicontrol class="+ topic/ph ui-d/uicontrol ">Output configuration</uicontrol><uicontrol class="+ topic/ph ui-d/uicontrol ">Wind the output </uicontrol><uicontrol class="+ topic/ph ui-d/uicontrol ">Yes</uicontrol></menucascade> and start to print. 
</cmd></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-E054F15A-BCD6-47D9-B1D0-CC54757FAE0D.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
