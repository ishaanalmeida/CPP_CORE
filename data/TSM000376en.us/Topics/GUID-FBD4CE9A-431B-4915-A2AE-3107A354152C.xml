<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-FBD4CE9A-431B-4915-A2AE-3107A354152C" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-FBD4CE9A-431B-4915-A2AE-3107A354152C" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to remove the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Media loading drawer 1 roll 2 sensor 1</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 12B6 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">MLO_DRA1_ROL2_SE1</compsignal></comp></title><abstract class="- topic/abstract " id="GUID-182E5B05-0514-4631-8FDB-3F7D0EA91F1F"><p class="- topic/p ">This document describes how to remove the media sensor 1 of roll 2.(12B6) 
</p><p class="- topic/p "> Besides removing the sensor it also describes how to replace the bracket for a different bracket on which the sensor is mounted. 
</p><p class="- topic/p ">The difference between the old end new bracket is the position of the sensor mounting holes. 
</p><p class="- topic/p ">With the new bracket the sensor is positioned closer to the media for a better registration. See Modification 03 of the M-series for more details. 
</p><p class="- topic/p ">Furthermore a reflection sticker needs to be glued for a better reflection of the transmitting light. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_34F2C03C97F249649B92631C09DBB41B" class="- topic/li "><p class="- topic/p ">Open the media loading drawer. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_69BB0AEB395F4E8AB96FD94A4C0C8696" class="- topic/ul "><li id="LI_06B1AE50C8584502AA32D102711C1229" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li id="LI_561D1BF957EA49F8BB49139266A92893" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-F2B90B66-C742-4C0B-9FA7-01812C675C08" class="- topic/fig "><image href="GUID-DB60865A-585F-4C58-AF93-8A6996BC4D31-low.png" placement="inline" class="- topic/image " otherprops="GUID-DB60865A-585F-4C58-AF93-8A6996BC4D31-low.png"/></fig></section><section id="SECTION_878FB6D82409436DB8132AB7ADFA1807" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_2D6BD70DB77E4579ACF13DF02715F1F6" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the cover (8 screws) at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8661E45D-7C56-4E99-A9D8-45882F254B0A" class="- topic/fig "><image href="GUID-06E69570-CDC3-48BD-ADFA-2B7118E33F64-low.png" placement="inline" class="- topic/image " otherprops="GUID-06E69570-CDC3-48BD-ADFA-2B7118E33F64-low.png"/></fig><fig id="GUID-D573907F-2A43-46C0-B997-42F943FF57D2" class="- topic/fig "><image href="GUID-40E67322-D9BF-49F8-BD8D-91F0B7792871-low.png" placement="inline" class="- topic/image " otherprops="GUID-40E67322-D9BF-49F8-BD8D-91F0B7792871-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the end stop of the vertical transport at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-65031544-D78D-479E-8CD8-58746C6D0531" class="- topic/fig "><image href="GUID-8D855FFD-7CE3-497E-8C02-4D62D15F7E15-low.png" placement="inline" class="- topic/image " otherprops="GUID-8D855FFD-7CE3-497E-8C02-4D62D15F7E15-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the vertical transport. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-60AE764E-40D2-4F89-9914-B91A97BA6C10" class="- topic/fig "><image href="GUID-41BA6F5C-E73A-44BB-AC30-40E2B5C1164C-low.png" placement="inline" class="- topic/image " otherprops="GUID-41BA6F5C-E73A-44BB-AC30-40E2B5C1164C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the lower screw and loosen the upper screw of the guide plate at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B688850B-5FEA-43D1-B9F6-5B325A8A88A9" class="- topic/fig "><image href="GUID-7F633886-915E-459B-95DF-314588A5D323-low.png" placement="inline" class="- topic/image " otherprops="GUID-7F633886-915E-459B-95DF-314588A5D323-low.png"/></fig><fig id="GUID-BC6EFB39-788F-4CFB-BCAF-9189D7D98A14" class="- topic/fig "><image href="GUID-E15EB8BB-2B7D-4C76-82D3-BA57FC95746F-low.png" placement="inline" class="- topic/image " otherprops="GUID-E15EB8BB-2B7D-4C76-82D3-BA57FC95746F-low.png"/></fig><fig id="GUID-67964CC6-9561-4A01-8871-3DB13E39D41D" class="- topic/fig "><image href="GUID-B339AEE4-7CE1-486D-89A4-3D56F9549304-low.png" placement="inline" class="- topic/image " otherprops="GUID-B339AEE4-7CE1-486D-89A4-3D56F9549304-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the guide plate: lift it, by moving the bolt upwards, with a screwdriver. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-96029605-0420-4FC4-A44E-0AF66B6DF4C7" class="- topic/fig "><image href="GUID-57DB8406-D46D-4D32-B599-20DA8714FD41-low.png" placement="inline" class="- topic/image " otherprops="GUID-57DB8406-D46D-4D32-B599-20DA8714FD41-low.png"/></fig><fig id="GUID-CDB1C864-4A44-4DE5-B3B1-55CEA59F9DAD" class="- topic/fig "><image href="GUID-FED10BF6-29EB-422F-A579-1FF706938330-low.png" placement="inline" class="- topic/image " otherprops="GUID-FED10BF6-29EB-422F-A579-1FF706938330-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the clamps 
</p><p class="- topic/p ">Remove the screws of the bracket and sensors. 
</p><p class="- topic/p ">Disconnect and remove the sensors. 
</p><note id="GUID-08F45960-6694-4281-BC67-D492CA2A313B" class="- topic/note "><p class="- topic/p ">The difference between the old end new bracket is the position of the sensor mounting holes. 
</p><p class="- topic/p ">With the new bracket the sensors are positioned closer to the media for a better registration. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7549F88B-9C6E-439A-BE31-2D274DCA86D9" class="- topic/fig "><image href="GUID-ED3093CE-6B2C-47CB-86C7-0C3DCC09EF98-low.png" placement="inline" class="- topic/image " otherprops="GUID-ED3093CE-6B2C-47CB-86C7-0C3DCC09EF98-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">After installing the new bracket with the sensors the reflection sticker has to be mounted.
</p><p class="- topic/p ">Before this can take place cover the needs to be moved up by rotation.
</p><p class="- topic/p ">Before the rotation can take place:
</p><p class="- topic/p ">- remove the 4 screws.
</p><p class="- topic/p ">- disconnect the cable. 
</p><p class="- topic/p ">- remove the cable from the clamps. 
</p><p class="- topic/p ">- move up the cover by rotation to get access to the hole where the reflective sticker must be placed.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-83B0ACD9-791B-4DB4-98B4-7832B243B5CE" class="- topic/fig "><image href="GUID-4433F69C-E1A0-4870-A18B-1E9F0763E767-low.png" placement="inline" class="- topic/image " otherprops="GUID-4433F69C-E1A0-4870-A18B-1E9F0763E767-low.png"/></fig><fig id="GUID-2EEF0B17-7066-4E73-9CCA-FD74C1D4B48C" class="- topic/fig "><image href="GUID-5E19CD11-C28D-4AA1-993A-A4351EA402EC-low.png" placement="inline" class="- topic/image " otherprops="GUID-5E19CD11-C28D-4AA1-993A-A4351EA402EC-low.png"/></fig><fig id="GUID-4CA1E29F-250A-46BA-94E4-0166D889D3B3" class="- topic/fig "><image href="GUID-14E42886-649D-4C79-BDBA-0F2DF4C0DA08-low.png" placement="inline" class="- topic/image " otherprops="GUID-14E42886-649D-4C79-BDBA-0F2DF4C0DA08-low.png"/></fig><fig id="GUID-6B53516B-80D5-46A2-AB2D-68D66025C14A" class="- topic/fig "><image href="GUID-A20AC92B-FDDD-43C0-B22B-553BFEE9077C-low.png" placement="inline" class="- topic/image " otherprops="GUID-A20AC92B-FDDD-43C0-B22B-553BFEE9077C-low.png"/></fig><fig id="GUID-F47CAEBB-E9F4-475E-8D76-6716E53F4726" class="- topic/fig "><image href="GUID-4433F69C-E1A0-4870-A18B-1E9F0763E767-low.png" placement="inline" class="- topic/image " otherprops="GUID-4433F69C-E1A0-4870-A18B-1E9F0763E767-low.png"/></fig><fig id="GUID-251D42F5-2B28-41E5-9A5D-3B4A4D6E25BF" class="- topic/fig "><image href="GUID-63D0BBEA-73E9-4A24-8610-B8911EA70AD4-low.png" placement="inline" class="- topic/image " otherprops="GUID-63D0BBEA-73E9-4A24-8610-B8911EA70AD4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the stickers as close to the edge as possible for the better reflection.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1FBB6E46-BC9F-4DE0-8017-1DC77837BEA1" class="- topic/fig "><image href="GUID-793A69FB-118F-4DB3-B7FA-E513E3BADD8C-low.png" placement="inline" class="- topic/image " otherprops="GUID-793A69FB-118F-4DB3-B7FA-E513E3BADD8C-low.png"/></fig><fig id="GUID-7CCCDBE5-03CF-447B-B5FA-98DBFDCA653E" class="- topic/fig "><image href="GUID-4D15BE19-C7D8-4DCF-922B-65AF5781BC31-low.png" placement="inline" class="- topic/image " otherprops="GUID-4D15BE19-C7D8-4DCF-922B-65AF5781BC31-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Press the sticker firmly to achieve the best adhesion of the sticker.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3A25FF72-C073-4145-AB00-D89034756B3F" class="- topic/fig "><image href="GUID-9FD3B149-407F-4E2A-B577-72EDAA35293F-low.png" placement="inline" class="- topic/image " otherprops="GUID-9FD3B149-407F-4E2A-B577-72EDAA35293F-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p><note id="GUID-956A624A-8538-43A7-8D30-FE3375992BAC" class="- topic/note "><p class="- topic/p ">Watch the position of the guide plate. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-AF30AA42-1168-450E-B997-1299E2468DEE" class="- topic/fig "><image href="GUID-1F89EA8C-96AB-4B1E-AD65-39FD79498235-low.png" placement="inline" class="- topic/image " otherprops="GUID-1F89EA8C-96AB-4B1E-AD65-39FD79498235-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B96AB9C-8847-4643-A8CB-09918FE19AAB.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
