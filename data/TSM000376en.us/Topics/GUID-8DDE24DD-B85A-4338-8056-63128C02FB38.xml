<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-8DDE24DD-B85A-4338-8056-63128C02FB38" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-8DDE24DD-B85A-4338-8056-63128C02FB38" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">24 How to replace the transparent section of the top cover</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes the replacement of the transparent section of the top cover. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><context id="GUID-E97D21F1-EF8D-4608-970B-67B98723300D" class="- topic/section task/context "><p class="- topic/p ">Possible reason: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Damage / scratches as result of wear out caused by printhead carriage and/or curing carriage. 
</p></li><li class="- topic/li "><p class="- topic/p "> Broken seams of the transparent section of the top cover. 
</p></li></ul></context><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_15B8D14878F44C99BFAC66EC679EEE04" class="- topic/ul "><li id="LI_A8FF400228E3408CA25F84084B474941" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Attention:</ph></title><p class="- topic/p ">2 persons are required to lift the items. 
</p></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-1C6A5506-8461-4BFD-8B7C-FB47C7EF289A" class="- topic/fig "><image href="GUID-52639E30-1224-4ADD-9048-89FFF0F87459-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-52639E30-1224-4ADD-9048-89FFF0F87459-low.png"/><image href="GUID-15049226-0CCC-4B65-AEF8-F78D50FFC777-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-15049226-0CCC-4B65-AEF8-F78D50FFC777-low.png"/></fig></section><section id="SECTION_9B52B4F9A6064E8FA0DA985640631979" class="- topic/section "><title class="- topic/title ">Preparation</title><table pgwide="1" id="TABLE_72520E2720514D4A9F47D90E3DC56450" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the lower screws of the cover of the crate ( with the new transparent section of the top cover). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-61A4B5E3-F1E6-4BD9-B49C-86E33979CA04" class="- topic/fig "><image href="GUID-287CA119-EEB1-4B7D-A28B-0CEE10199C58-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-287CA119-EEB1-4B7D-A28B-0CEE10199C58-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><note type="caution" id="GUID-F8BB65FC-65ED-4851-8979-32A8A05332BF" class="- topic/note "><p class="- topic/p ">2 persons are required to lift the item. 
</p></note><p class="- topic/p ">Lift and remove the cover of the crate. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4E73C817-4140-4DE3-AAA9-6923B411AA4F" class="- topic/fig "><image href="GUID-60E2E8A4-2C59-4906-83BE-A95EEA5346F9-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-60E2E8A4-2C59-4906-83BE-A95EEA5346F9-low.png"/></fig><fig id="GUID-BFA841FE-931E-47BD-981B-21A4FEC43ACC" class="- topic/fig "><image href="GUID-F1BA878C-F29C-4E94-88D7-7ED366EA2D95-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F1BA878C-F29C-4E94-88D7-7ED366EA2D95-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the cover of the crate near the printer. It is used to put the top cover on. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-44A95E11-7FA9-47B5-991E-AA4EFBC56A68" class="- topic/fig "><image href="GUID-30608209-C118-4EAF-BAF6-57C8AA99AABF-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-30608209-C118-4EAF-BAF6-57C8AA99AABF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><note type="caution" id="GUID-EE5DF9EA-7BA7-458A-AA55-78A973E6D76D" class="- topic/note "><p class="- topic/p ">2 persons are required to lift the item. 
</p></note><p class="- topic/p ">Do 
<xref keyref="24DISA09" class="- topic/xref " href="GUID-5CE51160-E27D-4814-BCC5-CA5F098D6CE7.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the top cover?>24 How to remove the top cover</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the top cover and place it on the cover of the crate. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-408FAA75-4F1F-4922-85DC-4EC721F7F3F4" class="- topic/fig "><image href="GUID-D4E46178-9E2B-49D2-859B-BE641EF1DBA4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D4E46178-9E2B-49D2-859B-BE641EF1DBA4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the left and right hand side cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-44084C5F-CE18-4916-B7B1-C8A5A73173B1" class="- topic/fig "><image href="GUID-D4E46178-9E2B-49D2-859B-BE641EF1DBA4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D4E46178-9E2B-49D2-859B-BE641EF1DBA4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the old damaged or scratched transparent section of the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> Pick-up the new transparent section of the top cover plate including bubble foam and the cardboard boxes inside. Place it next to the top cover frame. 
</p><note type="important" id="GUID-F8121701-90D7-423D-97B6-21F876D2B384" class="- topic/note "><p class="- topic/p ">Keep the orientation of the transparent section the same as the frame of the top cover is. Do not handle it unnecessarily! 
</p></note></li><li class="- topic/li "><p class="- topic/p "> Remove the bubble foam from the top side of the transparent section. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4264A5B0-E4F7-42B8-A6A7-2D88F822C3BA" class="- topic/fig "><image href="GUID-954678B7-9A62-494E-AFB2-433D42E5B57A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-954678B7-9A62-494E-AFB2-433D42E5B57A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 3 carton boxes and place the frame of the top cover on it. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8D6EBE5C-0C47-432B-A6A8-31B9F08A7DE3" class="- topic/fig "><image href="GUID-C3E1B2CC-6E31-4113-8FA1-7F7B07870C95-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C3E1B2CC-6E31-4113-8FA1-7F7B07870C95-low.png"/></fig><fig id="GUID-6CD62ECB-F21D-4E0C-B748-3521553A9B8A" class="- topic/fig "><image href="GUID-F167F61E-2E27-414D-8D0A-EC8C9A4C6FFE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F167F61E-2E27-414D-8D0A-EC8C9A4C6FFE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the anti-scratch foil from the inner side of the transparent section of the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-69CCE95F-D948-4C42-B09B-F49A5C76CBE8" class="- topic/fig "><image href="GUID-51B9226D-D204-4169-8C9C-73F5CC8368FD-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-51B9226D-D204-4169-8C9C-73F5CC8368FD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><note type="important" id="GUID-9EA8BD1D-C63E-49AD-8AC5-A28EE5274AAE" class="- topic/note "><p class="- topic/p "> The transparent section is very vulnerable! 
</p></note><p class="- topic/p ">Turn the transparent section of the top cover very carefully. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-66A07F12-39EC-41EB-9081-6F4A4003BE0B" class="- topic/fig "><image href="GUID-C807A426-9B94-43FF-903A-F0A3FA8A5095-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C807A426-9B94-43FF-903A-F0A3FA8A5095-low.png"/></fig><fig id="GUID-580AEE38-FFD6-472C-91CE-A4D461189636" class="- topic/fig "><image href="GUID-E087A539-D0FB-472A-BCA3-FD17ABAC4C9E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E087A539-D0FB-472A-BCA3-FD17ABAC4C9E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the transparent section of the top cover on the frame. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0257396D-3D7A-4E22-9778-FD14DA7168E8" class="- topic/fig "><image href="GUID-47A2F896-D1A8-4BB7-B00C-A48C10E302DF-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-47A2F896-D1A8-4BB7-B00C-A48C10E302DF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the left and right hand side cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FADFC1EB-5A2A-4FBC-A139-C345FAEEE223" class="- topic/fig "><image href="GUID-CAA8CE2B-C394-4CAE-A334-341A58838767-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CAA8CE2B-C394-4CAE-A334-341A58838767-low.png"/></fig><fig id="GUID-C7066133-598C-4AEA-9A9B-34930030A130" class="- topic/fig "><image href="GUID-8225B8F7-BD01-4FD5-B92D-B2302E2FC572-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8225B8F7-BD01-4FD5-B92D-B2302E2FC572-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the foil from te the transparent section of the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift and install the top cover. 
</p><p class="- topic/p ">See 
<xref keyref="24DISA09" class="- topic/xref " href="GUID-5CE51160-E27D-4814-BCC5-CA5F098D6CE7.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the top cover?>24 How to remove the top cover</xref> 
</p><note type="important" id="GUID-2D0AE673-8AC4-4AD6-A687-8975818FB9C2" class="- topic/note "><p class="- topic/p "> Pay attention to the hinges to get them fit in correctly! 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9508B2B5-130F-4412-A622-DE10916E05CE" class="- topic/fig "><image href="GUID-EA77BC12-1D14-4D73-8066-2F7FB3938F78-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EA77BC12-1D14-4D73-8066-2F7FB3938F78-low.png"/></fig><fig id="GUID-58A26F90-1908-4D31-9AF6-7B3B74B26F62" class="- topic/fig "><image href="GUID-EA77BC12-1D14-4D73-8066-2F7FB3938F78-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EA77BC12-1D14-4D73-8066-2F7FB3938F78-low.png"/></fig><fig id="GUID-C0D4C022-C0AC-406D-8A6D-7225CAAA4CAB" class="- topic/fig "><image href="GUID-30F95765-6904-4901-BDC9-137441BD46A4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-30F95765-6904-4901-BDC9-137441BD46A4-low.png"/></fig><fig id="GUID-D9735D90-601F-42A9-AE93-FBF7184741AD" class="- topic/fig "><image href="GUID-CC5FD62D-41E0-4DC6-AE3C-4E4895B86DC2-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CC5FD62D-41E0-4DC6-AE3C-4E4895B86DC2-low.png"/></fig></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-7AFD0866-DB58-478E-910C-31C411B10126.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
