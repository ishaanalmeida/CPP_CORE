<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-3A10D9A8-F181-4D93-B596-9F23CB84B79D" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-3A10D9A8-F181-4D93-B596-9F23CB84B79D" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">02 How to fill ink in the used system</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes the installation of pump tubes. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_CEA4CD427612471CA3540AD5430B21C2" class="- topic/ul "><li id="LI_B007BBFF5E5743C89A24651737F64808" class="- topic/li "><p class="- topic/p ">Cloth 
</p></li><li class="- topic/li "><p class="- topic/p ">A pair of scissors 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex 
</b> 93-260 gloves 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-2D7D94A0-B26C-4C0B-B6A3-20C8621663A2" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-63E079CC-61F0-4AF7-80FE-0189DD0FDD73" class="- topic/section "><title class="- topic/title "> Fill ink in the used system</title></section><section id="GUID-5EA27C95-5182-4D96-BE42-E409FBB87504" class="- topic/section "><title class="- topic/title "> Preparation actions before placing the printheads:</title><table pgwide="1" id="GUID-C5035010-056F-494D-A2DC-E59ECE77F797" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Clean the maintenance station 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Clean the matrix plate. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-533BAD0F-BA8D-4A44-A355-AB35F5B1042E" class="- topic/section "><title class="- topic/title ">Steps in the filling process</title><table pgwide="1" id="GUID-8ED3B277-CF0D-4776-B3EF-B4CC9CDA37F8" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check all tube connectors in the pump / Reservoir unit to prevent air in the tubes. 
</p><p class="- topic/p ">CAUTION: Close all covers. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Switch ON the system. 
</p><p class="- topic/p "> Start-up the printer in zero SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Disable all printheads. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> To avoid ink premature filling. 
</p><p class="- topic/p "> CAUTION: 
</p><p class="- topic/p "> When an MRE occurs before the ink loading is finished. 
</p><p class="- topic/p ">The system needs a restart and the heads need to be disable again. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Go to Warm SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Do SDS test 02-6-004 Estimated ink level / Mark ink jar as empty (C, M, Y or K). 
</p><p class="- topic/p "> [Special Tests]. Mark the ink jars as empty. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Update test description for White. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> When the green refill LEDs turn on: place the new well shaken ink bottles. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> CMYK:10 seconds , W: 30 seconds. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Wait at least 15 seconds after loading of the last ink bottle. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> The ink needs to drain sufficiently before using it. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Go to Cold SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Open the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Slide the printhead carriage to the middle of the platen (print surface). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place a sheet of media on the platen. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place a maintenance tray on the sheet. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Close the valves of the printheads. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Disconnect the ink tube from printhead. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1. Guide the empty ink tubes into the maintenance tray. 
</p><p class="- topic/p ">2. Lock the tube to the maintenance tray with a clip/tape. 
</p><p class="- topic/p ">3. Open the valve of the tubs after you mounted it. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-40D946B1-88A3-4F36-A52B-42C676C2B0C4" class="- topic/fig "><title class="- topic/title "/><image href="GUID-F5A9F34B-9F3B-4F2F-B430-7780862E7BAE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F5A9F34B-9F3B-4F2F-B430-7780862E7BAE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Do SDS test 02-6-001 Fill ink tube(s) [Special Tests]. 
</p><p class="- topic/p ">1. Select "Pump &amp; color + number" and 400 seconds (Time to flush the complete volume of the ink tube). Fill the ink tubes one by one. 
</p><p class="- topic/p ">2. Check the ink flow: After the air bubbles (due to air in the ink tube) disappeared the ink must have a constant flow for 30 seconds from the ink tube. 
</p><p class="- topic/p ">3. When there is still air left in the ink tube, you can extend the 400 seconds by pressing continue in the SDS test. 
</p><p class="- topic/p ">4. Result: tube is air free if the ink flow has a heartbeat rhythm from the pump 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Result : tube is air free if the ink flow has a heartbeat rhythm from the pump. In case still air is in the ink tube: squeeze the ink pump together to improve the functionality of the pump or check/lock the ink tube couplings. 
</p><p class="- topic/p ">Pump numbers for each color: Y=2, K=3, M=4, K=5 and W=6
</p><p class="- topic/p "> to 
</p><p class="- topic/p "> Pump numbers for each color: 
</p><p class="- topic/p ">see 
<xref keyref="mapprintheads" class="- topic/xref " href="GUID-67370C7B-66D6-4187-925F-34D9A20977DB.xml" format="dita" locktitle="yes" type="concept"><?ditaot usertext?><?xm-replace_text Mapping pumps to printheads?>Mapping pumps to printheads</xref>
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Close the valve of the ink tube. (Reason: prevent air pocket in tube and pollution). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Connect the ink tube to the printhead. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Open all the valves of ink tube. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the maintenance tray from the sheet. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">21 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the sheet from the platen. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">22 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Leave SDS and restart the system 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">To enable the Printheads again 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">23 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> When in warming up, replace the waste tray and reset the counter via the wizard in the user interface. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> To prevent previous ink levels being used for the current tray. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">24 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> To prevent previous ink levels being used for the current tray. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-B389A763-3BDF-47D8-8530-E2CB730B7104.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
</task>