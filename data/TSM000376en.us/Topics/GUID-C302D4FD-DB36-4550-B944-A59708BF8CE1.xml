<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-C302D4FD-DB36-4550-B944-A59708BF8CE1" version="2" lang="en-US"?><reference xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-C302D4FD-DB36-4550-B944-A59708BF8CE1" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic reference)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c reference oceReference-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic       reference/reference "><title class="- topic/title "> Introduction Error types (handling)</title><abstract class="- topic/abstract " id="M148531-B27"><p class="- topic/p ">Error-types do not define the result of the error, but the method the error is handled. </p><p class="- topic/p "> Error-types are incorporated into the errorcode.</p><p class="- topic/p ">The following types can be distinguished:</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Functional description</category></metadata></prolog><refbody class="- topic/body        reference/refbody "><section id="M148531-B28" class="- topic/section "><title class="- topic/title ">Error types</title><table id="M148531-TB29" class="- topic/table "><tgroup cols="3" outputclass="free" align="left" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="33*" align="left" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="33*" align="left" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="33*" align="left" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Abbreviation</p></entry><entry colname="col2" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Name</p></entry><entry colname="col3" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Error type code</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">FE</p></entry><entry colname="col2" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Fatal Error</p></entry><entry colname="col3" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">0</p></entry></row><row class="- topic/row "><entry colname="col1" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">PE</p></entry><entry colname="col2" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Permanent Error</p></entry><entry colname="col3" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">1</p></entry></row><row class="- topic/row "><entry colname="col1" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">MRE</p></entry><entry colname="col2" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Machine Recoverable Error</p></entry><entry colname="col3" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">5</p></entry></row><row class="- topic/row "><entry colname="col1" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">ORE</p></entry><entry colname="col2" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Operator Recoverable Error</p></entry><entry colname="col3" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">7</p></entry></row><row class="- topic/row "><entry colname="col1" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">OWAR</p></entry><entry colname="col2" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Operator Warning</p></entry><entry colname="col3" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">8</p></entry></row><row class="- topic/row "><entry colname="col1" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">SWAR</p></entry><entry colname="col2" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Service Warning</p></entry><entry colname="col3" morerows="0" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">9</p></entry></row></tbody></tgroup></table></section><section id="GUID-0859D4EF-BF66-4B1D-AFE6-60621007AE74" class="- topic/section "><title class="- topic/title ">Fatal error (FE):</title><p class="- topic/p "><?xm-replace_text Paragraph?></p><p class="- topic/p "> Critical error detected in the control hardware / software of a unit.</p><p class="- topic/p "> This error type is used for low level hardware / software errors.</p><p class="- topic/p "> Examples are ROM / RAM failures, power-up failures, watchdogs et cetera</p><p class="- topic/p "> The control of the unit is no longer reliable and operating of the unit is not safe or possible.</p><p class="- topic/p "> The unit is shutdown immediately.</p><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b "> Recovery:</b> </p><p class="- topic/p "> If possible the error code is displayed in the operator panel or a beep code of the engine control PBA is given.</p><p class="- topic/p "> To recover from this error the operator has to switch the system OFF and ON.</p></section><section id="GUID-4672CBA1-8E21-4201-B679-272C308F255E" class="- topic/section "><title class="- topic/title "> Permanent error (PE):</title><p class="- topic/p "><?xm-replace_text Paragraph?></p><p class="- topic/p "> This error type is used for defects where it is not possible to restart the unit.</p><p class="- topic/p "> This is because there is a possibility that the defect causes more machine defects or causes damage to the customer / environment.</p><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b "> Recovery:</b> </p><p class="- topic/p "> An error message is displayed in the operator panel including the instruction to call service.</p><p class="- topic/p "> Service intervention is necessary to solve the defect. This error can only be reset in SDS</p></section><section id="GUID-E8C1185B-AA3C-4C90-85F8-91A09A34B751" class="- topic/section "><title class="- topic/title "> Machine recoverable error (MRE):</title><p class="- topic/p "><?xm-replace_text Paragraph?></p><p class="- topic/p "> This error type is used for defects where it is possible to restart the machine. (without causing more machine damage or damage to the customer / environment).</p><p class="- topic/p "> For some errors the second time the error occurs they become a Permanent Error.</p><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b "> Recovery:</b> </p><p class="- topic/p "> The error code is displayed in the display.</p><p class="- topic/p "> To recover from this error the operator has to switch the system off and on.</p></section><section id="GUID-1192C032-9169-4B78-9E64-12666186B2F0" class="- topic/section "><title class="- topic/title "> Operator recoverable error (ORE):</title><p class="- topic/p "><?xm-replace_text Paragraph?></p><p class="- topic/p "> Errors that can be resolved by the operator by opening / closing panels and / or removing paper.</p><p class="- topic/p "> The user interface shows pictures to guide the operator.</p><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b "> Recovery:</b> </p><p class="- topic/p "> The job-recovery instructions on the display must be followed.</p></section><section id="GUID-C8C784C7-FD91-4D7B-95A0-DAF5566332EA" class="- topic/section "><title class="- topic/title "> Operator warning (OWAR):</title><p class="- topic/p "><?xm-replace_text Paragraph?></p><p class="- topic/p "> Errors related to a (digital) original (or job), for example job description error, language not recognized, plot clipped et cetera</p><p class="- topic/p "> These errors will cause a warning message for the operator (on the place where the error was caused) and will be logged in SDS.</p><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b "> Recovery:</b> </p><p class="- topic/p "> The display shows a message, until the operator confirms that he has seen the message.</p><p class="- topic/p "> If possible the job will continue.</p></section><section id="GUID-02492909-D8E7-4347-AE60-F4C40CF8D7EA" class="- topic/section "><title class="- topic/title "> Service warning (SWAR):</title><p class="- topic/p "><?xm-replace_text Paragraph?></p><p class="- topic/p "> A warning for the service engineer, detection of a minor machine failure that will be logged in SDS. (the user will not see this)</p><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b "> Recovery:</b> </p><p class="- topic/p "> These errors are saved for service only.</p></section><section id="GUID-1DAE988D-EDC0-46A5-AB01-2A5ED6309CD1" class="- topic/section "><title class="- topic/title "><?xm-replace_text Section Title?></title><p class="- topic/p "><?xm-replace_text Paragraph?></p></section><section id="GUID-B1392ABA-F0C5-475B-BA61-83964DB1E55C" class="- topic/section "><title class="- topic/title "> Error type recognition in the digits of the error code.</title><p class="- topic/p "> We have 4 to 7 error digit error codes. </p><p class="- topic/p ">They are a combination of:</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">casgroup number</p></li><li class="- topic/li "><p class="- topic/p ">errortype number</p></li><li class="- topic/li "><p class="- topic/p ">followup number</p></li></ol><table id="GUID-B1EF821B-187D-484A-903F-F189B20C8E78" class="- topic/table "><tgroup cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> Casgroup number</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Errortype number</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Followup number</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p "> 1 or 2 digits</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">1 digit</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> 2 or 4</p></entry></row></tbody></tgroup></table><fig id="GUID-DE36920E-E009-4B2A-A2F4-042EB2D2EE5A" class="- topic/fig "><image href="GUID-B0717F7D-E918-4CB7-A2CD-7BB4C5D613AE-low.png" placement="inline" class="- topic/image " otherprops="GUID-B0717F7D-E918-4CB7-A2CD-7BB4C5D613AE-low.png"/></fig><table id="GUID-031D2B7D-9672-481E-89C4-3E0B966B1CE8" class="- topic/table "><tgroup cols="6" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="*" class="- topic/colspec "/><colspec colname="col4" colnum="4" colwidth="*" class="- topic/colspec "/><colspec colname="col5" colnum="5" colwidth="*" class="- topic/colspec "/><colspec colname="col6" colnum="6" colwidth="*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Sample</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> 1<sup class="+ topic/ph hi-d/sup ">st</sup> split,</p><p class="- topic/p "> Based on length</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p "> 2<sup class="+ topic/ph hi-d/sup ">nd</sup> split, based on preceding number of error type</p></entry><entry colname="col4" namest="col4" nameend="col6" align="center" valign="top" class="- topic/entry "><p class="- topic/p "> Result</p><p class="- topic/p "> Casgroup - errortype - followup</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1709</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">17-09</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">1-7-09</p></entry><entry colname="col4" valign="top" class="- topic/entry "><p class="- topic/p ">1 Curing</p></entry><en