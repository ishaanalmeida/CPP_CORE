<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-1CBE1B1B-EB47-49C3-AE8A-518EE48DF6C1" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-1CBE1B1B-EB47-49C3-AE8A-518EE48DF6C1" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">05 How to remove the cover of the carriage unit</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to open the cover of the printhead carriage unit. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_36B761BDFC9944908A242CDD11A4E09A" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-7215619B-4D8E-42B1-B219-10C1EF6B5FB5" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_64BB077525D643BAA0D00A934918884D" class="- topic/ul "><li id="LI_FEBB1892C37D4D6DA26AFAA9949BAE22" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li class="- topic/li "><p class="- topic/p ">2 Protection caps. 
</p><note type="important" id="GUID-AE97ABB1-01A0-4BC8-BA2D-9D851A6C4D1B" class="- topic/note "><p class="- topic/p ">The fiber ends of the fiber cable are sensitive for contamination (dust) or scratches. 
<b class="+ topic/ph hi-d/b ">Use the protection caps</b>. 
</p><fig id="FIG_5513EC4AB4474633A64B06BC0E7B4D87" class="- topic/fig "><image href="GUID-01DBD0D9-F9B2-4E4C-BFD0-D1B408097401-low.png" id="IMAGE_4FCA66C485254EF1BA90600FA63C6461" keyref="" placement="inline" class="- topic/image " otherprops="GUID-01DBD0D9-F9B2-4E4C-BFD0-D1B408097401-low.png"/></fig><p class="- topic/p ">When the fiber protection caps are removed connect the connector immediately. 
</p><p class="- topic/p ">The bend radius of the cable is 60 mm during handling and 40 mm when installed. 
</p></note></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-FC941B26-7A40-4F1A-A161-B17CF88A4018" class="- topic/fig "><image href="GUID-7B709076-C288-45AF-8F9E-5CA401688621-low.png" placement="inline" class="- topic/image " otherprops="GUID-7B709076-C288-45AF-8F9E-5CA401688621-low.png"/></fig></section><section id="SECTION_5DFD4107D130461EA1E5D10D7A87C6FB" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_46EBC717D5F54590972FA762A7144ACD" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Squeeze the connector of the optical fiber cable and disconnect the connector. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-76332EFC-899D-45A6-A695-21AD4D91CB09" class="- topic/fig "><image href="GUID-BB849409-E480-42E7-8751-52452BA614D9-low.png" placement="inline" class="- topic/image " otherprops="GUID-BB849409-E480-42E7-8751-52452BA614D9-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><note id="GUID-5FCF9D60-0590-4EA6-9D51-E1C1A9CF4513" class="- topic/note "><p class="- topic/p ">Place 2 end caps on the connector to prevent pollution of the 2 glass fibers. 
</p></note><p class="- topic/p ">Tape the optical cable to the carriage so is does not get stuck or damaged anywhere. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-21982868-F604-4236-99BF-923328AF1435" class="- topic/fig "><image href="GUID-F096C38C-F72A-4A31-A499-9DA9B383967E-low.png" placement="inline" class="- topic/image " otherprops="GUID-F096C38C-F72A-4A31-A499-9DA9B383967E-low.png"/></fig><p class="- topic/p "><image href="GUID-9E10CA98-E2B6-471E-8A37-C8A449307708-low.png" placement="inline" class="- topic/image " otherprops="GUID-9E10CA98-E2B6-471E-8A37-C8A449307708-low.png"/> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the locking bracket of the printheads (4 screws). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FD98886A-8C7B-4137-962E-9E58C909F6FD" class="- topic/fig "><image href="GUID-173A9CCB-3E24-4486-9A21-43E1CBEC6A46-low.png" placement="inline" class="- topic/image " otherprops="GUID-173A9CCB-3E24-4486-9A21-43E1CBEC6A46-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Loosen 1 screw. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the other 3 screws of the cover . 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7E933198-B961-4000-8983-ECB36A1E0055" class="- topic/fig "><image href="GUID-3E8902BD-6E47-41B9-98EF-28FDD0C64004-low.png" placement="inline" class="- topic/image " otherprops="GUID-3E8902BD-6E47-41B9-98EF-28FDD0C64004-low.png"/></fig><fig id="GUID-2B7A7F6C-827E-4028-8AAD-9186BD43B457" class="- topic/fig "><image href="GUID-B5F85918-8A1C-4895-9598-9D3830372D9F-low.png" placement="inline" class="- topic/image " otherprops="GUID-B5F85918-8A1C-4895-9598-9D3830372D9F-low.png"/></fig><fig id="GUID-6590DA42-9130-4A94-AA0B-48FB8962A60C" class="- topic/fig "><image href="GUID-2633146E-9FA7-4032-8287-AC46C787E060-low.png" placement="inline" class="- topic/image " otherprops="GUID-2633146E-9FA7-4032-8287-AC46C787E060-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect all hoses and connectors .
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2C41A5A3-5F0E-40B7-8205-3515A49F1C7F" class="- topic/fig "><image href="GUID-D0B7EA6B-9C66-4AF0-B362-0855387B56D1-low.png" placement="inline" class="- topic/image " otherprops="GUID-D0B7EA6B-9C66-4AF0-B362-0855387B56D1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Lift the cover and remove the cable harness. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove cover 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-49B4CA72-6DB1-4F52-B04C-971CF79727E6" class="- topic/fig "><image href="GUID-4BA02C36-3184-4D79-BBF6-06FBD358E597-low.png" placement="inline" class="- topic/image " otherprops="GUID-4BA02C36-3184-4D79-BBF6-06FBD358E597-low.png"/></fig><fig id="GUID-C3857A64-E079-44EB-AF1C-B49838358302" class="- topic/fig "><image href="GUID-4AF32246-3160-4F19-839E-528F0471E9EF-low.png" placement="inline" class="- topic/image " otherprops="GUID-4AF32246-3160-4F19-839E-528F0471E9EF-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_BF222651FDC54D218A4605224C634311" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-413D000D-1733-4578-95D7-CBC36AC62908.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
