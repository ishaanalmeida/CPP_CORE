<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-9B3CF48D-9ADB-4D10-9BBB-7B3F704D7E75" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-9B3CF48D-9ADB-4D10-9BBB-7B3F704D7E75" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to remove the upper MLO roller (media feed of roll position 1)</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_34F2C03C97F249649B92631C09DBB41B" class="- topic/li "><p class="- topic/p ">Open the media loading drawer. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the media in the media loading drawer. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_69BB0AEB395F4E8AB96FD94A4C0C8696" class="- topic/ul "><li id="LI_06B1AE50C8584502AA32D102711C1229" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li id="LI_561D1BF957EA49F8BB49139266A92893" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T30.
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver. 
</p></li><li id="LI_B784B59E966743309622F0F98A079F05" class="- topic/li "><p class="- topic/p ">2x Open ended spanner 13. 
</p></li><li class="- topic/li "><p class="- topic/p ">Small ratchet wrench with T20 bit. 
</p></li><li class="- topic/li "><p class="- topic/p ">2 pieces of tape or a sheet of media
</p></li><li class="- topic/li "><p class="- topic/p ">Torx 30 screw (used e.g in the hinge of the top cover). 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-1C6A5506-8461-4BFD-8B7C-FB47C7EF289A" class="- topic/fig "><desc class="- topic/desc "><p class="- topic/p ">MLO roller 
</p></desc><image href="GUID-ECB15C69-5E52-4843-96E0-37240D79EC63-low.png" placement="inline" class="- topic/image " otherprops="GUID-ECB15C69-5E52-4843-96E0-37240D79EC63-low.png"/></fig></section><section id="SECTION_9A4E31FC8A1D474082EB98039B353FF0" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_BC6D1128E6D045B0884B679CB3343E94" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the indicated screw and nut of the mounting of the cover over the first pinch. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-20C1DA02-3D9B-4E86-9336-DD581A0ED8BC" class="- topic/fig "><image href="GUID-7EAB127A-FF8B-4B42-917A-7DFC9F185DD7-low.png" placement="inline" class="- topic/image " otherprops="GUID-7EAB127A-FF8B-4B42-917A-7DFC9F185DD7-low.png"/></fig><fig id="GUID-B9CB9BA4-A114-472B-A903-B7769A8B19F5" class="- topic/fig "><image href="GUID-70BBB8B3-F504-4DA9-B07C-B8056ADB0F05-low.png" placement="inline" class="- topic/image " otherprops="GUID-70BBB8B3-F504-4DA9-B07C-B8056ADB0F05-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Release the green lever. 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the pinch. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D743890E-C4A7-4728-965E-1A090CB6FC6E" class="- topic/fig "><image href="GUID-BAE24F9B-847D-428E-8423-494E288B003D-low.png" placement="inline" class="- topic/image " otherprops="GUID-BAE24F9B-847D-428E-8423-494E288B003D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws of the cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A457A127-8EB0-480C-B03E-9297B46D6DE0" class="- topic/fig "><image href="GUID-8FF1ACE1-14CA-41A6-9C9C-302663E59707-low.png" placement="inline" class="- topic/image " otherprops="GUID-8FF1ACE1-14CA-41A6-9C9C-302663E59707-low.png"/></fig><fig id="GUID-9671626E-9BB9-4CF1-B17D-8A1160463F1F" class="- topic/fig "><image href="GUID-9971575B-3401-4F89-9C23-0FEF897EBE06-low.png" placement="inline" class="- topic/image " otherprops="GUID-9971575B-3401-4F89-9C23-0FEF897EBE06-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cover to the top. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-13594457-E3D3-4177-8B77-980964925A12" class="- topic/fig "><image href="GUID-AC7D8BB0-183D-4375-97FA-A9D83F19333D-low.png" placement="inline" class="- topic/image " otherprops="GUID-AC7D8BB0-183D-4375-97FA-A9D83F19333D-low.png"/></fig><fig id="FIG_2D3AE3328DC84F9AA9845504C09080F1" class="- topic/fig "><image href="GUID-9DA12108-7938-4AE9-A280-9BB7255AD922-low.png" id="IMAGE_F41942FC40674CDA88BFF1EB368BD80B" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9DA12108-7938-4AE9-A280-9BB7255AD922-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the small cover (at the right hand side): 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the 2 screws. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the screw. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5146F480-F093-4537-93D2-EF78E495CB08" class="- topic/fig "><image href="GUID-2A104E90-5695-4AA0-8CBC-282DFC1B16A3-low.png" placement="inline" class="- topic/image " otherprops="GUID-2A104E90-5695-4AA0-8CBC-282DFC1B16A3-low.png"/></fig><fig id="GUID-F903A493-E10C-4C83-9E75-BCEB3389A28A" class="- topic/fig "><image href="GUID-907494AF-8592-4EAD-BC0F-4604E7BF9547-low.png" placement="inline" class="- topic/image " otherprops="GUID-907494AF-8592-4EAD-BC0F-4604E7BF9547-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the gas spring. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the small cover. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1D1E77C7-2DF6-48E7-A276-A722E6A4821F" class="- topic/fig "><image href="GUID-AF06DD52-27FA-4190-9BC5-147D11D2038C-low.png" placement="inline" class="- topic/image " otherprops="GUID-AF06DD52-27FA-4190-9BC5-147D11D2038C-low.png"/></fig><fig id="GUID-7AA8CCCD-59EB-4005-93A6-6B07D52F2247" class="- topic/fig "><image href="GUID-FFFF325B-8118-48B8-A289-80160FE68338-low.png" placement="inline" class="- topic/image " otherprops="GUID-FFFF325B-8118-48B8-A289-80160FE68338-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Loosen the tension of the drive belt (2 screws). Use the small ratchet wrench with T20 bit. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the spring. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EB45E53D-D0F6-4C9B-80CC-F2432ACE2D97" class="- topic/fig "><image href="GUID-576AD330-398F-40B8-8771-6774A5E10DD6-low.png" placement="inline" class="- topic/image " otherprops="GUID-576AD330-398F-40B8-8771-6774A5E10DD6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the screw of the gear. Use the small ratchet wrench with T20 bit. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the drive belt. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the gear from the axis (conical). 
</p><p class="- topic/p ">Use a Torx T30 screw. Insert it the center of the gear. Lock it and the gear is released from the axis. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CCAA9D13-3297-4B9E-BE20-B04A3DEC18F4" class="- topic/fig "><image href="GUID-F61CA455-9889-40CA-BE52-7F288E10DE2D-low.png" placement="inline" class="- topic/image " otherprops="GUID-F61CA455-9889-40CA-BE52-7F288E10DE2D-low.png"/></fig><fig id="GUID-A3675428-D138-448E-B9D0-BDECDD8EB738" class="- topic/fig "><image href="GUID-4766AE80-DEF1-463D-B542-0336DD765F1A-low.png" placement="inline" class="- topic/image " otherprops="GUID-4766AE80-DEF1-463D-B542-0336DD765F1A-low.png"/></fig><fig id="GUID-6F5F5D8F-A0AF-45E8-A990-67F94E3B00C5" class="- topic/fig "><image href="GUID-F767B4EE-849D-4A92-B51C-73C682222915-low.png" placement="inline" class="- topic/image " otherprops="GUID-F767B4EE-849D-4A92-B51C-73C682222915-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Turn the position ring of the axis till is free from the bracket. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A4F728C3-7E64-4BDA-9015-B57CF3C54654" class="- topic/fig "><image href="GUID-04A1BB31-9BC6-453A-AE78-5F9598D204D3-low.png" placement="inline" class="- topic/image " otherprops="GUID-04A1BB31-9BC6-453A-AE78-5F9598D204D3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Push the axis to the right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D6FD984D-470D-44C9-8C10-6D56FC70EDB9" class="- topic/fig "><image href="GUID-3D39CE51-19E5-4390-8FE6-4E5FBC95B6F1-low.png" placement="inline" class="- topic/image " otherprops="GUID-3D39CE51-19E5-4390-8FE6-4E5FBC95B6F1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Unhook the cable from the cable guides. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5D6FBC59-A5B0-4511-8E8B-A1C901C84801" class="- topic/fig "><image href="GUID-085A2A0D-BB5E-4649-A4C7-F93EBA0A20DC-low.png" placement="inline" class="- topic/image " otherprops="GUID-085A2A0D-BB5E-4649-A4C7-F93EBA0A20DC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the sensor (1 screw). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1F8A8927-3F30-45FC-8380-0F6A3B3F0FF3" class="- topic/fig "><image href="GUID-12C1ADA3-34DD-432C-8ED0-73CE3C8F03EA-low.png" placement="inline" class="- topic/image " otherprops="GUID-12C1ADA3-34DD-432C-8ED0-73CE3C8F03EA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 cable guides (to get a better view on the sides of the roller). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6571D83F-145F-471B-87C3-150020E3D73A" class="- topic/fig "><image href="GUID-3232BCA9-1656-426C-8501-624FC4D71B81-low.png" placement="inline" class="- topic/image " otherprops="GUID-3232BCA9-1656-426C-8501-624FC4D71B81-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place a piece of tape or a sheet of media over the opening of the bracket. This to prevent that the E-clips drops into the frame. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B586B493-B88A-4967-BD85-A0E366166F89" class="- topic/fig "><image href="GUID-B7BCC2D3-92DA-4B04-8FDE-27F68B92D3C4-low.png" placement="inline" class="- topic/image " otherprops="GUID-B7BCC2D3-92DA-4B04-8FDE-27F68B92D3C4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the E-clip and the bearing at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4906ECC4-2F59-44CD-9B67-64C20C65A634" class="- topic/fig "><image href="GUID-3218167C-06B5-45BF-89D0-12C8E1A09567-low.png" placement="inline" class="- topic/image " otherprops="GUID-3218167C-06B5-45BF-89D0-12C8E1A09567-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the roller. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9114320E-92A7-4B52-84E0-60C1930E4730" class="- topic/fig "><image href="GUID-99F742D1-6F36-4022-91C4-43B0710D9E71-low.png" placement="inline" class="- topic/image " otherprops="GUID-99F742D1-6F36-4022-91C4-43B0710D9E71-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B96AB9C-8847-4643-A8CB-09918FE19AAB.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>