<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-CF5B76F4-B74C-4A0E-BA1C-F1F72ABBF0D3" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-CF5B76F4-B74C-4A0E-BA1C-F1F72ABBF0D3" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title "> 05 How to replace the Aerosol Ink filter Assy</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes the replacement of the Aerosol Ink Filter Assy. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-90A3FB43-3A19-4FC6-82AA-D7F328812CD2" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Go to COLD SDS and disconnect the Service jumper. 
</p></li><li class="- topic/li "><p class="- topic/p "> Open the top cover. 
</p></li></ol><note id="GUID-F0E76CAF-1631-4329-B969-7D5A9BA760AA" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_CEA4CD427612471CA3540AD5430B21C2" class="- topic/ul "><li id="LI_B007BBFF5E5743C89A24651737F64808" class="- topic/li "><p class="- topic/p ">Small screwdriver. 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Cutter 
</p></li><li class="- topic/li "><p class="- topic/p "> Magnetizer tool 
</p></li><li class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-98726AAF-BB3F-4F58-8400-2939AAB281D0" class="- topic/section "><title class="- topic/title "/></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-2D7D94A0-B26C-4C0B-B6A3-20C8621663A2" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-FAE6B57A-7E8B-40C7-A31D-924C20F92D5C" class="- topic/fig "><image href="GUID-8CA8F7AD-D8C5-4438-AD30-E45AF1EF17CB-low.png" placement="inline" class="- topic/image " otherprops="GUID-8CA8F7AD-D8C5-4438-AD30-E45AF1EF17CB-low.png"/></fig></section><section id="GUID-BCF9CC76-F25B-4AF8-B39D-9707EF8C6035" class="- topic/section "><title class="- topic/title ">Before you begin</title><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Position manually the Carriage to the left side (chiller side) of the printer. 
</p></li><li class="- topic/li "><p class="- topic/p ">Place a sheet to protect the platen. 
</p><fig id="GUID-A6A10599-4B7F-41B2-BC6C-B0CA70F23903" class="- topic/fig "><image href="GUID-484B1913-E78A-4ED9-B9B1-C3821013F1E7-low.png" placement="inline" class="- topic/image " otherprops="GUID-484B1913-E78A-4ED9-B9B1-C3821013F1E7-low.png"/></fig></li></ol></section><section id="GUID-9E0C86C8-A7BA-445C-B976-1A5694002CD4" class="- topic/section "><title class="- topic/title ">Replace Aerosol filter Assy (Right-hand side)</title><table pgwide="1" id="GUID-8459C11E-D844-4D69-90DD-389EAF1FF35F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the shielding plate. 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Loosen the 4 screws. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove shielding plate. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-449DB587-2264-4345-920A-53C9040B5620" class="- topic/fig "><image href="GUID-FC7A44DA-CB3F-4D74-B865-A9AB904CAD9F-low.png" placement="inline" class="- topic/image " otherprops="GUID-FC7A44DA-CB3F-4D74-B865-A9AB904CAD9F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the harness of the Aerosol Ink filter Fan. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4FC4FBE3-7696-4118-8065-91D216736F55" class="- topic/fig "><image href="GUID-D5C8B228-4C0B-46E4-B999-AEF848BD215C-low.png" placement="inline" class="- topic/image " otherprops="GUID-D5C8B228-4C0B-46E4-B999-AEF848BD215C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove clip. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the 4 screws that are accessible through the 4 holes. 
</p><note id="GUID-C75D26D5-84A0-4D48-89A2-EA9236367137" class="- topic/note "><p class="- topic/p "> Use the magnetizer tool to prevent screws from falling down. 
</p></note><note id="GUID-C5A30BFA-660B-48E2-9216-79827DFF8490" class="- topic/note "><p class="- topic/p ">Do not loosen or remove the red painted screws. 
</p></note></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8E3DF711-58FB-4F1A-AE7C-6AB5C3A76A40" class="- topic/fig "><image href="GUID-82EB126A-F154-4B18-A856-E98D67EC0E95-low.png" placement="inline" class="- topic/image " otherprops="GUID-82EB126A-F154-4B18-A856-E98D67EC0E95-low.png"/></fig><fig id="GUID-B94F7A7D-CB2F-4CA0-8694-C2A6DBFBD8A0" class="- topic/fig "><image href="GUID-3D463647-FCEC-4E65-AA4B-EF9B906B8AE3-low.png" placement="inline" class="- topic/image " otherprops="GUID-3D463647-FCEC-4E65-AA4B-EF9B906B8AE3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen screw (T M3x8B) and position Bracket Lock in the highest position. 
</p><p class="- topic/p ">Remove the complete mirror box at the right side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-19FA58C3-92A8-4C28-B8FE-4D97BFAC2284" class="- topic/fig "><image href="GUID-EE7B3017-84D0-42D0-8E84-812A231184F2-low.png" placement="inline" class="- topic/image " otherprops="GUID-EE7B3017-84D0-42D0-8E84-812A231184F2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove and replace Aerosol Ink filter assy. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C961B164-E20F-4D09-849E-8A1F90D94BCE" class="- topic/fig "><image href="GUID-C4DBD683-A840-4542-B92B-C9DD839AB42C-low.png" placement="inline" class="- topic/image " otherprops="GUID-C4DBD683-A840-4542-B92B-C9DD839AB42C-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-02F38E11-B9C9-4A7D-AB20-4B44F2BA5EEB" class="- topic/section "><title class="- topic/title ">Install Aerosol Ink Filter assy</title><table pgwide="1" id="GUID-C9753406-D48A-4EDF-83C2-567C5EBB5E82" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the Aerosol Ink Filter Unit. 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Put the T-joint downward in the slit of the hotbox. 
</p><fig id="GUID-62227153-1C5A-418A-A902-9F5D1C33575F" class="- topic/fig "><image href="GUID-0E3D00E2-CA7B-4C24-8FFA-2D014040FF14-low.png" placement="inline" class="- topic/image " otherprops="GUID-0E3D00E2-CA7B-4C24-8FFA-2D014040FF14-low.png"/></fig></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-AB162F26-1A3C-4C09-A0BD-8020AE57ADE4" class="- topic/fig "><image href="GUID-C5919F60-72E0-4094-949E-AB6954CF08AF-low.png" placement="inline" class="- topic/image " otherprops="GUID-C5919F60-72E0-4094-949E-AB6954CF08AF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Check</b>: 
</p><p class="- topic/p ">After positioning of the Aerosol Ink Filter Unit, the free distance in the slit of the hotbox is nominal 4mm. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A106B01D-75C4-4206-97A6-FC03D7B0024F" class="- topic/fig "><image href="GUID-6E845A23-EC84-4839-9C58-1A691228CB9D-low.png" placement="inline" class="- topic/image " otherprops="GUID-6E845A23-EC84-4839-9C58-1A691228CB9D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the mirror box. 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Install the 4 screws that are accessible through the 4 holes. 
</p></li><li class="- topic/li "><p class="- topic/p ">Mount clip. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5C9E8C9D-658E-427D-859D-002422312E21" class="- topic/fig "><image href="GUID-4188224D-C7F8-4960-8A14-D0B1411023C3-low.png" placement="inline" class="- topic/image " otherprops="GUID-4188224D-C7F8-4960-8A14-D0B1411023C3-low.png"/></fig><fig id="GUID-287B7C48-5C37-41A6-BF7D-F8CE316AC473" class="- topic/fig "><image href="GUID-7B40E8D8-934D-4AF2-A9F9-D9055221544B-low.png" placement="inline" class="- topic/image " otherprops="GUID-7B40E8D8-934D-4AF2-A9F9-D9055221544B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Push bracket lock downwards to secure the Aerosol Ink Filter Unit in vertical direction. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9FEB2262-E473-4118-8A94-39EB6784D6E9" class="- topic/fig "><image href="GUID-CAEB71FE-59C5-4FFA-9B35-C04339730958-low.png" placement="inline" class="- topic/image " otherprops="GUID-CAEB71FE-59C5-4FFA-9B35-C04339730958-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Fix the bracket lock 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Fasten the screw (T M3x8B). 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A2A0BC6C-C70B-4A56-94E7-38C80F7035F7" class="- topic/fig "><image href="GUID-EE7B3017-84D0-42D0-8E84-812A231184F2-low.png" placement="inline" class="- topic/image " otherprops="GUID-EE7B3017-84D0-42D0-8E84-812A231184F2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Connect the harness of the fan. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9344EC90-96AB-400B-9814-78AC1862F052" class="- topic/fig "><image href="GUID-449C1283-18EB-46AF-ABC6-C42096C99F01-low.png" placement="inline" class="- topic/image " otherprops="GUID-449C1283-18EB-46AF-ABC6-C42096C99F01-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="SECTION_83EFA574E57B4B64A0DD595529E957E2" class="- topic/section "><title class="- topic/title ">Replace the Aerosol ink filter assy (left-hand side)</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cable ties that fixate the ink tubes to the mirror box. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4706F67B-C9DF-48A7-952B-7F940B44BBF4" class="- topic/fig "><image href="GUID-6004CF9C-C4F9-438E-A8CF-FFBD76B1A2BF-low.png" placement="inline" class="- topic/image " otherprops="GUID-6004CF9C-C4F9-438E-A8CF-FFBD76B1A2BF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the clip. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-595D5C00-66EC-4EC5-8F92-00EFC5F09EFE" class="- topic/fig "><image href="GUID-737707C5-6FCA-493F-9AF4-1FA97254CA38-low.png" placement="inline" class="- topic/image " otherprops="GUID-737707C5-6FCA-493F-9AF4-1FA97254CA38-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> From this point forward the Replacement procedure of the left Aerosol ink filter assy is identical to that of the right side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect the harness of the fan. 
</p><note id="GUID-0D7750BD-72B8-42DD-AB87-2B3133D667BB" class="- topic/note "><p class="- topic/p "> Double check all 
<b class="+ topic/ph hi-d/b ">air / ink tube connections</b>. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F754EA1C-40CE-4A44-8484-200082CC545B" class="- topic/fig "><image href="GUID-33924CCF-3526-4170-88F7-CDF394510DDD-low.png" placement="inline" class="- topic/image " otherprops="GUID-33924CCF-3526-4170-88F7-CDF394510DDD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the shielding plate. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9FE0C316-7D39-45A6-A3C9-95E369AC685F" class="- topic/fig "><image href="GUID-66BBD5E6-D79A-48FE-881E-49A56686214C-low.png" placement="inline" class="- topic/image " otherprops="GUID-66BBD5E6-D79A-48FE-881E-49A56686214C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the service Key and exit SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Press 
<b class="+ topic/ph hi-d/b ">Restart</b> on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-413D000D-1733-4578-95D7-CBC36AC62908.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>