<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-E6C1D680-E3F7-4C27-A6A6-6719294A7178" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-E6C1D680-E3F7-4C27-A6A6-6719294A7178" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title translate="no" class="- topic/title ">22-6-104 Check PSU 22G04 (48V Curing) [Special Tests]</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">SDS</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-2BD8C3DB-27B0-44E5-B999-CF486EF1CE0D" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">SDS</ph></title><p class="- topic/p "> 
<object id="GUID-B05ADA85-2825-44CF-BDFE-55B342E1C966" class="- topic/object "><desc class="- topic/desc "><p class="- topic/p ">Check PSU 22G04 (48V Curing) </p></desc><param name="testid" value="226104" class="- topic/param "/><param name="target" value="NIL" class="- topic/param "/><param name="axmodule" value="None" class="- topic/param "/></object> 
</p></section><section id="GUID-E2A64F88-C860-4F92-9903-5DE8759DAA76" class="- topic/section "><title class="- topic/title ">Component</title><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">48 VDC Supply Curing</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 22G04 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">48V_CUR/1</compsignal></comp> 
</p></li></ul></section><section id="GUID-1156E15C-FA11-42F7-80CE-F9823F371FA9" class="- topic/section "><title class="- topic/title ">Function</title><p class="- topic/p ">Use this test to switch the power supply ON and OFF. 
</p><p class="- topic/p ">The 48Volt curing power supply is part of the safety circuit. The safety circuit (hardware) turns off the power supply independent of the software. The following parts will turn off the power supply:
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> An active crash sensor (01B6, 01B7) will disable the 48V curing power supply immediately.
</p></li><li class="- topic/li "><p class="- topic/p ">An open interlock switch (24S1, 24S2, 24S3) will disable the 48V curing power supply immediately. 
</p></li><li class="- topic/li "><p class="- topic/p ">No 48V power on LAMP-CONTROL PBA (01PBA03) will disable the 48V curing power supply after approximate 2 seconds. The lamp control output signals LAMP_CUR1_N_IN, LAMP_CUR1_N_IN indicate that the lamps are on, which in turn triggers the safety circuit. 
</p></li></ol><note id="GUID-F5D7F74F-3047-4264-8E5B-0244ADAC044E" class="- topic/note "><p class="- topic/p ">This test requires ColdSDS. 
</p></note></section><section id="GUID-8ABEDADD-7570-4BA7-9AC2-4F3343EAD3F3" class="- topic/section "><title class="- topic/title ">Procedure</title><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Start the test. 
</p></li><li class="- topic/li "><p class="- topic/p ">The current power supply status is shown. 
</p></li><li class="- topic/li "><p class="- topic/p ">Press Continue to turn the Power supply OFF. 
</p></li><li class="- topic/li "><p class="- topic/p ">The power supply status is shown. 
</p></li><li class="- topic/li "><p class="- topic/p ">Press Continue to turn the Power supply ON. 
</p></li></ol></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-B18C4D70-E5ED-4D20-9CDD-BE802FF54BB7.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>SDS</linktext></link></linkpool></related-links>
