<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-0DEE531B-1829-44B1-9D7D-2489745F722D" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-0DEE531B-1829-44B1-9D7D-2489745F722D" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title "> 02 How to remove the ink refill unit</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the ink refill unit. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ul id="UL_21938DDBFE2C4558A2521E08DDCD31E9" class="- topic/ul "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_44FE05E8AA614EB29DDDC8E371A37315" class="- topic/li "><p class="- topic/p ">Remove the media input right cover. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA022" class="- topic/xref " href="GUID-A1586343-23C1-47B2-BE4B-BB8972057671.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the media input right cover?>24 How to remove the media input right cover</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the ink system. 
</p><p class="- topic/p ">See : 
<xref keyref="02DISA012" class="- topic/xref " href="GUID-1C874C66-3A17-4AC4-886B-753A1A37D196.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02 Open the ink system (todo)?>02 Open the ink system</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the lower cover of the ink system. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA052" class="- topic/xref " href="GUID-3EA4F7FC-3249-452F-A681-38FC94D794B9.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the lower cover of the ink system?>24 How to remove the lower cover of the ink system</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the middle cover of the ink system. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA054" class="- topic/xref " href="GUID-3DDBA7E4-FC98-4D59-B862-147D49213A2E.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the middle cover of the ink system?>24 How to remove the middle cover of the ink system</xref> 
</p><note type="caution" id="GUID-E783AB09-2B10-4FC9-B867-BDBBE3BE8ABB" class="- topic/note "><p class="- topic/p ">Do not forget this dis-assembly. It is a safety precaution. 
</p></note></li><li id="LI_CA72C8A04562492B990FC422EBD62204" class="- topic/li "><p class="- topic/p ">Remove the top cover of the ink system. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA056" class="- topic/xref " href="GUID-0EC7B866-5C12-4DD8-B785-606D4BE4F19B.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the top cover of the ink system?>24 How to remove the top cover of the ink system</xref> 
</p></li></ul></prereq><section id="GUID-E46F8DDC-7D6F-40DC-9068-F1E3819FBFBF" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-1DBFF03A-0802-46EF-A302-C72A452F8725" class="- topic/note "><p class="- topic/p ">The knife that cuts the ink bottle is uncovered when you remove the ink bottle. 
</p></note></section><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_5319AAF504144C93A8D661E317AE9889" class="- topic/ul "><li id="LI_AAA0FC8490A547538C29E0A65ABF9B58" class="- topic/li "><p class="- topic/p ">Towel 
</p></li><li class="- topic/li "><p class="- topic/p ">Small screwdriver 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="FIG_C24E6AAB222D49CEA1D3210A1A9A96E2" class="- topic/fig "><image href="GUID-379D3C51-14CA-472C-B79F-A7B1772709BA-low.png" id="IMAGE_C3F3FD752C894D3997FB8E159719DF00" keyref="" placement="inline" class="- topic/image " otherprops="GUID-379D3C51-14CA-472C-B79F-A7B1772709BA-low.png"/></fig></section><section id="SECTION_5BD7E7683DF5439C915BEF10F6533BA1" class="- topic/section "><title class="- topic/title ">How to remove</title><table id="TABLE_1C9449FE19064BF28D193733CAB035CE" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place a towel on the floor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_158D157AD365404AAB2A60351068990F" class="- topic/fig "><image href="GUID-A18CD20D-095F-4394-BFC4-0849FDC72E2A-low.png" id="IMAGE_22FEED74BBDC432EB0020A69C9233488" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A18CD20D-095F-4394-BFC4-0849FDC72E2A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 4 screws (2 at the front, 1 at each side of the locking mechanism). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-44380BE1-E268-40C5-B412-3861C3843D47" class="- topic/fig "><image href="GUID-EDC60D67-EED5-49CA-BADD-6A312198171B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EDC60D67-EED5-49CA-BADD-6A312198171B-low.png"/></fig><fig id="GUID-482FD6E6-4D18-4262-B93E-1778702CD326" class="- topic/fig "><image href="GUID-49E36D29-807A-47D0-B359-864F94B5A228-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-49E36D29-807A-47D0-B359-864F94B5A228-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the cables from the cable guide. 
</p></li><li class="- topic/li "><p class="- topic/p ">Disconnect the 2 connectors. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-191CEED4-AC30-42E6-875F-263A11087014" class="- topic/fig "><image href="GUID-6FE54EB8-B331-4823-8A61-6CC2555DC1BB-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6FE54EB8-B331-4823-8A61-6CC2555DC1BB-low.png"/></fig><fig id="GUID-6B6B18D0-E6E5-41A4-932C-B54388499525" class="- topic/fig "><image href="GUID-24EEADB2-300F-4350-9F01-CD999B394561-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-24EEADB2-300F-4350-9F01-CD999B394561-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift and remove the locking assembly. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2C7DB74A-E063-4AC5-AEEE-FAA6D02054E5" class="- topic/fig "><image href="GUID-69691A5D-E652-4C51-BBF2-B959E6A699FA-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-69691A5D-E652-4C51-BBF2-B959E6A699FA-low.png"/></fig><fig id="FIG_CFB54337014647C4AEB0A748AC113093" class="- topic/fig "><image href="GUID-379D3C51-14CA-472C-B79F-A7B1772709BA-low.png" id="IMAGE_3EA8FBD7B38E44349D94ED6AACC0C317" keyref="" placement="inline" class="- topic/image " otherprops="GUID-379D3C51-14CA-472C-B79F-A7B1772709BA-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Do 
<xref keyref="02DISA040" class="- topic/xref " href="GUID-4ED99740-E293-4E98-9B86-3959346620E1.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02 How to install the ink refill unit?>02 How to install the ink refill unit</xref> 
</p><note id="GUID-08637617-3536-4BAB-9BEA-4E5C9458C79F" type="note" class="- topic/note "><p class="- topic/p ">Make sure that the funnel of the assembly is positioned in the hole of the ink tank. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-1CE85252-F6D3-4421-930B-8AE723FFB49C.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
