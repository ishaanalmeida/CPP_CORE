<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-07BC7664-5AAE-4C27-A331-C2F6D4AB2349" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-07BC7664-5AAE-4C27-A331-C2F6D4AB2349" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">How to set up <ph translate="no" class="- topic/ph ">On Remote Service</ph> (ORS)</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-780852DB-FFDA-4A5A-9D56-34B0370D62C9" class="- topic/section "><title class="- topic/title ">Remark</title><p class="- topic/p ">On Remote Service must be enabled if updating the embedded TSM on-line via Robin is required. 
</p><p class="- topic/p ">Required for the proCARE service contracts. 
</p><p class="- topic/p "> A training video is available in the training video section: See 
<xref href="http://localhost:20346/VIDEO00394EN.US/video05/index.html" format="html" scope="external" class="- topic/xref "><?ditaot usertext?>Enable ORS on Colorado systems with a point to point setup</xref> 
</p></section><section id="GUID-02AC293E-AF4A-4805-BBDF-54C9A5CACF6E" class="- topic/section "><title class="- topic/title ">Procedure</title><table id="GUID-3553B4FF-6F19-498D-A707-9F03438F1C24" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="90*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap the System icon. 
</p><fig id="GUID-0490CD29-62A5-437B-9424-A4998C858E38" class="- topic/fig "><image href="GUID-713ACEFA-3423-4929-92E3-D10312746446-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-713ACEFA-3423-4929-92E3-D10312746446-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap Remote services. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Login as administrator (71617000). 
</p><fig id="GUID-DBC958DA-61F3-47F4-8A4C-A81751320C17" class="- topic/fig "><image href="GUID-C6F5199B-C683-4350-8D7D-7FD9DD05A159-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C6F5199B-C683-4350-8D7D-7FD9DD05A159-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap Proxy settings. 
</p><fig id="GUID-DE2F2BEB-75CF-48B6-A9E1-FFD20F100F4A" class="- topic/fig "><image href="GUID-E884BBE2-400C-4E00-B111-CE2F8F3706C7-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E884BBE2-400C-4E00-B111-CE2F8F3706C7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Enter all required Proxy settings for this customer (the values shown are just examples). 
</p><fig id="GUID-5575EA41-EE92-4AB0-A0DD-EA8692746A6C" class="- topic/fig "><image href="GUID-7EECC4B6-5FF1-4C4E-A25F-95AB7F1AE14B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7EECC4B6-5FF1-4C4E-A25F-95AB7F1AE14B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap Save. 
</p><fig id="GUID-1C00C7CC-18AA-4218-ABF7-655B530DA81E" class="- topic/fig "><image href="GUID-C22B2724-C810-4AEA-A080-96D24CACC3ED-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C22B2724-C810-4AEA-A080-96D24CACC3ED-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap Remote connection. 
</p><fig id="GUID-6BADCC1C-A38F-4669-A18C-B7D6A27F92DB" class="- topic/fig "><image href="GUID-3AD091B7-7313-400E-818A-2D2C240A4D15-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3AD091B7-7313-400E-818A-2D2C240A4D15-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Fill in the Service Organization ID applicable to your region/country. 
</p><p class="- topic/p ">If you do not know it see 
<xref keyref="FAQDOIS001" class="- topic/xref " href="GUID-611135E7-18E3-4468-8484-4FA6FE396EBE.xml" format="dita" locktitle="yes" type="concept"><?ditaot usertext?><?xm-replace_text What to do when you do not know the SOID?>What to do when you do not know the SOID</xref>. 
</p><fig id="GUID-D30D073C-95D0-4E41-9CEC-7BA7BBE7DB25" class="- topic/fig "><image href="GUID-C85E1F7A-B755-42D1-BDE0-830B03D48D1A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C85E1F7A-B755-42D1-BDE0-830B03D48D1A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Enable Remote connection. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap Save. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Tap Remote connection again. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Check the Remote connection status is 'Connected'. 
</p><fig id="GUID-633A2D9F-16F4-4071-A75B-0F572088EA18" class="- topic/fig "><image href="GUID-191880FF-6192-4FC3-9346-71829D0F4E43-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-191880FF-6192-4FC3-9346-71829D0F4E43-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Reboot the printer (only if updating the embedded TSM on-line via Robin is required). 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Goto the PRISMAservice portal: 
<xref href="https://prismaservice.cpp.canon/" format="html" scope="external" class="- topic/xref "><?ditaot usertext?>https://prismaservice.cpp.canon/ 
</xref> and search for the Colorado M-Series configuration 
</p></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-DFD95E44-6FE2-4690-855D-446A64ABF90C.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>ORS: On Remote Service</linktext></link></linkpool></related-links>
