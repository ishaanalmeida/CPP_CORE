<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-8E19573F-5578-464B-A3FC-C42E5341A22B" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-8E19573F-5578-464B-A3FC-C42E5341A22B" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">05 How to remove the air tube</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the air tube between carriage and APSU unit. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_E38C1631665D4BE69728BB4374F0432B" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-7215619B-4D8E-42B1-B219-10C1EF6B5FB5" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_E753369EFDC5426BBE20201BB8995B3D" class="- topic/ul "><li id="LI_817B42AA77184C32836CE70E1B0DBB6C" class="- topic/li "><p class="- topic/p ">Cleaning material. 
</p></li><li id="LI_2AA4C5033A104BD390424FEF9FB7401E" class="- topic/li "><p class="- topic/p ">Small screwdriver. 
</p></li><li id="LI_67247CE54317489BBC59527BD3ED3160" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li id="LI_4E0A2AAC80784F19B97EBA24BE695E98" class="- topic/li "><p class="- topic/p ">Side cutter. 
</p></li><li id="LI_35A57629CA024A218912ECC3269A64C8" class="- topic/li "><p class="- topic/p ">Cable ties. 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C77657B7-3CC9-414D-B65B-7ECDF3444AC1" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-D2F2E5A6-2766-49CD-939B-41BEB867017B" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="FIG_AF4EB42EF350455488DCBA4976B91340" class="- topic/fig "><image href="GUID-06B08EFE-178D-43A9-8287-B2CC631A59BA-low.png" id="IMAGE_A67B808D27F34FB4980ED2EE3044087E" placement="inline" class="- topic/image " otherprops="GUID-06B08EFE-178D-43A9-8287-B2CC631A59BA-low.png"/></fig></section><section id="SECTION_A7FFC9665B2F4122AF27A06C7CBEF297" class="- topic/section "><title class="- topic/title ">Preparations</title><table pgwide="1" id="TABLE_E42E6CC46B364362BF8288430C4E612A" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place a sheet of media on the platen. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_7AE29DE6AF2846C9994AC349161FE88D" class="- topic/fig "><image href="GUID-028128CA-1927-4C78-BBA1-E88638D0F3A2-low.png" id="IMAGE_7D64AC53225241D3A33A3A9F9C28DB82" placement="inline" class="- topic/image " otherprops="GUID-028128CA-1927-4C78-BBA1-E88638D0F3A2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the manual maintenance door and place a paper towel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_59E9C68B229443EBB7001CC44236041D" class="- topic/fig "><image href="GUID-BCF78FE4-D02E-415C-9A19-E9CA438B17FA-low.png" id="IMAGE_0963BDA3AA13454BAE60527E5FFF4DF1" placement="inline" class="- topic/image " otherprops="GUID-BCF78FE4-D02E-415C-9A19-E9CA438B17FA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Guide the printhead carriage to the left hand side of the system. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_43279F846E9D429688701088B155D466" class="- topic/fig "><image href="GUID-3D6247F6-CC27-40D0-A573-4C029C78B2DA-low.png" id="IMAGE_A103BD4CBE5A4FC8A1A97C18094147F3" placement="inline" class="- topic/image " otherprops="GUID-3D6247F6-CC27-40D0-A573-4C029C78B2DA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Guide the UV lamp carriage to the middle. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_E951821F695643FD919836750E28E2F0" class="- topic/fig "><image href="GUID-ECE3646D-FB56-4833-B155-AC2A729C837F-low.png" id="IMAGE_E9716AFC70894839A27DAB33C7CEF4CE" placement="inline" class="- topic/image " otherprops="GUID-ECE3646D-FB56-4833-B155-AC2A729C837F-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="SECTION_7BCF39D178844448B3A21E7E56376710" class="- topic/section "><title class="- topic/title ">How to remove</title><table id="TABLE_5FBEFB7447DE4A1D819BDF873A72E3DB" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the cover (3 screws). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_5D4073A9522B461F95A4DF40D0695E9D" class="- topic/fig "><image href="GUID-F8E73780-FF3D-4E83-9867-2132546B1332-low.png" id="IMAGE_AAF593FD610746DC8ED9A5A361D45391" placement="inline" class="- topic/image " otherprops="GUID-F8E73780-FF3D-4E83-9867-2132546B1332-low.png"/></fig><fig id="FIG_A5CDB800BB47456FB6E1BF14D94018EC" class="- topic/fig "><image href="GUID-5F8E28CB-A0D0-4ABC-BC40-9FBF277D14DE-low.png" id="IMAGE_145B6DF54FC2409387A2083FEF581100" placement="inline" class="- topic/image " otherprops="GUID-5F8E28CB-A0D0-4ABC-BC40-9FBF277D14DE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the air tube. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_DBEFD59F8D424D8EA2AFCCC4ADCE8C08" class="- topic/fig "><image href="GUID-CF4AA335-E7A0-4A3F-833B-3236A2808C33-low.png" id="IMAGE_B2A1B46D1771433C96DD9B2BE2A629F8" placement="inline" class="- topic/image " otherprops="GUID-CF4AA335-E7A0-4A3F-833B-3236A2808C33-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Take the air tube out of the carriage. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_5337A3AFC1134BB9A29F5D6FD54967CF" class="- topic/fig "><image href="GUID-EC07A3F3-F1D0-4760-9393-599C26276F0E-low.png" id="IMAGE_85B0BA2829F64975AB0ED2503D53475E" placement="inline" class="- topic/image " otherprops="GUID-EC07A3F3-F1D0-4760-9393-599C26276F0E-low.png"/></fig><fig id="FIG_33655818E2EE4632845B5811FC7DDAD6" class="- topic/fig "><image href="GUID-ECB3A953-4029-4429-94E5-49BC1A59A4DC-low.png" id="IMAGE_E2CB6EF292EE4C6D93504DF456E629EC" placement="inline" class="- topic/image " otherprops="GUID-ECB3A953-4029-4429-94E5-49BC1A59A4DC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove 1 screw of the locking strip of the tubes and loosen the other side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_8848CCB9E62140CAA243098306707819" class="- topic/fig "><image href="GUID-82E8250A-0768-4ACF-8755-A12F7CF82EB0-low.png" id="IMAGE_73DEAF5831F4407CBC7A9FC1BC08C839" placement="inline" class="- topic/image " otherprops="GUID-82E8250A-0768-4ACF-8755-A12F7CF82EB0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Turn the locking strip away. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_461671BFCCE0408EA4EEF8A1B4F61E88" class="- topic/fig "><image href="GUID-5F64D8A3-BD97-49C8-8759-6BE73FD340A1-low.png" id="IMAGE_1A3E1E78C3D84A57806BA56E3D9765FB" placement="inline" class="- topic/image " otherprops="GUID-5F64D8A3-BD97-49C8-8759-6BE73FD340A1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Pull out the air tube. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_563C37DC1DA14B5DAF955EBD5E5A2F8C" class="- topic/fig "><image href="GUID-41639A50-80E1-43B5-804F-29E29B693854-low.png" id="IMAGE_2EA370CE902243ACA637AEFD29BDA833" placement="inline" class="- topic/image " otherprops="GUID-41639A50-80E1-43B5-804F-29E29B693854-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the clip of the holder. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_EAEC6A37522C4F65AAD31C59B8A0AF1D" class="- topic/fig "><image href="GUID-6ECF1261-1B31-426B-8A84-85A773684F4D-low.png" id="IMAGE_3B01D406497C4AF1A094AFB075F34788" placement="inline" class="- topic/image " otherprops="GUID-6ECF1261-1B31-426B-8A84-85A773684F4D-low.png"/></fig><fig id="FIG_475E065AC2144CE299FCAEA3D26B0A59" class="- topic/fig "><image href="GUID-09A16186-8887-49B4-8C7F-DA968A2F3B51-low.png" id="IMAGE_55864C8A2F6D4B7E83A6DAB734A837DA" placement="inline" class="- topic/image " otherprops="GUID-09A16186-8887-49B4-8C7F-DA968A2F3B51-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the air tube (mark the position). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_9A7FDF82638F4DEF879B9D2545C4893A" class="- topic/fig "><image href="GUID-16CD05F6-CB79-4ADD-AD87-0C7C3CFD5637-low.png" id="IMAGE_F828463756824208A25E4942BB8B335F" placement="inline" class="- topic/image " otherprops="GUID-16CD05F6-CB79-4ADD-AD87-0C7C3CFD5637-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the guide strip. (Slide it out of the melinex strip). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_A8E27B6788194DFB958F0A030E130B6E" class="- topic/fig "><image href="GUID-1F09E497-9C8A-475B-B353-224F4EA47157-low.png" id="IMAGE_46E6C569301A495F9C500B125DC27F8F" placement="inline" class="- topic/image " otherprops="GUID-1F09E497-9C8A-475B-B353-224F4EA47157-low.png"/></fig><fig id="FIG_56CFEFE999C04D9FA9D4AFB67EE96B6A" class="- topic/fig "><image href="GUID-90ADF53A-EF3D-4FD7-875F-85259EE00268-low.png" id="IMAGE_901AC00DB15B4F758CA3F7A06464F8C3" placement="inline" class="- topic/image " otherprops="GUID-90ADF53A-EF3D-4FD7-875F-85259EE00268-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Repeat these actions for the other clips and guide strips. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_5F98CA0FDB6E45DF818531B9E3023AA0" class="- topic/fig "><image href="GUID-CCA405ED-79CB-4FA1-926D-FD96BFF41213-low.png" id="IMAGE_051E5884015245429B374F38DA1B4990" placement="inline" class="- topic/image " otherprops="GUID-CCA405ED-79CB-4FA1-926D-FD96BFF41213-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the bracket (2 screws). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_79609B9160A040FFAAA28CC3A5469DB1" class="- topic/fig "><image href="GUID-E2F4E2ED-A386-4D3B-BF40-EDF58871B1D5-low.png" id="IMAGE_533E659BC49B4F59BC3364D7062FA6F3" placement="inline" class="- topic/image " otherprops="GUID-E2F4E2ED-A386-4D3B-BF40-EDF58871B1D5-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Cut the 3 cable ties and remove the air tube. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_2ACFB96173AC45E191172D39F42BC451" class="- topic/fig "><image href="GUID-BB13B8A4-18A8-48DC-80C0-5F84DF2094A9-low.png" id="IMAGE_3622D4A895A84546AFA56B1B6B9D35FC" placement="inline" class="- topic/image " otherprops="GUID-BB13B8A4-18A8-48DC-80C0-5F84DF2094A9-low.png"/></fig><fig id="FIG_172A57821A944B079EC9665F59808F35" class="- topic/fig "><image href="GUID-CFE28A75-55BB-4799-9ACE-A9060EBC4569-low.png" id="IMAGE_BB632D04146F42C3ACE03323DFC11FA0" placement="inline" class="- topic/image " otherprops="GUID-CFE28A75-55BB-4799-9ACE-A9060EBC4569-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the ink supply unit (1 screw). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_07986D5A9CE24B2C8CB896A1BC6845DC" class="- topic/fig "><image href="GUID-DEAAD892-6A07-442E-9068-1317F0E23164-low.png" id="IMAGE_FEE3049185C34BB6AE1D13DC46EFA836" placement="inline" class="- topic/image " otherprops="GUID-DEAAD892-6A07-442E-9068-1317F0E23164-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Cut the cable ties to the APSU unit. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_DD304BCAE2DF40EEAF6BD5F0E5EEB543" class="- topic/fig "><image href="GUID-3D2AFC51-1417-4877-B041-C57FE877606C-low.png" id="IMAGE_28B8A3DBB21F410F9FB7688DED4E66AC" placement="inline" class="- topic/image " otherprops="GUID-3D2AFC51-1417-4877-B041-C57FE877606C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the APSU unit (2 screws). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_763809025C5741D49C0608ABD0F13469" class="- topic/fig "><image href="GUID-622CB865-04C1-4DD2-A47C-FA995274102F-low.png" id="IMAGE_210371AF31C2479F9B9E32F2C8D151AF" placement="inline" class="- topic/image " otherprops="GUID-622CB865-04C1-4DD2-A47C-FA995274102F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the air tube from the APSU unit. 
