<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-692040EE-18C9-45A4-88CD-940D0BBFA925" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-692040EE-18C9-45A4-88CD-940D0BBFA925" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">19 How to remove the winder assembly</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the complete winder assembly. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the take-up media shaft. 
</p><p class="- topic/p ">See : 
<xref keyref="19DISA015" class="- topic/xref " href="GUID-2885BF56-7B36-423E-B567-AB29516FD4CC.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 19 How to remove the take-up media shaft?>19 How to remove the take-up media shaft</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the Tension bar. 
</p></li><li id="LI_21C8B271522344C0958B457D5D3BA087" class="- topic/li "><p class="- topic/p ">Remove the left and right hand side cover of the winder. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA058" class="- topic/xref " href="GUID-018F073E-4ED3-414A-8FEC-3740B53F5DBE.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the left (or right) hand side cover of the winder?>24 How to remove the left (or right) hand side cover of the winder</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the ink system. 
</p><p class="- topic/p ">See : 
<xref keyref="02DISA012" class="- topic/xref " href="GUID-1C874C66-3A17-4AC4-886B-753A1A37D196.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02 Open the ink system (todo)?>02 Open the ink system</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the media output lower cover. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A32A562039FB485780CA65B069EE577C" class="- topic/ul "><li id="LI_55373F9DAE644089ABBC568E03CDE4FC" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T30. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Attention:</ph></title><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">2 persons are required to remove the unit. 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-FF69F477-2710-4886-983D-ABA089D2A451" class="- topic/fig "><image href="GUID-77417067-4D19-4366-9B7D-2FB0BCDFAF37-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-77417067-4D19-4366-9B7D-2FB0BCDFAF37-low.png"/></fig></section><section id="SECTION_521D99F65A144454BCCB5E25B2366263" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_F0323E51D9184ACDAA5DAB8F03D11BA5" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove 1 screws at the left a and right hand side of the security bracket. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2BA316D7-7F48-4440-8740-E61DF96C4D21" class="- topic/fig "><image href="GUID-C1B834FD-6804-4AE5-8356-A79A3228B8BC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C1B834FD-6804-4AE5-8356-A79A3228B8BC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the security bracket. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-829DC88F-281E-47D5-A7C4-AC9430B34C45" class="- topic/fig "><image href="GUID-8B012A25-14AF-4226-BBE4-065B44D23987-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8B012A25-14AF-4226-BBE4-065B44D23987-low.png"/></fig><fig id="GUID-24A480D7-588F-4E75-99FB-7B84BEDFA351" class="- topic/fig "><image href="GUID-D78CAE00-C8AB-4B6C-B8BC-CC96B84DC390-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D78CAE00-C8AB-4B6C-B8BC-CC96B84DC390-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Disconnect the connector 19X5 at the left hand side of the winder. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5E91B39C-1D73-4D4E-A98A-1ACEC03B1743" class="- topic/fig "><image href="GUID-5B948675-CFDD-4C6E-9A49-1BC22C454E68-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5B948675-CFDD-4C6E-9A49-1BC22C454E68-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the cable guides. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6638157D-93CE-4C1E-8557-D0B04BA75FBE" class="- topic/fig "><image href="GUID-648E8025-243D-464B-8C35-F92C08190329-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-648E8025-243D-464B-8C35-F92C08190329-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connectors 19X1, 19X2, 19X3 and 19X4. 
</p><p class="- topic/p ">These connectors connect the winder to the rest of the printer. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F81664EB-E85C-49E2-9DAD-0E0B88D7D837" class="- topic/fig "><image href="GUID-40F03104-4056-48D0-B9BA-530130D197FE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-40F03104-4056-48D0-B9BA-530130D197FE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Feed the cables through the hole in the frame towards the winder. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CCBEB9B2-9673-4C3A-AF5A-A2F64F483252" class="- topic/fig "><image href="GUID-C30DB27B-E620-48E2-867C-176312029D8B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C30DB27B-E620-48E2-867C-176312029D8B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 2 screws of the bracket at the left hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-AADB7A97-F693-40C7-A6A8-DBF4C13C91B6" class="- topic/fig "><image href="GUID-BEBD3C3D-040E-4686-B549-89C76711D222-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BEBD3C3D-040E-4686-B549-89C76711D222-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 2 screws of the bracket at the right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C49A1A8D-AAD6-4ABE-AF84-819F6548B93A" class="- topic/fig "><image href="GUID-99969B23-3D90-4700-99BA-E723C3E0BDB0-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-99969B23-3D90-4700-99BA-E723C3E0BDB0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws (T30) from the bracket at the left hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-60A57420-F063-4FCF-9F31-4A9AC5391897" class="- topic/fig "><image href="GUID-BE10DC14-242D-4776-80DA-C5806614AA70-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BE10DC14-242D-4776-80DA-C5806614AA70-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws of the locking plate at the left and right hand side of the winder. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-49FFDD45-A60C-40F6-B0B8-2A42026B2B63" class="- topic/fig "><image href="GUID-87FAC9FB-E15A-41C6-91FF-C6D822F857AE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-87FAC9FB-E15A-41C6-91FF-C6D822F857AE-low.png"/></fig><fig id="GUID-E5E973F3-18FB-438F-B343-D2BF9952FF60" class="- topic/fig "><image href="GUID-9D0A7CDE-5279-4F63-9C6D-CC305A898871-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9D0A7CDE-5279-4F63-9C6D-CC305A898871-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Push the bracket upwards and lock the 2 screws at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the upper screw (T30) from the hinge at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-96CC3EA2-6358-4F6A-9C17-7835BBC26FD8" class="- topic/fig "><image href="GUID-7FCE4F6F-415F-486E-ADFA-3BCBF4D5505D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7FCE4F6F-415F-486E-ADFA-3BCBF4D5505D-low.png"/></fig><fig id="GUID-90373D30-F57B-4988-B694-5DC1608B2003" class="- topic/fig "><image href="GUID-B7A8E0B9-031B-4573-A7DD-B7E35BBD73B3-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B7A8E0B9-031B-4573-A7DD-B7E35BBD73B3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Hold the winder in position. 
</p></li><li class="- topic/li "><p class="- topic/p ">Lift the locking mechanism at the left and right hand side. The winder unlocks. 
</p></li><li class="- topic/li "><p class="- topic/p ">Pull the winder outward at the top and lift it carefully from the printer. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A2DEBD86-6039-46FC-96E7-5AF231B072CC" class="- topic/fig "><image href="GUID-B324362A-EA50-467F-AACE-7E8CC1E500DA-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B324362A-EA50-467F-AACE-7E8CC1E500DA-low.png"/></fig><fig id="GUID-BE1A7FD3-2C12-457E-BFFB-BD24F7EB73E9" class="- topic/fig "><image href="GUID-77417067-4D19-4366-9B7D-2FB0BCDFAF37-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-77417067-4D19-4366-9B7D-2FB0BCDFAF37-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the winder flat on a table or on the floor. 
</p><note type="important" id="GUID-2E00C0D2-1303-45FE-A8B4-B044A0EF25D1" class="- topic/note "><p class="- topic/p ">Watch the cables. Do not pinch the wiring. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Carry out the adjustment: 
</p><p class="- topic/p ">Do 
<xref keyref="19ADJU002" class="- topic/xref " href="GUID-D7027CEA-D5AB-4EDB-A8A6-C62E98486F84.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 19 How to adjust the winder with respect to the printer?>19 How to adjust the winder with respect to the printer</xref>. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-8D3A1F62-9497-4853-8507-1AEACBF21ABC.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>