<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-028CFC92-378E-4C9F-A69D-1FF0C1CC441E" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-028CFC92-378E-4C9F-A69D-1FF0C1CC441E" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">06 Refill the chiller (V2)</title><abstract class="- topic/abstract " id="GUID-B40C3A85-B896-4560-8CB4-89CD8DABFC9B"><p class="- topic/p ">You can refill the chiller without service assistance. 
</p><fig class="- topic/fig " id="GUID-D3B3AA3C-642B-43EB-9760-CE8F28515933"><title class="- topic/title ">Chiller location</title><image class="- topic/image " href="GUID-006253D2-E356-4A6F-82A7-4489BC71CE2A-low.png" keyref="" placement="inline" otherprops="GUID-006253D2-E356-4A6F-82A7-4489BC71CE2A-low.png"/></fig></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><context id="CONTEXT_3E86AA76894C42E98A19A38E5CDE7405" class="- topic/section task/context "><p class="- topic/p ">Refill the chiller when the fluid level is near the bottom of the green zone on the level gauge glass. See 
<xref keyref="06USER002V2" class="- topic/xref " href="GUID-39E500F9-28C4-4306-AF2D-2563082345A2.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>06 Vacuum the chiller and check the fluid level (V2)</xref>. 
</p></context><prereq id="GUID-B0B13527-08D6-4F51-AFDD-05D4D756F110" class="- topic/section task/prereq "><p class="- topic/p ">Use <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> prescribed: 
</p><ul id="UL_1A8B9254C67F4BE7A695F93E693619E8" class="- topic/ul "><li id="LI_4184E64F20A0410F88173C8B3481B064" class="- topic/li "><p class="- topic/p ">Demineralized water 
</p></li><li id="LI_931CB2A72B4643B5B36B8C8E77348D22" class="- topic/li "><p class="- topic/p ">Pouring can 
</p></li><li id="LI_5D9B184942814EA9A8C10040ED9A6F74" class="- topic/li "><p class="- topic/p ">Screwdriver (Torx-25) 
</p></li></ul><note type="caution" id="GUID-C7AEED5D-BAFE-4BE6-8E8E-A8EE6D000B68" class="- topic/note "><p class="- topic/p ">Wear specified gloves when you refill the chiller to protect your skin. 
</p></note></prereq><section id="SECTION_60701E20A8BE4475B91A2DB2FFAA31F7" class="- topic/section "><title class="- topic/title "/><note id="GUID-5D2708A0-2547-4C15-B644-5B6FE866A669" type="important" class="- topic/note "><p class="- topic/p ">Only refill one liter of demineralized water. When you use more the liquid can spill and damage the machine. 
</p></note></section><steps id="GUID-3CDB5AD7-256B-48D6-85A9-EF8ED22C7DE3" class="- topic/ol task/steps "><step id="d434e53" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">On the operator panel, tap on the <uicontrol class="+ topic/ph ui-d/uicontrol "><text id="d434e57" class="- topic/text ">System</text></uicontrol> icon on the right. 
</cmd></step><step id="d434e60" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text id="d434e65" class="- topic/text ">Power management</text></uicontrol></ph>. 
</cmd></step><step id="d434e68" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text id="d434e73" class="- topic/text ">Power off</text></uicontrol>.</ph> 
</cmd><info class="- topic/itemgroup task/info "><p class="- topic/p ">The system shuts down. 
</p></info></step><step id="d434e80" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">When the system has shut down, switch the power switch to the 'off' position. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d434e84" class="- topic/fig "><image href="GUID-6FF6B50F-E2F2-4ECE-8E7C-087EEAF80FD0-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6FF6B50F-E2F2-4ECE-8E7C-087EEAF80FD0-low.png"/></fig></info></step><step id="d434e86" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Pull out the two power supply plugs from the sockets. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d434e90" class="- topic/fig "><image href="GUID-0750D9B2-39EE-491C-B94A-6E0088507DA0-low.png" id="d434e91" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0750D9B2-39EE-491C-B94A-6E0088507DA0-low.png"/></fig></info></step><step id="d434e92" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Go to the chiller side and locate the cover under the fan. 
</cmd></step><step id="d434e95" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Unscrew the left and right screws on top of the cover with the Torx-25. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d434e99" class="- topic/fig "><image href="GUID-F847F8F9-3D53-40B4-AA6B-233907EBBA3D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F847F8F9-3D53-40B4-AA6B-233907EBBA3D-low.png"/></fig></info></step><step id="d434e101" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Lift the cover a little up and towards you (1), then lift it up fully and take it out (2) 
</cmd><info class="- topic/itemgroup task/info "><fig id="d434e105" class="- topic/fig "><image href="GUID-DA662190-0F5C-4654-83ED-93B391692D8B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-DA662190-0F5C-4654-83ED-93B391692D8B-low.png"/></fig></info></step><step id="d434e107" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Locate the lid on top of the chiller. 
</cmd></step><step id="d434e110" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Twist to remove the lid. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d434e114" class="- topic/fig "><image href="GUID-8DCD3BF5-6639-49E8-90E4-53361B9267BE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8DCD3BF5-6639-49E8-90E4-53361B9267BE-low.png"/></fig></info></step><step id="d434e116" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Pour one liter of demineralized water from the bottle in the pouring can. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-BC565611-5C84-42CB-947C-575CD47C1224" class="- topic/note " type="important"><p class="- topic/p ">Use demineralized water, do not use any other liquid. 
</p></note></info></step><step id="d434e123" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Place the pouring can on the chiller and fill the tank with the liquid. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d434e127" class="- topic/fig "><image href="GUID-CDD39F34-8D96-41D4-B567-355BFD1D2C13-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CDD39F34-8D96-41D4-B567-355BFD1D2C13-low.png"/></fig><note id="d434e129" class="- topic/note "><p class="- topic/p ">Check the level gauge glass to ensure that you do not refill beyond the top of the green zone. 
</p></note><fig id="d434e132" class="- topic/fig "><image href="GUID-1FC71FB8-D6AF-4594-8BDA-60785CC78264-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1FC71FB8-D6AF-4594-8BDA-60785CC78264-low.png"/></fig></info></step><step id="d434e134" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Close the lid, twist it on tightly. 
</cmd></step><step id="d434e137" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Place the cover back into position. 
</cmd></step><step id="d434e140" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Fasten the left and right screws on top of the cover. 
</cmd></step><step id="d434e143" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Plug the two power supply plugs back into the sockets. 
</cmd></step><step id="d434e146" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Switch the power switch to the 'on' position. 
</cmd></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-96D013F9-74AE-4555-B4E4-FDA433643370.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
</task>