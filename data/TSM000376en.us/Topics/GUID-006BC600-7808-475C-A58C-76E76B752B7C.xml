<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-006BC600-7808-475C-A58C-76E76B752B7C" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-006BC600-7808-475C-A58C-76E76B752B7C" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">11 How to upgrade the system software with Settings Editor</title><abstract class="- topic/abstract " id="M140828-B205"><p class="- topic/p "> This procedure describes how to upgrade the system software by using the Settings Editor. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-579AB4E0-F760-4774-8366-8F86F3FC5489" class="- topic/section task/prereq "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">The 7 system software .exe files are available 
</p><p class="- topic/p ">See: 
<xref keyref="11DownloadandPrepareSoftwarewithSettingsEditor" class="- topic/xref " href="GUID-90D318BD-4695-46A9-B882-323F531C80F4.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 11 Download and prepare the software package for upgrade with...?>11 Download and prepare the software package for upgrade with Settings Editor</xref> 
</p></li></ul><note id="GUID-CD65E9DD-D67F-4934-92C8-579D6AFB5E80" class="- topic/note "><p class="- topic/p "> It is recommended to perform a manual backup before running any software upgrade procedure. 
</p><p class="- topic/p "> See: 
<xref keyref="BackupRestore" class="- topic/xref " href="GUID-2824B2AF-ED7C-439C-B15C-E12247D2ECB6.xml" format="dita" locktitle="yes" type="concept"><?ditaot usertext?><?xm-replace_text The backup and restore procedure?>The backup and restore procedure</xref> 
</p></note></prereq><section id="SECTION_8B2EDF5F2405440097F73F1429FA79F0" class="- topic/section "><title class="- topic/title ">Procedure</title><table id="GUID-44E51CAE-2EF5-431B-BFBB-AE0F0810C645" class="- topic/table "><tgroup cols="2" align="left" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" align="left" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="90*" class="- topic/colspec "/><thead class="- topic/thead "><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Open the Settings Editor. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Browse to: Support &gt; Software updates &gt; InstalledPRISMASync updates: 
</p><fig id="GUID-D6D97940-FDB0-4572-9A7B-99E688CDFF23" class="- topic/fig "><image href="GUID-9043DB78-2FDB-45E9-8A44-89A7D8038876-low.png" placement="inline" class="- topic/image " otherprops="GUID-9043DB78-2FDB-45E9-8A44-89A7D8038876-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Click the "Reinstall complete system" icon. 
</p><p class="- topic/p "> The System Administrator login window displays: 
</p><fig id="GUID-A70B783E-CC92-4AEC-A36A-9234B098FB5A" class="- topic/fig "><image href="GUID-80162CC8-0E30-4C5F-8DC9-4B4592D7B961-low.png" placement="inline" class="- topic/image " otherprops="GUID-80162CC8-0E30-4C5F-8DC9-4B4592D7B961-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Type in the System Administrator password 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Click Log in. 
</p><p class="- topic/p "> The Reinstall system window displays: 
</p><fig id="GUID-B0689718-89A8-42A6-B667-003D149F06DB" class="- topic/fig "><image href="GUID-40BF9D92-ABB4-477B-A01E-B1EB63FA5F45-low.png" placement="inline" class="- topic/image " otherprops="GUID-40BF9D92-ABB4-477B-A01E-B1EB63FA5F45-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Click Select a file (for File 1). 
</p><p class="- topic/p ">The Choose File to Upload window displays. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Browse to the directory where the .exe files are located: 
</p><fig id="GUID-3683F5C6-0DAD-4719-8396-516F34D2FDBD" class="- topic/fig "><image href="GUID-03A1274D-28D3-4428-A154-994A11D0EDD4-low.png" placement="inline" class="- topic/image " otherprops="GUID-03A1274D-28D3-4428-A154-994A11D0EDD4-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Select the "1of7_OS" file. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Click Open. 
</p><p class="- topic/p "> The Reinstall system window again displays, showing file 1 of 6 being uploaded: 
</p><fig id="GUID-B49B3B04-5A0D-411A-B265-08DC176184F9" class="- topic/fig "><image href="GUID-C705A69A-A11D-4E41-A9E8-5660EB6DF342-low.png" placement="inline" class="- topic/image " otherprops="GUID-C705A69A-A11D-4E41-A9E8-5660EB6DF342-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Repeat steps 6 to 9 for the 6 other software files. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Wait until all the 7 files are downloaded to the printer (6 green progress bars all disappear, OK button is not greyed out anymore). 
</p><note id="GUID-3DA969E9-F3B9-48EE-B5EC-E1D98AC4085F" class="- topic/note "><p class="- topic/p "> This process can take 15 minutes or more. 
</p></note><fig id="GUID-E7B56836-D1C7-4890-B130-D8A7C63BDA77" class="- topic/fig "><image href="GUID-76FFC680-5AE8-4700-84CB-8B3AD44938F8-low.png" placement="inline" class="- topic/image " otherprops="GUID-76FFC680-5AE8-4700-84CB-8B3AD44938F8-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Click OK. 
</p><p class="- topic/p "> The Updating window displays: 
</p><fig id="GUID-A79F7E3B-E777-4E66-A518-DA64641912C6" class="- topic/fig "><image href="GUID-5614B468-8E4F-4256-BA50-2BFB5A543607-low.png" placement="inline" class="- topic/image " otherprops="GUID-5614B468-8E4F-4256-BA50-2BFB5A543607-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Wait the process completed (progress bar at 100%, OK button not greyed out anymore). 
</p><fig id="GUID-841C0A1C-48C5-4649-A222-75A9D8A62F8C" class="- topic/fig "><image href="GUID-0D41AA8A-E4F7-4A87-815A-51CD630CC09D-low.png" placement="inline" class="- topic/image " otherprops="GUID-0D41AA8A-E4F7-4A87-815A-51CD630CC09D-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><note id="GUID-74A0A7C1-0894-4157-B3A1-4CD9EDB96DBA" class="- topic/note "><p class="- topic/p "> Verify that there is no media on the platen. 
</p></note><p class="- topic/p "> Click OK. 
</p><p class="- topic/p "> The Restart required window displays: 
</p><fig id="GUID-1621C602-B7E2-4B19-80CF-D5E289954919" class="- topic/fig "><image href="GUID-B1A1A9C1-788D-405A-AD32-0CE9F8F48163-low.png" placement="inline" class="- topic/image " otherprops="GUID-B1A1A9C1-788D-405A-AD32-0CE9F8F48163-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Select Restart now. 
</p><note id="GUID-B6FB4A3D-AF25-4942-BEFB-CCB6D3BC41CC" class="- topic/note "><p class="- topic/p ">When the system is in keep healthy mode the restart has to be initiated via the engine UI( Menu: system , sub menu: power management, Restart button).
</p></note></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Click OK. 
</p><p class="- topic/p "> The printer restarts. 
</p><p class="- topic/p "> The "Installing please wait..." progress wheel displays on the control panel: 
</p><fig id="GUID-2824C7B2-EEBD-4ED1-9D45-9D5CA6789DFD" class="- topic/fig "><image href="GUID-77740418-A78B-4530-8347-B7D066116CF1-low.png" placement="inline" class="- topic/image " otherprops="GUID-77740418-A78B-4530-8347-B7D066116CF1-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p "> Wait until the installation process completed (the printer restarts several times). 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">The printer automatically starts up after the upgrade. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" valign="top" align="left" class="- topic/entry "><p class="- topic/p ">Confirm the software was upgraded as expected by checking the software version in : 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> On the control panel: System tab &gt; About &gt; Version of printing system 
</p></li><li class="- topic/li "><p class="- topic/p ">In Settings Editor: Support tab &gt; About &gt; Version of printer software 
</p></li></ul></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-724C7F1C-09E3-4D8F-B77B-2B159E768314.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
</task>