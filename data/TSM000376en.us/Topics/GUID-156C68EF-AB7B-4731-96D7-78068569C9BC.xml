<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-156C68EF-AB7B-4731-96D7-78068569C9BC" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-156C68EF-AB7B-4731-96D7-78068569C9BC" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Add a leading or trailing strip</title><abstract class="- topic/abstract " id="GUID-912C3599-80A6-4893-AECB-A7D2BF4D029C"><p class="- topic/p ">You can define the length of a leading or trailing strip. The strip is added by default to every print job from this moment on. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><context id="GUID-A8CFA4FF-B289-4F4F-BE71-33C11133BB8D" class="- topic/section task/context "><ul id="d9023e21" class="- topic/ul "><li id="d9023e22" class="- topic/li "><p class="- topic/p ">You can add a leading strip before a job, to add white space when using it with finishers, such as for taping media to the winder. 
</p></li><li id="d9023e25" class="- topic/li "><p class="- topic/p ">You can add a trailing strip after the job, to add white space after an image before you make a cut. 
</p></li></ul></context><steps id="GUID-00C22994-23A7-4EAE-AD25-2BB2C761318B" class="- topic/ol task/steps "><step id="d9023e29" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">On the operator panel, tap on the <uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">System</text></uicontrol> icon on the right. 
</cmd></step><step id="d9023e35" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Default settings</text></uicontrol></ph>. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d9023e43" class="- topic/fig "><image href="GUID-DB0FEE93-86E1-41E2-AECE-F9A97631562B-low.png" id="d9023e44" placement="inline" class="- topic/image " otherprops="GUID-DB0FEE93-86E1-41E2-AECE-F9A97631562B-low.png"/></fig></info></step><step id="d9023e45" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on the box after <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Leading strip</text></uicontrol></ph> or <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Trailing strip</text></uicontrol></ph> and fill in the length you prefer. 
</cmd><info class="- topic/itemgroup task/info "><p class="- topic/p ">When you fill in 0 no strip will be added. 
</p></info><info class="- topic/itemgroup task/info "><fig id="d9023e60" class="- topic/fig "><image href="GUID-57D42004-6119-49D0-9D9C-5E10051843A3-low.png" id="d9023e61" placement="inline" class="- topic/image " otherprops="GUID-57D42004-6119-49D0-9D9C-5E10051843A3-low.png"/></fig></info></step><step id="d9023e62" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Tap on <ph class="- topic/ph "><uicontrol class="+ topic/ph ui-d/uicontrol "><text class="- topic/text ">Save</text></uicontrol></ph> to save the settings. 
</cmd></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B8E84B8-092A-4B76-84E3-AA295749E97E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
