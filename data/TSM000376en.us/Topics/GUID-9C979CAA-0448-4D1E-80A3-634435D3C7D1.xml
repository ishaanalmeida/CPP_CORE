<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-9C979CAA-0448-4D1E-80A3-634435D3C7D1" version="3" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-9C979CAA-0448-4D1E-80A3-634435D3C7D1" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Light transport of the printer</title><abstract class="- topic/abstract " id="M028334-B18"><p class="- topic/p ">This document describes the light transport of a printer. 
</p><p class="- topic/p ">A light transport means: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Re-location within same building 
</p></li><li class="- topic/li "><p class="- topic/p ">Transport (on its wheels) over an even and smooth floor 
</p></li><li class="- topic/li "><p class="- topic/p "> Maximum floor gap to cross: 5mm 
</p></li></ul></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-ED2DF8D8-EFFA-4798-96CA-2F2880474DFB" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Power off the system via the operating panel. 
</p></li><li class="- topic/li "><p class="- topic/p ">Switch off the mains switch. 
</p></li><li class="- topic/li "><p class="- topic/p ">Disconnect the 2 mains cables. 
</p></li><li class="- topic/li "><p class="- topic/p ">Disconnect the network cable. 
</p></li></ol></prereq><section id="SECTION_3EAAE870561847F1914DAA1BC10E2FD6" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_3397BAAC9D5940BDBB97249F1BE4C31D" class="- topic/ul "><li id="LI_82240E45AAA5452084E7E08BD56CD707" class="- topic/li "><p class="- topic/p ">New maintenance tray 
</p></li><li class="- topic/li "><p class="- topic/p "> 2 People are required to carry out this procedure. 
</p></li></ul></section><section id="SECTION_BB8C533001C043A9B5E24F6EEECB8B53" class="- topic/section "><title class="- topic/title ">Personal protection</title><note type="caution" id="GUID-C8810ABE-05AA-47B2-A506-D909EB952778" class="- topic/note "><p class="- topic/p ">Wear safety shoes when working with heavy material (e.g. installation) or dis-assemblies of units. 
</p><p class="- topic/p ">Wear protected clothing for protection of your personal clothing. 
</p></note></section><section id="GUID-94C20406-75A1-4BD0-A7DB-8CD9777F04B0" class="- topic/section "><title class="- topic/title ">Procedure</title><table id="NEW" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p translate="yes" class="- topic/p ">Replace the maintenance tray with a clean one. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Disconnect and remove the chiller. 
</p><p class="- topic/p ">See: 
<xref keyref="06DISA001V2" class="- topic/xref " href="GUID-FC1A6DFD-807D-4052-ACED-FC6F6C31BFB5.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06 How to remove the Chiller (V2)?>06 How to remove the Chiller (V2)</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><note type="other" id="GUID-6396BCC7-6CAD-469E-B625-3AE8F9EEE06B" class="- topic/note "><p class="- topic/p "> Move the chiller separate from the engine to prevent damages to equipment or yourself! 
</p></note></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lower the printer from its feet onto the wheels. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">In case the printer transport has to go through a door (840 mm) remove the following parts: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "><xref keyref="20DISA004" class="- topic/xref " href="GUID-C906C95B-41C0-495F-BEBF-8F6000C071CF.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 11 How to remove the User Panel 11PBA05 LUI?>11 How to remove the User Panel ( 11PBA05 ;LUI)</xref> 
</p></li><li class="- topic/li "><p class="- topic/p "><xref keyref="19DISA017" class="- topic/xref " href="GUID-692040EE-18C9-45A4-88CD-940D0BBFA925.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 19 How to remove the winder assembly?>19 How to remove the winder assembly</xref> 
</p></li><li class="- topic/li "><p class="- topic/p "><xref keyref="24DISA09" class="- topic/xref " href="GUID-5CE51160-E27D-4814-BCC5-CA5F098D6CE7.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the top cover?>24 How to remove the top cover</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Hinges of the top cover. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> The printer is transported in the following conditions: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">The printheads stay in the printhead carriage that is positioned above the maintenance tray. 
</p></li><li class="- topic/li "><p class="- topic/p ">Ink stays in the tubes and ink tanks. No action required. 
</p></li><li class="- topic/li "><p class="- topic/p ">The cooling liquid stays in the chiller. No action required. 
</p></li><li class="- topic/li "><p class="- topic/p ">Transport brackets, foam and tape are 
<b class="+ topic/ph hi-d/b ">not 
</b>mounted on the printer 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 people should now push/pull the printer towards the new location. 
</p><note type="important" id="GUID-FB6F27DA-906E-4E18-8179-D3C65CE72913" class="- topic/note "><p class="- topic/p ">Push the printer only at the metal part as shown in the picture. 
</p><p class="- topic/p ">Never push at the transparent part of the top cover. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-11B14C23-09F3-418E-972C-6F9469569A16" class="- topic/fig "><image href="GUID-4D116DA7-8E88-4A35-BDB5-11AE16DD6DDF-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4D116DA7-8E88-4A35-BDB5-11AE16DD6DDF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">On the new position place the height positioning feet again and level the printer. 
</p><p class="- topic/p ">See 
<xref keyref="ENGADJU01" class="- topic/xref " href="GUID-2BFE3033-C726-47A1-9A09-044CAA7F04FE.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 00 How to level the printer?>00 How to level the printer</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check winder unit is still in correct position after transport, no play in the halve moon is allowed. (left and right side)
</p><p class="- topic/p ">The picture shows a wrong position.
</p><p class="- topic/p ">In case of a wrong position, loosen the screws, the winder will re-position itself and tighten te screws again.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-11909CC7-A8D4-4BD5-B60F-641402F68DDB" class="- topic/fig "><title class="- topic/title "/><image href="GUID-C5216E0B-3029-4B0C-A10F-28D31A6EC001-low.png" placement="inline" class="- topic/image " otherprops="GUID-C5216E0B-3029-4B0C-A10F-28D31A6EC001-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Check winder unit if it is in correct position after transport where no play in the halve moon is allowed. (left and right side) 
</p><p class="- topic/p "> The picture shows a wrong position. 
</p><p class="- topic/p "> In case of a wrong position, loosen the screws, the winder will re-position itself and tighten te screws again. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install the chiller. 
</p><p class="- topic/p ">See 
<xref keyref="installchiller" class="- topic/xref " href="GUID-260E8B4D-A641-48EF-84A7-7344BE9CE5EC.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 06 How to install the chiller (V2)?>06 How to install the chiller (V2)</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remount all removed covers and assemblies. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect all cables. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Switch ON the printer with the mains switch 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-3955AF8F-9BF3-4DD3-AA2A-175FB2AE2E43.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
</task>