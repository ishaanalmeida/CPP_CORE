<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-563F9EBE-CC03-4CAA-93C8-8AA3AB9B162B" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-563F9EBE-CC03-4CAA-93C8-8AA3AB9B162B" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">05 How to remove the Measurement &amp; Control (M&amp;C) unit</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the Measurement &amp; Control (M&amp;C) unit components. 
</p><p class="- topic/p ">The Measurement &amp; Control unit consists of : 
</p><ul class="- topic/ul " id="UL_94CA4E50DB0B42CA87E03A3C5DBB0DC2"><li class="- topic/li " id="LI_4A5229F0B680444F9366CC15D4BF7136"><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Measurement and control receiver PBA</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 05PBA05 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">YMS_CAR_MC_SE</compsignal></comp>. 
</p></li><li class="- topic/li " id="LI_13626F9FA136458D8D2BDBCBF1134CD3"><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Measurement and control LED PBA</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 05PBA06 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">YMS_CAR_MC_SE</compsignal></comp>. 
</p></li></ul></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_36B761BDFC9944908A242CDD11A4E09A" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-7215619B-4D8E-42B1-B219-10C1EF6B5FB5" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_64BB077525D643BAA0D00A934918884D" class="- topic/ul "><li id="LI_FEBB1892C37D4D6DA26AFAA9949BAE22" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-70729E74-2376-488A-8B37-61102532C0BA" class="- topic/fig "><title class="- topic/title "/><image href="GUID-A82887A2-5769-48AA-B14F-DBB24F9C8B28-low.png" placement="inline" class="- topic/image " otherprops="GUID-A82887A2-5769-48AA-B14F-DBB24F9C8B28-low.png"/></fig></section><section id="SECTION_EEE779FF06CE4CF2835AB2CFCDC97FEF" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_331965A2B75545E4859A839BE3FBB5E2" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Cut the 2 cable ties. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-615349E3-F9C2-46AF-8A18-2CC88E56B51F" class="- topic/fig "><title class="- topic/title "/><image href="GUID-F4D3CB81-5D62-48F4-B80E-29678DE2C504-low.png" placement="inline" class="- topic/image " otherprops="GUID-F4D3CB81-5D62-48F4-B80E-29678DE2C504-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the screw of the mirror box (at the right hand side of the reflection plate on the printhead carriage). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-22BB8DEB-426F-4089-91BC-0501B5E813A9" class="- topic/fig "><image href="GUID-136BDBB5-03D5-4624-AA30-CF7C4C99EA2D-low.png" placement="inline" class="- topic/image " otherprops="GUID-136BDBB5-03D5-4624-AA30-CF7C4C99EA2D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the mirror box assembly (4 screws T10). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8F3D3AAE-AC16-489B-A4D4-8137AB84589F" class="- topic/fig "><title class="- topic/title "/><image href="GUID-88F0FDE7-4C97-4EE1-B425-DD828A5EBDDE-low.png" placement="inline" class="- topic/image " otherprops="GUID-88F0FDE7-4C97-4EE1-B425-DD828A5EBDDE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 3 screws of the M&amp;C unit . 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-24D0431E-A233-482D-A3CD-10639E55704D" class="- topic/fig "><title class="- topic/title "/><image href="GUID-8B1C3933-5874-49CB-8CFC-EE9B6AAE6F37-low.png" placement="inline" class="- topic/image " otherprops="GUID-8B1C3933-5874-49CB-8CFC-EE9B6AAE6F37-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the flat cable (brown). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9F47DF7E-FCD1-46E8-B9E9-FE10BDCD2159" class="- topic/fig "><title class="- topic/title "/><image href="GUID-A9F41B77-1649-4F86-9BF5-D454856F821E-low.png" placement="inline" class="- topic/image " otherprops="GUID-A9F41B77-1649-4F86-9BF5-D454856F821E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift and remove the M&amp;C unit . 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CFD83899-1736-4073-A6C1-4FED00019BBF" class="- topic/fig "><image href="GUID-2DFE2FCE-F698-43C0-8A8B-89218DB1A2B9-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2DFE2FCE-F698-43C0-8A8B-89218DB1A2B9-low.png"/></fig><fig id="GUID-8EC29767-87CE-4E55-955F-94E50419A2B0" class="- topic/fig "><image href="GUID-4FFCA6DD-99CB-40D6-BE6D-1B966A78E98B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4FFCA6DD-99CB-40D6-BE6D-1B966A78E98B-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_BF222651FDC54D218A4605224C634311" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Do SDS 05-6-017 M&amp;C scanner test. 
</p><p class="- topic/p ">See 
<xref keyref="SDS05-6-017" class="- topic/xref " href="GUID-17F448B7-8A72-45B1-B56D-FC5C0BE28701.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>05-6-017 M&amp;C scanner test [Special Tests]</xref> 
</p><p class="- topic/p "><b class="+ topic/ph hi-d/b "> Ignore the result of the test.</b> 
</p><p class="- topic/p ">It is used here to bring the printer in a defined state. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Calibrate the M&amp;C unit : 
</p><ol class="- topic/ol "><li class="- topic/li "><p translate="yes" class="- topic/p ">Do SDS test: 
<xref keyref="SDS21-6-002" class="- topic/xref " href="GUID-D650BDBB-4674-4B96-BD64-98FDD9BAF4CB.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>21-6-002 Select required printer calibrations [Special Tests]</xref> and select: <ph translate="no" class="- topic/ph ">M&amp;C scanner calibration</ph> . 
</p></li><li class="- topic/li "><p class="- topic/p ">Do SDS test: 
<xref keyref="SDS21-6-003" class="- topic/xref " href="GUID-B828E436-A124-4809-981E-2DBE1E09A388.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>21-6-003 Execute selected printer calibrations [Special Tests]</xref>. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Carry out the SDS test to verify the functioning of the M&amp;C scanner: 
</p><p class="- topic/p ">See 
<xref keyref="SDS05-6-017" class="- topic/xref " href="GUID-17F448B7-8A72-45B1-B56D-FC5C0BE28701.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>05-6-017 M&amp;C scanner test [Special Tests]</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-413D000D-1733-4578-95D7-CBC36AC62908.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
