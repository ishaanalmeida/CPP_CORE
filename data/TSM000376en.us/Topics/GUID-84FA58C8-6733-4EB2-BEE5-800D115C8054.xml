<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-84FA58C8-6733-4EB2-BEE5-800D115C8054" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-84FA58C8-6733-4EB2-BEE5-800D115C8054" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">07 How to remove the Air Pressure Supply Unit (APSU)</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the Air Pressure Supply Unit (APSU). 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_9506282B7A994A9990B8E3D883335743" class="- topic/li "><p class="- topic/p ">Remove the knife compartment cover. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA034" class="- topic/xref " href="GUID-1D8187CA-1F3B-4EBF-9E0A-F130AF910D4A.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the knife compartment cover?>24 How to remove the knife compartment cover</xref>. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the cover below the cover of the knife compartment. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA032" class="- topic/xref " href="GUID-704C0C6B-5CA9-4D4D-B8A9-6C1132D65581.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the cover below the cover of...?>24 How to remove the cover below the cover of the knife compartment</xref>. 
</p></li><li id="LI_B134E67306214D50843B008D8457BAB1" class="- topic/li "><p class="- topic/p ">Remove the media input right cover. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA022" class="- topic/xref " href="GUID-A1586343-23C1-47B2-BE4B-BB8972057671.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the media input right cover?>24 How to remove the media input right cover</xref>. 
</p></li><li id="LI_3A6A780FCE62425DA268B914DC7D2D21" class="- topic/li "><p class="- topic/p ">Open the ink supply unit. 
</p><p class="- topic/p ">See 
<xref keyref="02DISA012" class="- topic/xref " href="GUID-1C874C66-3A17-4AC4-886B-753A1A37D196.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02 Open the ink system?>02 Open the ink system</xref> 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_88D5352595F642AFA44E04454C82A41C" class="- topic/ul "><li id="LI_81BD581B2AB94DF7AD868492835F1346" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li id="LI_09DFB8A70D17453A89E1C6516B69232F" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-1C6A5506-8461-4BFD-8B7C-FB47C7EF289A" class="- topic/fig "><image href="GUID-85B79105-1628-4939-98CD-728202F74C09-low.png" id="IMAGE_386F5F8F25B543048CB1568B5FB9DBBC" keyref="" placement="inline" class="- topic/image " otherprops="GUID-85B79105-1628-4939-98CD-728202F74C09-low.png"/></fig></section><section id="SECTION_43C265C317124960971C8DC89357C70F" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_1DBCBCA7090F42239EA97BBE973A138D" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the air tubes of the printheads with the 4 white clamps. 
</p><note id="GUID-129E4591-8116-4052-A9F0-CCD1A5362B6C" class="- topic/note "><p class="- topic/p ">The printheads will leak ink if the air tubes of the prinheads are not closed. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-16DF15D8-63EC-4EAD-85CD-596CABEE1F06" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B90C1DAA-19AF-4AF4-B867-EC068FC0EB4F-low.png" placement="inline" class="- topic/image " otherprops="GUID-B90C1DAA-19AF-4AF4-B867-EC068FC0EB4F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Disconnect both connectors. 
</p><note id="GUID-81A2F2BD-F011-46D9-9B03-61AD54046C79" class="- topic/note "><p class="- topic/p ">You need to open the cable guides to do this. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the APSU 
</p><ul id="UL_1CB3F87A4C1F496B8A77C84D862B2E4C" class="- topic/ul "><li id="LI_2C406BA20F2F4F5DBA85DFCAE34A6129" class="- topic/li "><p class="- topic/p ">Disconnect the 2 connectors of the APSU. 
</p></li><li class="- topic/li "><p class="- topic/p ">Unhook the cable clip. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7EEA65BC-A110-42EB-97BA-DAA35C86FA26" class="- topic/fig "><image href="GUID-0C191067-FC03-4325-BD77-C8C0855E42BB-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0C191067-FC03-4325-BD77-C8C0855E42BB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Loosen the 2 screws (Left side of the APSU). 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the APSU from the slotted holes. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-898F0B6A-C980-4BAC-82AA-146C2070927B" class="- topic/fig "><image href="GUID-17F10DAE-D7F8-4600-863C-01D78F28ABCA-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-17F10DAE-D7F8-4600-863C-01D78F28ABCA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Place the APSU on the Ink Compartment in the slotted holes. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7C473155-AE8A-4C52-A3AB-08D741CFE0E5" class="- topic/fig "><image href="GUID-5A924F8A-B034-4982-9D82-9D4C14EE5709-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5A924F8A-B034-4982-9D82-9D4C14EE5709-low.png"/></fig><fig id="GUID-8BA8F0A8-4979-4C5D-A487-4B34E5B4A24E" class="- topic/fig "><image href="GUID-4E0D1F2E-D3AD-407E-B433-A2A179F2F2CC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-4E0D1F2E-D3AD-407E-B433-A2A179F2F2CC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the air tube at the connector: Push the ring at the connector inwards and pull out the air tube. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_108152DDACE347E3A5658685C3B219EF" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install in reverse order. 
</p><note id="GUID-CE7A6787-E903-4724-9A32-E1EF524258DF" class="- topic/note "><p class="- topic/p ">Open the 4 white clamps of the air tubes of the printheads. 
</p></note><note type="important" id="GUID-E5262001-CCD2-4ED1-833B-1C02DC862AB7" class="- topic/note "><p class="- topic/p ">Connect the air tube with some force into the connector. Check the connection: pull at the air tube. It must stay in the connector. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">When you install a 
<b class="+ topic/ph hi-d/b ">new unit</b> do not forget to reset the maintenance counters. 
</p><p class="- topic/p ">See 
<xref keyref="SDS07-8-007" class="- topic/xref " href="GUID-F8B6BCF6-1543-48C8-943E-40CC093242CE.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 07-8-007 APSU pump time [s] [Maintenance Counters]?>07-8-007 APSU pump time [s] [Maintenance Counters]</xref> 
</p><p class="- topic/p ">See 
<xref keyref="SDS07-8-008" class="- topic/xref " href="GUID-7F955383-BB82-47B5-81B7-493566CEC492.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 07-8-008 APSU switch valve cycles [Maintenance Counters]?>07-8-008 APSU switch valve cycles [Maintenance Counters]</xref> 
</p><p class="- topic/p ">See 
<xref keyref="SDS07-8-009" class="- topic/xref " href="GUID-6898F987-8F29-46CF-A557-E67F0DD04634.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 07-8-009 Release valve cycles [Maintenance Counters]?>07-8-009 Release valve cycles [Maintenance Counters]</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-6C227E52-0223-48E4-A655-F691AD09A3EC.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>