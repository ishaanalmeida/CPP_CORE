<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-90671113-E055-4561-9EEF-14CD9B5A386A" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-90671113-E055-4561-9EEF-14CD9B5A386A" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">05 How to remove the Guidance cleaners (felt)</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_36B761BDFC9944908A242CDD11A4E09A" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-7215619B-4D8E-42B1-B219-10C1EF6B5FB5" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_64BB077525D643BAA0D00A934918884D" class="- topic/ul "><li id="LI_FEBB1892C37D4D6DA26AFAA9949BAE22" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li id="LI_31CAAAA3EB6C4F618228E3F247365C9D" class="- topic/li "><p class="- topic/p ">3 needles. 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="FIG_EF963154066847CB8999B34E49BE0CE9" class="- topic/fig "><image href="GUID-12A743B5-E36D-4086-8787-5F0195D80F74-low.png" id="IMAGE_5B6BBCE3DB8649A0B98D171F9DBD6DCB" placement="inline" class="- topic/image " otherprops="GUID-12A743B5-E36D-4086-8787-5F0195D80F74-low.png"/></fig></section><section id="SECTION_995BFBF5AF30421F8AAEEBF8647BC6CF" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_7E98F27B230941C4B075D6AC77B482F3" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide the printhead carriage to the middle. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use the needle to fixate the felt in the slide mechanism. 
</p><note id="GUID-3576054E-DC5B-49E6-923C-DE9E7D1ED62A" type="important" class="- topic/note "><p class="- topic/p ">If you forget this step the felts will drop out while you lift the carriage out. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-729C681C-311E-4EE4-B431-8D5EE9BDCF34" class="- topic/fig "><image href="GUID-94C01284-C4E3-4532-8FBD-DDE17679BB58-low.png" placement="inline" class="- topic/image " otherprops="GUID-94C01284-C4E3-4532-8FBD-DDE17679BB58-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the assembly (1 screw) with the felt. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EC7E3E87-4873-4F0E-9B21-9487BA536E7C" class="- topic/fig "><image href="GUID-5B8C8816-3ADF-4EBC-A1C2-EB5EAA609355-low.png" placement="inline" class="- topic/image " otherprops="GUID-5B8C8816-3ADF-4EBC-A1C2-EB5EAA609355-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use 2 needles to fixate the felt in the slide mechanism. 
</p><note type="important" id="GUID-99A548A4-962D-41CA-90C4-490AE26E8731" class="- topic/note "><p class="- topic/p ">If you forget this step the felts will drop out while you lift the carriage out. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1F5B14EA-4017-42FC-974F-9C867F2F9DA1" class="- topic/fig "><image href="GUID-476FC1C5-E214-4BDB-9383-CC0EF26DCFF3-low.png" placement="inline" class="- topic/image " otherprops="GUID-476FC1C5-E214-4BDB-9383-CC0EF26DCFF3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 assemblies (1 screw) with the felt. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0DCF0AE5-45B9-4062-B319-4647E26DBBDC" class="- topic/fig "><image href="GUID-81348B52-89DE-489D-B626-485DF5E24828-low.png" placement="inline" class="- topic/image " otherprops="GUID-81348B52-89DE-489D-B626-485DF5E24828-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_BF222651FDC54D218A4605224C634311" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 3
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">When you mount new felts set the usage counter to zero. 
</p><p class="- topic/p ">See : SDS test: 
<xref keyref="SDS05-8-006" class="- topic/xref " href="GUID-D162B915-5F42-44D2-B392-37EED2E39FCF.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 05-8-006 Distance traveled of the guidance cleaners [m]?>05-8-006 Distance traveled of the guidance cleaners [m] [Maintenance Counters]</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-413D000D-1733-4578-95D7-CBC36AC62908.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
