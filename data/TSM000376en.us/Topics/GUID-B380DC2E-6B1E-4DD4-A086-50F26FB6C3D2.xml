<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-B380DC2E-6B1E-4DD4-A086-50F26FB6C3D2" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-B380DC2E-6B1E-4DD4-A086-50F26FB6C3D2" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to remove the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Media loading drawer 1 roll 1 motor encoder</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 12B3 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">MLO_DRA1_ROL1_MO_ENC</compsignal></comp></title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_34F2C03C97F249649B92631C09DBB41B" class="- topic/li "><p class="- topic/p ">Open the media loading drawer. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_69BB0AEB395F4E8AB96FD94A4C0C8696" class="- topic/ul "><li id="LI_06B1AE50C8584502AA32D102711C1229" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li id="LI_561D1BF957EA49F8BB49139266A92893" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li></ul></section><section id="GUID-F56DEEE4-F746-4C5E-B808-E951147DF22A" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Caution:</ph></title><p class="- topic/p ">When you remove this encoder it is broken. Make sure you have a replacement. 
</p></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-1C6A5506-8461-4BFD-8B7C-FB47C7EF289A" class="- topic/fig "><image href="GUID-12AFA39C-8238-462A-B88C-2D9A3500111F-low.png" id="IMAGE_4DC6EE8C1B14407E8C7C4A980645B932" placement="inline" class="- topic/image " otherprops="GUID-12AFA39C-8238-462A-B88C-2D9A3500111F-low.png"/></fig><fig id="FIG_AA8DF0677649429EAFDD1658D6336BA1" class="- topic/fig "><image href="GUID-B4D87D04-3D09-4C93-B63E-D3EAF416E656-low.png" id="IMAGE_A3656DC5C73A4CC898696103C2A1C4AE" placement="inline" class="- topic/image " otherprops="GUID-B4D87D04-3D09-4C93-B63E-D3EAF416E656-low.png"/></fig></section><section id="SECTION_079B9FE753A94ADABD479BD0E018D948" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_604AB09805EC4B89B181B7BA55FA3875" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the triangular middle cover that covers the motor and encoder. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_3B7BD0CF7E5444B3B50C248FABA56EE4" class="- topic/fig "><image href="GUID-EA1467BC-F5CF-46F5-962F-15AEDC73AB6C-low.png" id="IMAGE_BF6EC7BA819E481FA93A9204C0553544" placement="inline" class="- topic/image " otherprops="GUID-EA1467BC-F5CF-46F5-962F-15AEDC73AB6C-low.png"/></fig><fig id="FIG_51AC0AC4820142BE84BDDDB97CD32E12" class="- topic/fig "><image href="GUID-1F30291E-5D98-492C-B654-7B765D34A1BD-low.png" id="IMAGE_FCDF1FFA90944C6C803730D74B1C74CD" placement="inline" class="- topic/image " otherprops="GUID-1F30291E-5D98-492C-B654-7B765D34A1BD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the encoder. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_FE5916467AE746A985823662A1866FED" class="- topic/fig "><image href="GUID-5E65C4D6-842F-4F71-AADB-032A0B643240-low.png" id="IMAGE_031CF33715EB434E840050802DFB94B6" placement="inline" class="- topic/image " otherprops="GUID-5E65C4D6-842F-4F71-AADB-032A0B643240-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Rotate the encoder to unlock the bayonet lock, and remove the encoder. 
</p><note id="GUID-51C0E261-E7B0-47E9-AAF9-32798189A2E1" class="- topic/note "><p class="- topic/p ">The lower part of the encoder stays on the motor. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_13570A842ADE47409ABDDFFB9CBC88DE" class="- topic/fig "><image href="GUID-39260836-E408-4375-8F5C-302683F32351-low.png" id="IMAGE_79D9208B0D3D42709A36377DF1690EB9" placement="inline" class="- topic/image " otherprops="GUID-39260836-E408-4375-8F5C-302683F32351-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p><note id="GUID-B352DC5D-EF95-4679-B7E0-4F75756CEAC6" class="- topic/note "><p class="- topic/p ">Always install a new encoder. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5B96AB9C-8847-4643-A8CB-09918FE19AAB.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
