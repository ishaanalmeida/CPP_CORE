<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-69C93470-DBBC-48E8-9996-99D50028E362" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-69C93470-DBBC-48E8-9996-99D50028E362" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">12 How to install and configure the Interface unit for the Jumbo Roll Unit </title><abstract class="- topic/abstract " id="GUID-9DDA35A1-5C59-498F-B91B-BE61F74397CE"><note class="- topic/note " id="GUID-DAAEB28F-2B02-4A9B-9CB7-AACA23F283DD"><p class="- topic/p ">Software version R4.2.0.0 (or higher) is required to support the Interface unit and Jumbo Roll unit. 
</p></note><p class="- topic/p ">Estimated time of installation is 1 hour and 30 minutes. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Open the media drawer. 
</p></li><li class="- topic/li "><p class="- topic/p "> Open the ink system. 
</p><p class="- topic/p ">See 
<xref keyref="02DISA012" class="- topic/xref " href="GUID-1C874C66-3A17-4AC4-886B-753A1A37D196.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02 Open the ink system?>02 Open the ink system</xref>. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the cover below the media drawer. 
</p><p class="- topic/p ">See 
<xref keyref="24DISA050" class="- topic/xref " href="GUID-87DBD356-A13A-44A7-B799-70CBF324AF9D.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the cover below the media drawer?>24 How to remove the cover below the media drawer</xref>. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the media roll of the winder. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the left hand side cover of the winder. 
</p><p class="- topic/p ">See 
<xref keyref="24DISA058" class="- topic/xref " href="GUID-018F073E-4ED3-414A-8FEC-3740B53F5DBE.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the left (or right) hand side cover of the winder?>24 How to remove the left (or right) hand side cover of the winder</xref> 
</p><p class="- topic/p ">Only the left cover. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the left media output upper cover. 
</p><p class="- topic/p ">See 
<xref keyref="24DISA048" class="- topic/xref " href="GUID-962C3B4B-1844-4787-9FED-B89EB85CC5D6.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the media output upper covers?>24 How to remove the media output upper covers</xref>. 
</p><p class="- topic/p ">Only the left side cover. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_69BB0AEB395F4E8AB96FD94A4C0C8696" class="- topic/ul "><li id="LI_561D1BF957EA49F8BB49139266A92893" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T25 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T30 
</p></li><li id="LI_B784B59E966743309622F0F98A079F05" class="- topic/li "><p class="- topic/p ">Interface kit: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">2 x side blocks 
</p><p class="- topic/p ">(including 2 x fixation brackets (mounted on the 2 side blocks)) 
</p><fig id="GUID-36F84788-9F3D-4A13-8915-14C138372439" class="- topic/fig "><image href="GUID-5EDA4EB6-CC21-49E3-A420-F2710BC99909-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5EDA4EB6-CC21-49E3-A420-F2710BC99909-low.png"/></fig><fig id="GUID-B3584013-1F57-4CDC-A44B-AB963F86C749" class="- topic/fig "><image href="GUID-2A9B85BA-477D-4F75-A03E-F44DE97ED79A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2A9B85BA-477D-4F75-A03E-F44DE97ED79A-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">a bracket with a cable bundle. 
</p><fig id="GUID-E4155348-C0B6-45DF-8F46-1761CDE48D3C" class="- topic/fig "><image href="GUID-5962A108-15E3-4476-952A-0D8BC5855DAC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5962A108-15E3-4476-952A-0D8BC5855DAC-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">a small box with a new PBA: 21PBA01_6_7 BLDC_7A5 
</p></li><li class="- topic/li "><p class="- topic/p ">the interface unit 
</p><fig id="GUID-42DBE1BC-A370-45C3-8073-C750575C5C85" class="- topic/fig "><image href="GUID-A31ED876-60D0-428A-B812-D8AC8EE14B22-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A31ED876-60D0-428A-B812-D8AC8EE14B22-low.png"/></fig></li><li class="- topic/li "><p class="- topic/p ">a cover (of the interface unit) 
</p><fig id="GUID-A8217984-1E5B-49A6-B876-8A9C1649EB6F" class="- topic/fig "><image href="GUID-FDDFBF6D-03C5-4998-A05A-12E584BD991C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FDDFBF6D-03C5-4998-A05A-12E584BD991C-low.png"/></fig></li></ul></li><li class="- topic/li "><p class="- topic/p ">Antistatic wristband when working on electronics. 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-9848D934-FF3E-4AC9-BA07-69028FA44036" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note><note type="important" id="GUID-985FFBF4-CACE-47F4-AF21-7A7BEBBB34EA" class="- topic/note "><p class="- topic/p ">Use an antistatic wrist strap. 
</p></note><note type="caution" id="GUID-05D18BCF-DCCD-4C5B-8983-F6D90E3B2190" class="- topic/note "><p class="- topic/p ">2 persons are required to remove the unit. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-4E2BBB36-1B3A-44C0-97E3-E2CBBE0DD98E" class="- topic/fig "><image href="GUID-9B75A214-493A-4438-9C2B-60103E7F7C79-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-9B75A214-493A-4438-9C2B-60103E7F7C79-low.png"/></fig></section><section id="SECTION_9A4E31FC8A1D474082EB98039B353FF0" class="- topic/section "><title class="- topic/title ">Installation</title><table pgwide="1" id="TABLE_BC6D1128E6D045B0884B679CB3343E94" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Unhook the cables from the cable guides on the interface unit. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6C32DB8C-FB9D-411E-8B97-CB3C19592FC5" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AFB476A6-8C28-48A7-ABE3-3A4D886F226D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-AFB476A6-8C28-48A7-ABE3-3A4D886F226D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Guide the cable, as indicated, in the cable guides. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-46B0FA76-5281-4BEF-BB18-59BD33872D3E" class="- topic/fig "><image href="GUID-2C26F19C-1049-41AD-B23D-2F57CC154BE1-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2C26F19C-1049-41AD-B23D-2F57CC154BE1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Guide the cable, as indicated, in the cable guides. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EDAA8FE7-5E38-49C0-9AD5-33D0AFF7A7C5" class="- topic/fig "><image href="GUID-50DAC92D-4F21-4FEE-9AC3-3A940AAA6A69-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-50DAC92D-4F21-4FEE-9AC3-3A940AAA6A69-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Remove the 2 screws of the bracket that hold the cover below the media drawer at the left and right hand side. 
</p></li><li class="- topic/li "><p class="- topic/p ">Rotate the bracket to the rear side and remove it. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D237D0D7-2221-47D3-AC08-981A18532A07" class="- topic/fig "><image href="GUID-416804CE-9ED3-40DD-B48E-B3B07D76F77A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-416804CE-9ED3-40DD-B48E-B3B07D76F77A-low.png"/></fig><fig id="GUID-836FFC80-3578-44E4-AF95-569B12093FCC" class="- topic/fig "><image href="GUID-564DDBC7-5006-430A-99A9-C9D7CF1D6E01-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-564DDBC7-5006-430A-99A9-C9D7CF1D6E01-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install the side block that support the interface unit at the left and right hand side. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">1 screw: insert the screw (T25 M5) at the media drawer side (at the left and right hand side), 
</p></li><li class="- topic/li "><p class="- topic/p "> The other one (T30 ) through the frame plate from the chiller or ink unit side. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EBE957BD-3A2C-4E9D-B612-C609AD081FFB" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AC608E95-58FD-454F-9B6D-9BF0BA8401AD-low.png" placement="inline" class="- topic/image " otherprops="GUID-AC608E95-58FD-454F-9B6D-9BF0BA8401AD-low.png"/></fig><fig id="GUID-B3F13421-E85E-4CB1-B5D8-5DC686F84BEC" class="- topic/fig "><title class="- topic/title ">Below the screw added from the chiller side.</title><image href="GUID-A0A482E5-B664-45C3-AD45-20D014D36466-low.png" placement="inline" class="- topic/image " otherprops="GUID-A0A482E5-B664-45C3-AD45-20D014D36466-low.png"/></fig><fig id="GUID-1F22A665-5985-47C5-AD8B-79534D083B23" class="- topic/fig "><title class="- topic/title "/><image href="GUID-629546BC-0774-42D5-B732-A2B201EFAA43-low.png" placement="inline" class="- topic/image " otherprops="GUID-629546BC-0774-42D5-B732-A2B201EFAA43-low.png"/></fig><fig id="GUID-C268887C-3CB1-4EAB-A898-9B39E1E63EF2" class="- topic/fig "><title class="- topic/title ">Below the screw added from the I/O board side.</title><image href="GUID-A18D2653-975D-4736-A5B3-9B1B232A7084-low.png" placement="inline" class="- topic/image " otherprops="GUID-A18D2653-975D-4736-A5B3-9B1B232A7084-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the bracket (4 screws) with the cable bundle. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A50CF904-8170-4D26-8345-909F08E66043" class="- topic/fig "><title class="- topic/title ">Install the bracket (4 screws) with the cable holders.</title><image href="GUID-A47D2BFA-B60B-4F7D-AD3A-EE2A98C1A4CB-low.png" placement="inline" class="- topic/image " otherprops="GUID-A47D2BFA-B60B-4F7D-AD3A-EE2A98C1A4CB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount HARNESS 12W102 (BLUE) on the BRACKET BUNDLE in the bundle holders on the frame side and connect the connector housing to the BRACKET CONNECTOR. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-00466407-3AF6-4C95-9A9E-8C89BE9962DF" class="- topic/fig "><title class="- topic/title "/><image href="GUID-7DD96C50-8D67-4685-BD07-854B56927662-low.png" placement="inline" class="- topic/image " otherprops="GUID-7DD96C50-8D67-4685-BD07-854B56927662-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount HARNESS 12W103 (RED) on the BRACKET BUNDLE in the bundle clips to the other side and connect the connector housing to the BRACKET CONNECTOR. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CDC6BA3C-61B1-4A6C-9D0C-C9F59BEE5524" class="- topic/fig "><title class="- topic/title "/><image href="GUID-DA292316-469D-4CC9-9237-09452CA83AF2-low.png" placement="inline" class="- topic/image " otherprops="GUID-DA292316-469D-4CC9-9237-09452CA83AF2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Rear side engine: Guide the bundle carefully through the hole in the frame behind the metal bracket into the direction of the ink system (MORPH PBA). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-694598C0-5A09-44FB-89B5-063B5C716788" class="- topic/fig "><image href="GUID-A9F12BC6-7654-4047-92D4-1A803722B7FF-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A9F12BC6-7654-4047-92D4-1A803722B7FF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the fixation bracket (1 screw) at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-009F8EAB-CB87-4B6A-AE53-A9C2C56E82A9" class="- topic/fig "><image href="GUID-E80C09FE-5CF2-43A8-BE97-0D3C755C07F3-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E80C09FE-5CF2-43A8-BE97-0D3C755C07F3-low.png"/></fig><fig id="GUID-60BBC005-F74A-4029-8279-190B8E9ED896" class="- topic/fig "><image href="GUID-B6F59B80-BFDD-4467-8CF7-010D29DFA03E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B6F59B80-BFDD-4467-8CF7-010D29DFA03E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><note type="caution" id="GUID-233025A6-D2DD-449A-9971-F807D3D33131" class="- topic/note "><p class="- topic/p ">2 persons are required to remove the unit. 
</p></note><p class="- topic/p ">Place the interface unit on the side blocks at the left and right hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-52C174E9-326A-4AD6-AB9F-E04342535D2D" class="- topic/fig "><image href="GUID-7229DC46-8EED-4037-8BCF-98A17D6E28D7-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7229DC46-8EED-4037-8BCF-98A17D6E28D7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lock the interface unit with the fixation bracket (2 screw T20: M4x30) at the left and right hand side. Do this at the top and bottom. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2E9E781B-1B1D-4AAD-953E-ACC2F2C3C352" class="- topic/fig "><image href="GUID-DF9417BB-2FA2-458C-B3CA-26E5DA626A37-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-DF9417BB-2FA2-458C-B3CA-26E5DA626A37-low.png"/></fig><fig id="GUID-35F0A717-B41D-47A5-9C13-6061745AA733" class="- topic/fig "><image href="GUID-BCAD6C13-D995-4466-86CC-C2BEF7C5593D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BCAD6C13-D995-4466-86CC-C2BEF7C5593D-low.png"/></fig><fig id="GUID-AB7CF295-B80F-4C85-899E-9430F35B2AD4" class="- topic/fig "><title class="- topic/title "/><image href="GUID-84DEFF54-093D-4E1D-91EE-DB8A5EEA5E1C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-84DEFF54-093D-4E1D-91EE-DB8A5EEA5E1C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect the 2 connectors of the interface unit. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B988F871-336D-40C5-AAE6-FB22A14FEA14" class="- topic/fig "><image href="GUID-3293DAE7-D286-488A-8B1E-7D91BD9BEEAB-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3293DAE7-D286-488A-8B1E-7D91BD9BEEAB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the cover of the interface unit (2 x 2 screws / T20: M4x8). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8BC4FEF0-8D7F-45FB-9440-86062BA02B93" class="- topic/fig "><image href="GUID-7012F5B5-5EC3-48F0-8048-B91D3E6E22AD-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7012F5B5-5EC3-48F0-8048-B91D3E6E22AD-low.png"/></fig><fig id="GUID-E0D29E5A-1CE2-43E4-94B8-80C1C756F71A" class="- topic/fig "><image href="GUID-D4195968-259A-4C01-9A47-2A7068F9A62E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D4195968-259A-4C01-9A47-2A7068F9A62E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount an additional PBA I/O BOARD_DRAWER on the right bottom side of the PLATE BASE ASSY with 7 SCREWS, TORX WASHER-M3x6. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-87B7DA88-0B9D-4A5F-B781-913378CBA6C2" class="- topic/fig "><title class="- topic/title "/><image href="GUID-7A51A0FC-0C80-40E4-BFB2-D2EC36CEC071-low.png" placement="inline" class="- topic/image " otherprops="GUID-7A51A0FC-0C80-40E4-BFB2-D2EC36CEC071-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount HARNESS 12W102 (BLUE) to the FRAME and PLATE BASE ASSY in the lower bundle clips and connect the connectors to the additional PBA I/O BOARD_DRAWER on the connectors X76, X79 and X80. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A325B01A-6C86-4D28-8726-4D00B84B637A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-BB7A43B9-312E-4580-A220-D33F481DA6C1-low.png" placement="inline" class="- topic/image " otherprops="GUID-BB7A43B9-312E-4580-A220-D33F481DA6C1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount HARNESS 12W103 (RED) to the FRAME and the PLATE BASE ASSY in the upper bundle clips and connect the connectors to the additional PBA I/O BOARD_DRAWER on X57 and X59. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F6FC62C0-546D-4B8E-A6E6-69F88DE53502" class="- topic/fig "><title class="- topic/title "/><image href="GUID-33130137-2EA5-4644-90BA-1D24AED5F56F-low.png" placement="inline" class="- topic/image " otherprops="GUID-33130137-2EA5-4644-90BA-1D24AED5F56F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Mounting HARNESS 12W104</b> 
</p><p class="- topic/p ">Connect HARNESS 12W104 to the additional I/O BOARD_DRAWER on connectors X2 / A-B and X41. 
</p><p class="- topic/p ">The harness is for the ID from the Jumbo Roll Unit. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A2A09B00-F3EB-4AD6-9712-F5221AF180AF" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3077D186-1588-4E9C-A9B1-A17A34CF1C3D-low.png" placement="inline" class="- topic/image " otherprops="GUID-3077D186-1588-4E9C-A9B1-A17A34CF1C3D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Mounting HARNESS 12W105</b> 
</p><p class="- topic/p ">Connect the HARNESS 12W105 (BLUE) on the additional PBA I/O BOARD_DRAWER on the connector X67 and on the PBA DISTRIBUTION on connector X23. 
</p><p class="- topic/p ">This harness is for the power connection from the PBA DISTRIBUTION to the PBA I/O Board_DRAWER. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1476DF6E-5785-42FB-B098-7D4A77A4EC00" class="- topic/fig "><title class="- topic/title "/><image href="GUID-C2199DDF-59C7-415F-B42B-FD264EE92B5A-low.png" placement="inline" class="- topic/image " otherprops="GUID-C2199DDF-59C7-415F-B42B-FD264EE92B5A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The connector 12X110 from HARNESS 12W105 must connected to the HARNESS 21W03 to connector 12X110. 
</p><p class="- topic/p ">Mount the harness in the lower bundle clips. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9A185F7D-CBF0-4D73-B8DC-1FD6B8DE914E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-ADB73292-C7AE-4592-A3C1-154345F74A6D-low.png" placement="inline" class="- topic/image " otherprops="GUID-ADB73292-C7AE-4592-A3C1-154345F74A6D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">21 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Mount RJ45 Cable</b> 
</p><p class="- topic/p "> Mount the RJ45 cable to the connector X84 (lower RJ45 connector) from the original PBA I/O Board_DRAWER (UPPER PBA) to the connector X83 (upper RJ45 connector) from additional PBA I/O BOARD_DRAWER (LOWER PBA). 
</p><p class="- topic/p ">Mount the cable and the excess length from the cable in the bundle holders. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3CDC20E7-1515-4867-ADA6-76EC392D1C47" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3036066B-6359-429A-AC26-3CFF37F3D519-low.png" placement="inline" class="- topic/image " otherprops="GUID-3036066B-6359-429A-AC26-3CFF37F3D519-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">Configure / Finalize</title><table pgwide="1" id="TABLE_F77204E29D3E4F6D8F3503958683C72F" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install units in reversed order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Start SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><xref keyref="12SDS121010" class="- topic/xref " href="GUID-711D6CC9-5D34-419C-BC6F-82AC5B65A88B.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 12-1-010 externalRolConfigured [Parameters]?>12-1-010 externalRolConfigured [Parameters]</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Parameters 12-1-010 externalRolConfigured 
</p><p class="- topic/p ">External roll configuration 
</p><p class="- topic/p ">0 = not configured 
</p><p class="- topic/p ">1 = configured 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reboot the system. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Test the interface unit: 
</p><p class="- topic/p ">Feed a sheet of media into the slot of the interface unit. The interface grabs the media end provides feedback with a beep. No error must occur. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-76EA4F13-F119-49E5-9D32-8B03D284491B.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
