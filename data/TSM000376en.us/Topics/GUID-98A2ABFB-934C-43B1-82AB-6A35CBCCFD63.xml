<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-98A2ABFB-934C-43B1-82AB-6A35CBCCFD63" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-98A2ABFB-934C-43B1-82AB-6A35CBCCFD63" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title "> 04 How to replace a (failing) printhead: How to install (Example printhead 3)</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install (Example printhead 3)</title><note id="GUID-732C8B1F-1AFA-47AF-BF9B-4871AD515B1B" class="- topic/note "><p class="- topic/p ">Change your protective gloves to install the new printhead. 
</p></note><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> If applicable: Connect the pre-folded flex cable to the printhead. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-460FFAC3-F788-47AF-A465-CED1E9EF41D7" class="- topic/fig "><image href="GUID-C7889529-253B-415E-930B-6BE64D65EFCC-low.png" placement="inline" class="- topic/image " otherprops="GUID-C7889529-253B-415E-930B-6BE64D65EFCC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the (green) protection cap. 
</p><note id="GUID-80A8517F-C9FF-41FC-BFB1-280414F0FD9F" class="- topic/note "><p class="- topic/p ">Make sure the foam block does not stick to the nozzle plate. Remove the foam block if needed. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0B2381FA-3C02-4F8B-BA4E-73B2BD7750EF" class="- topic/fig "><image href="GUID-D32870D0-A8A1-4CCF-9F2C-D5DD89D63AF5-low.png" placement="inline" class="- topic/image " otherprops="GUID-D32870D0-A8A1-4CCF-9F2C-D5DD89D63AF5-low.png"/></fig><fig id="GUID-157EA392-6F67-48C5-9BE9-ED3842AEC922" class="- topic/fig "/></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide the printhead into the printhead carriage. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0508C7EF-0311-426A-96E7-4EDE79DFC763" class="- topic/fig "><image href="GUID-87473C48-8AC1-43D3-83A7-65400F29C847-low.png" placement="inline" class="- topic/image " otherprops="GUID-87473C48-8AC1-43D3-83A7-65400F29C847-low.png"/></fig><fig id="GUID-CE245FCC-85C6-45DD-A11C-E8F8748FF66E" class="- topic/fig "><image href="GUID-39E16A99-7CBA-46D4-823A-F7EDB4268488-low.png" placement="inline" class="- topic/image " otherprops="GUID-39E16A99-7CBA-46D4-823A-F7EDB4268488-low.png"/></fig><fig id="GUID-73D88762-4A7B-490C-B44F-E07B7B6AF010" class="- topic/fig "/></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Connect the flex cable to the Carriage PBA (05PBA07). 
</p><note id="GUID-9E6E02FF-FF66-492D-81BF-0621FF94BA92" class="- topic/note "><p class="- topic/p "> Push the flex cable to the right so that it is not in the way when you place the next printhead. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-09F61547-F674-4061-B4DB-D1EF2870E2A0" class="- topic/fig "><image href="GUID-53843753-EDA8-4054-B256-A4B828711C10-low.png" placement="inline" class="- topic/image " otherprops="GUID-53843753-EDA8-4054-B256-A4B828711C10-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p "> Remove the red cap from the air tube of the printhead. 
</p></li><li class="- topic/li "><p class="- topic/p "> Connect the air tube to the filter. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6CC6757C-8B56-498E-8E7F-241228D4A8BB" class="- topic/fig "><image href="GUID-510FDDE3-6710-4E3D-ACDD-E9C8E24F916F-low.png" placement="inline" class="- topic/image " otherprops="GUID-510FDDE3-6710-4E3D-ACDD-E9C8E24F916F-low.png"/></fig><fig id="GUID-59078534-3769-4B49-AF2F-90516C6C1DED" class="- topic/fig "><image href="GUID-5390924C-0AD9-4A21-A853-463A4DAAD14D-low.png" placement="inline" class="- topic/image " otherprops="GUID-5390924C-0AD9-4A21-A853-463A4DAAD14D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Open the clamp of the air tube. 
</p></li><li class="- topic/li "><p class="- topic/p ">Squeeze the air tubes to protect that the tube sticks together. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A01FD977-FFC5-466C-BEAF-DCC8E258E476" class="- topic/fig "><title class="- topic/title "/><image href="GUID-1B930E5D-8D81-4367-828D-9590397F133C-low.png" placement="inline" class="- topic/image " otherprops="GUID-1B930E5D-8D81-4367-828D-9590397F133C-low.png"/></fig><fig id="GUID-23C66650-A3E5-4B00-A08F-74CF740A24E4" class="- topic/fig "><image href="GUID-C2591A47-0992-4F44-97B2-B82C0BDC3B51-low.png" placement="inline" class="- topic/image " otherprops="GUID-C2591A47-0992-4F44-97B2-B82C0BDC3B51-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the red cap from the ink tube: 
</p><ul id="UL_2B95CA1DC9CC4B72B26A7C062A342A30" class="- topic/ul "><li id="LI_E34E3142A7524A0B9E1A0F53AD766DA9" class="- topic/li "><p class="- topic/p ">1 at the printhead side. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B8D346FB-EEFC-46F5-9FAC-1DE6FE103C0A" class="- topic/fig "><image href="GUID-F9C95F78-7986-4743-B655-7ACC7BBC3678-low.png" placement="inline" class="- topic/image " otherprops="GUID-F9C95F78-7986-4743-B655-7ACC7BBC3678-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect the ink tube to the assembly. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0277E3E0-5BD6-4A0B-B4EE-1EF2743167E9" class="- topic/fig "><image href="GUID-EE176834-CB4D-446A-977F-1813F86C20C5-low.png" placement="inline" class="- topic/image " otherprops="GUID-EE176834-CB4D-446A-977F-1813F86C20C5-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the assembly on the printhead clamp. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D147D61C-35EE-413F-B97D-C22DA1CB6BDB" class="- topic/fig "><image href="GUID-22B8D7D8-22EC-4616-A8EA-E8476718607E-low.png" placement="inline" class="- topic/image " otherprops="GUID-22B8D7D8-22EC-4616-A8EA-E8476718607E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the 2 ink valves of the printhead. 
</p><note type="important" id="GUID-880C54C1-42B8-4660-907C-EBD0E9DC5832" class="- topic/note "><p class="- topic/p ">Do not touch the other ink valves. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9A26D01A-A044-4430-88F1-FDE285B53B74" class="- topic/fig "><image href="GUID-915C2657-6CE2-4382-BFF3-45091877678C-low.png" placement="inline" class="- topic/image " otherprops="GUID-915C2657-6CE2-4382-BFF3-45091877678C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Check visually if all 8 printheads are in line. 
</p><p class="- topic/p ">If not: reseat the printheads that are not in-line. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C17FDFF3-FC08-4B40-9BFC-9389F0BA6B63" class="- topic/fig "><image href="GUID-17EA8842-563A-4F97-BD86-BE8981CCBEBC-low.png" placement="inline" class="- topic/image " otherprops="GUID-17EA8842-563A-4F97-BD86-BE8981CCBEBC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the printhead carriage locking handle. 
</p><note id="GUID-C8EC0951-47D1-46C9-8C83-E46486577F0E" class="- topic/note "><p class="- topic/p ">Make sure the handle does not touch the screw. Position it beside the screw. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A7A27225-23C9-4D78-810A-DE9D17538365" class="- topic/fig "><image href="GUID-181CD0AD-A04A-4F54-B6B8-B35B2B599389-low.png" placement="inline" class="- topic/image " otherprops="GUID-181CD0AD-A04A-4F54-B6B8-B35B2B599389-low.png"/></fig><fig id="GUID-0EC46999-D588-49CE-B7FD-CF7FC44382F8" class="- topic/fig "><image href="GUID-F6D37C65-5895-4497-B0A6-3F9409BC20F6-low.png" placement="inline" class="- topic/image " otherprops="GUID-F6D37C65-5895-4497-B0A6-3F9409BC20F6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Re-check</b> visually if the printheads are in-line 
<b class="+ topic/ph hi-d/b ">and 
</b>the spring wire is above the printhead hooks. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2294279C-E822-42F4-A12B-C00DD343EA4F" class="- topic/fig "><image href="GUID-17EA8842-563A-4F97-BD86-BE8981CCBEBC-low.png" placement="inline" class="- topic/image " otherprops="GUID-17EA8842-563A-4F97-BD86-BE8981CCBEBC-low.png"/></fig><fig id="FIG_EEA10603A3CE44AFBACE11A78ED1753B" class="- topic/fig "><image href="GUID-70AA5F99-BDA4-48B3-B177-863850F6D818-low.png" id="IMAGE_68C05063758F43C18E18C1961E192BF0" placement="inline" class="- topic/image " otherprops="GUID-70AA5F99-BDA4-48B3-B177-863850F6D818-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Push the air duct in the direction of the printheads. 
</p></li><li class="- topic/li "><p class="- topic/p "> Lock the air duct with 2 screws. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-40978937-3C1D-4049-ADC5-49A2CF9FB33F" class="- topic/fig "><image href="GUID-4632A651-91FF-40E6-B581-116923012A0D-low.png" placement="inline" class="- topic/image " otherprops="GUID-4632A651-91FF-40E6-B581-116923012A0D-low.png"/></fig><fig id="GUID-B5DFE33E-84D0-4EB5-BA94-1BB9718662C2" class="- topic/fig "><image href="GUID-475403F9-6304-4385-A5BC-A87695659BF3-low.png" placement="inline" class="- topic/image " otherprops="GUID-475403F9-6304-4385-A5BC-A87695659BF3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the bracket and lock it with the screw. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Result: 
</p><p class="- topic/p "> Assembled printhead carriage including 4 or 5 printheads and 3 or 4 dummy heads. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E08904B9-48B6-4A88-A71A-D7959B00AE08" class="- topic/fig "><image href="GUID-D3D791A6-3FAA-4264-B6F8-53765B65752F-low.png" placement="inline" class="- topic/image " otherprops="GUID-D3D791A6-3FAA-4264-B6F8-53765B65752F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Check: 
</p><p class="- topic/p "> Double check again all 
<b class="+ topic/ph hi-d/b ">ink tube connections</b> if they are properly connected. Make sure the ink tubes are not interchanged or do cross each other. 
</p></li><li class="- topic/li "><p class="- topic/p ">Check: 
</p><note type="important" id="GUID-968CCC37-CDFF-4519-8974-586F173530DA" class="- topic/note "><p class="- topic/p ">Make sure that the ink valves of the printheads are in the open (vertical) position. 
</p></note></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4FF0FF7E-5CC5-4D7F-8248-8BE3A614342F" class="- topic/fig "><image href="GUID-EEF650F8-C80E-4132-9A29-4C1E0D7320C5-low.png" placement="inline" class="- topic/image " otherprops="GUID-EEF650F8-C80E-4132-9A29-4C1E0D7320C5-low.png"/></fig><fig id="GUID-A015A42C-0804-4460-93EB-81EB37414754" class="- topic/fig "><image href="GUID-E320064B-7750-44C2-8140-E362F70520D2-low.png" placement="inline" class="- topic/image " otherprops="GUID-E320064B-7750-44C2-8140-E362F70520D2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check: 
</p><p class="- topic/p "> Double check again all 
<b class="+ topic/ph hi-d/b ">air tube connections</b>. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Clamps need to be opened. 
</p></li><li class="- topic/li "><p class="- topic/p ">Make sure the air tubes are not interchanged or do cross each other. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0C910E79-B7CA-4A39-AA95-1DBB9470F6EC" class="- topic/fig "><image href="GUID-9025CC4E-D584-49DC-9ED2-1D31F70C5B47-low.png" placement="inline" class="- topic/image " otherprops="GUID-9025CC4E-D584-49DC-9ED2-1D31F70C5B47-low.png"/></fig><fig id="GUID-44ED84FD-2AB9-44B5-B6C3-37119371C5FD" class="- topic/fig "><image href="GUID-C0C3323A-2085-490D-91A0-9BCC099C591C-low.png" placement="inline" class="- topic/image " otherprops="GUID-C0C3323A-2085-490D-91A0-9BCC099C591C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Check: 
</p><p class="- topic/p "> Double check again all 
<b class="+ topic/ph hi-d/b ">flex cable connections</b>. Make sure the flex cables are not interchanged or do cross each other. Check if the connectors are completely pressed in. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-CDB8A697-A93C-4AD9-8143-95D0F938EC7B" class="- topic/fig "><image href="GUID-052EC07C-F862-4F88-84BE-50CC288CD37A-low.png" placement="inline" class="- topic/image " otherprops="GUID-052EC07C-F862-4F88-84BE-50CC288CD37A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the clamp bracket and lock it with the 4 screws 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9A4925B2-5505-4EF7-9009-ED66E806996F" class="- topic/fig "><image href="GUID-07B0A69C-0AF2-4679-AB1E-CE1504207FF4-low.png" placement="inline" class="- topic/image " otherprops="GUID-07B0A69C-0AF2-4679-AB1E-CE1504207FF4-low.png"/></fig><fig id="GUID-8425A5D0-E256-46D9-BF10-A99CDC289AB8" class="- topic/fig "><image href="GUID-2DC02DE5-6812-402F-88C1-E75CE0775991-low.png" placement="inline" class="- topic/image " otherprops="GUID-2DC02DE5-6812-402F-88C1-E75CE0775991-low.png"/></fig></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-ECEDEBD8-6D40-49D8-874E-708F1E8B0062.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>