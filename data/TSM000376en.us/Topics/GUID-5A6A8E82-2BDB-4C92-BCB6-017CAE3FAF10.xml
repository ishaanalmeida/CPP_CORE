<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-5A6A8E82-2BDB-4C92-BCB6-017CAE3FAF10" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-5A6A8E82-2BDB-4C92-BCB6-017CAE3FAF10" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title translate="no" class="- topic/title ">02-6-004 Estimated ink level / Mark ink jar as empty (C, M, Y, K or W) [Special Tests]</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">SDS</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-2BD8C3DB-27B0-44E5-B999-CF486EF1CE0D" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">SDS</ph></title><p class="- topic/p "> 
<object id="GUID-18C98BCF-F7D9-4BE1-A6BC-9B5933FABF94" class="- topic/object "><desc class="- topic/desc "><p class="- topic/p ">Estimated ink level / Mark ink jar as empty </p></desc><param name="testid" value="026004" class="- topic/param "/><param name="target" value="NIL" class="- topic/param "/><param name="axmodule" value="None" class="- topic/param "/></object> 
</p></section><section id="GUID-6C52020E-2A0B-45D2-8A60-8F0791DDE92C" class="- topic/section "><title class="- topic/title "><?xm-replace_text Section Title?></title><note id="GUID-2FD6B1FC-C32C-4D30-BFCC-F64943E24407" class="- topic/note "/><p class="- topic/p ">DON'T MARK THE INK JARS EMPTY WITHOUT CONSULTING PPP SERVICE FIRST. You may damage the printer. 
</p></section><section id="GUID-1156E15C-FA11-42F7-80CE-F9823F371FA9" class="- topic/section "><title class="- topic/title ">Function</title><p class="- topic/p "> The ink level estimation is displayed on the operator panel. 
</p><p class="- topic/p "> The ink level estimation can be set to zero when there is no ink in the ink tank (intermediate ink supply). 
</p><p class="- topic/p "> The use of this test will influence on the billing counters. 
</p><p class="- topic/p "> The remainder of the ink will be accounted to the corresponding billing counter. 
</p></section><section id="GUID-8B850BDF-E4F3-4353-8EA8-26E9EC89A7EC" class="- topic/section "><title class="- topic/title ">Procedure</title><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Start the test. 
</p><p class="- topic/p ">The current estimated supply level is displayed. 
</p></li><li class="- topic/li "><p class="- topic/p ">Press Continue to reset this value to zero. 
</p></li><li class="- topic/li "><p class="- topic/p ">Stop the test to save this value. 
</p><p class="- topic/p ">or 
</p><p class="- topic/p ">Press Continue to restore the old value and than stop the test. 
</p></li></ol></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-E4C54F6E-7FBD-467E-A9DF-8C20AA8FEAEE.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>SDS</linktext></link></linkpool></related-links>
