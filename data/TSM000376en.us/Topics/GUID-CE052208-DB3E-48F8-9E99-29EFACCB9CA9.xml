<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-CE052208-DB3E-48F8-9E99-29EFACCB9CA9" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-CE052208-DB3E-48F8-9E99-29EFACCB9CA9" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">02 How to remove the ink system stir motor (02M2/4/6/8/51)</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the ink system stir motor. 
</p><p class="- topic/p ">It can be used for the following ink system stir motors : 
</p><ul class="- topic/ul " id="UL_37F1A7CF512C499FB71EE738E1BC96BB"><li class="- topic/li " id="LI_DED4F3445A944E3382677F939D9C6556"><p class="- topic/p "> <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Ink system Yellow stir motor</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02M2 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_2_STIR_MO</compsignal></comp> 
</p></li><li class="- topic/li " id="LI_013672B0A05F4E85881A3AD18E8BF99F"><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Ink system Cyan stir motor</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02M4</compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_3_STIR_MO</compsignal></comp> 
</p></li><li class="- topic/li " id="LI_40AAE798E01C40828A1549097F92B6E1"><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Ink system Magenta stir motor</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02M6 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_4_STIR_MO</compsignal></comp> 
</p></li><li class="- topic/li " id="LI_057754793F724577A6D1A32EE0834E05"><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Ink system Black stir motor</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02M8</compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_5_STIR_MO</compsignal></comp> 
</p></li><li class="- topic/li "><p class="- topic/p "><comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Ink system White stir motor</compname><compcodenr class="+ topic/keyword oce-d/compcodenr " translate="no"> 02M51 </compcodenr><compsignal class="+ topic/keyword oce-d/compsignal " translate="no">INK_6_STIR_MO</compsignal></comp> 
</p></li></ul></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the ink system. 
</p><p class="- topic/p ">See : 
<xref keyref="02DISA012" class="- topic/xref " href="GUID-1C874C66-3A17-4AC4-886B-753A1A37D196.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02 Open the ink system?>02 Open the ink system</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the rear top cover of the ink system. 
</p><p class="- topic/p ">See : 
<xref keyref="02DISA014" class="- topic/xref " href="GUID-44A21941-A21F-4C37-A066-3CEA7BE54DAA.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02 How to remove the rear top cover of the ink system...?>02 How to remove the rear top cover of the ink system</xref> 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_44E3E3F07D374BF6964EC50817FE9018" class="- topic/ul "><li id="LI_52DBF4023EA944F89CD5A1B41DA11017" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-F56D2715-E266-4396-9B34-5C0D37B6D01C" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-7B38D9F0-65B5-46A9-B14F-2FE72E84A806" class="- topic/fig "><image href="GUID-9A215E61-2D72-4C1C-A1AA-F4086BCC374C-low.png" placement="inline" class="- topic/image " otherprops="GUID-9A215E61-2D72-4C1C-A1AA-F4086BCC374C-low.png"/></fig></section><section id="SECTION_4AAEB624BD5D4C1FBE4191BD422BB53F" class="- topic/section "><title class="- topic/title ">How to remove</title><table id="TABLE_EF9BEF89F9944132802B5B8E23578113" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Disconnect the connector of the stirring motor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5BF563AE-CC81-4C4C-A85C-9A85124C90C4" class="- topic/fig "><image href="GUID-0CCEBAF9-FECC-4EED-B828-DD4F270907D3-low.png" placement="inline" class="- topic/image " otherprops="GUID-0CCEBAF9-FECC-4EED-B828-DD4F270907D3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the screw. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7842B3BA-00FB-4B14-8317-87F6C01BFF23" class="- topic/fig "><image href="GUID-6E7F39FB-DAF1-4DE3-854A-84F6590CBEE1-low.png" placement="inline" class="- topic/image " otherprops="GUID-6E7F39FB-DAF1-4DE3-854A-84F6590CBEE1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the motor with the ink tank to the top. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E70569F8-05B9-410C-AF72-8C60C2AA0CD5" class="- topic/fig "><image href="GUID-872A2DF4-539E-40A5-AE60-80C891C5A8E9-low.png" placement="inline" class="- topic/image " otherprops="GUID-872A2DF4-539E-40A5-AE60-80C891C5A8E9-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift the Ink Refill Unit to free the ink tank.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D26CC800-D350-4BE1-B230-E3B9D2290252" class="- topic/fig "><image href="GUID-C1CB31DD-8EEB-40A8-A7C2-579BDD406176-low.png" placement="inline" class="- topic/image " otherprops="GUID-C1CB31DD-8EEB-40A8-A7C2-579BDD406176-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the stirring motor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EF545CD4-5200-42AA-87C7-87A6E45D883A" class="- topic/fig "><image href="GUID-9918BB5B-0DDD-4FCD-8D52-E1BC1E0135F8-low.png" placement="inline" class="- topic/image " otherprops="GUID-9918BB5B-0DDD-4FCD-8D52-E1BC1E0135F8-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-1CE85252-F6D3-4421-930B-8AE723FFB49C.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
