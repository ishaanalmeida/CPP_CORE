<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-6B538C70-6992-49DE-8130-F64C17557F97" version="5" lang="en-US"?><concept xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-6B538C70-6992-49DE-8130-F64C17557F97" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic concept)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c concept oceConcept-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic concept/concept "><title class="- topic/title ">Exit <ph varid="Adam" translate="no" class="- topic/ph ">ADAM</ph></title><abstract class="- topic/abstract " id="M148684-B19"><p class="- topic/p ">To leave <ph class="- topic/ph " translate="no" varid="Adam">ADAM</ph>, click the Exit button at the top of the screen. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Functional description</category><category class="- topic/category ">Functional description</category></metadata></prolog><conbody class="- topic/body  concept/conbody "><section id="GUID-D141A350-C1AB-428E-9B67-B31379FD794F" class="- topic/section "><title class="- topic/title ">Example Exit screen</title><fig id="GUID-69E95D42-8C36-4C43-A4F3-C0DE22068BEF" class="- topic/fig "><image href="GUID-F04BB77D-A395-44F2-A91F-1F31591C8E36-low.png" placement="inline" class="- topic/image " otherprops="GUID-F04BB77D-A395-44F2-A91F-1F31591C8E36-low.png"/></fig></section><section id="M148684-B20" class="- topic/section "><title class="- topic/title ">Description</title><table id="GUID-84DA9D64-76D7-4DCF-AA25-79A11F81E199" class="- topic/table "><tgroup cols="2" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="30*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="70*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Option 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Description 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Exit with save 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Use this option to exit <ph varid="Adam" translate="no" class="- topic/ph ">ADAM</ph> and save the service visit data. All mandatory fields need to be filled in. 
</p><p class="- topic/p ">If you did not cover all the mandatory items (problems, issues, maintenance), then they will be prompted in this window. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Visit duration
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Before the Exit with save is possible, a Visit duration must be entered. Use the - and + buttons for the Hours and Minutes to indicate the duration of the visit.
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Create backup
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">When using <ph varid="Adam" translate="no" class="- topic/ph ">ADAM</ph> on laptop, there is a possibility to automatically create a system backup at the end of the visit. This backup will be stored in the <ph translate="no" class="- topic/ph ">PRISMAservice</ph> archive. However, it is possible to skip the backup with the Skip button. 
</p><fig id="GUID-AF662EEB-CB6C-41BE-A1AE-4D44AED3B663" class="- topic/fig "><image href="GUID-1B4883BC-9132-43FB-83DC-DB545073161F-low.png" placement="inline" class="- topic/image " otherprops="GUID-1B4883BC-9132-43FB-83DC-DB545073161F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Exit without save 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Use this option to exit <ph varid="Adam" translate="no" class="- topic/ph ">ADAM</ph> without saving the service visit data. All data which was entered will be lost. 
</p></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">cancel 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Use this option to cancel the exit and return to <ph varid="Adam" translate="no" class="- topic/ph ">ADAM</ph>. 
</p></entry></row></tbody></tgroup></table></section></conbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-000233.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Exit ADAM</linktext></link></linkpool></related-links>
