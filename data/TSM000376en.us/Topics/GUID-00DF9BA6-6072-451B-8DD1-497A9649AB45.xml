<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-00DF9BA6-6072-451B-8DD1-497A9649AB45" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-00DF9BA6-6072-451B-8DD1-497A9649AB45" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to adjust the distance (X direction) and height (Z direction) of the pincure and FLXfinish<sup class="+ topic/ph hi-d/sup ">+</sup> mirrors</title><abstract class="- topic/abstract " id="GUID-173AF84C-D126-4DD5-8ABA-ADD08113B9D4"><p class="- topic/p ">With this adjustment you can check and adjust the distance (X direction) and height (Z direction) of the pincure and FLXfinish<sup class="+ topic/ph hi-d/sup ">+</sup> mirrors. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Adjustment</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A392D23B9FA5434A8095E72A33F001E1" class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Flat nose pliers 
</p></li><li class="- topic/li "><p class="- topic/p ">2 x distance plates (2.7 and 3.0 mm) 
</p></li><li class="- topic/li "><p class="- topic/p ">1 x adjustment tool 
</p><fig id="GUID-A47BD57A-9EA7-4A30-A1CC-65A9B0CD2D9F" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3FA562DC-160E-403B-BAD2-0699ABA451B9-low.jpg" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3FA562DC-160E-403B-BAD2-0699ABA451B9-low.jpg"/></fig><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><prereq id="GUID-CD2EB63C-1892-4796-9F68-A5F36E6E256B" class="- topic/section task/prereq "/><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-C31565D1-28EB-425F-B238-D09C15FE4641" class="- topic/fig "><image href="GUID-E0F050C4-119F-45E0-B098-54F61D902001-low.jpg" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E0F050C4-119F-45E0-B098-54F61D902001-low.jpg"/></fig></section><section id="GUID-78B2BE24-2ED4-4C3A-896F-B833FCEFD5E6" class="- topic/section "><title class="- topic/title ">How to adjust</title><table pgwide="1" id="TABLE_B0B9EAFB44A1495897BD13F6422F5B24" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Make sure the printheads are in the printhead carriage. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Activate SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Activate SDS test 03-6-021: 
<xref keyref="SDS03-6-021" class="- topic/xref " href="GUID-18276791-F608-4B99-BBEF-C347C2C6250D.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 03-6-021 Check carriage height positions [Special Tests]?>03-6-021 Check carriage height positions [Special Tests]</xref> 
</p><p class="- topic/p ">Use the "Continue" button to set the "Carriage height position" to the value "<b class="+ topic/ph hi-d/b ">1</b>". 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Defined height of the printhead carriage 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Activate Cold SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open/Remove the Media Output lower cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the service jumper. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the print carriage in the middle of the platen (print surface). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table><table pgwide="1" id="GUID-A0CC6BA5-A7D4-4C23-B521-2C49AF2D4C4B" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the distance plate of 2.7 mm under the mirror box for FLXfinish<sup class="+ topic/ph hi-d/sup ">+</sup>. 
</p><p class="- topic/p ">Adjustment of the mirror boxes in Z direction. 
</p><fig id="GUID-3D2B37AB-9E5D-4F30-85DB-C814585990CC" class="- topic/fig "><title class="- topic/title "/><image href="GUID-289B53F7-FFFE-4A0E-8E25-9C4F40182470-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-289B53F7-FFFE-4A0E-8E25-9C4F40182470-low.png"/></fig></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2762CD93-E47C-4F1A-830B-8C30243CB3C1" class="- topic/fig "><title class="- topic/title "/><image href="GUID-A1D974B3-E7BB-4809-8DC0-CF65C2E74BB9-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-A1D974B3-E7BB-4809-8DC0-CF65C2E74BB9-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the distance plate of 3 mm under the bend assembly part of the pin-cure mirror. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5CCC9151-5591-4FFA-BA7E-33DBBD2E95D0" class="- topic/fig "><title class="- topic/title "/><image href="GUID-520E31F7-B5BE-4CD3-9CD8-AC47E2C4E780-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-520E31F7-B5BE-4CD3-9CD8-AC47E2C4E780-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the adjustment tool on the platen. 
</p><p class="- topic/p ">Adjustment of the mirror boxes in X direction. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-DD789581-5478-475C-9FB4-C47A86003F10" class="- topic/fig "><title class="- topic/title "/><image href="GUID-1A2BA6BC-C724-43A1-9E11-95A13243D9B7-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-1A2BA6BC-C724-43A1-9E11-95A13243D9B7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide the tool (as indicated) against the printhead carriage. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2C3B22BF-ADDE-42E0-9948-333C403A2077" class="- topic/fig "><title class="- topic/title "/><image href="GUID-024D1D88-3195-43AA-930A-13CC55E89F37-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-024D1D88-3195-43AA-930A-13CC55E89F37-low.png"/></fig><fig id="GUID-781FC53C-3832-495B-A90A-43097445FAF2" class="- topic/fig "><title class="- topic/title "/><image href="GUID-ECC8A426-92D1-4335-85C8-345007B12ADC-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-ECC8A426-92D1-4335-85C8-345007B12ADC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Push the mirror box against the adjustment tool. and downwards on the distance plate. 
</p><p class="- topic/p "> Lock the mirror boxes at the left and right hand side (4 bolts). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Check</b>: the adjustment in Z and X direction of the mirror boxes. The mirror boxes must touch the tools. 
</p><p class="- topic/p ">If not correct: do the adjustments starting at step 4 again. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the tools (3x) from the platen. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the clip at the left and right hand side on the mirror box and carriage assembly. 
</p><note type="important" id="GUID-4E1CA3D4-7712-42D4-8D32-4733E8F6BF6B" class="- topic/note "><p class="- topic/p ">The clip must lock in the slot of the frame. 
</p></note><p class="- topic/p ">Aim: Improve connection between mirrors boxes and printhead carriage. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5444B28D-DC15-43DE-ABD1-82E453F1FA08" class="- topic/fig "><title class="- topic/title "/><image href="GUID-B9ECCD9F-2E84-4AC3-9462-CDB20166BAC0-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B9ECCD9F-2E84-4AC3-9462-CDB20166BAC0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the plate shielding: 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Install the plate shielding. 
</p></li><li class="- topic/li "><p class="- topic/p ">Slide the shield in position. 
</p></li><li class="- topic/li "><p class="- topic/p ">Lock the shield with 4 screws. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-76D8A37B-5460-424E-A790-FB361766CF51" class="- topic/fig "><title class="- topic/title "/><image href="GUID-99273234-59D0-452B-8886-1FD5B8DC711C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-99273234-59D0-452B-8886-1FD5B8DC711C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the printhead carriage carefully to the left and right hand side and check that the carriages does not touch. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-2FE45200-1552-4F8E-8F5F-4C6DECC21084" class="- topic/section "><title class="- topic/title ">Final settings and adjustments</title><table pgwide="1" id="GUID-8AF8F94C-9DAD-4809-8996-C4BDEFF30803" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service Jumper, exit SDS and pres "Restart" on the operator panel 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Enter SDS 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Enable the FLXfinish<sup class="+ topic/ph hi-d/sup ">+</sup> option in SDS, 
</p><p class="- topic/p ">Do 
<xref keyref="SDS01-1-019" class="- topic/xref " href="GUID-B8515004-79C9-4D7A-9C81-5A3DEDADFD4B.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 01-1-019 FLXfinish+ mirror hardware installed [Parameters] (From R4.0)?>01-1-019 FLXfinish+ mirror hardware installed [Parameters] (From R4.0)</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Colorado 1650 from rel 2.5 
</p><p class="- topic/p ">Colorado 1630 from rel 3.1 
</p><p class="- topic/p ">Colorado M-series from rel 4.0 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 01 How to adjust the distance between the curing carriage and the printhead carriage 
</p><p class="- topic/p ">Do 
<xref keyref="01ADJU007" class="- topic/xref " href="GUID-E30D0D63-1649-498E-8E93-E4D51B79CDB8.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 01 How to adjust the distance between the curing carriage and the...?>01 How to adjust the distance between the curing carriage and the printhead carriage</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 01 How to adjust the alignment of the mirrors of the curing carriage and printhead carriage (used for matte print mode) 
</p><p class="- topic/p ">Do 
<xref keyref="01ADJU005" class="- topic/xref " href="GUID-BFCE5418-CBD6-4B74-8C3D-4193689786ED.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 01 How to adjust the alignment of the mirrors of the curing...?>01 How to adjust the alignment of the mirrors of the curing carriage and printhead carriage (used for matte print mode)</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Verify the FLXfinish<sup class="+ topic/ph hi-d/sup ">+</sup> mirror box position. 
</p><p class="- topic/p ">Do 
<xref keyref="01ADJU_FLEX_mirror" class="- topic/xref " href="GUID-40F8CF0F-FFAE-4714-B982-3D232C595AD3.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 01 How to verify the correct position of the FLXfinish+ mirror?>01 How to verify the correct position of the FLXfinish+ mirror</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Print a demo print and verify if the gloss squares are visible. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-1F897B6A-3B52-4EA1-AC18-9626A9B429D4.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Adjustment</linktext></link></linkpool></related-links>
