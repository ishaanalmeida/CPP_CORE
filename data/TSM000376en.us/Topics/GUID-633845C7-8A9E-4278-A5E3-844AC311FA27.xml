<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-633845C7-8A9E-4278-A5E3-844AC311FA27" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-633845C7-8A9E-4278-A5E3-844AC311FA27" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to remove the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Curing carriage motor encoder</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 01B2 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">CUR_CAR_MO_ENC</compsignal></comp></title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_CA72A11EC2AC4C48863612B5463B3EEE" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-82E389A6-7AFD-4350-950D-C361ECA740EE" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_F4740272E97F4AED97F40A4EE3A0F0DF" class="- topic/ul "><li id="LI_AF9665A95E074ECF894200B5B110D100" class="- topic/li "><p class="- topic/p ">Small screwdriver. 
</p></li><li id="LI_7BAABCFF27844982B7C1C326A26907F4" class="- topic/li "><p class="- topic/p ">A 
<b class="+ topic/ph hi-d/b ">new</b> encoder. 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves 
</p></li></ul></section><section id="SECTION_97C55A1D60E64D8DA812336D4E9A9A56" class="- topic/section "><title class="- topic/title "/><note id="GUID-A459706A-9140-4CD2-AA83-0706936740D0" class="- topic/note "><p class="- topic/p ">The encoder is broken after the removal from the motor. You must have a replacement. 
</p><p class="- topic/p ">Do not remove the base plate of the encoder. The base plate is positioned during production and should not be loosened. 
</p></note></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-BEF72DFE-9B24-4A9C-8E9D-2D9D000D1B09" class="- topic/fig "><desc class="- topic/desc "><p class="- topic/p ">The encoder is mounted on top of the motor. 
</p></desc><image href="GUID-6E97DC92-468F-4AB4-93E9-B8F95DD94E7E-low.png" placement="inline" class="- topic/image " otherprops="GUID-6E97DC92-468F-4AB4-93E9-B8F95DD94E7E-low.png"/></fig><fig id="FIG_6BEA0AA2C5344ADC8CBE547203C5ED23" class="- topic/fig "><desc class="- topic/desc "><p class="- topic/p ">The 2 parts of the encoder (base plate + housing). 
</p></desc><image href="GUID-B54E876D-E8F2-4C4D-9042-4B65BAAAA4F2-low.png" id="IMAGE_30E05D8D04554CDDAFFF24513DF04220" placement="inline" class="- topic/image " otherprops="GUID-B54E876D-E8F2-4C4D-9042-4B65BAAAA4F2-low.png"/></fig></section><section id="SECTION_461AEF503CF24714AE990D49064F26B7" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_672AA120F5B34936AE581E82FFA7D259" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Disconnect the connector of the encoder. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-DA5AAB4C-E2F4-45F1-B2AC-D0DDAE9327AE" class="- topic/fig "><image href="GUID-5C653FA3-483E-4834-9B53-A1C706C55E4A-low.png" placement="inline" class="- topic/image " otherprops="GUID-5C653FA3-483E-4834-9B53-A1C706C55E4A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The sensor is mounted using a bayonet locking. 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Rotate the top part of the sensor counter clockwise for approximately 3 mm to unlock it. 
</p></li><li class="- topic/li "><p class="- topic/p ">Lift the top part of the sensor OFF. 
</p><p class="- topic/p ">The base plate of the encoder must remain on the motor. 
</p></li></ol><note id="GUID-373D6135-DA01-459A-90AA-8A9ED19B816E" class="- topic/note "><p class="- topic/p ">The sensor is now broken. You must replace it with a new sensor. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-32EEB06D-D0DB-448E-A4BA-0CE631FDB5EC" class="- topic/fig "><image href="GUID-B353AF76-4AC8-4D67-A614-8B9B08FF783F-low.png" placement="inline" class="- topic/image " otherprops="GUID-B353AF76-4AC8-4D67-A614-8B9B08FF783F-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p><p class="- topic/p ">You only install the top part of the sensor, since the bottom part stays on the axis. 
</p><p class="- topic/p ">Make sure you keep the sensor straight when installing. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-22D79A6A-2191-46FA-BE14-24F47FE4288E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>