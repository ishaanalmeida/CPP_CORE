<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-EF7DB5A5-C507-4DD0-98A1-F6717F015D84" version="1" lang="en-US"?><concept xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-EF7DB5A5-C507-4DD0-98A1-F6717F015D84" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic concept)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c concept oceConcept-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic concept/concept "><title class="- topic/title ">What is new in software version R4.0.0.0</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Frequently Asked Question</category></metadata></prolog><conbody class="- topic/body  concept/conbody "><section id="M155103-B83" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Question</ph></title><p class="- topic/p ">What is new in software version R4.0.0.0? 
</p></section><section id="M155103-B84" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Answer</ph></title><table id="M155103-TB85" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="stage" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="20*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="20*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="60*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" namest="col1" nameend="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Classification 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Description 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Operator panel</b> 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Additional version information on WebUI and UI 
</b> 
</p><p class="- topic/p ">In the WebUI, the following additional info is shown under Support &gt; About &gt; System information: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Serial number 
</p></li><li class="- topic/li "><p class="- topic/p ">Version of PRISMAsync software 
</p></li><li class="- topic/li "><p class="- topic/p "> Version of operating system 
</p></li></ul><p class="- topic/p ">On the UI panel, the following additional info is shown under System &gt; About: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> Version of the controller 
</p></li></ul></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Explicit confirmation of usage of expired ink</b> 
</p><p class="- topic/p "> When expired ink is detected, a warning is raised: “Call service. Print head warranty is voided when you use expired ink”. 
</p><p class="- topic/p ">The customer is able to continue, under the condition that the customer explicitly confirms accepting the risk of using expired ink. 
</p><p class="- topic/p ">This all is shown in an extra user interaction dialog on the UI: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Every day if ink is about to expire (within 28 days) or is expired, the customer is asked to confirm he wants to continue printing 
</p></li><li class="- topic/li "><p class="- topic/p ">The Ink dialog contains new instructions to make clear that printhead warranty is voided if expired ink is used. 
</p></li></ul></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Support of new UI3 panel</b> 
</p><note type="note" id="GUID-F7739290-563C-4392-9561-2DFD61BE71A1" class="- topic/note "><p class="- topic/p "> Due to the new display controller, the horizontal startup bar cannot be shown anymore. Instead, the Windows startup icon (rolling circle with dots) is shown. 
</p></note></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Trigger service technician to open ink tube valves after PH replacement. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">ADAM</b> 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Entered info in ADAM is preserved after restart 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b "> Diagnostics</b> 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">TeamViewer 14</b> 
</p><p class="- topic/p ">TeamViewer 14 has been integrated. Note that this also requires TeamViewer 14 in the back office. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Enter Service mode during printing</b> 
</p><p class="- topic/p ">Note that it is not allowed to use "System Service Mode" (SDS) during printing. 
</p><p class="- topic/p ">When entering "System Service Mode" while the machine is printing, it is not possible to leave Service mode until all prints are ready. 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Allow restart after an MRE during Service mode 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b ">External interfaces</b> 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">PRISMAsync Remote Control App</b> 
</p><p class="- topic/p ">The PRISMAsync Remote Control app now works again with the new cloud infrastructure. Some issues have been fixed/added: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Alert when a media request is shown in between jobs (not in case of roll empty, because this already caused an alert). 
</p></li><li class="- topic/li "><p class="- topic/p ">Fixed the problem that the app reports a queue empty alert at every maintenance action. 
</p></li></ul></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "/><entry colname="col2" align="left" valign="top" class="- topic/entry "/><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Optional licenses</b> 
</p><p class="- topic/p ">The following options are now licensed: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Second roll in the drawer 
</p></li><li class="- topic/li "><p class="- topic/p ">Matte print modes 
</p></li><li class="- topic/li "><p class="- topic/p ">Print inside and double sided 
</p></li></ul></entry></row></tbody></tgroup></table></section></conbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-909051FD-B273-46E2-92C5-EE945BD06E0E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>R4.0.0.0</linktext></link></linkpool></related-links>
