<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-FF412B50-9595-4D6D-95B7-9B8DAC9763DF" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-FF412B50-9595-4D6D-95B7-9B8DAC9763DF" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title translate="no" class="- topic/title ">24-1-001 Type of air filtering [Parameters]</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">SDS</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-2BD8C3DB-27B0-44E5-B999-CF486EF1CE0D" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">SDS</ph></title><p class="- topic/p "> 
<object id="GUID-DF429606-9F9D-4399-BCE9-A10A27FF43C7" class="- topic/object "><desc class="- topic/desc "><p class="- topic/p ">Type of air filtering </p></desc><param name="testid" value="241001" class="- topic/param "/><param name="target" value="NIL" class="- topic/param "/><param name="axmodule" value="None" class="- topic/param "/></object> 
</p></section><section id="GUID-AA56EB35-EF7A-4140-ABAF-4AB5E5ECD418" class="- topic/section "><title class="- topic/title ">Component</title><p class="- topic/p ">1 = Check of <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Frame filter 1 present sensor</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 24B1 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">FRA_FILTER1_PRESENT_SE</compsignal></comp>, <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Frame filter 2 present sensor</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 24B2 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">FRA_FILTER2_PRESENT_SE</compsignal></comp> and <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">Frame filter fan</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 24M1 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">FRA_FILTER_FAN</compsignal></comp>. 
</p><p class="- topic/p ">0 = no check, due to external exhaust. 
</p><note id="GUID-9AF8392E-0BAE-4AF8-B9EC-70F119F9DD17" class="- topic/note "><p class="- topic/p "> Even if the air filtering is set to 'external', the sensors are being checked. If sensors are active while no internal filters are configures, you'll get a message on the screen to remove the filters or change the configuration. 
</p></note><note id="GUID-1FE70A11-3F4D-4887-9069-31D53E87E8FE" class="- topic/note "><p class="- topic/p ">If the type of air filtering is changed to external: disconnect the internal fan to avoid the system generating error 24901. 
</p></note></section><section id="GUID-1156E15C-FA11-42F7-80CE-F9823F371FA9" class="- topic/section "><title class="- topic/title ">Function</title><p class="- topic/p "> Set the type of air filtering. internal with fan and 2 filters or external. 
</p><note id="GUID-2287E327-A216-4A07-A77E-E8954D475E30" class="- topic/note "><p class="- topic/p ">A reboot is needed after changing this value. 
</p></note></section><section id="GUID-92369981-F020-4E62-9707-58F93D054214" class="- topic/section "><title class="- topic/title ">Values</title><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Default value: 1 
</p></li><li class="- topic/li "><p class="- topic/p ">1 = Air filters and fan are checked 
</p></li><li class="- topic/li "><p class="- topic/p ">0 = External exhaust connected 
</p></li></ul></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-188232CF-B05D-40C0-9038-8926799D9672.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>SDS</linktext></link></linkpool></related-links>
