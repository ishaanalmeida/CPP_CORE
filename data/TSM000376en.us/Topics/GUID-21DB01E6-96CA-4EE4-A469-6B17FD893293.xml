<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-21DB01E6-96CA-4EE4-A469-6B17FD893293" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-21DB01E6-96CA-4EE4-A469-6B17FD893293" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to replace the mirror assembly of the curing carriage (with protection glass)</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-4A711738-96E0-45A9-B83B-6D90217E1943" class="- topic/section "><title class="- topic/title ">Introduction</title><p class="- topic/p ">This document describes the replacement of the mirror assembly of the curing unit as well as the adjustment description of the basic adjustment of the curing carriage. 
</p></section><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Make sure the printer is leveled correctly. 
</p><p class="- topic/p ">See 
<xref keyref="ENGADJU01" class="- topic/xref " href="GUID-2BFE3033-C726-47A1-9A09-044CAA7F04FE.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>00 How to level the printer</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Make sure the winder is adjusted correctly. 
</p><p class="- topic/p ">See 
<xref keyref="19ADJU002" class="- topic/xref " href="GUID-D7027CEA-D5AB-4EDB-A8A6-C62E98486F84.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>19 How to adjust the winder with respect to the printer</xref> 
</p></li><li class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-405B737B-0174-4E5B-8F9D-460B9EA7D70C" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_0492307DCD35442EAC71B8DA95C8A8E5" class="- topic/ul "><li id="LI_421ADE177A4748CB8EAE9311930065D8" class="- topic/li "><p class="- topic/p ">screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">screwdriver Torx T10
</p></li><li class="- topic/li "><p class="- topic/p ">2 x distance strip 12 mm (part of modification 02) 
</p></li><li class="- topic/li "><p class="- topic/p ">caliper / feeler gauges 
</p></li><li class="- topic/li "><p class="- topic/p ">a sheet of paper 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-E2FF997A-3D69-440D-8537-DC74947917A9" class="- topic/fig "><image href="GUID-D59924AF-0085-44A2-8837-D3D98CBA2E2C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D59924AF-0085-44A2-8837-D3D98CBA2E2C-low.png"/></fig></section><section id="GUID-1E55A782-2771-49C6-9B05-C95668ECAC16" class="- topic/section "><title class="- topic/title ">How to minimize the play between the curing guidance and the main frame</title><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" namest="col2" nameend="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws [A]. 
</p><fig id="GUID-5F734FFF-3EFE-48E2-AD53-DB955247BE6F" class="- topic/fig "><image href="GUID-CCB419A2-83DE-4A00-9AC4-15ED4E63BE15-low.png" placement="inline" class="- topic/image " otherprops="GUID-CCB419A2-83DE-4A00-9AC4-15ED4E63BE15-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" namest="col2" nameend="col3" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Push the complete curing guidance to the rear side of the printer (as indicated with the arrow in the drawing). 
</p></li><li class="- topic/li "><p class="- topic/p ">Lock the 2 screws [A]. 
</p></li></ol><fig id="GUID-6DA9FF1A-94B1-4CF2-8F99-1581DBE7B7F9" class="- topic/fig "><image href="GUID-D9700989-5028-4AF1-950A-648069AF2AE5-low.png" placement="inline" class="- topic/image " otherprops="GUID-D9700989-5028-4AF1-950A-648069AF2AE5-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="SECTION_427616E2BC854A41A6E33F1B8684D8A6" class="- topic/section "><title class="- topic/title ">How to remove the (old) mirror assembly and install the new mirror assembly (with protection glass)</title><table pgwide="1" id="TABLE_0BF2156EA25344A5ABD0556D855F2FC9" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the Printhead carriage to the left hand side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EFF7AA67-52E2-4ED9-8BD3-AB79558E212A" class="- topic/fig "><image href="GUID-0BA7038C-9FF2-4F26-A100-3092B69731A6-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0BA7038C-9FF2-4F26-A100-3092B69731A6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Put a sheet of paper on the platen. 
</p></li><li class="- topic/li "><p class="- topic/p ">Slide the curing carriage to the middle of the platen above the sheet. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7A988D65-1946-44CF-865F-5021890EA06E" class="- topic/fig "><image href="GUID-6F5469AC-2256-41D6-854D-B2825411FFC4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6F5469AC-2256-41D6-854D-B2825411FFC4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the cables from the 4 cable guides. 
</p></li><li class="- topic/li "><p class="- topic/p "> Disconnect the connector of the sensor. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F4452266-9AAF-432C-BCD2-3BE76332CB35" class="- topic/fig "><image href="GUID-B0DA2529-3E22-4134-9803-A1038E93C185-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B0DA2529-3E22-4134-9803-A1038E93C185-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 4 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-25FB6FA6-77FF-468B-9D22-46A41B5D9B4E" class="- topic/fig "><image href="GUID-5567A414-37FE-4DBE-8FB4-642C14953300-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5567A414-37FE-4DBE-8FB4-642C14953300-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the mirror assembly from the curing carriage. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-EC18E9E3-AEBF-4735-A0A9-06008A8B55EC" class="- topic/fig "><image href="GUID-6E24305C-684B-4DBD-9D81-FD8CACF62E28-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6E24305C-684B-4DBD-9D81-FD8CACF62E28-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 2 screws of the Post and Pin curing lamp. 
</p><p class="- topic/p ">The curing lamp is now free from the mirror. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0BEF0856-906F-4759-AA9C-FE0837639536" class="- topic/fig "><image href="GUID-0ED797FD-CBB7-426A-B810-EA7CE51D8A2A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0ED797FD-CBB7-426A-B810-EA7CE51D8A2A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws of the crash sensor and the sensor bracket. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-5B0985E9-6628-461D-BF1D-3F2331FF376C" class="- topic/fig "><image href="GUID-25F1BCDF-D342-4850-A968-30389240690F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-25F1BCDF-D342-4850-A968-30389240690F-low.png"/></fig><fig id="GUID-210AA0F6-B9F4-41B0-8761-8C3BFB747A1F" class="- topic/fig "><image href="GUID-B1B927F0-8C0D-4888-B5FE-E74E2727F228-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B1B927F0-8C0D-4888-B5FE-E74E2727F228-low.png"/></fig><fig id="GUID-AEF056AB-AE71-45CB-A800-D7337D466372" class="- topic/fig "><image href="GUID-DCA1474E-C74F-43C6-B40E-647397866552-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-DCA1474E-C74F-43C6-B40E-647397866552-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove top screw of the sensor bracket. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-560D4156-0DB7-4112-880A-BDB059A63CCE" class="- topic/fig "><image href="GUID-EC647B03-CE37-4C96-ABBB-B40A4A443440-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EC647B03-CE37-4C96-ABBB-B40A4A443440-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove 2 lower screws of the sensor bracket. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-557129A0-5BFE-4BD6-863F-474EA2BF6B14" class="- topic/fig "><image href="GUID-57A1BE6E-5C9F-4D9B-9C75-802D85969D04-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-57A1BE6E-5C9F-4D9B-9C75-802D85969D04-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the bracket form the mirror. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7BCE2818-042A-42BD-A705-8EABFF93E622" class="- topic/fig "><image href="GUID-D41064D9-B6A3-4582-BC18-58FEB529BD1F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D41064D9-B6A3-4582-BC18-58FEB529BD1F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the old mirror assembly. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-B96EA771-CEB9-487A-BF96-75EFA1FA1597" class="- topic/fig "><image href="GUID-0C1A7531-67A5-4BBE-A0CD-2D6331AEFD77-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0C1A7531-67A5-4BBE-A0CD-2D6331AEFD77-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the mirror (with the protection glas) in reverse order. 
</p><note id="GUID-638408BE-D497-4E4A-A6EE-24EFA5C57DAC" class="- topic/note "><p class="- topic/p ">Do not install the mirror assembly on the curing unit yet (Not needed for the next adjustment). 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-B25C175C-F757-4B7C-B2D0-C6165F5B9E9A" class="- topic/section "><title class="- topic/title ">How to minimize the play between the plate frame assembly and the curing guidance frame</title><table pgwide="1" id="GUID-70B6BAD9-267B-407C-B598-C7C8687E9087" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the cover of the curing unit. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" namest="col2" nameend="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Position the curing carriage in the middle of the platen (no cover / no curing mirror). 
</p><fig id="GUID-DCCC4D0B-F09E-4A62-BA24-9D5FB2080E37" class="- topic/fig "><image href="GUID-346AE0B9-0842-45DC-9610-4239F6CDEB70-low.png" placement="inline" class="- topic/image " otherprops="GUID-346AE0B9-0842-45DC-9610-4239F6CDEB70-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" namest="col2" nameend="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 2 screws [A] and 4 screws [B] at the left and right hand side of the curing carriage. 
</p><note id="GUID-1062FAAA-5C7F-4C09-AF6A-1E19C8CDF8BA" class="- topic/note "><p class="- topic/p ">The screws [B] are sealed with red paint. Although it is against the service policy, in this particular case, it is allowed to unscrew the screws. 
</p></note><fig id="GUID-81AF29AD-D2C4-4A59-BBF2-0FEE05F4DE9D" class="- topic/fig "><image href="GUID-FD189365-C393-44CD-A5D1-28CA44299B29-low.png" placement="inline" class="- topic/image " otherprops="GUID-FD189365-C393-44CD-A5D1-28CA44299B29-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" namest="col2" nameend="col3" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Place the distance strip on the platen at the left and right hand side of the frame [F] of the curing unit. 
</p></li><li class="- topic/li "><p class="- topic/p ">Make sure the frame [F] touches the distance strip at position 1, 2, 3,and 4. 
</p><p class="- topic/p ">The distance = 12 +/- 0.5 mm. 
</p></li></ol><fig id="GUID-E3863CC0-E9B4-4755-84BD-A6632C3AA244" class="- topic/fig "><image href="GUID-FD32C9F6-2436-4A7B-BC37-A9B470B4725A-low.png" placement="inline" class="- topic/image " otherprops="GUID-FD32C9F6-2436-4A7B-BC37-A9B470B4725A-low.png"/></fig><fig id="GUID-2280152C-EB46-4298-A98E-0E71DDE0D209" class="- topic/fig "><image href="GUID-6CA6FF2E-922F-45BB-85B1-C90866BCFA1F-low.png" placement="inline" class="- topic/image " otherprops="GUID-6CA6FF2E-922F-45BB-85B1-C90866BCFA1F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" namest="col2" nameend="col3" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Push the curing carriage to the rear side of the printer. 
</p><note id="GUID-E0910D61-A298-40EC-B5C4-7C1F9B63BDE7" class="- topic/note "><p class="- topic/p ">Make sure the plate touches the distance tool by it's own weight. 
</p></note></li><li class="- topic/li "><p class="- topic/p ">Tighten the 2 screws [A] at the left and right hand side. 
</p></li><li class="- topic/li "><p class="- topic/p ">Tighten the 4 screws [B] at the left and right hand side. 
</p></li></ol><fig id="GUID-9027885C-80FE-4681-A83B-20DD0D929EFC" class="- topic/fig "><image href="GUID-E5CA30C4-2AB0-4C05-A214-E2607B15A2BB-low.png" placement="inline" class="- topic/image " otherprops="GUID-E5CA30C4-2AB0-4C05-A214-E2607B15A2BB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the cover and the mirror assembly on the curing unit. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">01 How to adjust the distance between the curing carriage and the printhead carriage</title></section><section id="GUID-C4CC5A0E-358E-4191-A77A-D419335CB771" class="- topic/section "><title class="- topic/title ">How to check</title><table pgwide="1" id="GUID-629F58CA-E2C0-44BB-9002-79969014A363" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Do SDS test 
<xref keyref="SDS01-6-001" class="- topic/xref " href="GUID-D8E038CE-9D98-45E8-B362-A1C9227FCAE7.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text xref?>01-6-001 Align the mirrors of the printhead and curing carriage [Special Tests]</xref> 
</p><p class="- topic/p ">Position the curing carriage (with the mirror) in the middle of the platen (print surface). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D4DAFD04-6758-470D-BDC0-90A82C3F3DB3" class="- topic/fig "><image href="GUID-43DAAA38-FF82-4C11-AC24-CE2143D285B6-low.png" placement="inline" class="- topic/image " otherprops="GUID-43DAAA38-FF82-4C11-AC24-CE2143D285B6-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Align the printhead carriage with the curing carriage: specification 0 +/- 1 mm. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-6F8EF468-674E-43FC-8FA3-00C64FD114C9" class="- topic/fig "><image href="GUID-BCA00EFD-ECF9-4EEF-920A-19A1E20457B1-low.png" placement="inline" class="- topic/image " otherprops="GUID-BCA00EFD-ECF9-4EEF-920A-19A1E20457B1-low.png"/></fig><fig id="GUID-3C770FFE-5BB0-485A-AAE5-F2B67B06A20E" class="- topic/fig "><image href="GUID-0463D05B-8659-46AD-80AB-2FFA232D8A3F-low.png" placement="inline" class="- topic/image " otherprops="GUID-0463D05B-8659-46AD-80AB-2FFA232D8A3F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Check</b>: Specification distance between the curing carriage glass plate and printhead carriage at a height of 60 +/- 5 mm: 5 +1/-0 mm. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-8F2BFA38-3419-4E50-8BE6-53AAB5858C81" class="- topic/fig "><image href="GUID-F0240404-AD43-4650-8D67-9AA3FC4AA026-low.png" placement="inline" class="- topic/image " otherprops="GUID-F0240404-AD43-4650-8D67-9AA3FC4AA026-low.png"/></fig><fig id="GUID-F62A53A6-DD5D-4123-86F7-4D0B1F8A6A45" class="- topic/fig "><image href="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png" placement="inline" class="- topic/image " otherprops="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-13DAAEE5-97C7-4E27-8719-5C53E0F22566" class="- topic/section "><title class="- topic/title ">How to adjust</title><table pgwide="1" id="GUID-037C22CA-C2AC-4CF4-AAD0-27B22786DC88" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen the 4 screws [A]. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1E465B8F-1787-40DC-9566-462ED3CC2341" class="- topic/fig "><image href="GUID-7D3D4C8A-2ED5-4458-B578-D9B8AFA5BF57-low.png" placement="inline" class="- topic/image " otherprops="GUID-7D3D4C8A-2ED5-4458-B578-D9B8AFA5BF57-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Adjust the distance between the curing carriage glass plate and printhead carriage at a height of 60 +/- 5 mm to 5 +1/-0 mm. 
</p><note id="GUID-278650C7-E77E-4276-BC24-D2CA264EEB90" class="- topic/note "><p class="- topic/p ">If you cannot reach 5 mm then use the highest possible distance. 
</p><p class="- topic/p ">It may happen that the distance is less than 5 mm. If the distance is less than 2 mm it is recommended to maintain the old situation to avoid a mirror clash. 
</p></note></li><li class="- topic/li "><p class="- topic/p ">Lock the 4 screws [A]. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-3D6B3534-22AD-4A34-826E-E058547F350C" class="- topic/fig "><image href="GUID-F0240404-AD43-4650-8D67-9AA3FC4AA026-low.png" placement="inline" class="- topic/image " otherprops="GUID-F0240404-AD43-4650-8D67-9AA3FC4AA026-low.png"/></fig><fig id="GUID-56C22014-CBD7-44BF-B989-EC2E7CF960A4" class="- topic/fig "><image href="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png" placement="inline" class="- topic/image " otherprops="GUID-BEB50866-CD52-4467-8296-0CD3E51DA9D1-low.png"/></fig><fig id="GUID-B82B1F23-BCEA-480D-888C-E526AE28468B" class="- topic/fig "><image href="GUID-7D3D4C8A-2ED5-4458-B578-D9B8AFA5BF57-low.png" placement="inline" class="- topic/image " otherprops="GUID-7D3D4C8A-2ED5-4458-B578-D9B8AFA5BF57-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">After the adjustment always check if the mirrors do not touch: 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Move both carriages to the lefthand position and check. 
</p></li><li class="- topic/li "><p class="- topic/p ">Move both carriages to the right hand position and check.. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D2EDFDDE-0B31-4096-903E-FAD25C756227" class="- topic/fig "><image href="GUID-D9067578-EE0C-4121-ACF9-6C51652259DD-low.png" placement="inline" class="- topic/image " otherprops="GUID-D9067578-EE0C-4121-ACF9-6C51652259DD-low.png"/></fig><fig id="GUID-8FC2D866-82DE-4FA4-98F9-5299FB0E0CE8" class="- topic/fig "><image href="GUID-C40C24BF-7034-47ED-A851-CB2D5E44C269-low.png" placement="inline" class="- topic/image " otherprops="GUID-C40C24BF-7034-47ED-A851-CB2D5E44C269-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-73A86D74-9723-4E3B-87A0-D945F1EF1950" class="- topic/section "><title class="- topic/title "> How to adjust the alignment of the mirrors of the curing carriage and printhead carriage (used for matte print mode)</title><table pgwide="1" id="GUID-54E18838-226E-464D-A09F-B85D89330C2C" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Activate SDS test: 01-6-001 Adjust carriage pin-cure positions 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">The printhead carriage and the curing carriage will move to the home position. 
</p></li><li class="- topic/li "><p class="- topic/p ">The printhead carriage is moved to the middle position (of the platen) 
</p></li><li class="- topic/li "><p class="- topic/p ">The curing carriage is moved to the current offset value for<b class="+ topic/ph hi-d/b "> left</b> hand side pin cure mirror. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the top cover and align the printhead and/or curing carriage. 
</p><note id="GUID-9F260772-8A76-4D1A-AB0D-F9B99D55A9AE" class="- topic/note "><p class="- topic/p ">Both carriages are allowed to be moved. 
</p><p class="- topic/p ">The software will track the absolute encoder difference. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Confirm the alignment in the SDS test. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The curing carriage is moved to the current offset value for<b class="+ topic/ph hi-d/b "> right</b> hand side pin cure mirror. 
</p><p class="- topic/p "> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the top cover and align the printhead and/or curing carriage. 
</p><note id="GUID-F53A7CC8-166F-4439-9E77-CE2BBB88D5FA" class="- topic/note "><p class="- topic/p ">Both carriages are allowed to be moved. 
</p><p class="- topic/p ">The software will track the absolute encoder difference. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the top cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Confirm the alignment in the SDS test. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-22D79A6A-2191-46FA-BE14-24F47FE4288E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
