<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-0E83FD3C-C5B9-486D-A8BD-8C665D7C0387" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-0E83FD3C-C5B9-486D-A8BD-8C665D7C0387" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">16 How to remove the Media output knife unit (including CUTTER-SLIDER-UNIT and BELT)</title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_35207BEF3E4741349723CA41FBA916C3" class="- topic/li "><p class="- topic/p ">Open the top cover. 
</p><note type="important" id="GUID-7215619B-4D8E-42B1-B219-10C1EF6B5FB5" class="- topic/note "><p class="- topic/p ">Do not lean on the strip support. 
</p></note></li><li id="LI_DD2C82FE0AD74D388646BDB20675AE6A" class="- topic/li "><p class="- topic/p ">Do 
<xref keyref="24DISA034" class="- topic/xref " href="GUID-1D8187CA-1F3B-4EBF-9E0A-F130AF910D4A.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the knife compartment cover?>24 How to remove the knife compartment cover</xref> 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A32A562039FB485780CA65B069EE577C" class="- topic/ul "><li id="LI_1D9EE245DE6547E09D8CB22E45CFC7A0" class="- topic/li "><p class="- topic/p ">• Screwdriver. Tx6, Tx8, Tx10, Tx20, Tx25
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-DB340B14-87E5-4FDB-8108-245D16C84FF1" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-54BDEC12-F4B4-4B64-88DD-A510604C8E87" class="- topic/fig "><title class="- topic/title "/><image href="GUID-4F70E9EE-405D-4E5A-9833-7868E44CD6DB-low.png" placement="inline" class="- topic/image " otherprops="GUID-4F70E9EE-405D-4E5A-9833-7868E44CD6DB-low.png"/></fig></section><section id="SECTION_A6C9FA5271F340608CD9E1255A43AD88" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_536D3F7F2B904E1D946D85DF65CD3BED" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connector for the motor and sensor next to it.
</p><p class="- topic/p ">Remove the motor connector from the cutter unit.
</p><p class="- topic/p ">Release all cable holders for the 2 harnesses.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1526D658-5A47-4090-8E40-52B483876B17" class="- topic/fig "><title class="- topic/title "/><image href="GUID-88154834-2339-4A10-9AE3-904B075306EC-low.png" placement="inline" class="- topic/image " otherprops="GUID-88154834-2339-4A10-9AE3-904B075306EC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connector for the other sensor (UI side). Release the cable holder.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-9C2CD7D3-608E-4D6E-9E54-18238516342E" class="- topic/fig "><title class="- topic/title "/><image href="GUID-2C74EF9E-3BD1-4ACE-B45E-B675DF515CDA-low.png" placement="inline" class="- topic/image " otherprops="GUID-2C74EF9E-3BD1-4ACE-B45E-B675DF515CDA-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove cover on the output side (2 screws).
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D103F159-2062-4A95-8D23-89B5DF2CA56A" class="- topic/fig "><title class="- topic/title "/><image href="GUID-EB98961B-B2B5-4F1A-A509-BECB3D5A5C12-low.png" placement="inline" class="- topic/image " otherprops="GUID-EB98961B-B2B5-4F1A-A509-BECB3D5A5C12-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove guide plate next to the cutter unit (2 screws).
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-27082BDF-8E01-4D48-A016-B4104DE18BE9" class="- topic/fig "><title class="- topic/title "/><image href="GUID-2BBC043F-53BB-445E-A648-6081757ECCD7-low.png" placement="inline" class="- topic/image " otherprops="GUID-2BBC043F-53BB-445E-A648-6081757ECCD7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 5 screws (Torx 10) holding the unit to the print surface assy.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-BB1A8D6A-EF0C-44A7-9644-EE17122184E5" class="- topic/fig "><title class="- topic/title "/><image href="GUID-7012F8E0-B6D8-4408-BED4-8013B6FB49EC-low.png" placement="inline" class="- topic/image " otherprops="GUID-7012F8E0-B6D8-4408-BED4-8013B6FB49EC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the unit from the printer.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Release the spring tensioning the belt.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2986400E-BC08-4D19-BD26-FA030651391B" class="- topic/fig "><title class="- topic/title "/><image href="GUID-26E9E532-49CF-48AA-AAC7-05DF5C1E3703-low.png" placement="inline" class="- topic/image " otherprops="GUID-26E9E532-49CF-48AA-AAC7-05DF5C1E3703-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the motor (2 screws)
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D6AEDDD2-1130-4369-B6DE-1A32959C8BA5" class="- topic/fig "><title class="- topic/title "/><image href="GUID-587032EE-FBBA-46ED-8F80-09893EF815C7-low.png" placement="inline" class="- topic/image " otherprops="GUID-587032EE-FBBA-46ED-8F80-09893EF815C7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide out the 2 ends of the belt from the CUTTER-SLIDER-UNIT.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-957F9745-0DE7-4A57-8E33-2DEF10E1C69F" class="- topic/fig "><title class="- topic/title "/><image href="GUID-20DB4347-1B26-4678-842B-890AA50B09AB-low.png" placement="inline" class="- topic/image " otherprops="GUID-20DB4347-1B26-4678-842B-890AA50B09AB-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove antistatic brush and blocking crew.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E6A90778-0023-47D7-9BC9-962009A3A612" class="- topic/fig "><title class="- topic/title "/><image href="GUID-43FD9E44-FCF6-4D05-902C-CE79F2A24615-low.png" placement="inline" class="- topic/image " otherprops="GUID-43FD9E44-FCF6-4D05-902C-CE79F2A24615-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide out the CUTTER-SLIDER-UNIT.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-2142A7FF-5303-48FD-A720-357AF2179A5C" class="- topic/fig "><title class="- topic/title "/><image href="GUID-AD85C44F-C930-4A35-9381-0ABB706C2056-low.png" placement="inline" class="- topic/image " otherprops="GUID-AD85C44F-C930-4A35-9381-0ABB706C2056-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_AC5F4D5915E341089E1B9C89B4C94B7D" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS, and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-E4FDA785-F361-44FA-9544-60C955D47C49.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>