<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-EB95C544-F807-4FBD-93DF-1BAA135C7154" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-EB95C544-F807-4FBD-93DF-1BAA135C7154" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">15 How to remove the Beam MPU</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the Beam MPU. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li id="LI_B00BCB492EC546EE98CD25996779F334" class="- topic/li "><p class="- topic/p ">Open the top cover 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A32A562039FB485780CA65B069EE577C" class="- topic/ul "><li id="LI_1D9EE245DE6547E09D8CB22E45CFC7A0" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10 
</p></li><li id="LI_55373F9DAE644089ABBC568E03CDE4FC" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Protective gloves : 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-1C1D16A3-2A1D-4D37-ABF1-8765295D454D" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-9848D934-FF3E-4AC9-BA07-69028FA44036" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title "><ph class="- topic/ph ">Attention:</ph></title><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">The buffer plate can get hot. 
</p></li><li class="- topic/li "><p class="- topic/p ">Beware of sharp edges. 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-D2D6FA5E-572C-451F-B075-CDB1559F9F28" class="- topic/fig "><image href="GUID-BCCAAAC9-D9E6-4FE1-9B7D-132EA5BBD8DE-low.png" placement="inline" class="- topic/image " otherprops="GUID-BCCAAAC9-D9E6-4FE1-9B7D-132EA5BBD8DE-low.png"/></fig></section><section id="SECTION_85850035E8CE4CC39A0C4C889CC723AA" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_CA7C513836B040B586702F43AB214201" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the upper cover. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-77909086-0EC4-4B7E-B47B-3EFD72716A44" class="- topic/fig "><image href="GUID-67A52571-472E-4E7F-BD7B-0A50D16BC8DC-low.png" placement="inline" class="- topic/image " otherprops="GUID-67A52571-472E-4E7F-BD7B-0A50D16BC8DC-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the strip above the buffer plate. 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Remove 2 screws at the right hand side 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove 2 screws at the left hand side 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4F39BC37-18A2-42AE-902F-CE5B48343349" class="- topic/fig "><image href="GUID-2753F12D-34AD-403A-A68B-EEFC73242F38-low.png" placement="inline" class="- topic/image " otherprops="GUID-2753F12D-34AD-403A-A68B-EEFC73242F38-low.png"/></fig><fig id="GUID-A35ED03A-D5BB-49E5-8863-5D38F22402D7" class="- topic/fig "><image href="GUID-4C8D8A8C-3773-4DF6-8B95-0DC004EF8BC1-low.png" placement="inline" class="- topic/image " otherprops="GUID-4C8D8A8C-3773-4DF6-8B95-0DC004EF8BC1-low.png"/></fig><fig id="GUID-A0E82E0E-1668-4836-9439-3F84D568A0A4" class="- topic/fig "><image href="GUID-8F6DC336-E58B-4917-AE7F-791CEC4E468C-low.png" placement="inline" class="- topic/image " otherprops="GUID-8F6DC336-E58B-4917-AE7F-791CEC4E468C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the strip below the buffer plate: 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Remove 1 screw at the right hand side 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove 1 screw at the left hand side 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A9BAFC58-1916-4C13-8318-C7532EA2CC51" class="- topic/fig "><image href="GUID-13AF5620-AA50-475D-8AF0-B7D42CBB1DCC-low.png" placement="inline" class="- topic/image " otherprops="GUID-13AF5620-AA50-475D-8AF0-B7D42CBB1DCC-low.png"/></fig><fig id="GUID-3C717FC1-906F-4787-9330-C2B1ADD2BC38" class="- topic/fig "><image href="GUID-8508A923-FAD0-482C-8533-051E8E1C2584-low.png" placement="inline" class="- topic/image " otherprops="GUID-8508A923-FAD0-482C-8533-051E8E1C2584-low.png"/></fig><fig id="GUID-71848911-4438-452E-A1B8-E41FE5C20A52" class="- topic/fig "><image href="GUID-9776282E-8C8E-4474-8591-6EC740BEA113-low.png" placement="inline" class="- topic/image " otherprops="GUID-9776282E-8C8E-4474-8591-6EC740BEA113-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the media positioning unit beam (this unit holds the upper part of the media pinch mechanism) 
</p><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the screw of the locking pin at the right hand side. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the locking pin. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C8492B5D-55EC-4C6A-A026-5444227042F8" class="- topic/fig "><image href="GUID-C7004370-C158-4ACA-872E-93CA246F00C5-low.png" placement="inline" class="- topic/image " otherprops="GUID-C7004370-C158-4ACA-872E-93CA246F00C5-low.png"/></fig><fig id="GUID-E7182AEF-C30D-4F83-AC81-FFD40569D768" class="- topic/fig "><image href="GUID-EF0F356F-3D09-46F9-B51A-C94B40859824-low.png" placement="inline" class="- topic/image " otherprops="GUID-EF0F356F-3D09-46F9-B51A-C94B40859824-low.png"/></fig><fig id="GUID-C6CB61B3-B409-46E6-8231-4FF0AD009BE5" class="- topic/fig "><image href="GUID-46D5C75E-03C3-4123-8EC7-36814A99ADE7-low.png" placement="inline" class="- topic/image " otherprops="GUID-46D5C75E-03C3-4123-8EC7-36814A99ADE7-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Close the upper cover 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-BAAB20B1-6C57-496B-B7E2-09153170C9AA" class="- topic/fig "><image href="GUID-F52AFE4A-BBC0-4AF6-BF05-ACB285BA92C4-low.png" placement="inline" class="- topic/image " otherprops="GUID-F52AFE4A-BBC0-4AF6-BF05-ACB285BA92C4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Loosen 1 screw (T10) at least 1 cm at the right hand side. 
</p></li><li class="- topic/li "><p class="- topic/p ">Loosen 1 screw (T10) at least 1 cm at the left hand side. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E917A07A-6B35-4412-840E-BADE5F25BE50" class="- topic/fig "><image href="GUID-54C7146B-CC8B-4AFC-AF1B-DF019D601D38-low.png" placement="inline" class="- topic/image " otherprops="GUID-54C7146B-CC8B-4AFC-AF1B-DF019D601D38-low.png"/></fig><fig id="GUID-45025D9D-FD1D-4257-AAF5-4D468A678875" class="- topic/fig "><image href="GUID-ACAB1827-D71D-4397-9615-1F7C88EF6374-low.png" placement="inline" class="- topic/image " otherprops="GUID-ACAB1827-D71D-4397-9615-1F7C88EF6374-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift and slide out the pinch assembly. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-67A8B738-3B24-4164-B0CE-CE4FB3113CCE" class="- topic/fig "><image href="GUID-9888D893-DBC7-4512-8FD4-CDCC54E7AB64-low.png" placement="inline" class="- topic/image " otherprops="GUID-9888D893-DBC7-4512-8FD4-CDCC54E7AB64-low.png"/></fig><fig id="GUID-7F5A2909-5DA2-4E0F-B5B3-62C05223E8AB" class="- topic/fig "><image href="GUID-BCCAAAC9-D9E6-4FE1-9B7D-132EA5BBD8DE-low.png" placement="inline" class="- topic/image " otherprops="GUID-BCCAAAC9-D9E6-4FE1-9B7D-132EA5BBD8DE-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_A7B7F2276EC64F88A303AD9C9A521E96" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-027A0565-F050-4419-9B19-C5C075964C5A.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
