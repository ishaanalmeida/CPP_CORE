<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-80B536BA-42CB-45F4-A807-81A030D93745" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-80B536BA-42CB-45F4-A807-81A030D93745" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Clean the mirrors</title><abstract class="- topic/abstract " id="GUID-DAC521FD-E03E-41BD-AD12-5D714F339050"><p class="- topic/p ">When you see pollution on the mirrors or on the glass plate in front of the mirror funnel, immediately clean these parts. 
</p><p class="- topic/p "> It is advised to clean the mirrors and the glass plate in front of the mirror funnel regularly to keep the printer in the best condition. 
</p><p class="- topic/p ">Video: <ph class="- topic/ph " varid="Video: 13 - Clean the mirrors"><xref class="- topic/xref " format="html" href="https://sus.cpp.canon/2QC33N9T" scope="external"><?ditaot usertext?> 
<image class="- topic/image " href="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png" placement="inline" otherprops="GUID-1B93C780-C233-4810-947C-7EC17F913975-low.png"/> Clean the mirrors</xref></ph>. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">User task</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="PREREQ_4A7484C23E5E46BA8D46F5927CC3D1A5" class="- topic/section task/prereq "><p class="- topic/p ">Use <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> prescribed: 
</p><ul id="UL_F7D24440ECD14DC3855D62229C39E403" class="- topic/ul "><li id="LI_F25E77D536FB4B799C750062564C45BC" class="- topic/li "><p class="- topic/p "><ph translate="no" class="- topic/ph ">Microflex</ph> gloves for handling ink 
</p></li><li id="LI_E6E8F65EDAAD4C49A430C5EE6B66BE55" class="- topic/li "><p class="- topic/p ">Lint free cloths 
</p></li><li id="LI_75F3D3584EDA44A6BE2FEB3B7513627F" class="- topic/li "><p class="- topic/p ">Demineralized water 
</p></li></ul></prereq><section id="SECTION_D0733117B373496C80C08866542BBEDF" class="- topic/section "><title class="- topic/title "/><note id="GUID-E43902BD-9129-4E20-8F2C-B09A9A85CBF1" class="- topic/note " type="caution"><p class="- topic/p "> Wear gloves when contact with ink or maintenance materials is possible. Gloves should always overlap sleeves. Wear safety glasses with side shields when handling ink or maintenance materials. Follow the ink related Safety Data Sheets (SDS) guidelines carefully in order to ensure maximum safety. 
</p></note></section><steps id="GUID-E135CFAD-DDB4-474A-AFF5-CD569E61424B" class="- topic/ol task/steps "><step id="d28932e62" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Make sure the printer is not printing. 
</cmd></step><step id="d28932e65" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Put on the <ph varid="productname" class="- topic/ph ">Colorado M-Series</ph> approved gloves. 
</cmd></step><step id="d28932e71" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Open the top cover from the media input side. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Carefully push the printhead carriage to the left in manual maintenance position. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-A8426D12-3D12-4435-A9E7-81E07C40999A" class="- topic/note " type="important"><p class="- topic/p ">Touch the printhead carriage on the covered area only, otherwise you can damage the printheads. 
</p></note></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Locate the mirror boxes on both sides of the printhead carriage. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Unscrew the six green screws of the mirror boxes manually. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d28932e87" class="- topic/fig "><image href="GUID-5A8909DB-8CC5-4B93-8C8F-17607B55ECAF-low.png" placement="inline" class="- topic/image " otherprops="GUID-5A8909DB-8CC5-4B93-8C8F-17607B55ECAF-low.png"/></fig><fig id="d28932e89" class="- topic/fig "><image href="GUID-511C2C67-77FD-494D-B425-A4B39BCA9133-low.png" placement="inline" class="- topic/image " otherprops="GUID-511C2C67-77FD-494D-B425-A4B39BCA9133-low.png"/></fig><fig id="d28932e91" class="- topic/fig "><image href="GUID-E21A97F0-858A-4C09-A8B9-13BFEC69A51C-low.png" placement="inline" class="- topic/image " otherprops="GUID-E21A97F0-858A-4C09-A8B9-13BFEC69A51C-low.png"/></fig><p class="- topic/p "> 
</p></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dampen a lint free cloth with the demineralized water and clean all mirrors on the inside of the mirror boxes. 
</cmd><info class="- topic/itemgroup task/info "><p class="- topic/p ">There are 3 mirrors. 
</p><note id="GUID-4542C33C-7132-4490-9610-96F8CC733A6C" class="- topic/note " type="important"><p class="- topic/p ">Use demineralized water, do not use any other liquid. 
</p></note></info></step><step id="d28932e103" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Make sure that all matte deposits are removed. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Carefully wipe the mirror boxes dry. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Place the mirror boxes back into position. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Fasten the screws, hand tight. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Carefully push the printhead carriage and the curing carriage past each other to ensure they do not touch each other. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Locate the mirror funnel on the curing carriage. 
</cmd><info class="- topic/itemgroup task/info "><fig id="d28932e123" class="- topic/fig "><image href="GUID-BEC085D5-8C9B-4CD5-B0D4-95BBD9F46AE8-low.png" placement="inline" class="- topic/image " otherprops="GUID-BEC085D5-8C9B-4CD5-B0D4-95BBD9F46AE8-low.png"/></fig></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Dampen a lint free cloth with the demineralized water and clean the glass plate in front of the mirror funnel. 
</cmd><info class="- topic/itemgroup task/info "><note id="GUID-591C7C35-729A-4F0C-B330-69EAE19802FD" class="- topic/note " type="important"><p class="- topic/p ">Use demineralized water, do not use any other liquid. 
</p></note></info></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Make sure that all matte deposits are removed. 
</cmd></step><step class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Carefully wipe the glass plate dry. 
</cmd></step><step id="d28932e137" class="- topic/li task/step "><cmd class="- topic/ph task/cmd "> Dispose the gloves and cloths as chemical waste according to local regulations. 
</cmd></step><step id="d28932e140" class="- topic/li task/step "><cmd class="- topic/ph task/cmd ">Close the top cover. 
</cmd></step></steps></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-0FBDD088-6DC8-4070-AE99-8FA350E9FC0A.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>User task</linktext></link></linkpool></related-links>
