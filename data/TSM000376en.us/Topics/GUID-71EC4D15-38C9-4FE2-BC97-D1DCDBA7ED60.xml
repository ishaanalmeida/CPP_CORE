<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-71EC4D15-38C9-4FE2-BC97-D1DCDBA7ED60" version="1" lang="en-US"?><reference xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-71EC4D15-38C9-4FE2-BC97-D1DCDBA7ED60" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic reference)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c reference oceReference-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic       reference/reference "><title class="- topic/title ">Connectivity requirements</title><abstract class="- topic/abstract " id="M148564-B35"><p class="- topic/p ">This section gives information on the IT connection of the printer, IT connectivity requirements and supported interfaces.</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Specifications</category></metadata></prolog><refbody class="- topic/body        reference/refbody "><section id="SECTION_C7404AEC158B4FBE83EFC36FEDF21F44" class="- topic/section "><title class="- topic/title ">Location IT connection</title><p class="- topic/p ">The IT connection is at location [A].</p><fig id="FIG_573DEC5B4F1240C096DEB2ADD1E15C58" class="- topic/fig "><image href="GUID-77B717E5-0FC0-4C0D-8BAB-F502B1EBF6F9-low.png" id="IMAGE_B98653360EA742F3BE3885CF7817F8E5" placement="inline" class="- topic/image " otherprops="GUID-77B717E5-0FC0-4C0D-8BAB-F502B1EBF6F9-low.png"/></fig></section><section id="SECTION_15502EB586AC4E4198363CF4D3B1D0C1" class="- topic/section "><title class="- topic/title ">IT connectivity</title><ul id="UL_4AB2964D7F4E4024A6397A27F98B0151" class="- topic/ul "><li id="LI_A46F0B0B74E24AB6ACE3CD4DC6E9415C" class="- topic/li "><p class="- topic/p "> Network connection: Ethernet 100 or 1000 Mbits/sec (preferred) and RJ45.</p></li><li id="LI_F065471BA9BA4F0D8CA789FC9ACA7288" class="- topic/li "><p class="- topic/p ">Network protocol type : TCP/IP V4 or TCP/IP V6.</p></li><li class="- topic/li "><p class="- topic/p "> Printer and RIP workstation network connection: on the customer network (highly recommended).</p></li></ul><note id="GUID-8AA6EF78-4CEA-4AEB-AD9C-58A6285151CE" class="- topic/note "><p class="- topic/p ">Do not use 10 Mbit network connections. </p><p class="- topic/p ">A printer not connected to the customer network is a non-standard installation with impact on the following controller features which request access to the customer network:</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">On Remote Service/Technical Service manual update (with associated Proxy settings if required). </p></li><li class="- topic/li "><p class="- topic/p ">Automatic download of software updates.</p></li><li class="- topic/li "><p class="- topic/p "> Mail server (with eventually trusted certificates).</p></li></ul></note></section><section id="SECTION_4B067156A4154BE9B42863887B108545" class="- topic/section "><title class="- topic/title ">Supported interfaces</title><ul id="UL_891473853F054E778B20E5F816E82E71" class="- topic/ul "><li id="LI_D6CB22DF52C242F7A8DFADBFC2013F9A" class="- topic/li "><p class="- topic/p ">Support for a proxy server.</p></li><li id="LI_7493264506FA491AB64374083A6FE880" class="- topic/li "><p class="- topic/p ">Connection to external RIP: via the Colorado API and port 9100</p></li><li id="LI_67805C9768334EDB90FDFF81E34CB491" class="- topic/li "><p class="- topic/p ">Web user interface via HTTP</p></li><li id="LI_9FC0CA479DE041DBB505E85DD0751D07" class="- topic/li "><p class="- topic/p "> On Remote Service (ORS).</p></li><li id="LI_3A18A48E7DE14ABDB52A5F66C4CC88E4" class="- topic/li "><p class="- topic/p "> Automatic update of service documentation</p></li></ul></section></refbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-033BA4C4-476D-4C92-BA63-BAE09A5D9EB3.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Specifications</linktext></link></linkpool></related-links>
