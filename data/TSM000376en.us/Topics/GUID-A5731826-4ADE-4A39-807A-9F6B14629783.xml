<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-A5731826-4ADE-4A39-807A-9F6B14629783" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-A5731826-4ADE-4A39-807A-9F6B14629783" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">Install a license received via e-mail</title><abstract class="- topic/abstract " id="M148553-B105"><p class="- topic/p ">This procedure describes how to install the license file once received via e-mail. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-997E8A68-AA33-4DF3-A4F8-1D92B4AAE341" class="- topic/section "><title class="- topic/title ">How to install a license</title><table pgwide="1" id="GUID-B31E85BD-080F-4527-97DE-7308C50687CC" class="- topic/table "><tgroup cols="2" align="left" class="- topic/tgroup "><colspec colname="col1" colnum="216.00pt" colwidth="10*" align="left" class="- topic/colspec "/><colspec colname="col2" colnum="369.00pt" colwidth="90*" align="left" class="- topic/colspec "/><thead class="- topic/thead "><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry></row></thead><tbody class="- topic/tbody "><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Save the received zipped license file on the workstation. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Open the Settings Editor. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Browse to: Support &gt; Licenses. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Click install: 
</p><fig id="GUID-54CE8529-01AC-468B-97F3-A456F24216D1" class="- topic/fig "><image href="GUID-40E74F55-E356-4501-9B3B-C47135A9BA13-low.png" placement="inline" class="- topic/image " otherprops="GUID-40E74F55-E356-4501-9B3B-C47135A9BA13-low.png"/></fig><p class="- topic/p ">The System Administrator login window displays: 
</p><fig id="GUID-51AD3BF9-A98E-459B-81BA-305655885F15" class="- topic/fig "><image href="GUID-69ECDB8F-F007-4174-9819-671D101204EB-low.png" placement="inline" class="- topic/image " otherprops="GUID-69ECDB8F-F007-4174-9819-671D101204EB-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Enter the System Administrator password. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Click Log in. 
</p><p class="- topic/p ">The Install license from file window displays: 
</p><fig id="GUID-C3615298-8562-4606-BF08-B60348BF21CC" class="- topic/fig "><image href="GUID-85D2E65A-D8B6-4AFD-97BB-33D5574F354E-low.png" placement="inline" class="- topic/image " otherprops="GUID-85D2E65A-D8B6-4AFD-97BB-33D5574F354E-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Browse to the workstation directory where you saved the new zipped license file. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Select the license file and click Open. 
</p><p class="- topic/p ">The following window displays : 
</p><fig id="GUID-7C0F4EF7-3CDC-4ABE-9861-354261A731CB" class="- topic/fig "><image href="GUID-852F1ACF-0F2E-4B51-BAAB-194E5B7B8328-low.png" placement="inline" class="- topic/image " otherprops="GUID-852F1ACF-0F2E-4B51-BAAB-194E5B7B8328-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Click Install. 
</p><p class="- topic/p ">The Restart required window displays: 
</p><fig id="GUID-146068AE-ADDC-4F61-A617-64B8E259DCA5" class="- topic/fig "><image href="GUID-75C2FF19-C055-4EF8-8838-A5CDB013CFCB-low.png" placement="inline" class="- topic/image " otherprops="GUID-75C2FF19-C055-4EF8-8838-A5CDB013CFCB-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Click OK. 
</p><note id="GUID-D29D5D17-FF9C-4159-B1B8-A129EB282CF8" class="- topic/note "><p class="- topic/p ">The printer will not reboot. 
</p></note><p class="- topic/p ">The following window displays: 
</p><fig id="GUID-5AA59170-C97B-4DCB-9A6F-A6EEDF8C3DDB" class="- topic/fig "><image href="GUID-9E2673A7-366A-4E4F-9067-2AE2BF86B54F-low.png" placement="inline" class="- topic/image " otherprops="GUID-9E2673A7-366A-4E4F-9067-2AE2BF86B54F-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Click OK. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Browse to: Support &gt; Licenses. 
</p></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Check that the required options are licensed as expected. At this moment the licences are present, but not yet activated. 
</p><p class="- topic/p ">For instance: 
</p><fig id="GUID-FEBA735E-C1B2-47F4-A771-2AD4728DD123" class="- topic/fig "><image href="GUID-1158EFDF-E5E7-4A52-8934-A3F6CFAC1E02-low.png" placement="inline" class="- topic/image " otherprops="GUID-1158EFDF-E5E7-4A52-8934-A3F6CFAC1E02-low.png"/></fig></entry></row><row valign="top" class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">14
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">To activate the licences, restart the printer via the menu Support --&gt;Troubleshooting
</p><p class="- topic/p ">--&gt; Printer restart and job removal --&gt; Restart the system. 
</p></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-7D3F358C-1AB9-4A5D-9B0E-C75D689F152E.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
</task>