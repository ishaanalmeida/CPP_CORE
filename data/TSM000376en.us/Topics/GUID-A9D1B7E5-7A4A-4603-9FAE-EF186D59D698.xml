<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-A9D1B7E5-7A4A-4603-9FAE-EF186D59D698" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-A9D1B7E5-7A4A-4603-9FAE-EF186D59D698" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">22 How to measure the power supply voltages in the power box</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to measure the power supply voltages in the power box. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li id="LI_53184B16D403439F881DA2AB90C20E0F" class="- topic/li "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Power off the system</b>: 
</p><p class="- topic/p ">On the operator panel, tap on the [System] icon on the right. Tap on [Power management]. Tap on [Power off]. The system shuts down. 
</p></li><li class="- topic/li "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Switch off the power supply</b>: 
</p><p class="- topic/p ">When the system has shut down, pull to open the cover under the roll winder. Switch the power switch to the 'off' position. 
</p></li><li id="LI_63A0C945A5EE411381005D65504AC5A8" class="- topic/li "><p class="- topic/p ">Unplug the mains cables. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_AF872F56095B4EBC963FCD3D016D0A0D" class="- topic/ul "><li id="LI_D07056304E1A4AE79EA3506142BD1B4E" class="- topic/li "><p class="- topic/p ">A roll of tape (to place underneath the power box) 
</p></li><li id="LI_0F85C7CD6ECE40AAA6414F5D383EF9C1" class="- topic/li "><p class="- topic/p ">Multi meter. 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-57E76982-FA66-4438-A047-18DEAEDD35F0" class="- topic/fig "><image href="GUID-C6B05FAD-699A-41A4-A51E-7EE0645DB176-low.png" placement="inline" class="- topic/image " otherprops="GUID-C6B05FAD-699A-41A4-A51E-7EE0645DB176-low.png"/></fig></section><section id="GUID-0A9F3D6D-1040-4F56-955A-EB7ACDB10B97" class="- topic/section "><title class="- topic/title ">Slide out the power box (30 cm)</title><table id="GUID-D30A3D9D-AC30-4352-AB85-882298700784" class="- topic/table "><tgroup cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead class="- topic/thead "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody class="- topic/tbody "><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the 2 screws (T20) of the power supply unit at the media drawer side. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><fig id="FIG_C3CA095615724D7C88854CE861AEA0FF" class="- topic/fig "><image href="GUID-8E06318B-706A-4951-89A4-C93FE787ACF7-low.png" id="IMAGE_B83BF14092164FA8939907D828CE98C8" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8E06318B-706A-4951-89A4-C93FE787ACF7-low.png"/></fig><fig id="GUID-51F53878-8462-4F9F-BCC5-1CF1946BF851" class="- topic/fig "><image href="GUID-2E9BAFF0-AE3F-4197-9812-65EBC9AE75B5-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-2E9BAFF0-AE3F-4197-9812-65EBC9AE75B5-low.png"/></fig><fig id="GUID-C34741CC-836B-4BAF-9536-131A4109A51F" class="- topic/fig "><image href="GUID-525F7479-2B28-4BCD-8212-151D564358FE-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-525F7479-2B28-4BCD-8212-151D564358FE-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p "> Remove the 3 plates (4 nuts and 4 screws) of the power box. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><fig id="GUID-9972626C-53E6-45B5-A495-4A55C30A4F97" class="- topic/fig "><image href="GUID-AA00357F-A855-4849-A254-C951E05F23E9-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-AA00357F-A855-4849-A254-C951E05F23E9-low.png"/></fig><fig id="GUID-B5B4D2CC-0B78-4CD2-922B-2DFFEEB67346" class="- topic/fig "><image href="GUID-F8786CA5-00EF-4D28-BBC7-E24524694F8F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F8786CA5-00EF-4D28-BBC7-E24524694F8F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the 2 connectors. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><fig id="GUID-EE72B00D-E10A-422D-BA23-A4F52076B3BE" class="- topic/fig "><image href="GUID-C029244B-57C4-4679-94D0-99640BE732FD-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C029244B-57C4-4679-94D0-99640BE732FD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the small plate (2 screws). 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><fig id="GUID-7AF6AFA9-5E58-4E74-9C53-EC40B4019E7E" class="- topic/fig "><image href="GUID-36D5D333-8618-4BBE-B74A-C5D94DC287BF-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-36D5D333-8618-4BBE-B74A-C5D94DC287BF-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" valign="top" class="- topic/entry "><p class="- topic/p ">Slide out the power box for approximately 30 cm. 
</p></entry><entry colname="col3" valign="top" class="- topic/entry "><fig id="GUID-42835212-587D-44A0-A8FE-8C0AA09433CD" class="- topic/fig "><image href="GUID-5A07C04F-B1DF-44DC-9064-5CEE055DDFFF-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5A07C04F-B1DF-44DC-9064-5CEE055DDFFF-low.png"/></fig></entry></row></tbody></tgroup></table></section><section id="SECTION_C42196505C324E42B0E7D944D8104A5A" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_21A0BE677EF045B591BA1B755EABFA33" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect the connectors. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-0A3C3D60-26E4-4092-AE57-889D3F0F2F68" class="- topic/fig "><image href="GUID-F1454F66-2CED-4752-989C-59A65EBA7AE3-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F1454F66-2CED-4752-989C-59A65EBA7AE3-low.png"/></fig><fig id="GUID-5287E38D-9B71-4B74-8BAD-DF24E807ED81" class="- topic/fig "><image href="GUID-84011D5C-E96F-451F-8066-5029E19D3832-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-84011D5C-E96F-451F-8066-5029E19D3832-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Plug-in the mains cables. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Switch on the system. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-BAA8D951-A9CF-4ACD-AD4B-50AAC199385C" class="- topic/fig "><image href="GUID-F5E2FE24-335C-4E52-965A-5F140B4728A5-low.png" placement="inline" class="- topic/image " otherprops="GUID-F5E2FE24-335C-4E52-965A-5F140B4728A5-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" namest="col2" nameend="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Measure the power supply voltages within the power box: 
</p><note id="GUID-B0D2A62A-B833-4B9F-A8D1-CDC087917919" class="- topic/note "><p class="- topic/p "> Mains supply present on L1 and L2 on AC_Switch PBA (X1-1&amp;2, X2-1&amp;2) 
</p></note><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b "> Start printer in Zero SDS</b> 
</p><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Check 22G02</b> 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Do 22-6-102 Check PSU 22G02 (24V) = AC_Switch PBA K5 is activated 
</p></li><li class="- topic/li "><p class="- topic/p ">Check sequentially 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">22G02-L to 22G02-N 
</p></li><li class="- topic/li "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">If not present AC_Switch PBA is suspected 
</p></li></ul></li><li class="- topic/li "><p class="- topic/p ">22G02 P_24V to 22G02_GND24V 
</p></li><li class="- topic/li "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Primary AC present, DC secondary not present = Power supply defect 
</p></li></ul></li></ul></li></ul><p class="- topic/p "><b class="+ topic/ph hi-d/b "> Check 22G03</b> 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Do 22-6-103 Check PSU 22G03 (36V) = AC_Switch PBA K3 is activated 
</p></li><li class="- topic/li "><p class="- topic/p ">Check sequentially 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">22G03-L to 22G03-N 
</p></li><li class="- topic/li "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">If not present AC_Switch PBA is suspected 
</p></li></ul></li><li class="- topic/li "><p class="- topic/p ">22G03 P_36V to 22G03_GND36V 
</p></li><li class="- topic/li "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Primary AC present, DC secondary not present = Power supply defect 
</p></li></ul></li></ul></li></ul><p class="- topic/p "><b class="+ topic/ph hi-d/b "> Check 22G04</b> 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Do 22-6-104 Check PSU 22G04 (48V Curing) = AC_Switch PBA K1 is activated 
</p></li><li class="- topic/li "><p class="- topic/p ">Check sequentially 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">22G04-L to 22G04-N 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">If not present AC_Switch PBA is suspected 
</p></li></ul></li><li class="- topic/li "><p class="- topic/p ">22G04 P_48V_CUR to 22G02_GND48V_CUR 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Primary AC present, DC secondary not present = Power supply defect 
</p></li></ul></li></ul></li></ul><p class="- topic/p "> 
<b class="+ topic/ph hi-d/b ">Check 22G05</b> 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Do 22-6-105 Check PSU 22G05 (48V Printhead) = AC_Switch PBA K4 is activated 
</p></li><li class="- topic/li "><p class="- topic/p ">Check sequentially 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">22G05-L to 22G05-N 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">If not present AC_Switch PBA is suspected 
</p></li></ul></li><li class="- topic/li "><p class="- topic/p ">22G05 P_48V_PH to 22G02_GND48V_PH 
</p><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Primary AC present, DC secondary not present = Power supply defect 
</p></li></ul></li></ul></li></ul></entry></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_E3FC7EE10DDC46BA880F87671551C890" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Install in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-5C4B92A8-575C-4245-83D5-3D2AA8FD31BA.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
