<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-C9995C05-210E-4B35-BCAC-37422D9C0B02" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-C9995C05-210E-4B35-BCAC-37422D9C0B02" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">How to place the printer and chiller on the pallet and finalize the packing</title><abstract class="- topic/abstract " id="M028334-B18"><p class="- topic/p ">This document show you how to place the printer on the pallet and to finalize the packing. 
</p><note class="- topic/note " id="GUID-F7FD5401-C801-493F-88CF-310D495998AE"><p class="- topic/p "> The photos in this instruction manual are based on the Colorado 1640, not the M-series. 
</p></note></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Installation</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-C71E4B56-F6A6-429E-9630-3F0443D53874" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Makes sure the floor is flat. Bumps or tilts may damage the printer in the process. 
</p></li><li class="- topic/li "><p class="- topic/p "> 2 People are required to carry out this procedure. 
</p></li></ol></prereq><section id="SECTION_BB8C533001C043A9B5E24F6EEECB8B53" class="- topic/section "><title class="- topic/title ">Personal protection</title><note type="caution" id="GUID-C8810ABE-05AA-47B2-A506-D909EB952778" class="- topic/note "><p class="- topic/p ">Wear safety shoes when working with heavy material (e.g. installation) or dis-assemblies of units. 
</p><p class="- topic/p ">Wear protected clothing for protection of your personal clothing. 
</p></note></section><section id="SECTION_0C3117AA47E845948FE99C8DF21ECCCC" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="FIG_DE975462509F4390844B708D4F35A342" class="- topic/fig "><image href="GUID-BDC15672-E17D-45CB-810D-93DACBCB8B0D-low.png" id="IMAGE_86721C669C37424DB836EB73BE2E317A" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BDC15672-E17D-45CB-810D-93DACBCB8B0D-low.png"/></fig></section><section id="SECTION_3EAAE870561847F1914DAA1BC10E2FD6" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_3397BAAC9D5940BDBB97249F1BE4C31D" class="- topic/ul "><li id="LI_82240E45AAA5452084E7E08BD56CD707" class="- topic/li "><p class="- topic/p ">Spanner 17 and 19 or Allen key 6 mm 
</p></li><li id="LI_6CA35BF5CE07492090E94288EB2EADF4" class="- topic/li "><p class="- topic/p ">Phillips screwdriver 
</p></li><li id="LI_CB1E4686BB85462D8888B625E861F0C3" class="- topic/li "><p class="- topic/p ">Large screwdriver 
</p></li><li id="LI_17EAF354BD33438382E22D2654B776EB" class="- topic/li "><p class="- topic/p ">Small screwdriver 
</p></li><li id="LI_D34221B3DB454612A5D28513C820709F" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li id="LI_290002EE166E404DA9E9837407082573" class="- topic/li "><p class="- topic/p ">Tape 
</p></li></ul></section><section id="GUID-94C20406-75A1-4BD0-A7DB-8CD9777F04B0" class="- topic/section "><title class="- topic/title ">Place the printer on the pallet and finalize the packing</title><table id="NEW" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the bracket of the power supply box. 
</p><p class="- topic/p ">The bracket will hit the ramp while riding on the pallet. 
</p><ul id="UL_50A742D2282A4A03B1852518B623FB2A" class="- topic/ul "><li id="LI_7793A4DE92914730AE504A420BD3992E" class="- topic/li "><p class="- topic/p ">Remove the indicated screws 
</p></li><li id="LI_AFF3E5A425584F0D96DD6F9449AFEE9C" class="- topic/li "><p class="- topic/p ">Remove the bracket completely. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_1C00C61663354B76B6455F5A83B37A24" class="- topic/fig "><image href="GUID-66A85AF5-C28F-4D48-8F7E-38D9F71BA79F-low.png" id="IMAGE_D99A74AD7EC347EC869078DB46B2BFAE" keyref="" placement="inline" class="- topic/image " otherprops="GUID-66A85AF5-C28F-4D48-8F7E-38D9F71BA79F-low.png"/></fig><fig id="FIG_39653FBE38A14DB2B83196F6AF7BD98C" class="- topic/fig "><image href="GUID-00DCCBC3-37BB-49C5-81C4-F61174A42B13-low.png" id="IMAGE_816A3190A00F4DA6AF62A2F8B97F7F25" keyref="" placement="inline" class="- topic/image " otherprops="GUID-00DCCBC3-37BB-49C5-81C4-F61174A42B13-low.png"/></fig><fig id="FIG_A74CF0D04D3B4878B723BB3733E8DDE4" class="- topic/fig "><image href="GUID-B9BF4E92-A944-4117-90D1-C9EC2930DF01-low.png" id="IMAGE_A54341E83A6F46C3BF21239715864B30" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B9BF4E92-A944-4117-90D1-C9EC2930DF01-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the printer on the 4 wheels. 
</p><note id="GUID-AD90D7C4-9D9E-488A-AA83-9ACA8C4D522C" class="- topic/note "><p class="- topic/p ">Turn the leveling adjustment screws completely in. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_CAE0F34BA0FB4167AA1280042A1A32B9" class="- topic/fig "><image href="GUID-6118D1DB-CD87-4E96-A1B7-693BC774E7B2-low.png" id="IMAGE_FC121BAD9CDA400DACB7F1C3CB7A99F8" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6118D1DB-CD87-4E96-A1B7-693BC774E7B2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the pallet in the room. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use the U-shaped bars to create the ramp. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_B0D0AC7DAD6D4888A383FDF0635EED24" class="- topic/fig "><image href="GUID-FCE3538A-4F04-456F-A17B-EA04D9007B53-low.png" id="IMAGE_3D8C4D1CD3C145F5AFF3CC758749F7BA" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCE3538A-4F04-456F-A17B-EA04D9007B53-low.png"/></fig><fig id="FIG_FA4775E838A54182AE4E610DBBF7DB41" class="- topic/fig "><image href="GUID-CE6056BF-7A8E-4448-A2ED-3309CB497E56-low.png" id="IMAGE_CD94CF7B5FA24D2483EF595443566E8B" keyref="" placement="inline" class="- topic/image " otherprops="GUID-CE6056BF-7A8E-4448-A2ED-3309CB497E56-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Align the printer properly before the ramp. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_E61B5CF2188B41F79AFB594A51D103F9" class="- topic/fig "><image href="GUID-0D6AF177-676F-49E6-94D6-D53B37246428-low.png" id="IMAGE_27E3DFA74CCB4EA4A27803FFCEF22B81" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0D6AF177-676F-49E6-94D6-D53B37246428-low.png"/></fig><fig id="FIG_58D821AE41A64FD8BBD1B280D62AB812" class="- topic/fig "><image href="GUID-E571BDBC-7939-4D6F-B9BE-30820AEC8DA2-low.png" id="IMAGE_ACDD49447D42400B81AF6F65B0A928E4" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E571BDBC-7939-4D6F-B9BE-30820AEC8DA2-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 people should now push/pull the printer over the ramp on the pallet. 
</p><note type="important" id="GUID-C6CB72FF-D5D7-4413-B8B4-5DB6EDC79D79" class="- topic/note "><p class="- topic/p ">Push the printer only at the metal part as shown in the picture. 
</p><p class="- topic/p ">Never push at the transparent part of the top cover. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_0E8255D9568E48AF911037E970D8D200" class="- topic/fig "><image href="GUID-B325C476-DEDD-4ED9-A795-B053610781F3-low.png" id="IMAGE_F95F375679AA4ABE8056E6EBED5D98CF" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B325C476-DEDD-4ED9-A795-B053610781F3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the 2 metal u-shaped bars (of ramp) under the pallet. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_D64266697EEA49798E19D736B52D803C" class="- topic/fig "><image href="GUID-B676B496-3F98-4994-8275-4446F455BD2F-low.png" id="IMAGE_D71F1044D73C43F684C65FDA33A923FB" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B676B496-3F98-4994-8275-4446F455BD2F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the 4 wooden block on the corners of the printer. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_A9C1AC26688549D29CBE44925CCB6D39" class="- topic/fig "><image href="GUID-19FE398D-4D16-45F8-AFAE-CF36BAFF6218-low.png" id="IMAGE_1F8EEBAFCA2542B2BF355D8922C2514D" keyref="" placement="inline" class="- topic/image " otherprops="GUID-19FE398D-4D16-45F8-AFAE-CF36BAFF6218-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use the 4 rubber mountings and 4 long bolts to mount the wooden blocks and ramps onto the pallet. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_7D91B0C4FF47490C8390AC386AFB6CE6" class="- topic/fig "><image href="GUID-75A9EEDC-406A-423D-B9B0-20466C0E71AD-low.png" id="IMAGE_7093F7DD6791435DB2311589CFEFCDD4" keyref="" placement="inline" class="- topic/image " otherprops="GUID-75A9EEDC-406A-423D-B9B0-20466C0E71AD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use the leveling adjustment screws to raise the printer of the wheels. 
</p><note id="GUID-BC221969-4339-4D1F-840E-7210B88C8E94" class="- topic/note "><p class="- topic/p ">Do not do it all at once. Go half the way on all 4 corners before you continue. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_154CECB4B53A4E8EAD9F0869F06CD738" class="- topic/fig "><image href="GUID-F84E98D8-24A8-4F14-A0B1-267A03386264-low.png" id="IMAGE_1F39AB59A0EC49828A4B70AD62574519" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F84E98D8-24A8-4F14-A0B1-267A03386264-low.png"/></fig><fig id="FIG_5B5C4703F59D42CDBB118FA4D38359E5" class="- topic/fig "><image href="GUID-BE3924D7-7F3F-4688-B24A-9852EBE87989-low.png" id="IMAGE_20E9CD61EFFF412AB2FBF72BE851A97E" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BE3924D7-7F3F-4688-B24A-9852EBE87989-low.png"/></fig><fig id="FIG_BAF023F1F5874BCB8F2079C0146ABB53" class="- topic/fig "><image href="GUID-6E6BB24E-EF98-48AC-8EBF-64815A0ECB8C-low.png" id="IMAGE_4E461F8A153746018421B0CE24BFBA73" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6E6BB24E-EF98-48AC-8EBF-64815A0ECB8C-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lock the wheels with tape to the pallet. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the 2 brackets (above the rubber blocks). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_E4D9EC938B344EE5AFA6227E55D27E02" class="- topic/fig "><image href="GUID-64F68243-7854-4796-A5E1-A002F946762E-low.png" id="IMAGE_93884DF4D65842299412F35D141CDBC2" keyref="" placement="inline" class="- topic/image " otherprops="GUID-64F68243-7854-4796-A5E1-A002F946762E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use the leveling adjustment bolts to lift the printer until there is a 2 mm gap between the engine and the U shaped bracket. 
</p><p class="- topic/p ">Do this on all 4 corners. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_43D9B278E1AC4C399DC042FBE6663FA5" class="- topic/fig "><image href="GUID-AFAF7677-7FC5-4D60-B74B-82CAE65AC3BC-low.png" id="IMAGE_8D1B5A4D107E4BF3B50E43BBA2D9C61F" keyref="" placement="inline" class="- topic/image " otherprops="GUID-AFAF7677-7FC5-4D60-B74B-82CAE65AC3BC-low.png"/></fig><fig id="FIG_69EB5239681F401C8E889D4D95785817" class="- topic/fig "><image href="GUID-B2FB2E64-3511-4153-B38B-8090BB475951-low.png" id="IMAGE_90C456CF6EF04E2FA9C90247CFE5DCCD" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B2FB2E64-3511-4153-B38B-8090BB475951-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the 2 brackets at the paper input side. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_A10BFE07B1F54D18A32A53C564ED21E4" class="- topic/fig "><image href="GUID-5B53478D-82EB-44D0-9685-EB7937F95FF2-low.png" id="IMAGE_2C10DFC1EA0E45719D066DD4D4E8B285" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5B53478D-82EB-44D0-9685-EB7937F95FF2-low.png"/></fig><fig id="FIG_7317E774097548A9AD32F588C9049E96" class="- topic/fig "><image href="GUID-D3721492-CDE0-49FC-966D-6D4F34C4EE8B-low.png" id="IMAGE_B77C59B6DE99497E915301BCF4A03C40" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D3721492-CDE0-49FC-966D-6D4F34C4EE8B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the 2 brackets (Bottom left and right hand side of the winder). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_2ED5D0597EA346D188AA25B5755AB21E" class="- topic/fig "><image href="GUID-5B53478D-82EB-44D0-9685-EB7937F95FF2-low.png" id="IMAGE_3A1C1D54DFCF4B58AA13407352D8024F" keyref="" placement="inline" class="- topic/image " otherprops="GUID-5B53478D-82EB-44D0-9685-EB7937F95FF2-low.png"/></fig><fig id="FIG_3661949FBAE74B51963B116B53EDAD15" class="- topic/fig "><image href="GUID-D3721492-CDE0-49FC-966D-6D4F34C4EE8B-low.png" id="IMAGE_AD500BE6061B4B28BCACFC1EC077641D" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D3721492-CDE0-49FC-966D-6D4F34C4EE8B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Raise the leveling adjustment screws on all 4 corners. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lock the 2 brackets with 4 bolts. 
</p><p class="- topic/p ">The printer is resting on the 4 rubber blocks of the pallet. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_C948742E8D934D85B7FE2ADC4E3E6905" class="- topic/fig "><image href="GUID-8158C512-1D85-4E67-A391-0A951D32ADBD-low.png" id="IMAGE_3F991630592844CD8C18AD0F5C752925" keyref="" placement="inline" class="- topic/image " otherprops="GUID-8158C512-1D85-4E67-A391-0A951D32ADBD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the 2 L shape brackets (at the winder side). 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_7F90516AAE7F45CCA698EC14D87C3C70" class="- topic/fig "><image href="GUID-7381AB49-6D6C-4B3A-8509-3933C15D4607-low.png" id="IMAGE_D0390A642A954BEA8FE63DD44BF87A0B" keyref="" placement="inline" class="- topic/image " otherprops="GUID-7381AB49-6D6C-4B3A-8509-3933C15D4607-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the cover and rollers carefully on the L shape bracket. 
</p><p class="- topic/p ">Lock them with 2 cable ties. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_0E5ED867FC8B48B389B5EF67A22B587F" class="- topic/fig "><image href="GUID-BC2775A7-372E-42D9-B962-98DCCE5261DF-low.png" id="IMAGE_83042B82362F44839F0CCEBC5908D781" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BC2775A7-372E-42D9-B962-98DCCE5261DF-low.png"/></fig><fig id="GUID-9F44A8F5-B129-4CC7-851E-27BF31E7E3BD" class="- topic/fig "><image href="GUID-EE53D519-CA47-452E-9659-3F66C278DD42-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EE53D519-CA47-452E-9659-3F66C278DD42-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">20
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use the rubber mountings and long bolts to mount the wooden blocks and ramps onto the pallet.
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">21 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Use 2 straps to fit the bottom frame and chiller together. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">22
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Move the chiller on the pallet using the handles. 
</p><note id="GUID-94141C9B-A2E0-4F3C-916C-AF582C0989AB" class="- topic/note "><p class="- topic/p ">Two persons needed to reduce the risk of injury. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E637BF48-1DC6-42CF-AB6D-9E87AF02CEBD" class="- topic/fig "><image href="GUID-0093C8F9-DEAE-4978-AAA0-584A79FB3A31-low.png" placement="inline" class="- topic/image " otherprops="GUID-0093C8F9-DEAE-4978-AAA0-584A79FB3A31-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">23 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the horizontal transportation strap. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-D8D10490-44D9-47A3-9282-6561F4C56C78" class="- topic/fig "><title class="- topic/title "/><image href="GUID-081DF91F-204E-469B-8151-9BCA6B1E928F-low.png" placement="inline" class="- topic/image " otherprops="GUID-081DF91F-204E-469B-8151-9BCA6B1E928F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">24 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the 3 screws located under the pallet to secure the chiller on the pallet. (sw17) 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-87A66009-890E-4FD1-827C-4D8BD1EEA29D" class="- topic/fig "><title class="- topic/title "/><image href="GUID-2B275285-73FE-462B-B9CE-01D7EF983CCD-low.png" placement="inline" class="- topic/image " otherprops="GUID-2B275285-73FE-462B-B9CE-01D7EF983CCD-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">25 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the cover plate. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-C011BAC2-B1C8-4674-80AE-A2C483FADED9" class="- topic/fig "><title class="- topic/title "/><image href="GUID-9D57A887-104A-4A4A-B4A1-C66F9706FF05-low.png" placement="inline" class="- topic/image " otherprops="GUID-9D57A887-104A-4A4A-B4A1-C66F9706FF05-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">26 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Make sure the 2 covers of the winder are open (not closed). 
</p><note id="GUID-C2879D9C-34FB-4380-8624-5B7928B7CD93" class="- topic/note "><p class="- topic/p ">They must be open to prevent that the cover touches the crate during transport. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">27 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the aluminum bag around the printer. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_1DF857E18B1C4F9DA3FAE3EE15A115E7" class="- topic/fig "><image href="GUID-E539242C-592B-4FCC-88EA-30D2F1ECA29B-low.png" id="IMAGE_4EC9AD9BADA7446D9A97E46BA053BFCA" keyref="" placement="inline" class="- topic/image " otherprops="GUID-E539242C-592B-4FCC-88EA-30D2F1ECA29B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">28
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount all side covers one by one. 
</p><ul id="UL_FF01AFE0992847BC82096D62B2797F14" class="- topic/ul "><li id="LI_ACB83BD401C442598341C89B7D5D51B5" class="- topic/li "><p class="- topic/p ">Mount the cover with exit side sticker at the correct place. 
</p></li></ul></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_34BAE95EC35148F8B0E380F2A5BF5D22" class="- topic/fig "><image href="GUID-40287BBE-8170-49F3-BE22-FE9D53038819-low.png" id="IMAGE_ACA380BCFCE84A968F4290085BA07875" keyref="" placement="inline" class="- topic/image " otherprops="GUID-40287BBE-8170-49F3-BE22-FE9D53038819-low.png"/></fig><fig id="FIG_8C8F195DF6014A5689B0806E91DD61E6" class="- topic/fig "><image href="GUID-024757DB-E317-4CB6-9A6D-E4CB332F2A94-low.png" id="IMAGE_3ED3CD4BBEAE4B638E73AC630EA9A73D" keyref="" placement="inline" class="- topic/image " otherprops="GUID-024757DB-E317-4CB6-9A6D-E4CB332F2A94-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">29 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount the top cover of the crate. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_06CC1616B37547259EAC23480687404A" class="- topic/fig "><image href="GUID-EC18F8A4-2185-4A0E-A210-8C4DCCBCC4F1-low.png" id="IMAGE_A95593C69DEC4EDEAB3C1C8453F66F42" keyref="" placement="inline" class="- topic/image " otherprops="GUID-EC18F8A4-2185-4A0E-A210-8C4DCCBCC4F1-low.png"/></fig><fig id="FIG_2C5F13577A744FA0AF64BC015ED97FF6" class="- topic/fig "><image href="GUID-30D4C49D-1744-4470-9924-96CD55CC4BC4-low.png" id="IMAGE_05A170A20F8E41E594E3F1F760E5B134" keyref="" placement="inline" class="- topic/image " otherprops="GUID-30D4C49D-1744-4470-9924-96CD55CC4BC4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">30 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">The crate is ready for shipment. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="FIG_317EE630518242A690A2BCF75F0CA76D" class="- topic/fig "><image href="GUID-BDC15672-E17D-45CB-810D-93DACBCB8B0D-low.png" id="IMAGE_5983363E99764EC9BAF7165054DB7483" keyref="" placement="inline" class="- topic/image " otherprops="GUID-BDC15672-E17D-45CB-810D-93DACBCB8B0D-low.png"/></fig></entry></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-3955AF8F-9BF3-4DD3-AA2A-175FB2AE2E43.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Installation</linktext></link></linkpool></related-links>
