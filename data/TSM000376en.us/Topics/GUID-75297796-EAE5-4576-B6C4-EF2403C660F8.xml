<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-75297796-EAE5-4576-B6C4-EF2403C660F8" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-75297796-EAE5-4576-B6C4-EF2403C660F8" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">02 How to remove the ink from the ink tank</title><abstract class="- topic/abstract " id="GUID-0E3E2CA2-5349-4FAF-80F5-347AA9765351"><p class="- topic/p ">This document describes how to remove the ink from the ink tank. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_44E3E3F07D374BF6964EC50817FE9018" class="- topic/ul "><li id="LI_52DBF4023EA944F89CD5A1B41DA11017" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Maintenance tray 
</p></li><li class="- topic/li "><p class="- topic/p ">4 new ink tanks or use cleaned ink tanks 
</p></li><li id="LI_929C0F12811B4096BB70DA320BD9C6C8" class="- topic/li "><p class="- topic/p ">Towel 
</p></li><li class="- topic/li "><p class="- topic/p ">Protective gloves: 
<b class="+ topic/ph hi-d/b ">Microflex</b> 93-260 gloves. 
</p></li></ul></section><section id="GUID-C02D66D1-E3CC-4BC2-95F8-775D93D93431" class="- topic/section "><title class="- topic/title ">Warning / Caution</title><note type="caution" id="GUID-A97040BC-F110-4E4B-9CFF-E8082B9DA00E" class="- topic/note "><fig id="GUID-F56D2715-E266-4396-9B34-5C0D37B6D01C" class="- topic/fig "><image href="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-FCF86E23-0DD4-40BC-ACDF-FF8ABA1E6502-low.png"/></fig><p class="- topic/p ">Avoid skin contact with ink: wear protective gloves. 
</p><fig id="GUID-7C716739-2AD7-42F8-8EF6-B28A8E7B1F76" class="- topic/fig "><image href="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D8099BBE-C3A2-4392-8B56-C532EDDD6073-low.png"/></fig><p class="- topic/p "> Protect your eyes from splashing ink: wear safety glasses. 
</p></note></section><section id="GUID-DAA76E44-17DA-4172-B724-20E3389834BB" class="- topic/section "><title class="- topic/title ">How to remove the ink from the ink tank</title><note id="GUID-4480BAEB-DCBE-48FC-8DFE-3A6CCE0D78FE" class="- topic/note "><p class="- topic/p ">Do this procedure for each color (C, M, Y, K). 
</p></note><table pgwide="1" id="GUID-A85C321B-F308-43E0-934E-A3E1E02ABCC6" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Remove the ink refill units. 
</p></li><li class="- topic/li "><p class="- topic/p ">Do this procedure for each color (C, M, Y, K). 
</p><p class="- topic/p ">See : 
<xref keyref="02DISA009" class="- topic/xref " href="GUID-0DEE531B-1829-44B1-9D7D-2489745F722D.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02 How to remove the ink refill unit?>02 How to remove the ink refill unit</xref>. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-A6DB3768-8174-444E-9946-8BAB388DAE0B" class="- topic/fig "><image href="GUID-B86D8410-36A2-495E-98D2-7734E2E5649F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B86D8410-36A2-495E-98D2-7734E2E5649F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connector of stirring motor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7574B16C-F333-47BC-AF37-7636EBCB2552" class="- topic/fig "><image href="GUID-0CCEBAF9-FECC-4EED-B828-DD4F270907D3-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0CCEBAF9-FECC-4EED-B828-DD4F270907D3-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Open the cover ink pump of this ink tank and remove the ink pump tube from the pump. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-66D968C4-5C1E-4866-8843-E3E1E3BEDBD6" class="- topic/fig "><image href="GUID-C2C5750B-F933-46B5-939A-B14024DD198C-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C2C5750B-F933-46B5-939A-B14024DD198C-low.png"/></fig><fig id="GUID-6FC6F0C7-C0BB-4872-BA97-628839C5CB09" class="- topic/fig "><image href="GUID-F6916527-F5A2-4ADD-978A-ADF5766BF6B4-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F6916527-F5A2-4ADD-978A-ADF5766BF6B4-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the screw of the locking bracket of the ink tank. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-24838E7D-2190-442E-AB42-CBC1FEDD1B5A" class="- topic/fig "><image href="GUID-6E7F39FB-DAF1-4DE3-854A-84F6590CBEE1-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-6E7F39FB-DAF1-4DE3-854A-84F6590CBEE1-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Lift and remove the ink tank. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1E2B20D5-474C-4772-AEAA-235BA50B9B4A" class="- topic/fig "><image href="GUID-C1CB31DD-8EEB-40A8-A7C2-579BDD406176-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-C1CB31DD-8EEB-40A8-A7C2-579BDD406176-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Lift and remove the ink tank. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-7A96C527-3554-4136-A523-C33DCCC0D8E9" class="- topic/fig "><image href="GUID-872A2DF4-539E-40A5-AE60-80C891C5A8E9-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-872A2DF4-539E-40A5-AE60-80C891C5A8E9-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place a new maintenance tray in front of the ink tank. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remove the lid of the ink tank. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F25059B1-A966-42E8-AFCD-33660BF301CD" class="- topic/fig "><title class="- topic/title "/><image href="GUID-3DEEDD76-4F7E-4949-A0C5-3D008FFD688A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-3DEEDD76-4F7E-4949-A0C5-3D008FFD688A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">8 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Hold the ink tank and carefully slide out the mixer blade. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-084C866B-0F8C-4F2F-A950-A43AB1C3FE9F" class="- topic/fig "><image href="GUID-F2D4C3A0-219B-4D36-B415-16906312ED7D-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-F2D4C3A0-219B-4D36-B415-16906312ED7D-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">9 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the mixer blade in the maintenance tray. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-E44495C0-7186-4A4A-8CF7-3D53559BA3C7" class="- topic/fig "><image href="GUID-27B3BFE8-7C57-49A9-AAE3-94F0BF91F33B-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-27B3BFE8-7C57-49A9-AAE3-94F0BF91F33B-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">10 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Clean the mixer blade with a lint free cloth. 
</p></li><li class="- topic/li "><p class="- topic/p ">Dispose the ink of the ink tank. 
</p></li><li class="- topic/li "><p class="- topic/p ">If applicable (no new ink tanks used): Clean the inside of the ink tank. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-F5DD8DFD-3611-49AA-AABB-F272638506AD" class="- topic/fig "><image href="GUID-D5B328FD-EA85-4626-B159-A2FB8CDA63B0-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-D5B328FD-EA85-4626-B159-A2FB8CDA63B0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">11 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Slide the mixer blade in a 
<b class="+ topic/ph hi-d/b ">new</b> or 
<b class="+ topic/ph hi-d/b ">cleaned</b> ink tank. 
</p></li><li class="- topic/li "><p class="- topic/p ">Lock the lid. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-ABBF50D5-390B-4A7B-A3A2-09E59C33F6F0" class="- topic/fig "><image href="GUID-43324D7F-2676-48F0-A28A-9666F65E128E-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-43324D7F-2676-48F0-A28A-9666F65E128E-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">12 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Place the ink tank, flat surface of the ink tank at the sensors side, in the unit. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">13 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Secure the locking bracket with a screw. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">14 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Connect the connector of the stirring motor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">15 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> Place the ink pump tube in the ink pump and close the cover of the ink pump. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">16 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the ink refill unit. 
</p><note type="important" id="GUID-B7B9F502-5ED9-4713-9375-6D16E474A718" class="- topic/note "><p class="- topic/p ">Make sure the funnel is placed correctly in the top cover of the ink tank. 
</p></note><p class="- topic/p ">See : 
<xref keyref="02DISA009" class="- topic/xref " href="GUID-0DEE531B-1829-44B1-9D7D-2489745F722D.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02 How to remove the ink refill unit?>02 How to remove the ink refill unit</xref>. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-715A25C1-2260-4B1E-BFCB-5F9DF8CFAA07" class="- topic/fig "><image href="GUID-B86D8410-36A2-495E-98D2-7734E2E5649F-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-B86D8410-36A2-495E-98D2-7734E2E5649F-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">17 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p "><b class="+ topic/ph hi-d/b ">Check:</b> Use a flashlight to make sure the funnel is in the top cover of the ink tank. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">18 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Continue with the next color, until they are all done. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">19 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mark the emptied ink jars as empty. 
</p><p class="- topic/p ">See : 
<xref keyref="SDS02-6-004" class="- topic/xref " href="GUID-5A6A8E82-2BDB-4C92-BCB6-017CAE3FAF10.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 02-6-004 Estimated ink level / Mark ink jar as empty (C, M, Y, K or W) [Special Tests]?>02-6-004 Estimated ink level / Mark ink jar as empty (C, M, Y, K or W) [Special Tests]</xref> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-1CE85252-F6D3-4421-930B-8AE723FFB49C.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Dis-assembly</linktext></link></linkpool></related-links>
</task>