<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-BA0BED95-DA3C-4596-9E5B-6F658A8B73EA" version="2" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-BA0BED95-DA3C-4596-9E5B-6F658A8B73EA" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">01 How to adjust the plate shielding</title><abstract class="- topic/abstract " id="GUID-173AF84C-D126-4DD5-8ABA-ADD08113B9D4"><p class="- topic/p "> During this adjustment the plate shielding will be positioned in such a way that no straylight will reach the printheads. 
</p><p class="- topic/p ">The plate shielding adjustment is required when a new carriage is been installed or when a new plate-adjust has to be installed. 
</p><p class="- topic/p ">Actions should be done in the sequence mentioned in this document. 
</p></abstract><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Adjustment</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A392D23B9FA5434A8095E72A33F001E1" class="- topic/ul "><li class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20 
</p></li><li class="- topic/li "><p class="- topic/p ">Adjustment tools (thickness 2.5mm)
</p><p class="- topic/p "> <ph varid="SPP-Z-0503-1070127995" class="- topic/ph ">
          <xref href="PRTV2-SPP-0503-1070127995.xml" scope="external" type="extpl" format="html" class="- topic/xref "><?ditaot usertext?>Z-0503</xref>
        </ph>
</p><p class="- topic/p "><ph varid="SPP-Z-0608-1070127066" class="- topic/ph ">
          <xref href="PRTV2-SPP-0608-1070127066.xml" scope="external" type="extpl" format="html" class="- topic/xref "><?ditaot usertext?>Z-0608</xref>
        </ph>
</p></li></ul></section><prereq id="GUID-58EF85A1-8290-4904-A975-FD24699036CA" class="- topic/section task/prereq "><ul class="- topic/ul "><li class="- topic/li "><p class="- topic/p "> Printer should be in SDS mode and no media on the platen allowed 
</p></li><li class="- topic/li "><p class="- topic/p ">The printcarriage should be positioned in Y-direction in the middle of the printsurface +/- 100mm. 
</p></li></ul></prereq><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to adjust</title><fig id="GUID-BB058453-D025-4BE2-B14C-4DDAA5740702" class="- topic/fig "><title class="- topic/title "/><image href="GUID-90BD471B-5AAD-43FD-B247-6C7CD9393B27-low.png" placement="inline" class="- topic/image " otherprops="GUID-90BD471B-5AAD-43FD-B247-6C7CD9393B27-low.png"/></fig><table id="GUID-BDB87D50-9E70-4086-AC9E-FA7970C76B0D" pgwide="1" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Start SDS test : 
<xref keyref="SDS03-6-021" class="- topic/xref " href="GUID-18276791-F608-4B99-BBEF-C347C2C6250D.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 03-6-021 Check carriage height positions [Special Tests]?>03-6-021 Check carriage height positions [Special Tests]</xref> and select position 1 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Loosen 3 screws a little bit but don't remove them. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-43068577-9E5D-4B5D-B360-0E40E6B47095" class="- topic/fig "><image href="GUID-1A163134-1268-466F-9163-02CA6F9856D0-low.png" placement="inline" class="- topic/image " otherprops="GUID-1A163134-1268-466F-9163-02CA6F9856D0-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Mount Plate-Shielding together with the loose Plate-Black and Plate Nut on the carriage with 4 screws. 
</p><p class="- topic/p ">Shift the Plate Shielding max. down in the slotted holes and fix the 4 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-685CCA80-6B2A-4DB6-AAC6-BD47234E2E63" class="- topic/fig "><image href="GUID-ADC1574D-2954-41D7-85C7-DE2DF059BEA2-low.png" placement="inline" class="- topic/image " otherprops="GUID-ADC1574D-2954-41D7-85C7-DE2DF059BEA2-low.png"/></fig><fig id="GUID-319161FE-8DFC-4908-B81A-19E532EFFC2B" class="- topic/fig "><image href="GUID-11FDE482-79B2-4281-A57C-625FA72DE067-low.png" placement="inline" class="- topic/image " otherprops="GUID-11FDE482-79B2-4281-A57C-625FA72DE067-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">4 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Lift the (vertical free moving) Plate-Black. 
</p></li><li class="- topic/li "><p class="- topic/p ">Position two Adjustment Tools (thickness 2.5 mm) on the Printsurface. 
</p></li></ol></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-1CDD34FA-E5E2-4E69-80A5-6F0E9F0A3CA4" class="- topic/fig "><image href="GUID-DEDC8B0F-456E-4C77-BC75-329D52DBC401-low.png" placement="inline" class="- topic/image " otherprops="GUID-DEDC8B0F-456E-4C77-BC75-329D52DBC401-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">5 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Push the Plate-Black smoothly down untill the Plate-Black is just hitting both tools and fasten the 3 screws. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-FA3A01A5-13DD-4342-AAB0-73D46AAD8580" class="- topic/fig "><image href="GUID-E9663174-2DE0-47C3-8FB9-6257131DC741-low.png" placement="inline" class="- topic/image " otherprops="GUID-E9663174-2DE0-47C3-8FB9-6257131DC741-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">6 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Slide out the 2 adjustment tools and store them in the printer 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">7 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Stop SDS test : 
<xref keyref="SDS03-6-021" class="- topic/xref " href="GUID-18276791-F608-4B99-BBEF-C347C2C6250D.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 03-6-021 Check carriage height positions [Special Tests]?>03-6-021 Check carriage height positions [Special Tests]</xref> and leave SDS. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section></taskbody><related-links class="- topic/related-links "><linkpool class="- topic/linkpool " mapkeyref="GUID-8A41CFEA-5928-4042-A2CB-507A5D034160"><link class="- topic/link " mapclass="- map/topicref " format="dita" type="concept" href="generated-topic-GUID-BB9FFD1B-E53B-488A-980C-657E28D40896.xml" role="parent"><?ditaot usertext?><linktext class="- topic/linktext "><?ditaot usertext?>Adjustment</linktext></link></linkpool></related-links>
