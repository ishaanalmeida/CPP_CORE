<?xml version="1.0" encoding="UTF-8"?><?ish ishref="GUID-7BD2D931-E2DF-4B3E-BF51-4128E53065F2" version="1" lang="en-US"?><task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" id="GUID-7BD2D931-E2DF-4B3E-BF51-4128E53065F2" xml:lang="en-US" ditaarch:DITAArchVersion="1.3" domains="(topic task)                            (topic hi-d)                            (topic ui-d)                            (topic sw-d)                            (topic indexing-d)                            (topic ut-d)                            a(base ishcondition)                            a(base varid)                            a(base varref)                            a(base cid)                            a(base partslist)                            (topic oce-d)                            (topic sdlVariables-c)                            (topic oceCommonElements-c)                            (topic oceMetaDecl-c)                            (topic oceTopic-c)                            (topic oceTopic-c task oceTask-c)                            (topic oceTopic-c hi-d oceHighlight-c)                            (topic oceTopic-c ui-d oceUi-c)                            (topic oceTopic-c sw-d oceSoftware-c)   " class="- topic/topic task/task "><title class="- topic/title ">19 How to remove the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">External output winder drive motor encoder</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 19B1 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">EXO_WND_DRV_MO_ENC</compsignal></comp></title><prolog class="- topic/prolog "><metadata class="- topic/metadata "><category class="- topic/category ">Dis-assembly</category></metadata></prolog><taskbody class="- topic/body task/taskbody "><prereq id="GUID-F8EE43B1-36AF-4F86-8810-3B686A03AF19" class="- topic/section task/prereq "><ol class="- topic/ol "><li class="- topic/li "><p class="- topic/p ">Go to COLD SDS and disconnect the Service jumper. 
</p></li><li class="- topic/li "><p class="- topic/p ">After removal of the sensor it is broken. 
</p><p class="- topic/p ">Make sure you have a new one at hand. 
</p></li><li id="LI_21C8B271522344C0958B457D5D3BA087" class="- topic/li "><p class="- topic/p ">Remove the left hand winder cover. 
</p><p class="- topic/p ">See : 
<xref keyref="24DISA058" class="- topic/xref " href="GUID-018F073E-4ED3-414A-8FEC-3740B53F5DBE.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 24 How to remove the left (or right) hand side cover of the winder?>24 How to remove the left (or right) hand side cover of the winder</xref>. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the take-up media shaft. 
</p><p class="- topic/p ">See : 
<xref keyref="19DISA015" class="- topic/xref " href="GUID-2885BF56-7B36-423E-B567-AB29516FD4CC.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 19 How to remove the take-up media shaft?>19 How to remove the take-up media shaft</xref>. 
</p></li><li class="- topic/li "><p class="- topic/p ">Remove the left hand winder drive assembly. 
</p><p class="- topic/p ">See : 
<xref keyref="19DISA016" class="- topic/xref " href="GUID-F8FD5418-11AE-468B-8C1A-CA4E0023C5B7.xml" format="dita" locktitle="yes" type="task"><?ditaot usertext?><?xm-replace_text 19 How to remove the left hand winder drive assembly?>19 How to remove the left hand winder drive assembly</xref>. 
</p></li></ol></prereq><section id="GUID-E4895B67-7FC1-4974-A5C8-D34725505879" class="- topic/section "><title class="- topic/title ">Required tools</title><ul id="UL_A32A562039FB485780CA65B069EE577C" class="- topic/ul "><li id="LI_1D9EE245DE6547E09D8CB22E45CFC7A0" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T10. 
</p></li><li id="LI_55373F9DAE644089ABBC568E03CDE4FC" class="- topic/li "><p class="- topic/p ">Screwdriver Torx T20. 
</p></li><li class="- topic/li "><p class="- topic/p ">New sensor, after removal it is broken. 
</p></li></ul></section><section id="GUID-EC9C24D5-D455-4022-B616-D7FEF4DE0A1A" class="- topic/section "><title class="- topic/title ">Illustration</title><fig id="GUID-1C6A5506-8461-4BFD-8B7C-FB47C7EF289A" class="- topic/fig "><image href="GUID-0568BF02-E45C-42FC-902A-D449A1BCF9EC-low.png" id="IMAGE_1EE8E6CF131C4064913FA3D3B4E13E44" keyref="" placement="inline" class="- topic/image " otherprops="GUID-0568BF02-E45C-42FC-902A-D449A1BCF9EC-low.png"/></fig></section><section id="SECTION_1731F22FB56546AA9F2B221562C31FAE" class="- topic/section "><title class="- topic/title ">How to remove</title><table pgwide="1" id="TABLE_FDFE25EB87A747129337DEFB99A3F30E" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Locate the sensor on the end of the <comp class="+ topic/ph oce-d/comp "><compname class="+ topic/keyword oce-d/compname ">External output winder drive motor encoder</compname><compcodenr translate="no" class="+ topic/keyword oce-d/compcodenr "> 19B1 </compcodenr><compsignal translate="no" class="+ topic/keyword oce-d/compsignal ">EXO_WND_DRV_MO_ENC</compsignal></comp> 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><fig id="GUID-4E440938-4EF7-43BA-9432-5FC605A4407C" class="- topic/fig "><image href="GUID-03C70ABD-38BE-4687-A03D-5AA44160D72A-low.png" keyref="" placement="inline" class="- topic/image " otherprops="GUID-03C70ABD-38BE-4687-A03D-5AA44160D72A-low.png"/></fig></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Disconnect the connector from the sensor. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">3 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Turn the enoder housing counter clockwise to remove it. This is a bayonet closure. 
</p><note id="GUID-BA9116D1-F34F-4767-89A4-D13666A97832" class="- topic/note "><p class="- topic/p ">The base plate of the encoder must remain on the motor. The base plate is positioned during production and should not be loosened. 
</p></note></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "/></row></tbody></tgroup></table></section><section id="GUID-234D70A5-41EC-40E2-9E43-4217D346F540" class="- topic/section "><title class="- topic/title ">How to install</title><table pgwide="1" id="TABLE_944D21C7443944D5B66AB958B2ECB416" class="- topic/table "><tgroup align="left" outputclass="step" cols="3" class="- topic/tgroup "><colspec colname="col1" colnum="1" colwidth="10*" class="- topic/colspec "/><colspec colname="col2" colnum="2" colwidth="50*" class="- topic/colspec "/><colspec colname="col3" colnum="3" colwidth="40*" class="- topic/colspec "/><thead valign="top" class="- topic/thead "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Step 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Action 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Remarks 
</p></entry></row></thead><tbody valign="top" class="- topic/tbody "><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">1 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Install the 
<b class="+ topic/ph hi-d/b ">new sensor</b> in reverse order. 
</p></entry><entry colname="col3" align="left" valign="top" class="- topic/entry "><p class="- topic/p "> 
</p></entry></row><row class="- topic/row "><entry colname="col1" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">2 
</p></entry><entry colname="col2" align="left" valign="top" class="- topic/entry "><p class="- topic/p ">Reconnect the Service jumper, exit SDS and press 'Restart' on the operator panel. 
